@model PTGOilSystem.Web.Models.Balance.CustomersBalanceViewModel
@{
    ViewData["Title"] = UiText.T(Context,"بیلانس مشتریان","Customer Balances");
    var totalSalesUsd = Model.Items.Sum(item => item.TotalSalesUsd);
    var totalExpensesUsd = Model.Items.Sum(item => item.TotalExpensesUsd);
    var totalBaseBalanceUsd = Model.Items.Sum(item => item.BaseBalanceUsd);
    var hasAdvancedFilter = Model.Filter.FromDate.HasValue || Model.Filter.ToDate.HasValue
        || Model.Filter.CustomerId.HasValue || !string.IsNullOrWhiteSpace(Model.Filter.Country);
}

<div class="ak-list-page">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((UiText.T(Context,"بیلانس مشتریان","Customer Balances"), false,
                       (string?)null, (string?)null, (string?)null, (string?)null,
                       (string?)null, (string?)null, (string?)null))" />

    <section class="ak-stat-grid" aria-label="@UiText.T(Context, "آمار بیلانس مشتریان", "Customer balance metrics")">
        <vc:stat-card title="@UiText.T(Context,"مشتریان","Customers")" value="@Model.TotalCount.ToString("N0")" unit="@UiText.T(Context,"مشتری","customers")" avatar="customers"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context,"جمع فروش","Total Sales")" value="@totalSalesUsd.ToString("N2")" unit="USD" avatar="sales-value"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context,"جمع مصرف","Total Expenses")" value="@totalExpensesUsd.ToString("N2")" unit="USD" avatar="expenses"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context,"تراز پایه","Base Balance")" value="@totalBaseBalanceUsd.ToString("N2")" unit="USD" avatar="profit-loss"></vc:stat-card>
    </section>

    <div class="ak-list">
        @{
            List<AkFilterOption> BcOpts(object? s) => (s as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>
                ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
                .Where(i => !string.IsNullOrEmpty(i.Value)).Select(i => new AkFilterOption(i.Value, i.Text)).ToList();
            string? BcQ(string k) { var v = Context.Request.Query[k].ToString(); return string.IsNullOrEmpty(v) ? null : v; }
            var balCustFilter = new AkSearchFilterModel("Filter.Search", Model.Filter.Search,
                "نام مشتری، کشور، تماس یا کد...",
                new List<AkFilterDefinition>
                {
                    new("Filter.FromDate", UiText.T(Context, "بازه تاریخ", "Date range"), "daterange", null,
                        Model.Filter.FromDate?.ToString("yyyy-MM-dd"), "Filter.ToDate", Model.Filter.ToDate?.ToString("yyyy-MM-dd")),
                    new("Filter.CustomerId", UiText.T(Context, "مشتری", "Customer"), "select", BcOpts(ViewBag.Customers), BcQ("Filter.CustomerId")),
                    new("Filter.Country", UiText.T(Context, "کشور", "Country"), "select", BcOpts(ViewBag.Countries), BcQ("Filter.Country"))
                });
        }
        <div class="ak-list-toolbar">
            <partial name="~/Views/Shared/_AkSearchFilter.cshtml" model="balCustFilter" />
            <div class="ak-list-toolbar-actions">
                <partial name="~/Views/Shared/_ExportMenu.cshtml" model="@(new PTGOilSystem.Web.Services.Exports.ExportMenuModel("CustomersExport"))" />
            </div>
        </div>

        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead>
                    <tr>
                        <th class="ak-col-grow">@UiText.T(Context,"مشتری","Customer")</th>
                        <th>@UiText.T(Context,"کشور","Country")</th>
                        <th class="ak-col-num">@UiText.T(Context,"قراردادها","Contracts")</th>
                        <th>@UiText.T(Context,"فعال / بسته","Active / Closed")</th>
                        <th class="ak-col-num">@UiText.T(Context,"جمع فروش","Total Sales")</th>
                        <th class="ak-col-num">@UiText.T(Context,"جمع مصرف","Total Expenses")</th>
                        <th class="ak-col-num">Ledger</th>
                        <th class="ak-col-num">@UiText.T(Context,"تراز پایه","Base Balance")</th>
                        <th class="ak-col-actions">@UiText.T(Context,"عملیات","Operations")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="ak-col-grow"><a class="ak-name" asp-controller="Customers" asp-action="Details" asp-route-id="@item.Id">@item.Name</a></td>
                            <td>@(item.Country ?? "-")</td>
                            <td class="ak-col-num ak-num">@item.RelatedContractsCount</td>
                            <td>@item.ActiveContractsCount / @item.ClosedContractsCount</td>
                            <td class="ak-col-num ak-num">@item.TotalSalesUsd.ToString("N2")</td>
                            <td class="ak-col-num ak-num">@item.TotalExpensesUsd.ToString("N2")</td>
                            <td class="ak-col-num ak-num">@item.RelatedLedgerCount</td>
                            <td class="ak-col-num ak-num @(item.BaseBalanceUsd >= 0 ?"ak-num" : "ak-num")">@item.BaseBalanceUsd.ToString("N2")</td>
                            <td class="ak-col-actions"><a asp-controller="Customers" asp-action="Details" asp-route-id="@item.Id">@UiText.T(Context,"جزئیات","Details")</a></td>
                        </tr>
                    }
                    @if (!Model.Items.Any())
                    {
                        <tr><td colspan="9"><div class="ak-empty"><i class="bi bi-people"></i> @UiText.T(Context,"مشتری‌ای برای نمایش بیلانس پیدا نشد","No customers found for balance view")</div></td></tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="ak-pager">
            @await Html.PartialAsync("_Pagination", (Model.CurrentPage, Model.PageCount))
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var toggle = document.getElementById('balCustFilterToggle');
            var pop = document.getElementById('balCustFilterPop');
            if (!toggle || !pop) return;
            function close() { pop.hidden = true; toggle.setAttribute('aria-expanded', 'false'); }
            toggle.addEventListener('click', function (e) {
                e.stopPropagation();
                var open = pop.hidden;
                pop.hidden = !open;
                toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
            });
            document.addEventListener('click', function (e) {
                if (!pop.hidden && !pop.contains(e.target) && e.target !== toggle) close();
            });
            document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
        })();
    </script>
}
