@model DailyFxRate
@using PTGOilSystem.Web.Models.Shared
@{
    ViewData["Title"] = UiText.T(Context, "جزئیات نرخ ارز", "Daily FX Rate Details");
    ViewData["AkHeaderContext"] = $"{Model.BaseCurrency}/{Model.QuoteCurrency} · {Model.RateDate.ToDisplayDate()}";
    ViewData["AkHeaderKebab"] = new List<AkHeaderMenuItem>
    {
        new() { Label = UiText.T(Context, "ویرایش", "Edit"), Href = Url.Action("Edit", new { id = Model.Id }), Icon = "bi-pencil" }
    };
}

<div class="ak-form-page ak-detail-page" data-ak-detail-v2="true">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((UiText.T(Context, "جزئیات نرخ ارز", "Daily FX Rate Details"), false,
                       (string?)null, (string?)null, (string?)null, (string?)null,
                       UiText.T(Context, "بازگشت", "Back"), "bi-arrow-right", (string?)Url.Action("Index")))" />

    <div class="summary-strip ak-detail-summary">
        <div class="summary-tile"><div class="summary-tile-label">@UiText.T(Context, "تاریخ", "Date")</div><div class="summary-tile-value">@Model.RateDate.ToDisplayDate()</div></div>
        <div class="summary-tile"><div class="summary-tile-label">@UiText.T(Context, "جفت ارز", "Pair")</div><div class="summary-tile-value"><code>@Model.BaseCurrency/@Model.QuoteCurrency</code></div></div>
        <div class="summary-tile"><div class="summary-tile-label">@UiText.T(Context, "نرخ", "Rate")</div><div class="summary-tile-value ak-num">@Model.Rate.ToString("N4")</div></div>
    </div>

    <div class="ak-form-section ak-detail-section">
        <div class="ak-section-head ak-detail-section-header">@UiText.T(Context, "اطلاعات نرخ", "Rate Information")</div>
        <div>
            <dl class="ak-list">
                <div class="ak-list-row"><dt>@UiText.T(Context, "تاریخ", "Date")</dt><dd>@Model.RateDate.ToDisplayDate()</dd></div>
                <div class="ak-list-row"><dt>@UiText.T(Context, "ارز پایه", "Base Currency")</dt><dd><code>@Model.BaseCurrency</code></dd></div>
                <div class="ak-list-row"><dt>@UiText.T(Context, "ارز مقصد", "Quote Currency")</dt><dd><code>@Model.QuoteCurrency</code></dd></div>
                <div class="ak-list-row"><dt>@UiText.T(Context, "نرخ", "Rate")</dt><dd class="ak-num">@Model.Rate.ToString("N4")</dd></div>
                <div class="ak-list-row"><dt>@UiText.T(Context, "منبع", "Source")</dt><dd>@(string.IsNullOrWhiteSpace(Model.Source) ? "-" : Model.Source)</dd></div>
            </dl>
        </div>
    </div>
</div>
