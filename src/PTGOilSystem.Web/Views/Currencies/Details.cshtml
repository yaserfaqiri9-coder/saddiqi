@model Currency
@{
    ViewData["Title"] = $"ارز {Model.Code}";
    var statusText = Model.IsActive ? "فعال" : "غیرفعال";
}

<div class="ak-form-page">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((ViewData["Title"]?.ToString() ?? "جزئیات", false,
                       "ویرایش", "bi-pencil", (string?)Url.Action("Edit", new { id = Model.Id }), (string?)null,
                       "بازگشت", "bi-arrow-right", (string?)Url.Action("Index")))" />
<section id="currency-info" class="ak-form-section">
        @await Html.PartialAsync("~/Views/Shared/Components/Ak/_AkSectionHead.cshtml", ("مشخصات ارز", (string?)"اطلاعات کامل این ارز مرجع."))
        <dl class="ak-list">
            <div class="ak-list-row"><dt>کد</dt><dd><code>@Model.Code</code></dd></div>
            <div class="ak-list-row"><dt>نام</dt><dd>@Model.Name</dd></div>
            <div class="ak-list-row"><dt>نام فارسی</dt><dd>@(string.IsNullOrWhiteSpace(Model.NamePersian) ? "—" : Model.NamePersian)</dd></div>
            <div class="ak-list-row"><dt>نماد</dt><dd>@(string.IsNullOrWhiteSpace(Model.Symbol) ? "—" : Model.Symbol)</dd></div>
            <div class="ak-list-row"><dt>وضعیت</dt><dd><span class="ak-status @(Model.IsActive ?"is-active" : "is-inactive")">@statusText</span></dd></div>
            <div class="ak-list-row"><dt>تاریخ ایجاد</dt><dd>@Model.CreatedAtUtc.ToDisplayDateTime()</dd></div>
        </dl>
    </section>
</div>
