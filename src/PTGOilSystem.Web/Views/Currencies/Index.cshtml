@model IEnumerable<Currency>
@{
    ViewData["Title"] = UiText.T(Context, "ارزها", "Currencies");
    var items = Model.ToList();
    var hasFilters = ViewData["isActive"] != null;
    var hasSearch = !string.IsNullOrWhiteSpace((string?)ViewData["q"]) || hasFilters;
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="ak-list-page">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((UiText.T(Context, "ارزهای سیستم", "System currencies"), true,
                       UiText.T(Context, "ارز جدید", "New currency"), "bi-plus-lg",
                       (string?)Url.Action("Create", new { returnUrl }), (string?)null,
                       (string?)null, (string?)null, (string?)null))" />

    @{
        var currenciesIsActive = ViewData["isActive"] is bool curAct ? (curAct ? "true" : "false") : null;
        var currenciesFilter = new AkSearchFilterModel("q", (string?)ViewData["q"],
            UiText.T(Context, "جستجو در کد، نام یا نماد...", "Search code, name, or symbol..."),
            new List<AkFilterDefinition>
            {
                new("isActive", UiText.T(Context, "وضعیت", "Status"), "bool",
                    new List<AkFilterOption> { new("true", UiText.T(Context, "فعال", "Active")), new("false", UiText.T(Context, "غیرفعال", "Inactive")) },
                    currenciesIsActive)
            });
    }
    <partial name="~/Views/Shared/_AkSearchFilter.cshtml" model="currenciesFilter" />

    <div class="ak-list">
        <div class="ak-table-wrap">
            <table class="ak-table" aria-label="@UiText.T(Context, "لیست ارزها", "Currency list")">
                <thead>
                    <tr>
                        <th class="ak-col-check"><input type="checkbox" class="ak-check" aria-label="@UiText.T(Context, "انتخاب همه", "Select all")" /></th>
                        <th class="ak-col-grow">@UiText.T(Context, "نام", "Name")</th>
                        <th>@UiText.T(Context, "نام فارسی", "Persian name")</th>
                        <th>@UiText.T(Context, "کد", "Code")</th>
                        <th>@UiText.T(Context, "نماد", "Symbol")</th>
                        <th class="ak-col-spacer"></th>
                        <th>@UiText.T(Context, "وضعیت", "Status")</th>
                        <th class="ak-col-actions"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in items)
                    {
                        <tr>
                            <td class="ak-col-check"><input type="checkbox" class="ak-check" aria-label="@UiText.T(Context, "انتخاب", "Select")" /></td>
                            <td class="ak-col-grow"><a asp-action="Details" asp-route-id="@item.Id" class="ak-name">@item.Name</a></td>
                            <td>@(string.IsNullOrWhiteSpace(item.NamePersian) ? "—" : item.NamePersian)</td>
                            <td>@item.Code</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Symbol) ? "—" : item.Symbol)</td>
                            <td class="ak-col-spacer"></td>
                            <td>
                                <span class="ak-status @(item.IsActive ?"is-active" : "is-inactive")">@(item.IsActive ? "فعال" : "غیرفعال")</span>
                            </td>
                            <td class="ak-col-actions">
                                <div class="dropdown ak-row-menu">
                                    <button type="button" class="ak-row-menu-btn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="@UiText.T(Context, "عملیات", "Actions")">
                                        <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a class="dropdown-item" asp-action="Details" asp-route-id="@item.Id"><i class="bi bi-eye" aria-hidden="true"></i>مشاهده</a></li>
                                        <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil" aria-hidden="true"></i>ویرایش</a></li>
                                        <li>
                                            <a class="dropdown-item" asp-action="Create" asp-route-cloneFromId="@item.Id">
                                                <i class="bi bi-copy" aria-hidden="true"></i>کلون
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li>
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" data-ptg-confirm="true" data-ptg-confirm-title="حذف ارز" data-ptg-confirm-message="این رکورد حذف یا غیرفعال شود؟">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-item ak-danger"><i class="bi bi-trash" aria-hidden="true"></i>حذف</button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!items.Any())
                    {
                        <tr>
                            <td colspan="8"><div class="ak-empty"><i class="bi bi-currency-exchange" aria-hidden="true"></i>ارزی ثبت نشده</div></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @{ ViewData["ShownCount"] = items.Count; }
        <div class="ak-pager">@await Html.PartialAsync("_PagedListFooter")</div>
    </div>
</div>
