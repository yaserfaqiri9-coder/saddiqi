@model PTGOilSystem.Web.Models.Customs.CustomsDeclarationCreateViewModel
@using PTGOilSystem.Web.Models.Entities
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    var returnUrl = Model.ReturnUrl;
    var hasSource = Model.LoadingRegisterId.HasValue || Model.TransportLegId.HasValue || Model.TruckDispatchId.HasValue;
    var loadingOptions = ViewBag.LoadingRegisterOptions as IReadOnlyList<SelectListItem> ?? Array.Empty<SelectListItem>();
    var transportOptions = ViewBag.TransportLegOptions as IReadOnlyList<SelectListItem> ?? Array.Empty<SelectListItem>();
    var truckDispatchOptions = ViewBag.TruckDispatchOptions as IReadOnlyList<SelectListItem> ?? Array.Empty<SelectListItem>();
    var loadingDetailsUrl = Model.TransportLegId.HasValue
        ? Url.Action("Details", "InventoryTransportLegs", new { id = Model.TransportLegId })
        : (Model.TruckDispatchId.HasValue
            ? Url.Action("Details", "Dispatch", new { id = Model.TruckDispatchId })
            : (Model.LoadingRegisterId.HasValue
                ? Url.Action("Details", "Loading", new { id = Model.LoadingRegisterId })
                : Url.Action("Index", "CustomsDeclarations")));
    loadingDetailsUrl = loadingDetailsUrl
        ?? Url.Action("Index", "CustomsDeclarations", new { loadingRegisterId = Model.LoadingRegisterId, transportLegId = Model.TransportLegId, truckDispatchId = Model.TruckDispatchId })
        ?? "/CustomsDeclarations";
    var backUrl = !string.IsNullOrWhiteSpace(returnUrl) && Url.IsLocalUrl(returnUrl)
        ? returnUrl
        : loadingDetailsUrl;
    var isEdit = Model.Id > 0;
    var formAction = isEdit ? "Edit" : "Create";
    var headerTitle = isEdit ? UiText.T(Context, "ویرایش گمرک", "Edit Customs") : UiText.T(Context, "ثبت گمرک", "Customs Registration");
    var submitLabel = isEdit ? UiText.T(Context, "ذخیره تغییرات", "Save changes") : UiText.T(Context, "ثبت اعلامیه", "Save declaration");
    ViewData["Title"] = isEdit ? "ویرایش اعلامیه گمرکی" : "ثبت اعلامیه گمرکی";
    ViewData["ContentBodyClass"] = "boltz-content-body";
    ViewData["HideSectionTabs"] = true;
    ViewData["LoadingCreateAssets"] = true;
}

@if (!hasSource)
{
    <div class="page-stack ak-form-page customs-create-page">
        <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
                 model="@((UiText.T(Context, "ثبت گمرک", "Customs Registration"), false,
                           (string?)null, (string?)null, (string?)null, (string?)null,
                           UiText.T(Context, "بازگشت", "Back"), "bi-arrow-right", (string?)backUrl))" />
                <form asp-action="Create" method="get" class="ak-form" data-customs-source-selector>
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <div asp-validation-summary="All" class="alert alert-danger ak-form-alert"></div>
                    <section class="ak-form-section">
                    <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@((UiText.T(Context, "انتخاب منبع", "Select Source"), (string?)UiText.T(Context, "یکی از منابع زیر را انتخاب کنید.", "Select one source below.")))" />
                    <div class="ak-form-grid">
                    <div class="ak-field">
                        <label class="ak-label">@UiText.T(Context, "منبع از بارگیری", "Loading Source")</label>
                        <select name="loadingRegisterId" class="ak-input" data-customs-loading-source>
                            <option value=""></option>
                            @foreach (var option in loadingOptions)
                            {
                                <option value="@option.Value">@option.Text</option>
                            }
                        </select>
                    </div>
                    <div class="ak-field">
                        <label class="ak-label">@UiText.T(Context, "منبع از انتقال موجودی", "Inventory Transfer Source")</label>
                        <select name="transportLegId" class="ak-input" data-customs-transport-source>
                            <option value=""></option>
                            @foreach (var option in transportOptions)
                            {
                                <option value="@option.Value">@option.Text</option>
                            }
                        </select>
                    </div>
                    <div class="ak-field">
                        <label class="ak-label">@UiText.T(Context, "منبع از ارسال با موتر", "Truck Dispatch Source")</label>
                        <select name="truckDispatchId" class="ak-input" data-customs-dispatch-source>
                            <option value=""></option>
                            @foreach (var option in truckDispatchOptions)
                            {
                                <option value="@option.Value">@option.Text</option>
                            }
                        </select>
                    </div>
                    </div>
                    </section>
                    <partial name="~/Views/Shared/Components/Ak/_AkFooterActions.cshtml" model="@((UiText.T(Context, "ادامه ثبت", "Continue"), backUrl, UiText.T(Context, "انصراف", "Cancel")))" />
                </form>
    </div>
}
else
{
<div class="page-stack ak-form-page customs-create-page">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((headerTitle, false, (string?)null, (string?)null, (string?)null, (string?)null,
                       UiText.T(Context, "بازگشت", "Back"), "bi-arrow-right", (string?)backUrl))" />
    <form asp-action="@formAction" method="post" class="ak-form">
        @{ ViewData["OpHeaderBackUrl"] = backUrl; }
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <input asp-for="LoadingRegisterId" type="hidden" />
        <input asp-for="TransportLegId" type="hidden" />
        <input asp-for="TruckDispatchId" type="hidden" />
        <input asp-for="ReturnUrl" type="hidden" />

            <div asp-validation-summary="All" class="alert alert-danger ak-form-alert"></div>

            <div class="ak-form-grid">
                <span><i class="bi bi-truck-front"></i> @(Model.TruckDispatchId.HasValue ? Model.TruckDispatchLabel : (Model.TransportLegId.HasValue ? Model.TransportLegLabel : Model.LoadingRegisterLabel))</span>
                <span><i class="bi bi-file-earmark-text"></i> @Model.ContractNumber</span>
                <span><i class="bi bi-box-seam"></i> @Model.ProductName</span>
                @if (!string.IsNullOrWhiteSpace(Model.WagonNumber))
                {
                    <span><i class="bi bi-train-front"></i> @Model.WagonNumber</span>
                }
            </div>

                <section class="ak-form-section" aria-label="اطلاعات اعلامیه">
                    <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@((UiText.T(Context, "اطلاعات اعلامیه", "Declaration Information"), (string?)null))" />
                    <div class="ak-form-grid">
                        <div class="ak-field">
                            <label asp-for="DeclarationDate" class="ak-label"></label>
                            <input asp-for="DeclarationDate" type="date" class="ak-input" />
                            <span asp-validation-for="DeclarationDate" class="ak-field-error"></span>
                        </div>
                        <div class="ak-field">
                            <label asp-for="WagonOrTruckNumber" class="ak-label"></label>
                            <input asp-for="WagonOrTruckNumber" class="ak-input" />
                            <span asp-validation-for="WagonOrTruckNumber" class="ak-field-error"></span>
                        </div>
                        <div class="ak-field">
                            <label asp-for="DeclarationReference" class="ak-label"></label>
                            <input asp-for="DeclarationReference" class="ak-input" />
                        </div>
                        <div class="ak-field">
                            <label asp-for="ConsignmentWeightMt" class="ak-label"></label>
                            <input asp-for="ConsignmentWeightMt" type="number" step="0.0001" class="ak-input" id="consignmentWeight" />
                            <span asp-validation-for="ConsignmentWeightMt" class="ak-field-error"></span>
                        </div>
                        <div class="ak-field">
                            <label asp-for="PermitNumber" class="ak-label"></label>
                            <input asp-for="PermitNumber" class="ak-input" />
                        </div>
                        <div class="ak-field">
                            <label asp-for="PermitHolderName" class="ak-label"></label>
                            <input asp-for="PermitHolderName" class="ak-input" />
                        </div>
                        <div class="ak-field">
                            <label asp-for="CustomsType" class="ak-label"></label>
                            <input asp-for="CustomsType" class="ak-input" />
                        </div>
                        <div class="ak-field">
                            <label asp-for="GoodsName" class="ak-label"></label>
                            <input asp-for="GoodsName" class="ak-input" />
                        </div>
                        <div class="ak-field">
                            <label asp-for="Route" class="ak-label"></label>
                            <input asp-for="Route" class="ak-input" />
                        </div>
                        <div class="ak-field ak-col-full">
                            <label asp-for="Notes" class="ak-label"></label>
                            <textarea asp-for="Notes" class="ak-input" rows="2"></textarea>
                        </div>
                    </div>
                </section>

                <section class="ak-form-section" aria-label="تفکیک مصارف گمرکی">
                    <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@((UiText.T(Context, "تفکیک مصارف گمرکی", "Customs Expense Breakdown"), (string?)null))" />
                    <div class="ak-table-wrap">
                        <table class="ak-table" id="customsItemsTable">
                            <thead>
                                <tr>
                                    <th style="min-width:220px;">نوع مصرف</th>
                                    <th style="min-width:110px;">ارز</th>
                                    <th style="min-width:150px;">مبلغ</th>
                                    <th style="min-width:140px;">نرخ تبدیل (AFN/USD)</th>
                                    <th style="min-width:160px;">معادل</th>
                                    <th style="min-width:180px;">یادداشت</th>
                                </tr>
                            </thead>
                            <tbody id="customsItemsBody">
                                @for (int i = 0; i < Model.Items.Count; i++)
                                {
                                    <tr class="customs-item-row">
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <button type="button" class="customs-row-remove" title="حذف ردیف" aria-label="حذف ردیف">
                                                    <i class="bi bi-x-lg" aria-hidden="true"></i>
                                                </button>
                                                <input asp-for="Items[i].ComponentType" type="hidden" class="row-component-type" />
                                                <input asp-for="Items[i].ComponentLabel" type="text" class="ak-input customs-label-input" placeholder="عنوان مصرف" />
                                            </div>
                                        </td>
                                        <td>
                                            <select asp-for="Items[i].Currency" class="ak-input currency-input">
                                                <option value="AFN">AFN</option>
                                                <option value="USD">USD</option>
                                            </select>
                                        </td>
                                        <td>
                                            <input asp-for="Items[i].Amount" type="number" step="0.01" min="0" class="ak-input amount-input" />
                                        </td>
                                        <td>
                                            <input asp-for="Items[i].Rate" type="number" step="0.0001" min="0" class="ak-input rate-input" placeholder="نرخ تبدیل" aria-label="نرخ تبدیل" />
                                        </td>
                                        <td>
                                            <span class="customs-equivalent text-muted" aria-live="polite">—</span>
                                        </td>
                                        <td>
                                            <input asp-for="Items[i].Notes" class="ak-input" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td class="fw-bold" colspan="2">مجموع</td>
                                    <td class="fw-bold text-warning" id="totalAfn">0.00 AFN</td>
                                    <td></td>
                                    <td class="fw-bold" id="totalUsd">—</td>
                                    <td><small class="text-muted" id="ratePerMt">نرخ / MT: —</small></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                    <div class="mt-3">
                        <button type="button" class="btn btn-sm btn-outline-primary" id="addCustomsRow">
                            <i class="bi bi-plus-lg ms-1" aria-hidden="true"></i>افزودن ردیف
                        </button>
                    </div>

                    <template id="customsRowTemplate">
                        <tr class="customs-item-row">
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <button type="button" class="customs-row-remove" title="حذف ردیف" aria-label="حذف ردیف">
                                        <i class="bi bi-x-lg" aria-hidden="true"></i>
                                    </button>
                                    <input type="hidden" class="row-component-type" name="Items[0].ComponentType" value="Other" />
                                    <input type="text" class="ak-input customs-label-input" name="Items[0].ComponentLabel" value="" placeholder="عنوان مصرف" />
                                </div>
                            </td>
                            <td>
                                <select class="ak-input currency-input" name="Items[0].Currency">
                                    <option value="AFN">AFN</option>
                                    <option value="USD">USD</option>
                                </select>
                            </td>
                            <td>
                                <input type="number" step="0.01" min="0" class="ak-input amount-input" name="Items[0].Amount" value="0" />
                            </td>
                            <td>
                                <input type="number" step="0.0001" min="0" class="ak-input rate-input" placeholder="نرخ تبدیل" aria-label="نرخ تبدیل" name="Items[0].Rate" />
                            </td>
                            <td>
                                <span class="customs-equivalent text-muted" aria-live="polite">—</span>
                            </td>
                            <td>
                                <input type="text" class="ak-input" name="Items[0].Notes" value="" />
                            </td>
                        </tr>
                    </template>
                </section>
        <partial name="~/Views/Shared/Components/Ak/_AkFooterActions.cshtml" model="@((submitLabel, backUrl, UiText.T(Context, "بازگشت", "Back")))" />
    </form>
</div>
}

@section Scripts {
<script>
(function () {
    var table = document.getElementById('customsItemsTable');
    var body = document.getElementById('customsItemsBody');
    if (!table || !body) return;

    var weightEl = document.getElementById('consignmentWeight');
    var totalAfnEl = document.getElementById('totalAfn');
    var totalUsdEl = document.getElementById('totalUsd');
    var ratePerMtEl = document.getElementById('ratePerMt');

    function num(v) { var n = parseFloat(v); return isNaN(n) ? 0 : n; }

    // هر ردیف یک مبلغ اصلی در ارز انتخابی دارد؛ معادل ارز دوم با نرخ (AFN در هر USD) محاسبه می‌شود.
    // معادل فقط نمایشی است و هیچ‌وقت به‌عنوان مبلغ مستقل در جمع‌ها حساب نمی‌شود.
    function rowAmounts(row) {
        var currencyEl = row.querySelector('.currency-input');
        var amountEl = row.querySelector('.amount-input');
        var rateEl = row.querySelector('.rate-input');
        var amount = num(amountEl && amountEl.value);
        var rate = num(rateEl && rateEl.value);
        var isUsd = currencyEl && currencyEl.value === 'USD';
        var afn = 0, usd = 0;
        if (isUsd) { usd = amount; afn = rate > 0 ? amount * rate : 0; }
        else { afn = amount; usd = rate > 0 ? amount / rate : 0; }
        return { afn: afn, usd: usd, isUsd: isUsd, amount: amount, rate: rate };
    }

    function syncRow(row) {
        var eqEl = row.querySelector('.customs-equivalent');
        if (!eqEl) return;
        var a = rowAmounts(row);
        if (!(a.amount > 0)) { eqEl.textContent = '—'; return; }
        if (a.rate > 0) {
            eqEl.textContent = a.isUsd
                ? a.afn.toLocaleString('en', { maximumFractionDigits: 0 }) + ' AFN'
                : a.usd.toFixed(2) + ' USD';
        } else {
            eqEl.textContent = 'نرخ تبدیل را وارد کنید';
        }
    }

    function recalc() {
        // معادل هر ردیف از روی همان مبلغِ اصلی حساب می‌شود؛ AFN و USD مستقیم با هم جمع نمی‌شوند.
        var totalAfn = 0, totalUsd = 0;
        body.querySelectorAll('tr.customs-item-row').forEach(function (row) {
            var a = rowAmounts(row);
            totalAfn += a.afn;
            totalUsd += a.usd;
        });
        totalAfnEl.textContent = totalAfn.toLocaleString('fa', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' AFN';
        totalUsdEl.textContent = totalUsd > 0 ? totalUsd.toFixed(2) + ' USD' : '—';
        var weight = weightEl ? num(weightEl.value) : 0;
        if (weight > 0 && totalAfn > 0) {
            ratePerMtEl.textContent = 'نرخ / MT: ' + (totalAfn / weight).toFixed(2) + ' AFN/MT';
        } else {
            ratePerMtEl.textContent = 'نرخ / MT: —';
        }
    }

    // بازشماری اندیس‌ها تا model-binding با ترتیب 0..n همخوان بماند
    function renumber() {
        body.querySelectorAll('tr.customs-item-row').forEach(function (row, i) {
            row.querySelectorAll('[name]').forEach(function (inp) {
                inp.name = inp.name.replace(/Items\[\d+\]/, 'Items[' + i + ']');
            });
        });
    }

    function handleRowChange(t) {
        if (t.classList.contains('amount-input')
            || t.classList.contains('rate-input')
            || t.classList.contains('currency-input')) {
            syncRow(t.closest('tr.customs-item-row'));
            recalc();
        }
    }

    body.addEventListener('input', function (e) { handleRowChange(e.target); });
    body.addEventListener('change', function (e) { handleRowChange(e.target); });

    body.addEventListener('click', function (e) {
        var btn = e.target.closest('.customs-row-remove');
        if (!btn) return;
        var row = btn.closest('tr.customs-item-row');
        if (row) { row.remove(); renumber(); recalc(); }
    });

    var addBtn = document.getElementById('addCustomsRow');
    var tpl = document.getElementById('customsRowTemplate');
    if (addBtn && tpl && 'content' in tpl) {
        addBtn.addEventListener('click', function () {
            body.appendChild(tpl.content.cloneNode(true));
            renumber();
            var rows = body.querySelectorAll('tr.customs-item-row');
            var newRow = rows[rows.length - 1];
            if (newRow) { var l = newRow.querySelector('.customs-label-input'); if (l) l.focus(); }
            recalc();
        });
    }

    if (weightEl) { weightEl.addEventListener('input', recalc); }

    body.querySelectorAll('tr.customs-item-row').forEach(syncRow);
    recalc();
})();
</script>
<script>
(() => {
    const selector = document.querySelector('[data-customs-source-selector]');
    if (!selector) return;
    const loading = selector.querySelector('[data-customs-loading-source]');
    const transport = selector.querySelector('[data-customs-transport-source]');
    const dispatch = selector.querySelector('[data-customs-dispatch-source]');
    const sources = [loading, transport, dispatch].filter(Boolean);
    sources.forEach(src => {
        src.addEventListener('change', () => {
            if (!src.value) return;
            sources.forEach(other => { if (other !== src) other.value = ''; });
        });
    });
})();
</script>
}
