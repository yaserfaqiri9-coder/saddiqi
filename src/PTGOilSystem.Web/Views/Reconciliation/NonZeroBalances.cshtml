@model PTGOilSystem.Web.Models.Reconciliation.NonZeroBalancesViewModel
@{
    ViewData["Title"] = "Non-zero Balances";
}

<div class="ak-form-page" dir="rtl">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@(("مانده‌های غیرصفر", false,
                       (string?)null, (string?)null, (string?)null, (string?)null,
                       "Reconciliation", "bi-arrow-right", Url.Action("Index")))" />

    <div class="ak-page-actions">
        <button type="button" class="btn btn-light" onclick="window.print()">چاپ</button>
        <a asp-action="NonZeroBalancesCsv" class="btn btn-light">Export CSV</a>
    </div>

    <p class="ak-note">محاسبه بر اساس LedgerEntry و فرمول Credit منهای Debit انجام شده است.</p>

    @await Html.PartialAsync("_BalanceTable", Model.ContractBalances, new ViewDataDictionary(ViewData) { { "Title", "Contracts" } })
    @await Html.PartialAsync("_BalanceTable", Model.CustomerBalances, new ViewDataDictionary(ViewData) { { "Title", "Customers" } })
    @await Html.PartialAsync("_BalanceTable", Model.SupplierBalances, new ViewDataDictionary(ViewData) { { "Title", "Suppliers" } })
</div>
