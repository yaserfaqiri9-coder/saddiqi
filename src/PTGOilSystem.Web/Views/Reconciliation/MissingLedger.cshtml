                    <tr><td colspan="10">@await Html.PartialAsync("_EmptyState", ("حرکت موجودی با قرارداد غیر Purchase وجود ندارد", "همه حرکت‌های موجودی به قرارداد خرید مرتبط هستند.", "bi-check2-circle"))</td></tr>
                }
