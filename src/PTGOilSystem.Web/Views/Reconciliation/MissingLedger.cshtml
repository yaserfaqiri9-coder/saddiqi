                <tbody>
                @foreach (var row in Model.ExpensesWithoutLedger)
                {
                    <tr><td>@row.SourceId</td><td>@row.Date.ToDisplayDate()</td><td>@row.Reference</td><td class="ak-col-num ak-num">@row.AmountUsd.ToString("N2")</td><td><span class="ak-status is-inactive">@row.Status</span></td></tr>
                }
                @if (!Model.ExpensesWithoutLedger.Any())
                {
                    <tr><td colspan="5">@await Html.PartialAsync("_EmptyState", ("Expense بدون ledger وجود ندارد", "همه مصارف قابل‌ردیابی ledger متناظر دارند.", "bi-check2-circle"))</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="ak-form-section">
        <div class="ak-section-head ak-section-title">Payments بدون Ledger</div>
        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead><tr><th>SourceId</th><th>@UiText.T(Context,"نوع","Type")</th><th>@UiText.T(Context,"تاریخ","Date")</th><th>@UiText.T(Context,"مرجع","Reference")</th><th class="ak-col-num">USD</th><th>@UiText.T(Context,"وضعیت","Status")</th></tr></thead>
                <tbody>
                @foreach (var row in Model.PaymentsWithoutLedger)
                {
                    <tr><td>@row.SourceId</td><td>@row.SourceType</td><td>@row.Date.ToDisplayDate()</td><td>@row.Reference</td><td class="ak-col-num ak-num">@row.AmountUsd.ToString("N2")</td><td><span class="ak-status is-inactive">@row.Status</span></td></tr>
                }
                @if (!Model.PaymentsWithoutLedger.Any())
                {
                    <tr><td colspan="6">@await Html.PartialAsync("_EmptyState", ("Payment بدون ledger وجود ندارد", "همه پرداخت‌ها و دریافت‌های ثبت‌شده ledger متناظر دارند.", "bi-check2-circle"))</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
