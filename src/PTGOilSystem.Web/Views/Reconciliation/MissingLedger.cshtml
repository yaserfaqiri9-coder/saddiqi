    <div class="ak-form-section">
        <div class="ak-section-head ak-section-title">ToInventory allocation بدون InventoryMovement</div>
        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead><tr><th>Allocation</th><th>Receipt</th><th>تاریخ رسید</th><th>قرارداد</th><th>ترمینال</th><th class="ak-col-num">مقدار MT</th><th>InventoryMovement</th><th>Issue</th></tr></thead>
                <tbody>
                @foreach (var row in Model.ToInventoryAllocationsWithoutMovement)
                {
                    <tr>
                        <td>#@row.AllocationId</td>
                        <td>#@row.LoadingReceiptId</td>
                        <td>@(row.ReceiptDate == default ? "—" : row.ReceiptDate.ToDisplayDate())</td>
                        <td>@row.ContractNumber</td>
                        <td>@row.TerminalName</td>
                        <td class="ak-col-num">@row.AllocationQuantityMt.ToString("N4")</td>
                        <td>@(row.InventoryMovementId.HasValue ? "#" + row.InventoryMovementId : "—")</td>
                        <td><span class="ak-status is-inactive">@row.Issue</span></td>
                    </tr>
                }
                @if (!Model.ToInventoryAllocationsWithoutMovement.Any())
                {
                    <tr><td colspan="8">@await Html.PartialAsync("_EmptyState", ("ToInventory allocation بدون InventoryMovement وجود ندارد", "همه allocationهای ToInventory به یک InventoryMovement واقعی متصل‌اند.", "bi-check2-circle"))</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="ak-form-section">
        <div class="ak-section-head ak-section-title">احتمال ثبت تکراری گمرک</div>
        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead><tr><th>قرارداد</th><th>نوع</th><th class="ak-col-num">CustomsDeclaration USD</th><th class="text-center">تعداد اعلامیه</th><th class="ak-col-num">Customs Expense USD</th><th class="text-center">تعداد رکورد</th><th>Issue</th></tr></thead>
                <tbody>
                @foreach (var row in Model.DuplicateCustomsCandidates)
                {
                    <tr>
                        <td>@row.ContractNumber <span class="ak-note">#@row.ContractId</span></td>
                        <td>@row.ContractType</td>
                        <td class="ak-col-num">@row.CustomsDeclarationTotalUsd.ToString("N2")</td>
                        <td class="text-center">@row.CustomsDeclarationCount</td>
                        <td class="ak-col-num">@row.CustomsExpenseTotalUsd.ToString("N2")</td>
                        <td class="text-center">@row.CustomsExpenseCount</td>
