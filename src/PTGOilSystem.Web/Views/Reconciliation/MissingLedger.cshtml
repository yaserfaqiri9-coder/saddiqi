                    <tr><td colspan="7">@await Html.PartialAsync("_EmptyState", ("ثبت تکراری گمرک شناسایی نشد", "هیچ قراردادی همزمان در CustomsDeclaration و ExpenseTransaction گمرکی یافت نشد.", "bi-check2-circle"))</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="ak-form-section">
        <div class="ak-section-head ak-section-title">مشکلات منبع اعلامیه گمرکی</div>
