@model PTGOilSystem.Web.Models.Reconciliation.MissingLedgerViewModel
@{
    ViewData["Title"] = "بررسی رکوردهای ناقص دفتر کل";
    var serviceProviderIssues = Model.ServiceProviderExpensesWithoutLedger.Select(row => ("Expense without ledger", row))
        .Concat(Model.ServiceProviderPaymentsWithoutLedger.Select(row => ("Payment without ledger", row)))
        .Concat(Model.ServiceProviderLedgerMissingSource.Select(row => ("Ledger trace incomplete", row)))
        .Concat(Model.ServiceProviderPaymentLedgerMismatches.Select(row => ("Payment ledger mismatch", row)))
        .Concat(Model.ServiceProviderExpenseLedgerMismatches.Select(row => ("Expense ledger mismatch", row)))
        .Concat(Model.CancelledServiceProviderExpensesWithBalanceImpact.Select(row => ("Cancelled balance impact", row)))
        .ToList();
    var operationalAssetIssues = Model.AssetRentTransactionsWithoutShares.Select(row => ("Rent without shares", row))
        .Concat(Model.AssetRentShareSumMismatches.Select(row => ("Share amount mismatch", row)))
        .Concat(Model.AssetRentOwnershipCoverageIssues.Select(row => ("Ownership not 100%", row)))
        .Concat(Model.OperationalAssetLinkIssues.Select(row => ("Invalid asset link", row)))
        .Concat(Model.AssetExpenseInactiveAssetIssues.Select(row => ("Asset expense issue", row)))
        .Concat(Model.AssetRentPostedWithoutLedger.Select(row => ("Posted without ledger", row)))
        .Concat(Model.AssetRentContractRequirementIssues.Select(row => ("Missing contract", row)))
        .Concat(Model.AssetRentDuplicateCandidates.Select(row => ("Duplicate candidate", row)))
        .ToList();
    var sarrafIssues = Model.SarrafSettlementsWithoutSupplierLedger.Select(row => ("Supplier ledger missing", row))
        .Concat(Model.SarrafSettlementSupplierLedgerMismatches.Select(row => ("Supplier ledger mismatch", row)))
        .Concat(Model.SarrafSettlementsWithoutDifferenceLedger.Select(row => ("Difference ledger missing", row)))
        .Concat(Model.SarrafSettlementDifferenceLedgerMismatches.Select(row => ("Difference ledger mismatch", row)))
        .ToList();
}

<div class="ak-form-page" dir="rtl">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@(("رکوردهای بدون دفتر کل", false,
                       (string?)null, (string?)null, (string?)null, (string?)null,
                       "بررسی تطبیق", "bi-arrow-right", Url.Action("Index")))" />

    <div class="ak-page-actions">
        <partial name="~/Views/Shared/_ExportMenu.cshtml" model="@(new PTGOilSystem.Web.Services.Exports.ExportMenuModel("MissingLedgerExport"))" />
    </div>

    <p class="ak-note">فروش‌ها، مصارف و پرداخت‌هایی که هنوز رکورد دفتر کل متناظر ندارند برای بررسی سریع دیده می‌شوند. داده عملیاتی اصلی تغییر نمی‌کند و فقط اتصال دفتر کل باید بازبینی شود.</p>

    <div class="ak-form-section">
        <div class="ak-section-head ak-section-title">Sarraf settlement ledger checks</div>
        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead>
                    <tr>
                        <th>Check</th>
                        <th>Settlement</th>
                        <th>Date</th>
                        <th>Sarraf</th>
                        <th>Supplier</th>
                        <th>Contract</th>
                        <th>Reference</th>
                        <th class="ak-col-num">Expected USD</th>
                        <th class="ak-col-num">Ledger USD</th>
                        <th>Ledger</th>
                        <th>Issue</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in sarrafIssues)
                {
                    var row = item.Item2;
                    var expectedUsd = item.Item1.Contains("Difference", StringComparison.OrdinalIgnoreCase)
                        ? Math.Abs(row.DifferenceAmountUsd)
                        : row.SupplierLedgerAmountUsd;
                    <tr>
                        <td>@item.Item1</td>
                        <td>#@row.SettlementId</td>
                        <td>@row.SettlementDate.ToDisplayDate()</td>
                        <td>@row.SarrafName</td>
                        <td>@row.SupplierName</td>
                        <td>@row.ContractNumber</td>
                        <td>@row.Reference</td>
                        <td class="ak-col-num ak-num">@expectedUsd.ToString("N2")</td>
                        <td class="ak-col-num ak-num">@(row.LedgerAmountUsd?.ToString("N2") ?? row.DifferenceLedgerAmountUsd?.ToString("N2") ?? "-")</td>
                        <td>@(row.LedgerEntryId.HasValue ? $"#{row.LedgerEntryId.Value}" : row.ExchangeDifferenceLedgerEntryId.HasValue ? $"#{row.ExchangeDifferenceLedgerEntryId.Value}" : "-")</td>
                        <td><span class="ak-status is-inactive">@row.Issue</span></td>
                    </tr>
                }
                @if (!sarrafIssues.Any())
                {
                    <tr><td colspan="11">@await Html.PartialAsync("_EmptyState", ("Sarraf settlement ledger issue not found", "Sarraf supplier reductions and recognized exchange differences have matching ledger traces.", "bi-check2-circle"))</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="ak-form-section">
        <div class="ak-section-head ak-section-title">Operational Asset checks</div>
        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead>
                    <tr>
                        <th>Check</th>
                        <th>Source</th>
                        <th>Date</th>
                        <th>Asset</th>
                        <th>Reference</th>
                        <th class="ak-col-num">Amount USD</th>
                        <th class="ak-col-num">Related USD / %</th>
                        <th>Issue</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in operationalAssetIssues)
                {
                    var row = item.Item2;
                    <tr>
                        <td>@item.Item1</td>
                        <td>@row.SourceType #@row.SourceId</td>
                        <td>@row.Date.ToDisplayDate()</td>
                        <td>@row.OperationalAssetName</td>
                        <td>@row.Reference</td>
                        <td class="ak-col-num ak-num">@row.AmountUsd.ToString("N2")</td>
                        <td class="ak-col-num ak-num">@(row.RelatedAmountUsd?.ToString("N4") ?? "—")</td>
                        <td><span class="ak-status @(row.Status =="Warning" ? "" : "is-inactive")">@row.Issue</span></td>
                    </tr>
                }
                @if (!operationalAssetIssues.Any())
                {
                    <tr><td colspan="8">@await Html.PartialAsync("_EmptyState", ("Operational Asset issue not found", "Asset rent shares, ownership coverage, links and expense asset references are consistent.", "bi-check2-circle"))</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="ak-form-section">
        <div class="ak-section-head ak-section-title">Service Provider ledger checks</div>
        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead>
                    <tr>
                        <th>Check</th>
                        <th>Source</th>
                        <th>Date</th>
                        <th>Service Provider</th>
                        <th>Reference</th>
                        <th class="ak-col-num">Source USD</th>
                        <th class="ak-col-num">Ledger USD</th>
                        <th>Ledger</th>
                        <th>Issue</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in serviceProviderIssues)
                {
                    var row = item.Item2;
                    <tr>
                        <td>@item.Item1</td>
                        <td>@row.SourceType #@row.SourceId</td>
                        <td>@row.Date.ToDisplayDate()</td>
                        <td>@row.ServiceProviderName</td>
                        <td>@row.Reference</td>
                        <td class="ak-col-num ak-num">@row.AmountUsd.ToString("N2")</td>
                        <td class="ak-col-num ak-num">@(row.LedgerAmountUsd?.ToString("N2") ?? "—")</td>
                        <td>@(row.LedgerEntryId.HasValue ? $"#{row.LedgerEntryId.Value}" : "—")</td>
                        <td><span class="ak-status @(row.Status =="Warning" ? "" : "is-inactive")">@row.Issue</span></td>
                    </tr>
                }
                @if (!serviceProviderIssues.Any())
                {
                    <tr><td colspan="9">@await Html.PartialAsync("_EmptyState", ("Service Provider ledger issue not found", "Service provider expenses, payments, sources and cancelled expense balance impact are consistent.", "bi-check2-circle"))</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="ak-form-section">
        <div class="ak-section-head ak-section-title">پرداخت تأمین‌کننده بدون شناسه تأمین‌کننده</div>
        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead><tr><th>پرداخت</th><th>تاریخ</th><th>تأمین‌کننده</th><th>قرارداد</th><th>مرجع</th><th class="ak-col-num">USD</th><th>دفتر کل</th><th>مشکل</th></tr></thead>
                <tbody>
                @foreach (var row in Model.SupplierPaymentsWithoutSupplier)
                {
                    <tr>
                        <td>#@row.PaymentId</td>
                        <td>@row.PaymentDate.ToDisplayDate()</td>
                        <td>@row.SupplierName</td>
                        <td>@row.ContractNumber</td>
                        <td>@row.Reference</td>
                        <td class="ak-col-num">@row.AmountUsd.ToString("N2")</td>
                        <td>@(row.LedgerEntryId.HasValue ? $"#{row.LedgerEntryId.Value}" : "—")</td>
                        <td><span class="ak-status is-inactive">@row.Issue</span></td>
                    </tr>
                }
                @if (!Model.SupplierPaymentsWithoutSupplier.Any())
                {
                    <tr><td colspan="8">@await Html.PartialAsync("_EmptyState", ("پرداخت تأمین‌کننده بدون شناسه وجود ندارد", "همه پرداخت‌های تأمین‌کننده شناسه قابل ردیابی دارند.", "bi-check2-circle"))</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="ak-form-section">
        <div class="ak-section-head ak-section-title">عدم تطابق تأمین‌کننده پرداخت و قرارداد</div>
        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead><tr><th>پرداخت</th><th>تاریخ</th><th>تأمین‌کننده</th><th>قرارداد</th><th>مرجع</th><th class="ak-col-num">USD</th><th>دفتر کل</th><th>مشکل</th></tr></thead>
                <tbody>
                @foreach (var row in Model.SupplierPaymentContractSupplierMismatches)
                {
                    <tr>
                        <td>#@row.PaymentId</td>
                        <td>@row.PaymentDate.ToDisplayDate()</td>
                        <td>@row.SupplierName</td>
                        <td>@row.ContractNumber</td>
                        <td>@row.Reference</td>
                        <td class="ak-col-num">@row.AmountUsd.ToString("N2")</td>
                        <td>@(row.LedgerEntryId.HasValue ? $"#{row.LedgerEntryId.Value}" : "—")</td>
                        <td><span class="ak-status is-inactive">@row.Issue</span></td>
                    </tr>
                }
                @if (!Model.SupplierPaymentContractSupplierMismatches.Any())
                {
                    <tr><td colspan="8">@await Html.PartialAsync("_EmptyState", ("عدم تطابق پرداخت و قرارداد وجود ندارد", "تأمین‌کننده پرداخت‌ها با تأمین‌کننده قراردادهای وصل‌شده هماهنگ است.", "bi-check2-circle"))</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="ak-form-section">
        <div class="ak-section-head ak-section-title">رکورد دفتر کل پرداخت تأمین‌کننده با تأمین‌کننده یا قرارداد ناقص</div>
        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead><tr><th>پرداخت</th><th>تاریخ</th><th>تأمین‌کننده</th><th>قرارداد</th><th>مرجع</th><th class="ak-col-num">USD</th><th>دفتر کل</th><th>مشکل</th></tr></thead>
                <tbody>
                @foreach (var row in Model.SupplierPaymentLedgerMissingSupplierOrContract)
                {
                    <tr>
                        <td>#@row.PaymentId</td>
                        <td>@row.PaymentDate.ToDisplayDate()</td>
                        <td>@row.SupplierName</td>
                        <td>@row.ContractNumber</td>
                        <td>@row.Reference</td>
                        <td class="ak-col-num">@row.AmountUsd.ToString("N2")</td>
                        <td>@(row.LedgerEntryId.HasValue ? $"#{row.LedgerEntryId.Value}" : "—")</td>
                        <td><span class="ak-status is-inactive">@row.Issue</span></td>
                    </tr>
                }
                @if (!Model.SupplierPaymentLedgerMissingSupplierOrContract.Any())
                {
                    <tr><td colspan="8">@await Html.PartialAsync("_EmptyState", ("رکورد ناقص دفتر کل برای پرداخت تأمین‌کننده وجود ندارد", "شناسه تأمین‌کننده و قرارداد پرداخت‌ها در رکورد دفتر کل متناظر حفظ شده‌اند.", "bi-check2-circle"))</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="ak-form-section">
        <div class="ak-section-head ak-section-title">پرداخت تأمین‌کننده بدون رکورد دفتر کل</div>
        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead><tr><th>پرداخت</th><th>تاریخ</th><th>تأمین‌کننده</th><th>قرارداد</th><th>مرجع</th><th class="ak-col-num">USD</th><th>دفتر کل</th><th>مشکل</th></tr></thead>
                <tbody>
                @foreach (var row in Model.SupplierPaymentsWithoutLedger)
                {
                    <tr>
                        <td>#@row.PaymentId</td>
                        <td>@row.PaymentDate.ToDisplayDate()</td>
                        <td>@row.SupplierName</td>
                        <td>@row.ContractNumber</td>
                        <td>@row.Reference</td>
                        <td class="ak-col-num">@row.AmountUsd.ToString("N2")</td>
                        <td>@(row.LedgerEntryId.HasValue ? $"#{row.LedgerEntryId.Value}" : "—")</td>
                        <td><span class="ak-status is-inactive">@row.Issue</span></td>
                    </tr>
                }
                @if (!Model.SupplierPaymentsWithoutLedger.Any())
                {
                    <tr><td colspan="8">@await Html.PartialAsync("_EmptyState", ("پرداخت تأمین‌کننده بدون رکورد دفتر کل وجود ندارد", "همه پرداخت‌های تأمین‌کننده رکورد دفتر کل متناظر دارند.", "bi-check2-circle"))</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="ak-form-section">
        <div class="ak-section-head ak-section-title">نرخ تبدیل ناقص در دفتر کل تأمین‌کننده</div>
        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead><tr><th>دفتر کل</th><th>تاریخ</th><th>تأمین‌کننده</th><th>قرارداد</th><th>منبع</th><th>ارز</th><th class="ak-col-num">مبلغ منبع</th><th class="ak-col-num">نرخ تبدیل</th><th class="ak-col-num">USD</th><th>مشکل</th></tr></thead>
                <tbody>
                @foreach (var row in Model.SupplierLedgerFxIssues)
                {
                    <tr>
                        <td>#@row.LedgerEntryId</td>
                        <td>@row.EntryDate.ToDisplayDate()</td>
                        <td>@row.SupplierName</td>
                        <td>@row.ContractNumber</td>
                        <td>@row.SourceType</td>
                        <td>@row.SourceCurrencyCode</td>
                        <td class="ak-col-num">@(row.SourceAmount?.ToString("N2") ?? "—")</td>
                        <td class="ak-col-num">@(row.AppliedFxRateToUsd?.ToString("N6") ?? "—")</td>
                        <td class="ak-col-num">@row.AmountUsd.ToString("N2")</td>
                        <td><span class="ak-status is-inactive">@row.Issue</span></td>
                    </tr>
                }
                @if (!Model.SupplierLedgerFxIssues.Any())
                {
                    <tr><td colspan="10">@await Html.PartialAsync("_EmptyState", ("نرخ تبدیل ناقص در دفتر کل تأمین‌کننده وجود ندارد", "رکوردهای غیر USD دفتر کل تأمین‌کننده نرخ تبدیل و مبلغ USD معتبر دارند.", "bi-check2-circle"))</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="ak-form-section">
        <div class="ak-section-head ak-section-title">مشکلات انتقال از موجودی</div>
        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead>
                    <tr>
                        <th>Leg</th>
                        <th>Contract</th>
                        <th>Product</th>
                        <th>Source</th>
                        <th class="ak-col-num">Quantity MT</th>
                        <th>Status</th>
                        <th>Movement</th>
                        <th>Issue</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.InventoryTransportLegIssues)
                {
                    <tr>
                        <td>#@row.LegId</td>
                        <td>@row.ContractNumber</td>
                        <td>@row.ProductName</td>
                        <td>@row.SourceTerminalName @(string.IsNullOrWhiteSpace(row.SourceTankCode) ? "" : $" / {row.SourceTankCode}")</td>
                        <td class="ak-col-num">@row.QuantityMt.ToString("N4")</td>
                        <td>@row.StatusText</td>
                        <td>@(row.MovementId.HasValue ? $"#{row.MovementId.Value}" : "—")</td>
                        <td><span class="ak-status @(row.Status =="Warning" ? "" : "is-inactive")">@row.Issue</span></td>
                    </tr>
                }
                @if (!Model.InventoryTransportLegIssues.Any())
                {
                    <tr><td colspan="8">@await Html.PartialAsync("_EmptyState", ("مشکل انتقال از موجودی وجود ندارد", "همه سندهای انتقال از موجودی با خروجی موجودی خود هماهنگ هستند.", "bi-check2-circle"))</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="ak-form-section">
        <div class="ak-section-head ak-section-title">حرکت‌های موجودی با قرارداد غیر Purchase</div>
        <div class="ak-table-wrap">
            <table class="ak-table recon-movement-contract">
                <thead><tr><th>Movement</th><th>تاریخ</th><th>قرارداد</th><th>نوع قرارداد</th><th>جنس</th><th>ترمینال</th><th>جهت</th><th class="ak-col-num">مقدار MT</th><th>مرجع</th><th>Issue</th></tr></thead>
                <tbody>
                @foreach (var row in Model.InventoryMovementsWithNonPurchaseContract)
                {
                    <tr>
                        <td>#@row.MovementId</td>
                        <td>@row.MovementDate.ToDisplayDate()</td>
                        <td>@row.ContractNumber</td>
                        <td>@row.ContractType</td>
                        <td>@row.ProductName</td>
                        <td>@row.TerminalName</td>
                        <td>@row.DirectionText</td>
                        <td class="ak-col-num">@row.QuantityMt.ToString("N4")</td>
