@model PTGOilSystem.Web.Models.ShipmentPnl.ShipmentPnlIndexViewModel
@{
    ViewData["Title"] = UiText.T(Context, "پرونده‌های کشتی / محموله‌ها", "Shipment files");
}

<div class="ak-form-page ak-list-page" data-operations-list>
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((UiText.T(Context, "پرونده‌های کشتی / محموله‌ها", "Shipment files"), true, UiText.T(Context, "ثبت محموله", "New shipment"), "bi-plus-lg", Url.Action("Create", "Shipments"), (string?)null, (string?)null, (string?)null, (string?)null))" />
    <section class="ak-stat-grid mb-3" aria-label="@UiText.T(Context, "آمار محموله‌ها", "Shipment statistics")">
        <vc:stat-card title="@UiText.T(Context, "کل محموله‌ها", "Total shipments")" value="@Model.TotalCount.ToString("N0")" unit="@UiText.T(Context, "محموله", "shipments")" avatar="shipments"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "مقدار این صفحه", "Quantity on this page")" value="@NumberDisplay.Quantity(Model.Items.Sum(x => x.QuantityMt))" unit="MT" avatar="total-inventory"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "فروش‌های مرتبط", "Related sales")" value="@Model.Items.Sum(x => x.RelatedSalesCount).ToString("N0")" unit="@UiText.T(Context, "فروش", "sales")" avatar="sales-value"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "نتیجه این صفحه", "Page result")" value="@Model.Items.Sum(x => x.GrossMarginUsd).ToString("N0")" unit="USD" avatar="profit-loss" state="@(Model.Items.Sum(x => x.GrossMarginUsd) < 0m ? "warning" : null)"></vc:stat-card>
    </section>
    <div class="ak-list">
        <div class="ak-list-toolbar justify-content-end">
            <partial name="~/Views/Shared/_ExportMenu.cshtml" model="@(new PTGOilSystem.Web.Services.Exports.ExportMenuModel("Export"))" />
        </div>
        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead>
                    <tr>
                        <th><input type="checkbox" class="ak-check" data-ops-select-all aria-label="@UiText.T(Context,"انتخاب همه","Select all")" /></th>
                        <th class="col-name">@UiText.T(Context,"محموله","Shipment")</th>
                        <th>@UiText.T(Context,"جنس و مسیر","Product & route")</th>
                        <th>@UiText.T(Context,"مقدار","Quantity")</th>
                        <th>@UiText.T(Context,"وضعیت فعالیت","Activity")</th>
                        <th class="col-actions">@UiText.T(Context,"عملیات","Operations")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        var route = string.Join(" → ", new[] { item.OriginName, item.DestinationName }.Where(v => !string.IsNullOrWhiteSpace(v)));
                        <tr data-href="@Url.Action("Details", new { id = item.Id })">
                            <td><input type="checkbox" class="ak-check" data-ops-row-select aria-label="@UiText.T(Context,"انتخاب ردیف","Select row")" /></td>
                            <td class="col-name">
                                @await Html.PartialAsync("_OperationsListIdentity", ("bi-box-seam", item.ShipmentCode, string.IsNullOrWhiteSpace(item.VesselName) ? "-" : item.VesselName, false))
                            </td>
                            <td>
                                <span class="ak-label">@(item.ProductName ?? "-")</span>
                                <span class="ak-section-desc">@UiText.T(Context,"مسیر","Route"): @(string.IsNullOrWhiteSpace(route) ? "-" : route)</span>
                            </td>
                            <td class="col-ltr">@item.QuantityMt.ToString("N2") MT</td>
                            <td>
                                <span class="ak-label">@UiText.T(Context,"حمل","Transport") @item.RelatedTransportLegCount · @UiText.T(Context,"فروش","Sales") @item.RelatedSalesCount</span>
                                <span class="ak-section-desc">@UiText.T(Context,"مصرف","Expense") @item.RelatedExpensesCount</span>
                            </td>
                            <td class="col-actions">
                                <div class="ak-row-menu">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-light ak-secondary-action" title="@UiText.T(Context,"باز کردن پرونده","Open file")" aria-label="@UiText.T(Context,"باز کردن پرونده","Open file")"><i class="bi bi-eye" aria-hidden="true"></i></a>
                                    <a asp-controller="Shipments" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-light ak-secondary-action" title="@UiText.T(Context,"ویرایش محموله","Edit shipment")" aria-label="@UiText.T(Context,"ویرایش محموله","Edit shipment")"><i class="bi bi-pencil" aria-hidden="true"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="6">
                                <div class="ak-empty">
                                    <i class="bi bi-box-seam"></i>
                                    @UiText.T(Context,"هنوز پرونده‌ای برای نمایش پیدا نشد","No shipment files found yet")
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="ak-pager">
            @await Html.PartialAsync("_OperationsListFooter", (Model.CurrentPage, Model.PageCount, Model.TotalCount, 5))
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            document.querySelectorAll('.ak-list-page .ak-table tbody tr[data-href]').forEach(function (row) {
                row.style.cursor = 'pointer';
                row.addEventListener('click', function (e) {
                    if (e.target.closest('a, button, input, label, select, form')) return;
                    window.location.href = row.getAttribute('data-href');
                });
            });
        })();
    </script>
}
