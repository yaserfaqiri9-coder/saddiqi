@model PTGOilSystem.Web.Models.Loading.LoadingIndexViewModel
@{
    ViewData["Title"] = UiText.T(Context,"ثبت‌های بارگیری","Loading Records");
    ViewData["LoadingExpenseEditorAssets"] = true;
    var currentUrl = Context.Request.Path + Context.Request.QueryString;
    var hasAdvancedFilter = Model.FromDate.HasValue || Model.ToDate.HasValue;
    var hasAnyFilter = Model.ContractId.HasValue || !string.IsNullOrWhiteSpace(Model.Query) || Model.FromDate.HasValue || Model.ToDate.HasValue;
}

<div class="ak-list-page" data-operations-list>
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((UiText.T(Context, "ثبت‌های بارگیری", "Loading Records"), false,
                       UiText.T(Context, "ثبت بارگیری", "New Loading"), "bi-plus-lg",
                       Url.Action("Create", new { contractId = Model.ContractId, returnUrl = currentUrl }), (string?)null,
                       (string?)null, (string?)null, (string?)null))" />

    <div class="ak-list">
        @{
            var loadingHidden = new Dictionary<string, string>();
            if (Model.ContractId.HasValue) loadingHidden["contractId"] = Model.ContractId.Value.ToString();
            var loadingFilter = new AkSearchFilterModel(
                "q", Model.Query,
                UiText.T(Context, "قرارداد، جنس، وسیله حمل، مرجع یا مقصد...", "Contract, product, vehicle, reference or destination..."),
                new List<AkFilterDefinition>
                {
                    new("fromDate", UiText.T(Context, "بازه تاریخ", "Date range"), "daterange", null,
                        Model.FromDate?.ToString("yyyy-MM-dd"), "toDate", Model.ToDate?.ToString("yyyy-MM-dd"))
                },
                loadingHidden.Count > 0 ? loadingHidden : null);
        }
        <partial name="~/Views/Shared/_AkSearchFilter.cshtml" model="loadingFilter" />

        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead>
                    <tr>
                        <th class="ak-col-check"><input type="checkbox" class="ak-check" data-ops-select-all aria-label="@UiText.T(Context,"انتخاب همه","Select all")" /></th>
                        <th class="ak-col-grow">@UiText.T(Context,"قرارداد","Contract")</th>
                        <th>@UiText.T(Context,"جنس","Product")</th>
                        <th>@UiText.T(Context,"حمل","Transport")</th>
                        <th>@UiText.T(Context,"مقدار / ارزش","Quantity / Value")</th>
                        <th>@UiText.T(Context,"وضعیت","Status")</th>
                        <th class="ak-col-actions">@UiText.T(Context,"عملیات","Action")</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr>
                        <td colspan="7">
                            <div class="ak-empty">
                                <i class="bi bi-truck"></i>
                                @UiText.T(Context,"هنوز بارگیری‌ای ثبت نشده است","No loading records yet")
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    for (var index = 0; index < Model.Items.Count; index++)
                    {
                        var item = Model.Items[index];
                        <tr data-href="@Url.Action("Details", new { id = item.Id, returnUrl = currentUrl })">
                            <td class="ak-col-check"><input type="checkbox" class="ak-check" data-ops-row-select aria-label="@UiText.T(Context,"انتخاب ردیف","Select row")" /></td>
                            <td class="ak-col-grow">
                                <a asp-action="Details" asp-route-id="@item.Id" asp-route-returnUrl="@currentUrl" class="ak-name">@item.ContractNumber</a>
                                <span class="ak-section-desc">@item.LoadingDate.ToDisplayDate()</span>
                            </td>
                            <td>
                                <span class="ak-name">@item.ProductName</span>
                                <span class="ak-section-desc">@(item.DestinationName ?? item.OriginLocationName ?? "-")</span>
                            </td>
                            <td>
                                <span class="ak-name">@item.TransportTypeLabel</span>
                                <span class="ak-section-desc"><bdi>@(string.IsNullOrWhiteSpace(item.VehicleSummary) ? "-" : item.VehicleSummary)</bdi></span>
                            </td>
                            <td>
                                <span class="ak-num">@NumberDisplay.Quantity(item.LoadedQuantityMt) MT</span>
                                <span class="ak-section-desc ak-num">@(item.LoadingValueUsd.HasValue ? item.LoadingValueUsd.Value.ToString("N2") + " USD" : "-")</span>
                            </td>
                            <td>
                                <span class="ak-status @(item.IsPricePending ?"is-inactive" : "is-active")">@(item.IsPricePending ? UiText.T(Context,"نرخ معطل","Price pending") : UiText.T(Context,"تکمیل","Complete"))</span>
                            </td>
                            <td class="ak-col-actions">
                                <div class="dropdown ak-row-menu">
                                    <button type="button"
                                            class="ak-row-menu-btn" data-bs-toggle="dropdown" aria-expanded="false"
                                            aria-label="@UiText.T(Context,"عملیات","Actions")">
                                        <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a asp-action="Details" asp-route-id="@item.Id" asp-route-returnUrl="@currentUrl" class="dropdown-item"><i class="bi bi-eye"></i> @UiText.T(Context,"جزئیات","Details")</a></li>
                                        <li><button type="button" class="dropdown-item" data-bs-toggle="modal" data-bs-target="#loadingIndexExpensesModal" data-loading-expense-trigger="true" data-expense-url="@Url.Action("EditExpenses", "Loading", new { id = item.Id, returnUrl = currentUrl, modal = true })"><i class="bi bi-receipt"></i> @UiText.T(Context,"مصارف","Expenses")</button></li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
                @if (Model.Items.Any())
                {
                    <tfoot>
                        <tr>
                            <td colspan="3" class="fw-bold">@UiText.T(Context, "مجموع کل", "Grand Total")</td>
                            <td class="ak-num fw-bold">@NumberDisplay.Quantity((decimal)ViewBag.SumQuantity)</td>
                            <td></td>
                            <td class="ak-num fw-bold">@(((decimal)ViewBag.SumValue).ToString("N2"))</td>
                            <td></td>
                        </tr>
                    </tfoot>
                }
            </table>
        </div>

        <div class="ak-pager">
            @await Html.PartialAsync("_OperationsListFooter", (Model.CurrentPage, Model.PageCount, Model.TotalCount, 5))
        </div>
    </div>

    <div class="modal fade" id="loadingIndexExpensesModal" tabindex="-1" aria-labelledby="loadingIndexExpensesModalLabel" aria-hidden="true" data-loading-expense-remote-modal="true">
        <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <div>
                        <h2 class="modal-title" id="loadingIndexExpensesModalLabel">تکمیل مصارف بارگیری</h2>
                    </div>
                    <button type="button" class="btn-close ms-0" data-bs-dismiss="modal" aria-label="بستن"></button>
                </div>
                <div class="modal-body" data-loading-expense-remote-body>
                    <div class="ak-empty">
                        <div class="spinner-border spinner-border-sm text-primary" role="status" aria-hidden="true"></div>
                        <span>در حال بارگذاری...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            document.querySelectorAll('.ak-table tbody tr[data-href]').forEach(function (row) {
                row.style.cursor = 'pointer';
                row.addEventListener('click', function (e) {
                    if (e.target.closest('a, button, input, label, select, form')) return;
                    window.location.href = row.getAttribute('data-href');
                });
            });
        })();
    </script>
}
