@model PTGOilSystem.Web.Models.Sales.SalesIndexViewModel
@using PTGOilSystem.Web.Models.Sales
@{
    ViewData["Title"] = UiText.T(Context, "فاکتورهای فروش", "Sales invoices");
    var items = Model.Items.ToList();
    var hasAdvancedFilter =
        Model.Filter.ContractId.HasValue
        || Model.Filter.CompanyId.HasValue
        || Model.Filter.CustomerId.HasValue
        || Model.Filter.ProductId.HasValue
        || Model.Filter.FromDate.HasValue
        || Model.Filter.ToDate.HasValue;
    var hasFilters = hasAdvancedFilter || !string.IsNullOrWhiteSpace(Model.Filter.InvoiceNumber);
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="ak-form-page ak-list-page" data-operations-list>
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((UiText.T(Context, "فاکتورهای فروش", "Sales invoices"), true, UiText.T(Context, "ثبت فاکتور فروش", "New sales invoice"), "bi-plus-lg", Url.Action("Create"), (string?)null, UiText.T(Context, "ثبت فروش گروهی", "Group sale"), "bi-collection", Url.Action("CreateGroup")))" />
    <section class="ak-stat-grid mb-3" aria-label="@UiText.T(Context, "آمار فروش", "Sales statistics")">
        <vc:stat-card title="@UiText.T(Context, "کل فاکتورها", "Total invoices")" value="@Model.TotalCount.ToString("N0")" unit="@UiText.T(Context, "فاکتور", "invoices")" avatar="sales-value"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "مقدار این صفحه", "Quantity on this page")" value="@NumberDisplay.Quantity(items.Sum(x => x.QuantityMt))" unit="MT" avatar="sold-quantity"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "فروش این صفحه", "Sales on this page")" value="@items.Sum(x => x.TotalUsd).ToString("N0")" unit="USD" avatar="payments"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "مشتریان این صفحه", "Customers on this page")" value="@items.Select(x => x.CustomerName).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct().Count().ToString("N0")" unit="@UiText.T(Context, "مشتری", "customers")" avatar="customers"></vc:stat-card>
    </section>
    <div class="ak-list">
        @{
            List<AkFilterOption> SalesOpts(object? s) => (s as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>
                ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
                .Where(i => !string.IsNullOrEmpty(i.Value)).Select(i => new AkFilterOption(i.Value, i.Text)).ToList();
            string? SalesQ(string k) { var v = Context.Request.Query[k].ToString(); return string.IsNullOrEmpty(v) ? null : v; }
            var salesFilter = new AkSearchFilterModel("Filter.InvoiceNumber", Model.Filter.InvoiceNumber,
                UiText.T(Context, "جستجوی شماره فاکتور", "Search invoice number"),
                new List<AkFilterDefinition>
                {
                    new("Filter.ContractId", UiText.T(Context, "قرارداد فروش", "Sale contract"), "select", SalesOpts(ViewBag.Contracts), SalesQ("Filter.ContractId")),
                    new("Filter.CustomerId", UiText.T(Context, "مشتری", "Customer"), "select", SalesOpts(ViewBag.Customers), SalesQ("Filter.CustomerId")),
                    new("Filter.ProductId", UiText.T(Context, "جنس", "Product"), "select", SalesOpts(ViewBag.Products), SalesQ("Filter.ProductId")),
                    new("Filter.CompanyId", UiText.T(Context, "شرکت", "Company"), "select", SalesOpts(ViewBag.Companies), SalesQ("Filter.CompanyId")),
                    new("Filter.FromDate", UiText.T(Context, "بازه تاریخ", "Date range"), "daterange", null,
                        Model.Filter.FromDate?.ToString("yyyy-MM-dd"), "Filter.ToDate", Model.Filter.ToDate?.ToString("yyyy-MM-dd"))
                });
        }
        <div class="ak-list-toolbar">
            <partial name="~/Views/Shared/_AkSearchFilter.cshtml" model="salesFilter" />
            <partial name="~/Views/Shared/_ExportMenu.cshtml" model="@(new PTGOilSystem.Web.Services.Exports.ExportMenuModel("Export"))" />
        </div>

        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead>
                    <tr>
                        <th><input type="checkbox" class="ak-check" data-ops-select-all aria-label="@UiText.T(Context,"انتخاب همه","Select all")" /></th>
                        <th class="col-name">@UiText.T(Context, "فاکتور", "Invoice")</th>
                        <th>@UiText.T(Context, "مشتری / شرکت", "Customer / Company")</th>
                        <th>@UiText.T(Context, "قرارداد / محصول", "Contract / Product")</th>
                        <th>@UiText.T(Context, "مقدار / جمع", "Quantity / Total")</th>
                        <th class="col-status">@UiText.T(Context, "وضعیت", "Status")</th>
                        <th class="col-actions">@UiText.T(Context, "عملیات", "Action")</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var index = 0; index < items.Count; index++)
                    {
                        var item = items[index];
                        <tr data-href="@Url.Action("Details", new { id = item.Id, returnUrl })">
                            <td><input type="checkbox" class="ak-check" data-ops-row-select aria-label="@UiText.T(Context,"انتخاب ردیف","Select row")" /></td>
                            <td class="col-name">
                                @await Html.PartialAsync("_OperationsListIdentity", ("bi-receipt", item.InvoiceNumber, item.SaleDate.ToDisplayDate(), true))
                            </td>
                            <td>
                                <span>@item.CustomerName</span>
                                @if (!string.IsNullOrWhiteSpace(item.CompanyName))
                                {
                                    <span class="ak-section-desc">@item.CompanyName</span>
                                }
                            </td>
                            <td>
                                @{
                                    var saleContractNo = string.Equals(item.ContractNumber, SalesContractText.WithoutSalesContract, StringComparison.Ordinal) ? null : item.ContractNumber;
                                }
                                <span class="col-ltr">@(string.IsNullOrWhiteSpace(saleContractNo) ? "-" : saleContractNo)</span>
                                @if (!string.IsNullOrWhiteSpace(item.ProductName))
                                {
                                    <span class="ak-section-desc">@item.ProductName@(string.IsNullOrWhiteSpace(item.DestinationName) ? "" : " · " + item.DestinationName)</span>
                                }
                            </td>
                            <td>
                                <span class="col-ltr">@item.TotalInCurrency.ToString("N2") @item.Currency</span>
                                <span class="ak-section-desc col-ltr">@NumberDisplay.Quantity(item.QuantityMt) MT</span>
                            </td>
                            <td class="col-status"><span class="ak-status is-info">@SaleStageLabels.ToPersian(item.SaleStage)</span></td>
                            <td class="col-actions">
                                <div class="ak-row-menu">
                                    <a asp-action="Details" asp-route-id="@item.Id" asp-route-returnUrl="@returnUrl" class="btn btn-light ak-secondary-action" title="@UiText.T(Context, "مشاهده", "View")" aria-label="@UiText.T(Context, "مشاهده", "View")"><i class="bi bi-eye" aria-hidden="true"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!items.Any())
                    {
                    <tr>
                            <td colspan="7">
                                <div class="ak-empty">
                                    <i class="bi bi-receipt"></i>
                                    هیچ فاکتور فروشی یافت نشد
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
                @if (items.Any())
                {
                    <tfoot>
                        <tr>
                            <td colspan="4" class="fw-bold">@UiText.T(Context, "مجموع کل", "Grand Total")</td>
                            <td class="col-ltr fw-bold">@NumberDisplay.Quantity((decimal)ViewBag.SumQuantity) MT</td>
                            <td class="col-ltr fw-bold">@(((decimal)ViewBag.SumTotalUsd).ToString("N2")) USD</td>
                            <td></td>
                        </tr>
                    </tfoot>
                }
            </table>
        </div>

        <div class="ak-pager">
            @await Html.PartialAsync("_OperationsListFooter", (Model.CurrentPage, Model.PageCount, Model.TotalCount, 5))
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var toggle = document.getElementById('salesFilterToggle');
            var pop = document.getElementById('salesFilterPop');
            if (!toggle || !pop) return;
            function close() { pop.hidden = true; toggle.setAttribute('aria-expanded', 'false'); }
            toggle.addEventListener('click', function (e) {
                e.stopPropagation();
                var open = pop.hidden;
                pop.hidden = !open;
                toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
            });
            document.addEventListener('click', function (e) {
                if (!pop.hidden && !pop.contains(e.target) && e.target !== toggle) close();
            });
            document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
        })();
        (function () {
            document.querySelectorAll('.ak-list-page .ak-table tbody tr[data-href]').forEach(function (row) {
                row.style.cursor = 'pointer';
                row.addEventListener('click', function (e) {
                    if (e.target.closest('a, button, input, label, select, form')) return;
                    window.location.href = row.getAttribute('data-href');
                });
            });
        })();
    </script>
}
