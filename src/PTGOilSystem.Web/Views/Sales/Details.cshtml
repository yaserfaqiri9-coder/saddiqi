@model PTGOilSystem.Web.Models.Sales.SalesDetailsViewModel
@using PTGOilSystem.Web.Models.Sales
@{
    string T(string fa, string en) => UiText.T(Context, fa, en);

    var returnUrl = ViewBag.ReturnUrl as string;
    var backUrl = !string.IsNullOrWhiteSpace(returnUrl)
        ? returnUrl
        : Url.Action("Index", "Sales") ?? "/Sales";
    var currentReturnUrl = Context.Request.Path + Context.Request.QueryString;
    var contractText = SalesContractText.Display(Model.ContractNumber);
    var stockSourceText = Model.StockSourceType?.ToString() switch
    {
        "Wagon" => T("واگن", "Wagon"),
        "Stock" => T("انبار / مخزن", "Stock"),
        "Tank" => T("تانک", "Tank"),
        _ => T("ثبت نشده", "Not set")
    };
    var ledgerRecorded = Model.LedgerEntryId.HasValue;
    var hasInventoryTrace = Model.InventoryMovementId.HasValue
        || Model.LoadingReceiptId.HasValue
        || Model.InventoryTransportReceiptId.HasValue
        || Model.LoadingReceiptAllocationId.HasValue;
    var inventoryStatus = Model.InventoryMovementId.HasValue
        ? T("خروج موجودی", "Inventory out")
        : hasInventoryTrace
            ? T("فقط ردیابی", "Trace only")
            : T("ثبت نشده", "No trace");
    var isSameCurrency = string.Equals(Model.Currency, "USD", StringComparison.OrdinalIgnoreCase);

    ViewData["AkHeaderStatus"] = Model.IsCancelled ? T("لغو شده", "Cancelled") : T("تکمیل شده", "Completed");
    ViewData["AkHeaderStatusState"] = Model.IsCancelled ? "is-danger" : "is-active";
    ViewData["AkHeaderContext"] = $"{Model.CustomerName} · {contractText} · {Model.SaleDate.ToDisplayDate()}";
    ViewData["AkHeaderKebab"] = new List<AkHeaderMenuItem>
    {
        new() { Label = T("ویرایش", "Edit"), Href = Url.Action("Edit", new { id = Model.Id, returnUrl = currentReturnUrl }), Icon = "bi-pencil-square" },
        new() { Label = T("فاکتور دوم", "Alternate invoice"), Href = Url.Action("Invoice", new { id = Model.Id, template = "fawad" }), Icon = "bi-receipt-cutoff" },
        new() { Label = T("فروش جدید", "New sale"), Href = Url.Action("Create", new { returnUrl = backUrl }), Icon = "bi-plus-lg" }
    };
    var timelineItems = new List<AkTimelineItem>
    {
        new() { Title = T("فروش ثبت شد", "Sale recorded"), Date = Model.SaleDate.ToDisplayDate(), Timestamp = Model.CreatedAtUtc, Icon = "bi-cart-check", State = Model.IsCancelled ? "is-muted" : "is-current", Meta = $"{Model.TotalUsd:N2} USD" }
    };
    var relatedRecords = new List<AkRelatedRecord>();
    if (!string.IsNullOrWhiteSpace(Model.ContractNumber))
    {
        relatedRecords.Add(new AkRelatedRecord { TypeLabel = T("قرارداد", "Contract"), Label = Model.ContractNumber, KeyValue = Model.ProductName, Icon = "bi-file-earmark-text" });
    }
    if (!string.IsNullOrWhiteSpace(Model.ShipmentCode))
    {
        relatedRecords.Add(new AkRelatedRecord { TypeLabel = T("محموله", "Shipment"), Label = Model.ShipmentCode, Icon = "bi-box-seam" });
    }
    if (Model.LedgerEntryId.HasValue)
    {
        relatedRecords.Add(new AkRelatedRecord { TypeLabel = T("سند دفتر کل", "Ledger entry"), Label = $"#{Model.LedgerEntryId.Value}", KeyValue = $"{Model.TotalUsd:N2} USD", Icon = "bi-journal-text" });
    }
    var nextActions = new List<AkHeaderMenuItem>
    {
        new() { Label = T("نمایش فاکتور", "View invoice"), Href = Url.Action("Invoice", new { id = Model.Id, template = "faisal" }), Icon = "bi-receipt" },
        new() { Label = T("فروش جدید", "New sale"), Href = Url.Action("Create", new { returnUrl = backUrl }), Icon = "bi-plus-lg" }
    };

    ViewData["Title"] = T("جزئیات فروش", "Sale Details");
    ViewData["HideSectionTabs"] = true;
}

<div class="ak-form-page ak-detail-page" dir="rtl" data-ak-detail-v2="true">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((T("جزئیات فروش", "Sale details") + " " + Model.InvoiceNumber, false,
                       T("نمایش فاکتور", "View invoice"), "bi-receipt",
                       Url.Action("Invoice", new { id = Model.Id, template = "faisal" }), (string?)null,
                       T("بازگشت", "Back"), "bi-arrow-right", (string?)backUrl))" />

    <div class="ak-page-actions">
        @if (Model.IsCancelled)
        {
            <span class="ak-status is-inactive"><i class="bi bi-x-circle"></i> @T("لغو شده", "Cancelled")</span>
        }
        else
        {
            <span class="ak-status is-active"><i class="bi bi-check-circle"></i> @T("تکمیل شده", "Completed")</span>
        }
        <div class="dropdown ak-row-menu">
            <button type="button" class="ak-row-menu-btn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="@T("عملیات", "Actions")">
                <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" asp-action="Invoice" asp-route-id="@Model.Id" asp-route-template="faisal" target="_blank" rel="noopener"><i class="bi bi-receipt"></i> @T("فاکتور Faisal", "Faisal invoice")</a></li>
                <li><a class="dropdown-item" asp-action="Invoice" asp-route-id="@Model.Id" asp-route-template="fawad" target="_blank" rel="noopener"><i class="bi bi-receipt-cutoff"></i> @T("فاکتور Fawad", "Fawad invoice")</a></li>
                <li><a class="dropdown-item" href="@(Url.Action("Create", new { returnUrl = backUrl }) ?? "#")"><i class="bi bi-plus-lg"></i> @T("فروش جدید", "New sale")</a></li>
                @if (!Model.IsCancelled)
                {
                    <li>
                        <form asp-action="Cancel" asp-route-id="@Model.Id" asp-route-returnUrl="@currentReturnUrl" method="post" data-no-spa="true"
                              onsubmit="return confirm('@T("این فروش ابطال شود؟", "Cancel this sale?")');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="dropdown-item ak-danger">
                                <i class="bi bi-slash-circle"></i> @T("ابطال فروش", "Cancel sale")
                            </button>
                        </form>
                    </li>
                }
            </ul>
        </div>
    </div>

    <section class="ak-stat-grid no-print" aria-label="@T("شاخص‌های فروش", "Sale metrics")">
        <vc:stat-card title="@T("مقدار فروش", "Sale quantity")" value="@NumberDisplay.Quantity(Model.QuantityMt)" unit="MT" avatar="sold-quantity"></vc:stat-card>
        <vc:stat-card title="@T("قیمت واحد", "Unit price")" value="@Model.UnitPriceUsd.ToString("N2")" unit="USD/MT" avatar="profit-loss"></vc:stat-card>
        <vc:stat-card title="@T("مبلغ قابل دریافت", "Amount due")" value="@Model.TotalUsd.ToString("N2")" unit="USD" avatar="payments"></vc:stat-card>
        <vc:stat-card title="@T("وضعیت دفتر", "Ledger status")" value="@(ledgerRecorded ? T("ثبت‌شده", "Recorded") : T("در انتظار", "Pending"))" unit="" avatar="ledger"></vc:stat-card>
    </section>

    <section class="ak-form-section ak-detail-section">
        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@((T("اقلام فروش", "Sale items"), (string?)null))" />
        <div class="ak-table-wrap">
            <table class="ak-table ak-detail-table">
                <thead>
                    <tr>
                        <th class="ak-col-grow">@T("محصول", "Product")</th>
                        <th>@T("واحد", "Unit")</th>
                        <th class="ak-col-num">@T("مقدار", "Quantity")</th>
                        <th class="ak-col-num">@T("قیمت واحد", "Unit price") (USD)</th>
                        <th class="ak-col-num">@T("مبلغ کل", "Total") (USD)</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="ak-col-grow">@Model.ProductName</td>
                        <td>MT</td>
                        <td class="ak-num">@NumberDisplay.Quantity(Model.QuantityMt)</td>
                        <td class="ak-num">@Model.UnitPriceUsd.ToString("N2")</td>
                        <td class="ak-num">@Model.TotalUsd.ToString("N2")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>

    <div class="ak-form-grid">
        <section class="ak-form-section ak-detail-section">
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@((T("اطلاعات پرداخت و دفتر", "Payment & ledger"), (string?)null))" />
            <dl class="ak-list">
                <div class="ak-list-row"><dt>@T("ارز پرداخت", "Currency")</dt><dd>@Model.Currency</dd></div>
                <div class="ak-list-row"><dt>@T("نرخ ارز", "FX rate")</dt><dd class="ak-num">@NumberDisplay.FxRate(Model.AppliedFxRateToUsd)</dd></div>
                <div class="ak-list-row"><dt>@T("مبلغ قابل دریافت", "Amount due")</dt><dd class="ak-num">@Model.TotalUsd.ToString("N2") USD</dd></div>
                <div class="ak-list-row">
                    <dt>@T("وضعیت دفتر", "Ledger status")</dt>
                    <dd>
                        <span class="ak-status @(ledgerRecorded ?"is-active" : "is-inactive")">
                            @(ledgerRecorded ? T("ثبت‌شده", "Recorded") : T("ثبت نشده", "Pending"))
                        </span>
                    </dd>
                </div>
                <div class="ak-list-row"><dt>@T("مرجع دفتر", "Ledger ref")</dt><dd>@(Model.LedgerReference ?? "-")</dd></div>
                <div class="ak-list-row"><dt>@T("سمت / شرح", "Side / note")</dt><dd>@(Model.LedgerSideName ?? "-")@(string.IsNullOrWhiteSpace(Model.LedgerDescription) ? "" : " · " + Model.LedgerDescription)</dd></div>
            </dl>
        </section>

        <section class="ak-form-section ak-detail-section">
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@((T("خلاصه فروش", "Sale summary"), (string?)null))" />
            <dl class="ak-list">
                <div class="ak-list-row"><dt>@T("جمع مقدار", "Total quantity")</dt><dd class="ak-num">@NumberDisplay.Quantity(Model.QuantityMt) MT</dd></div>
                <div class="ak-list-row"><dt>@T("قیمت واحد", "Unit price") (USD)</dt><dd class="ak-num">@Model.UnitPriceUsd.ToString("N2")</dd></div>
                <div class="ak-list-row"><dt>@T("جمع مبلغ", "Total amount") (USD)</dt><dd class="ak-num">@Model.TotalUsd.ToString("N2")</dd></div>
                @if (!isSameCurrency)
                {
                    <div class="ak-list-row"><dt>@T("قیمت واحد سند", "Doc unit price")</dt><dd class="ak-num">@Model.UnitPriceInCurrency.ToString("N2") @Model.Currency</dd></div>
                    <div class="ak-list-row"><dt>@T("جمع سند", "Document total")</dt><dd class="ak-num">@Model.TotalInCurrency.ToString("N2") @Model.Currency</dd></div>
                }
            </dl>
        </section>
    </div>

    <section class="ak-form-section ak-detail-section">
        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@((T("منبع و ردیابی موجودی", "Source & inventory trace"), (string?)null))" />
        <dl class="ak-list">
            <div class="ak-list-row"><dt>@T("منبع موجودی", "Stock source")</dt><dd>@stockSourceText</dd></div>
            <div class="ak-list-row"><dt>@T("ترمینال منبع", "Source terminal")</dt><dd>@(Model.SourceTerminalName ?? "-")</dd></div>
            <div class="ak-list-row"><dt>@T("مخزن منبع", "Source tank")</dt><dd>@(Model.SourceStorageTankCode ?? "-")</dd></div>
            <div class="ak-list-row"><dt>@T("قرارداد خرید منبع", "Source purchase")</dt><dd>@(Model.SourcePurchaseContractNumber ?? "-")</dd></div>
            <div class="ak-list-row"><dt>@T("محموله", "Shipment")</dt><dd>@(Model.ShipmentCode ?? "-")</dd></div>
            <div class="ak-list-row"><dt>@T("مقصد", "Destination")</dt><dd>@(Model.DestinationName ?? "-")</dd></div>
            <div class="ak-list-row"><dt>@T("سریال تکت", "Ticket serial")</dt><dd>@(Model.TicketSerialNumber ?? "-")</dd></div>
            <div class="ak-list-row"><dt>@T("ردیابی موجودی", "Inventory trace")</dt><dd>@inventoryStatus</dd></div>
        </dl>
        @if (!string.IsNullOrWhiteSpace(Model.Notes))
        {
            <p class="ak-note">@Model.Notes</p>
        }
    </section>

    <section class="ak-form-section ak-detail-section" aria-labelledby="sale-timeline-title">
        <h2 class="ak-section-title" id="sale-timeline-title">@T("روند سند", "Document timeline")</h2>
        <partial name="~/Views/Shared/Partials/_DetailTimeline.cshtml" model="@((IReadOnlyList<AkTimelineItem>)timelineItems)" />
    </section>
    @if (relatedRecords.Count > 0)
    {
        <section class="ak-form-section ak-detail-section" aria-labelledby="sale-related-title">
            <h2 class="ak-section-title" id="sale-related-title">@T("رکوردهای مرتبط", "Related records")</h2>
            <partial name="~/Views/Shared/Partials/_RelatedRecords.cshtml" model="@((IReadOnlyList<AkRelatedRecord>)relatedRecords)" />
        </section>
    }
    <partial name="~/Views/Shared/Partials/_DetailActionBar.cshtml" model="@((IReadOnlyList<AkHeaderMenuItem>)nextActions)" />
</div>
