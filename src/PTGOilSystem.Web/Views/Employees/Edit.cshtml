@model PTGOilSystem.Web.Models.Employees.EmployeeFormViewModel
@{
    ViewData["Title"] = UiText.T(Context, "ویرایش کارمند", "Edit Employee");
}

<div class="ak-form-page">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((UiText.T(Context, "ویرایش کارمند", "Edit Employee"), true,
                       (string?)null, (string?)null, (string?)null, (string?)null,
                       UiText.T(Context, "بازگشت", "Back"), "bi-arrow-right",
                       (string?)Url.Action("Details", new { id = Model.Id })))" />

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="ak-form" data-no-spa>
        @Html.AntiForgeryToken()
        <partial name="_Form" model="Model" />
        <partial name="~/Views/Shared/Components/Ak/_AkFooterActions.cshtml"
                 model="@((UiText.T(Context, "ذخیره تغییرات", "Save Changes"), Url.Action("Details", new { id = Model.Id }) ?? "#", UiText.T(Context, "انصراف", "Cancel")))" />
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
