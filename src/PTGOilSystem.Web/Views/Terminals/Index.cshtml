@model IEnumerable<Terminal>
@{
    ViewData["Title"] = UiText.T(Context, "ترمینال ها", "Terminals");
    var items = Model.ToList();
    var hasFilters = ViewData["isActive"] != null;
    var hasSearch = !string.IsNullOrWhiteSpace((string?)ViewData["q"]) || hasFilters;
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var activeCount = items.Count(item => item.IsActive);
    var inactiveCount = items.Count - activeCount;
    var locatedCount = items.Count(item => !string.IsNullOrWhiteSpace(item.Location));
}

<div class="ak-list-page">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((UiText.T(Context, "ترمینال ها", "Terminals"), true,
                       UiText.T(Context, "ترمینال جدید", "New terminal"), "bi-plus-lg",
                       (string?)Url.Action("Create", new { returnUrl }), (string?)null,
                       (string?)null, (string?)null, (string?)null))" />

    <section class="ak-stat-grid mb-3" aria-label="@UiText.T(Context, "آمار ترمینال‌ها", "Terminal statistics")">
        <vc:stat-card title="@UiText.T(Context, "تعداد ترمینال‌ها", "Terminals")" value="@items.Count.ToString("N0")" unit="@UiText.T(Context, "ترمینال", "terminals")" avatar="unloaded"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "ترمینال‌های فعال", "Active terminals")" value="@activeCount.ToString("N0")" unit="@UiText.T(Context, "ترمینال", "terminals")" avatar="loading"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "ترمینال‌های غیرفعال", "Inactive terminals")" value="@inactiveCount.ToString("N0")" unit="@UiText.T(Context, "ترمینال", "terminals")" avatar="losses"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "دارای موقعیت", "With location")" value="@locatedCount.ToString("N0")" unit="@UiText.T(Context, "ترمینال", "terminals")" avatar="shipments"></vc:stat-card>
    </section>

    @{
        var terminalsIsActive = ViewData["isActive"] is bool termAct ? (termAct ? "true" : "false") : null;
        var terminalsFilter = new AkSearchFilterModel("q", (string?)ViewData["q"],
            UiText.T(Context, "جستجو در کد، نام یا موقعیت...", "Search code, name, or location..."),
            new List<AkFilterDefinition>
            {
                new("isActive", UiText.T(Context, "وضعیت", "Status"), "bool",
                    new List<AkFilterOption> { new("true", UiText.T(Context, "فعال", "Active")), new("false", UiText.T(Context, "غیرفعال", "Inactive")) },
                    terminalsIsActive)
            });
    }
    <partial name="~/Views/Shared/_AkSearchFilter.cshtml" model="terminalsFilter" />

    <div class="ak-list">
        <div class="ak-table-wrap">
            <table class="ak-table" aria-label="@UiText.T(Context, "لیست ترمینال ها", "Terminal list")">
                <thead><tr>
                    <th class="ak-col-check"><input type="checkbox" class="ak-check" aria-label="@UiText.T(Context, "انتخاب همه", "Select all")" /></th>
                    <th class="ak-col-grow">@UiText.T(Context, "نام", "Name")</th>
                    <th>@UiText.T(Context, "کد", "Code")</th>
                    <th>@UiText.T(Context, "موقعیت", "Location")</th>
                    <th class="ak-col-spacer"></th>
                    <th>@UiText.T(Context, "وضعیت", "Status")</th>
                    <th class="ak-col-actions"></th>
                </tr></thead>
                <tbody>
                    @foreach (var item in items)
                    {
                        <tr>
                            <td class="ak-col-check"><input type="checkbox" class="ak-check" aria-label="@UiText.T(Context, "انتخاب", "Select")" /></td>
                            <td class="ak-col-grow"><a asp-action="Details" asp-route-id="@item.Id" class="ak-name">@item.Name</a></td>
                            <td>@item.Code</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Location) ? "—" : item.Location)</td>
                            <td class="ak-col-spacer"></td>
                            <td><span class="ak-status @(item.IsActive ?"is-active" : "is-inactive")">@(item.IsActive ? "فعال" : "غیرفعال")</span></td>
                            <td class="ak-col-actions">
                                <div class="dropdown ak-row-menu">
                                    <button type="button" class="ak-row-menu-btn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="@UiText.T(Context, "عملیات", "Actions")"><i class="bi bi-three-dots-vertical" aria-hidden="true"></i></button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a class="dropdown-item" asp-action="Details" asp-route-id="@item.Id"><i class="bi bi-eye" aria-hidden="true"></i>مشاهده</a></li>
                                        <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil" aria-hidden="true"></i>ویرایش</a></li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><form asp-action="Delete" asp-route-id="@item.Id" method="post" data-ptg-confirm="true" data-ptg-confirm-title="حذف ترمینال" data-ptg-confirm-message="آیا از حذف مطمئن هستید؟">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item ak-danger"><i class="bi bi-trash" aria-hidden="true"></i>حذف</button>
                                        </form></li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!items.Any())
                    {
                        <tr><td colspan="7"><div class="ak-empty"><i class="bi bi-pin-map" aria-hidden="true"></i>رکوردی یافت نشد</div></td></tr>
                    }
                </tbody>
            </table>
        </div>
        @{ ViewData["ShownCount"] = items.Count; }
        <div class="ak-pager">@await Html.PartialAsync("_PagedListFooter")</div>
    </div>
</div>
