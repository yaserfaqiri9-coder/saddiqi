@using PTGOilSystem.Web.Models.ContractJourney
@model PTGOilSystem.Web.Models.ContractJourney.ContractJourneyLedgerTabViewModel
@{
    string T(string fa, string en) => UiText.T(Context, fa, en);
    string UnitUsd() => T("دالر", "USD");
    string LocalizeDisplay(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "-";
        }

        var text = value.Trim();
        var fa = text switch
        {
            "Sale" => "فروش",
            "Expense" => "مصرف",
            "CustomerReceipt" => "دریافت از مشتری",
            "SupplierPayment" => "پرداخت به تأمین‌کننده",
            "SupplierReceipt" => "دریافت از تأمین‌کننده",
            "CustomerPayment" => "پرداخت به مشتری",
            "ExpensePayment" => "پرداخت مصرف",
            "TruckPayment" => "پرداخت موتر",
            "ManualPayment" => "پرداخت دستی",
            "ManualReceipt" => "دریافت دستی",
            "EmployeeReturn" => "برگشت از کارمند",
            _ => text
        };

        return T(fa, text);
    }

    string ReturnUrl(string tab)
        => Url.Action("Details", "ContractJourney", new { contractId = Model.ContractId, tab, lockContract = Model.LockContract })
            ?? $"/ContractJourney/Details?contractId={Model.ContractId}&tab={tab}&lockContract={Model.LockContract.ToString().ToLowerInvariant()}";
}

<div id="journey-tab-lists" class="ak-tab-panel">
    <section class="ak-form-section">
        <div class="ak-section-head">
            <div>
                <h2 class="ak-section-title">@T("ردیف‌های دفتر کل مرتبط", "Related ledger entries")</h2>
            </div>
            <a href="@Model.LedgerIndexUrl" class="btn btn-primary ak-primary-action">
                <i class="bi bi-journal-richtext"></i>
                <span>@T("مشاهده دفتر کل", "Open ledger")</span>
            </a>
        </div>

        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead>
                    <tr>
                        <th class="ak-col-grow">@T("شماره", "ID")</th>
                        <th>@T("تاریخ", "Date")</th>
                        <th>@T("ماهیت", "Side")</th>
                        <th class="ak-col-num">@T("مبلغ", "Amount")</th>
                        <th>@T("منبع", "Source")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="ak-col-grow">
                            <a asp-controller="Ledger" asp-action="Details" asp-route-id="@item.LedgerEntryId" asp-route-returnUrl="@ReturnUrl(ContractJourneyTabs.Details.Ledger)" class="ak-name">#@item.LedgerEntryId</a>
                        </td>
                        <td>@item.EntryDate.ToDisplayDate()</td>
                        <td>@LocalizeDisplay(item.SideName)</td>
                        <td class="ak-num">@item.AmountUsd.ToString("N2") @UnitUsd()</td>
                        <td>@LocalizeDisplay(item.SourceType) / #@item.SourceId</td>
                    </tr>
                }
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="5">
                            <div class="ak-empty">
                                <i class="bi bi-journal-bookmark"></i>
                                @Model.NoRecordsText
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        @Model.PagerHtml
    </section>
</div>
