@model PTGOilSystem.Web.Models.ContractJourney.ContractJourneyInventoryTabViewModel
@{
    string T(string fa, string en) => UiText.T(Context, fa, en);
    string UnitMt() => T("تن", "MT");
    string TextOrDash(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value.Trim();
    bool IsIn(string? direction) => string.Equals(direction, "In", StringComparison.OrdinalIgnoreCase);

    // گروه‌بندی حرکات بر اساس ترمینال + مخزن
    var tankGroups = Model.Items
        .GroupBy(i => new { Terminal = i.TerminalName, Tank = i.StorageTankCode ?? "" })
        .Select(g => {
            var latestItem = g.OrderByDescending(i => i.MovementDate).First();
            return new {
                TerminalName = g.Key.Terminal,
                TankName = g.Key.Tank,
                CurrentBalance = latestItem.RunningBalanceMt,
                TotalIn  = g.Where(i => IsIn(i.DirectionName)).Sum(i => i.QuantityMt),
                TotalOut = g.Where(i => !IsIn(i.DirectionName)).Sum(i => i.QuantityMt),
                InCount  = g.Count(i => IsIn(i.DirectionName)),
                OutCount = g.Count(i => !IsIn(i.DirectionName)),
            };
        })
        .OrderByDescending(g => g.CurrentBalance)
        .ToList();
}

<div id="journey-tab-lists" class="ak-tab-panel">
    <section class="ak-form-section">
        <div class="ak-section-head">
            <div>
                <h2 class="ak-section-title">@T("وضعیت موجودی", "Inventory status")</h2>
            </div>
            <a href="@Model.StockCardUrl" class="btn btn-primary ak-primary-action">
                <i class="bi bi-card-list" aria-hidden="true"></i>
                <span>@T("کارت موجودی", "Stock card")</span>
            </a>
        </div>

        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead>
                    <tr>
                        <th class="ak-col-grow">@T("ترمینال", "Terminal")</th>
                        <th>@T("مخزن", "Tank")</th>
                        <th class="ak-col-num">@T("موجودی", "Balance")</th>
                        <th class="ak-col-num">@T("ورودی", "In")</th>
                        <th class="ak-col-num">@T("خروجی", "Out")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var tank in tankGroups)
                {
                    <tr>
                        <td class="ak-col-grow">@TextOrDash(tank.TerminalName)</td>
                        <td>@TextOrDash(tank.TankName)</td>
                        <td class="ak-num">@NumberDisplay.Quantity(tank.CurrentBalance) @UnitMt()</td>
                        <td class="ak-num">@NumberDisplay.Quantity(tank.TotalIn) @UnitMt() (@tank.InCount)</td>
                        <td class="ak-num">@NumberDisplay.Quantity(tank.TotalOut) @UnitMt() (@tank.OutCount)</td>
                    </tr>
                }
                @if (!tankGroups.Any())
                {
                    <tr>
                        <td colspan="5">
                            <div class="ak-empty">
                                <i class="bi bi-inbox"></i>
                                @Model.NoRecordsText
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>

    <section class="ak-form-section">
        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml"
                 model="@((T("حرکت‌های موجودی", "Inventory movements"), (string?)null))" />
        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead>
                    <tr>
                        <th class="ak-col-grow">@T("مرجع", "Reference")</th>
                        <th>@T("تاریخ", "Date")</th>
                        <th>@T("ترمینال / تانک", "Terminal / Tank")</th>
                        <th>@T("جهت", "Direction")</th>
                        <th class="ak-col-num">@T("مقدار", "Quantity")</th>
                        <th class="ak-col-num">@T("مانده", "Balance")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="ak-col-grow">@TextOrDash(item.ReferenceDocument ?? item.SourceLabel)</td>
                        <td>@item.MovementDate.ToDisplayDate()</td>
                        <td>@TextOrDash(item.TerminalName) / @TextOrDash(item.StorageTankCode)</td>
                        <td>
                            <span class="ak-status @(IsIn(item.DirectionName) ?"is-active" : "is-inactive")">
                                @(IsIn(item.DirectionName) ? T("ورود", "In") : T("خروج", "Out"))
                            </span>
                        </td>
                        <td class="ak-num">@NumberDisplay.Quantity(item.SignedQuantityMt) @UnitMt()</td>
                        <td class="ak-num">@NumberDisplay.Quantity(item.RunningBalanceMt) @UnitMt()</td>
                    </tr>
                }
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="6">
                            <div class="ak-empty">
                                <i class="bi bi-boxes"></i>
                                @Model.NoRecordsText
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        @Model.PagerHtml
    </section>
</div>
