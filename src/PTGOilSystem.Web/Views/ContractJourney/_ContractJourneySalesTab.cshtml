@using PTGOilSystem.Web.Models.ContractJourney
@model PTGOilSystem.Web.Models.ContractJourney.ContractJourneySalesTabViewModel
@{
    string T(string fa, string en) => UiText.T(Context, fa, en);
    string UnitMt() => T("تن", "MT");
    string UnitUsd() => T("دالر", "USD");
    string ReturnUrl(string tab)
        => Url.Action("Details", "ContractJourney", new { contractId = Model.ContractId, tab, lockContract = Model.LockContract })
            ?? $"/ContractJourney/Details?contractId={Model.ContractId}&tab={tab}&lockContract={Model.LockContract.ToString().ToLowerInvariant()}";
}

<div id="journey-tab-lists" class="ak-tab-panel">
    <section class="ak-form-section">
        <div class="ak-section-head">
            <div>
                <h2 class="ak-section-title">@T("فاکتورهای فروش", "Sales invoices")</h2>
            </div>
            @if (Model.IsPurchaseContract)
            {
                <a asp-controller="Sales" asp-action="Create" asp-route-sourcePurchaseContractId="@Model.ContractId" asp-route-returnUrl="@ReturnUrl(ContractJourneyTabs.Details.Sales)" class="btn btn-primary ak-primary-action">
                    <i class="bi bi-receipt"></i>
                    <span>@T("صدور فاکتور جدید", "Issue invoice")</span>
                </a>
            }
            else
            {
                <a asp-controller="Sales" asp-action="Create" asp-route-contractId="@Model.ContractId" asp-route-returnUrl="@ReturnUrl(ContractJourneyTabs.Details.Sales)" class="btn btn-primary ak-primary-action">
                    <i class="bi bi-receipt"></i>
                    <span>@T("صدور فاکتور جدید", "Issue invoice")</span>
                </a>
            }
        </div>

        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead>
                    <tr>
                        <th class="ak-col-grow">@T("فاکتور", "Invoice")</th>
                        <th>@T("تاریخ", "Date")</th>
                        <th>@T("مشتری", "Customer")</th>
                        <th class="ak-col-num">@T("مقدار", "Quantity")</th>
                        <th class="ak-col-num">@T("قیمت واحد", "Unit price")</th>
                        <th class="ak-col-num">@T("مبلغ کل", "Total amount")</th>
                        <th class="ak-col-actions">@T("عملیات", "Actions")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.SalesItems)
                {
                    <tr>
                        <td class="ak-col-grow">
                            <a asp-controller="Sales" asp-action="Details" asp-route-id="@item.SalesTransactionId" asp-route-returnUrl="@ReturnUrl(ContractJourneyTabs.Details.Sales)" class="ak-name">@item.InvoiceNumber</a>
                        </td>
                        <td>@item.SaleDate.ToDisplayDate()</td>
                        <td>@item.CustomerName</td>
                        <td class="ak-num">@NumberDisplay.Quantity(item.QuantityMt) @UnitMt()</td>
                        <td class="ak-num">@item.UnitPriceUsd.ToString("N2") @UnitUsd()</td>
                        <td class="ak-num">@item.AmountUsd.ToString("N2") @UnitUsd()</td>
                        <td class="ak-col-actions">
                            <div class="dropdown ak-row-menu">
                                <button type="button" class="ak-row-menu-btn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="@T("عملیات", "Actions")">
                                    <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a asp-controller="Sales" asp-action="Details" asp-route-id="@item.SalesTransactionId" asp-route-returnUrl="@ReturnUrl(ContractJourneyTabs.Details.Sales)" class="dropdown-item"><i class="bi bi-eye"></i> @T("جزئیات", "Details")</a></li>
                                    <li><a asp-controller="Payments" asp-action="Create" asp-route-contractId="@Model.ContractId" asp-route-salesTransactionId="@item.SalesTransactionId" asp-route-returnUrl="@ReturnUrl(ContractJourneyTabs.Details.Sales)" class="dropdown-item"><i class="bi bi-cash-coin"></i> @T("دریافت", "Receive")</a></li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.SalesItems.Any())
                {
                    <tr>
                        <td colspan="7">
                            <div class="ak-empty">
                                <i class="bi bi-cart-check"></i>
                                @Model.NoSalesText
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        @Model.SalesPagerHtml
    </section>
</div>
