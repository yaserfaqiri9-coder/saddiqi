@using PTGOilSystem.Web.Models.ContractJourney
@model PTGOilSystem.Web.Models.ContractJourney.ContractJourneyDispatchTabViewModel
@{
    string T(string fa, string en) => UiText.T(Context, fa, en);
    string UnitMt() => T("تن", "MT");
    string LocalizeDisplay(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "-";
        }

        var text = value.Trim();
        var fa = text switch
        {
            "Loaded" => "بارگیری‌شده",
            "InTransit" => "در مسیر",
            "Delivered" => "تحویل‌شده",
            "Cancelled" => "لغوشده",
            _ => text
        };

        return T(fa, text);
    }

    string StatusToneClass(string? value)
        => string.Equals(value, "Delivered", StringComparison.OrdinalIgnoreCase) ? "is-active" : "is-inactive";

    string ReturnUrl(string tab)
        => Url.Action("Details", "ContractJourney", new { contractId = Model.ContractId, tab, lockContract = Model.LockContract })
            ?? $"/ContractJourney/Details?contractId={Model.ContractId}&tab={tab}&lockContract={Model.LockContract.ToString().ToLowerInvariant()}";
}

<div id="journey-tab-lists" class="ak-tab-panel">
    <section class="ak-form-section">
        <div class="ak-section-head">
            <div>
                <h2 class="ak-section-title">@T("نقل و انتقالات", "Transfers")</h2>
            </div>
            <a asp-controller="Dispatch" asp-action="Create" asp-route-contractId="@Model.ContractId" asp-route-returnUrl="@ReturnUrl(ContractJourneyTabs.Details.Dispatch)" class="btn btn-primary ak-primary-action">
                <i class="bi bi-truck"></i>
                <span>@T("ثبت نقل و انتقال", "New Transfer")</span>
            </a>
        </div>

        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead>
                    <tr>
                        <th class="ak-col-grow">@T("شماره", "ID")</th>
                        <th>@T("تاریخ", "Date")</th>
                        <th>@T("موتر", "Truck")</th>
                        <th>@T("وضعیت", "Status")</th>
                        <th class="ak-col-num">@T("مقدار", "Quantity")</th>
                        <th class="ak-col-actions">@T("عملیات", "Actions")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="ak-col-grow">
                            <a asp-controller="Dispatch" asp-action="Details" asp-route-id="@item.Id" asp-route-returnUrl="@ReturnUrl(ContractJourneyTabs.Details.Dispatch)" class="ak-name">#@item.Id</a>
                        </td>
                        <td>@item.DispatchDate.ToDisplayDate()</td>
                        <td>@item.TruckPlateNumber</td>
                        <td><span class="ak-status @StatusToneClass(item.StatusName)">@LocalizeDisplay(item.StatusName)</span></td>
                        <td class="ak-num">@NumberDisplay.Quantity(item.LoadedQuantityMt) @UnitMt()</td>
                        <td class="ak-col-actions">
                            <div class="dropdown ak-row-menu">
                                <button type="button" class="ak-row-menu-btn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="@T("عملیات", "Actions")">
                                    <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a asp-controller="Dispatch" asp-action="Details" asp-route-id="@item.Id" asp-route-returnUrl="@ReturnUrl(ContractJourneyTabs.Details.Dispatch)" class="dropdown-item"><i class="bi bi-eye"></i> @T("جزئیات", "Details")</a></li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="6">
                            <div class="ak-empty">
                                <i class="bi bi-truck"></i>
                                @Model.NoRecordsText
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        @Model.PagerHtml
    </section>
</div>
