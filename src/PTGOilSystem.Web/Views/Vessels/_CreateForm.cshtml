@model Vessel

@Html.AntiForgeryToken()
<div asp-validation-summary="ModelOnly" class="alert alert-danger ak-form-alert"></div>

<section class="ak-form-section">
    <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml"
             model="@(("اطلاعات کشتی", (string?)"کد، نام، IMO و مالک کشتی را وارد کنید."))" />
    <div class="ak-form-grid">
        <div class="ak-field">
            <label asp-for="Code" class="ak-label">کد</label>
            <input asp-for="Code" class="ak-input" />
            <span asp-validation-for="Code" class="ak-field-error"></span>
        </div>
        <div class="ak-field">
            <label asp-for="Name" class="ak-label">نام <span class="ak-req">*</span></label>
            <input asp-for="Name" class="ak-input" />
            <span asp-validation-for="Name" class="ak-field-error"></span>
        </div>
        <div class="ak-field">
            <label asp-for="Imo" class="ak-label">IMO</label>
            <input asp-for="Imo" class="ak-input" />
            <span asp-validation-for="Imo" class="ak-field-error"></span>
        </div>
        <div class="ak-field">
            <label asp-for="Flag" class="ak-label">پرچم</label>
            <input asp-for="Flag" class="ak-input" />
            <span asp-validation-for="Flag" class="ak-field-error"></span>
        </div>
        <div class="ak-field">
            <label asp-for="OwnerOrOperator" class="ak-label">مالک یا اپراتور</label>
            <input asp-for="OwnerOrOperator" class="ak-input" />
            <span asp-validation-for="OwnerOrOperator" class="ak-field-error"></span>
        </div>
        <div class="ak-toggle-field">
            <div class="form-check form-switch">
                <input asp-for="IsActive" class="form-check-input" role="switch" />
                <label asp-for="IsActive" class="form-check-label">فعال</label>
            </div>
        </div>
        <div class="ak-field ak-col-full">
            <label asp-for="Notes" class="ak-label">یادداشت</label>
            <textarea asp-for="Notes" class="ak-input" rows="3"></textarea>
            <span asp-validation-for="Notes" class="ak-field-error"></span>
        </div>
    </div>
</section>
