@model IEnumerable<Vessel>
@{
    ViewData["Title"] = UiText.T(Context, "کشتی‌ها", "Vessels");
    var vessels = Model.ToList();
    var query = ViewData["q"]?.ToString();
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var hasFilters = !string.IsNullOrWhiteSpace((string?)ViewData["flag"]) || ViewData["isActive"] != null;
    var hasSearch = !string.IsNullOrWhiteSpace(query) || hasFilters;

    string TextOrDash(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value.Trim();
}

<div class="ak-list-page">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((UiText.T(Context, "کشتی‌ها", "Vessels"), true,
                       UiText.T(Context, "کشتی جدید", "New vessel"), "bi-plus-lg",
                       (string?)Url.Action("Create", new { returnUrl }), (string?)null,
                       (string?)null, (string?)null, (string?)null))" />

    @{
        var vesselsIsActive = ViewData["isActive"] is bool vesAct ? (vesAct ? "true" : "false") : null;
        var vesselFlagOptions = (ViewData["Flags"] as List<string> ?? new List<string>())
            .Select(fl => new AkFilterOption(fl, fl)).ToList();
        var vesselsFilter = new AkSearchFilterModel("q", query,
            UiText.T(Context, "جستجو در نام، کد، IMO، پرچم یا مالک...", "Search name, code, IMO, flag, or owner..."),
            new List<AkFilterDefinition>
            {
                new("flag", UiText.T(Context, "پرچم", "Flag"), "select", vesselFlagOptions, (string?)ViewData["flag"]),
                new("isActive", UiText.T(Context, "وضعیت", "Status"), "bool",
                    new List<AkFilterOption> { new("true", UiText.T(Context, "فعال", "Active")), new("false", UiText.T(Context, "غیرفعال", "Inactive")) },
                    vesselsIsActive)
            });
    }
    <partial name="~/Views/Shared/_AkSearchFilter.cshtml" model="vesselsFilter" />

    <div class="ak-list">
        <div class="ak-table-wrap">
            <table class="ak-table" aria-label="@UiText.T(Context, "لیست کشتی‌ها", "Vessel list")">
                <thead>
                    <tr>
                        <th class="ak-col-check"><input type="checkbox" class="ak-check" aria-label="@UiText.T(Context, "انتخاب همه", "Select all")" /></th>
                        <th class="ak-col-grow">@UiText.T(Context, "نام", "Name")</th>
                        <th>@UiText.T(Context, "کد", "Code")</th>
                        <th>@UiText.T(Context, "IMO", "IMO")</th>
                        <th>@UiText.T(Context, "پرچم", "Flag")</th>
                        <th>@UiText.T(Context, "مالک", "Owner")</th>
                        <th class="ak-col-spacer"></th>
                        <th>@UiText.T(Context, "وضعیت", "Status")</th>
                        <th class="ak-col-actions"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in vessels)
                    {
                        <tr data-href="@Url.Action("Details", new { id = item.Id })">
                            <td class="ak-col-check"><input type="checkbox" class="ak-check" aria-label="@UiText.T(Context, "انتخاب", "Select")" /></td>
                            <td class="ak-col-grow"><a asp-action="Details" asp-route-id="@item.Id" class="ak-name">@item.Name</a></td>
                            <td>@TextOrDash(item.Code)</td>
                            <td>@TextOrDash(item.Imo)</td>
                            <td>@TextOrDash(item.Flag)</td>
                            <td>@TextOrDash(item.OwnerOrOperator)</td>
                            <td class="ak-col-spacer"></td>
                            <td>
                                <span class="ak-status @(item.IsActive ?"is-active" : "is-inactive")">
                                    @(item.IsActive ? UiText.T(Context, "فعال", "Active") : UiText.T(Context, "غیرفعال", "Inactive"))
                                </span>
                            </td>
                            <td class="ak-col-actions">
                                <div class="dropdown ak-row-menu">
                                    <button type="button" class="ak-row-menu-btn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="@UiText.T(Context, "عملیات", "Actions")">
                                        <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a class="dropdown-item" asp-action="Details" asp-route-id="@item.Id"><i class="bi bi-eye" aria-hidden="true"></i>@UiText.T(Context, "جزئیات", "Details")</a></li>
                                        <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil" aria-hidden="true"></i>@UiText.T(Context, "ویرایش", "Edit")</a></li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><partial name="~/Views/Shared/Partials/_ToggleActiveButton.cshtml" model="@(("Vessels", item.Id, item.IsActive, "dropdown-item ak-danger", (string?)returnUrl))" /></li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!vessels.Any())
                    {
                        <tr>
                            <td colspan="9">
                                <div class="ak-empty"><i class="bi bi-life-preserver" aria-hidden="true"></i>@UiText.T(Context, "رکوردی یافت نشد", "No records found")</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @{ ViewData["ShownCount"] = vessels.Count; }
        <div class="ak-pager">@await Html.PartialAsync("_PagedListFooter")</div>
    </div>
</div>
