@model PTGOilSystem.Web.Models.PlattsRates.PlattsRatesPageViewModel
@using PTGOilSystem.Web.Models.PlattsRates
@Html.AntiForgeryToken()
<div asp-validation-summary="ModelOnly" class="alert alert-danger mb-0"></div>

<input asp-for="MonthlyManualForm.Id" type="hidden" />
<input asp-for="ActiveTab" type="hidden" value="@PlattsRatesTabs.Manual" />
<input asp-for="DailyFilter.ProductId" type="hidden" />
<input asp-for="DailyFilter.BenchmarkCode" type="hidden" />
<input asp-for="DailyFilter.From" type="hidden" />
<input asp-for="DailyFilter.To" type="hidden" />
<input asp-for="MonthlyFilter.ProductId" type="hidden" />
<input asp-for="MonthlyFilter.BenchmarkCode" type="hidden" />
<input asp-for="MonthlyFilter.Year" type="hidden" />
<input asp-for="ManualFilter.ProductId" type="hidden" />
<input asp-for="ManualFilter.BenchmarkCode" type="hidden" />

<section class="form-section ak-form-section">
    <h2 class="form-section-title">@(Model.MonthlyManualForm.Id.HasValue ? "ویرایش نرخ دستی ماهانه" : "ثبت نرخ دستی ماهانه")</h2>
    <div class="ak-form-grid modal-form-grid">
        <div class="ak-field">
            <label asp-for="MonthlyManualForm.ProductId" class="ak-label"></label>
            <select asp-for="MonthlyManualForm.ProductId" asp-items="(Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Products" class="ak-input">
                <option value="">انتخاب جنس</option>
            </select>
            <span asp-validation-for="MonthlyManualForm.ProductId" class="ak-field-error"></span>
        </div>
        <div class="ak-field">
            <label asp-for="MonthlyManualForm.BenchmarkCode" class="ak-label"></label>
            <input asp-for="MonthlyManualForm.BenchmarkCode" class="ak-input" />
            <span asp-validation-for="MonthlyManualForm.BenchmarkCode" class="ak-field-error"></span>
        </div>
        <div class="ak-field">
            <label asp-for="MonthlyManualForm.Month" class="ak-label"></label>
            <input asp-for="MonthlyManualForm.Month" type="month" class="ak-input" value="@Model.MonthlyManualForm.Month.ToHtmlMonthInput()" />
            <span asp-validation-for="MonthlyManualForm.Month" class="ak-field-error"></span>
        </div>
        <div class="ak-field">
            <label asp-for="MonthlyManualForm.PriceUsdPerMt" class="ak-label"></label>
            <input asp-for="MonthlyManualForm.PriceUsdPerMt" class="ak-input" />
            <span asp-validation-for="MonthlyManualForm.PriceUsdPerMt" class="ak-field-error"></span>
        </div>
        <div class="ak-field ak-col-full">
            <label asp-for="MonthlyManualForm.Notes" class="ak-label"></label>
            <input asp-for="MonthlyManualForm.Notes" class="ak-input" />
            <span asp-validation-for="MonthlyManualForm.Notes" class="ak-field-error"></span>
        </div>
    </div>
</section>
