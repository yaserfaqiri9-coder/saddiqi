@model IEnumerable<Location>
@{
    ViewData["Title"] = UiText.T(Context, "مکان ها", "Locations");
    var items = Model.ToList();
    var hasFilters = !string.IsNullOrWhiteSpace((string?)ViewData["kind"]) || ViewData["isActive"] != null;
    var hasSearch = !string.IsNullOrWhiteSpace((string?)ViewData["q"]) || hasFilters;
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var activeCount = items.Count(item => item.IsActive);
    var originCount = items.Count(item => string.Equals(item.Kind, "Origin", StringComparison.OrdinalIgnoreCase));
    var destinationCount = items.Count(item => string.Equals(item.Kind, "Destination", StringComparison.OrdinalIgnoreCase));
}

<div class="ak-list-page">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((UiText.T(Context, "مکان ها", "Locations"), true,
                       UiText.T(Context, "بندر جدید", "New port"), "bi-plus-lg",
                       (string?)Url.Action("Create", new { returnUrl }), (string?)null,
                       (string?)null, (string?)null, (string?)null))" />

    <section class="ak-stat-grid mb-3" aria-label="@UiText.T(Context, "آمار مکان‌ها", "Location statistics")">
        <vc:stat-card title="@UiText.T(Context, "تعداد مکان‌ها", "Locations")" value="@items.Count.ToString("N0")" unit="@UiText.T(Context, "مکان", "locations")" avatar="shipments"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "مکان‌های فعال", "Active locations")" value="@activeCount.ToString("N0")" unit="@UiText.T(Context, "مکان", "locations")" avatar="loading"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "مبداها", "Origins")" value="@originCount.ToString("N0")" unit="@UiText.T(Context, "مکان", "locations")" avatar="unloading"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "مقصدها", "Destinations")" value="@destinationCount.ToString("N0")" unit="@UiText.T(Context, "مکان", "locations")" avatar="transported"></vc:stat-card>
    </section>

    @{
        var locationsIsActive = ViewData["isActive"] is bool locAct ? (locAct ? "true" : "false") : null;
        var locationsFilter = new AkSearchFilterModel("q", (string?)ViewData["q"],
            UiText.T(Context, "جستجو در کد، نام یا کشور...", "Search code, name, or country..."),
            new List<AkFilterDefinition>
            {
                new("kind", UiText.T(Context, "نوع", "Type"), "select",
                    new List<AkFilterOption> { new("Origin", "مبدا"), new("Transit", "ترانزیت"), new("Destination", "مقصد") },
                    (string?)ViewData["kind"]),
                new("isActive", UiText.T(Context, "وضعیت", "Status"), "bool",
                    new List<AkFilterOption> { new("true", UiText.T(Context, "فعال", "Active")), new("false", UiText.T(Context, "غیرفعال", "Inactive")) },
                    locationsIsActive)
            });
    }
    <partial name="~/Views/Shared/_AkSearchFilter.cshtml" model="locationsFilter" />

    <div class="ak-list">
        <div class="ak-table-wrap">
            <table class="ak-table" aria-label="@UiText.T(Context, "لیست مکان ها", "Location list")">
                <thead><tr>
                    <th class="ak-col-check"><input type="checkbox" class="ak-check" aria-label="@UiText.T(Context, "انتخاب همه", "Select all")" /></th>
                    <th class="ak-col-grow">@UiText.T(Context, "نام", "Name")</th>
                    <th>@UiText.T(Context, "کشور / نام فارسی", "Country / Persian name")</th>
                    <th>@UiText.T(Context, "نوع", "Type")</th>
                    <th class="ak-col-spacer"></th>
                    <th>@UiText.T(Context, "وضعیت", "Status")</th>
                    <th class="ak-col-actions"></th>
                </tr></thead>
                <tbody>
                    @foreach (var item in items)
                    {
                        <tr>
                            <td class="ak-col-check"><input type="checkbox" class="ak-check" aria-label="@UiText.T(Context, "انتخاب", "Select")" /></td>
                            <td class="ak-col-grow"><a asp-action="Details" asp-route-id="@item.Id" class="ak-name">@item.Name</a></td>
                            <td>@(string.IsNullOrWhiteSpace(item.Country) ? (string.IsNullOrWhiteSpace(item.NamePersian) ? "—" : item.NamePersian) : item.Country)</td>
                            <td>@item.Kind</td>
                            <td class="ak-col-spacer"></td>
                            <td><span class="ak-status @(item.IsActive ?"is-active" : "is-inactive")">@(item.IsActive ? "فعال" : "غیرفعال")</span></td>
                            <td class="ak-col-actions">
                                <div class="dropdown ak-row-menu">
                                    <button type="button" class="ak-row-menu-btn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="@UiText.T(Context, "عملیات", "Actions")"><i class="bi bi-three-dots-vertical" aria-hidden="true"></i></button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a class="dropdown-item" asp-action="Details" asp-route-id="@item.Id"><i class="bi bi-eye" aria-hidden="true"></i>مشاهده</a></li>
                                        <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil" aria-hidden="true"></i>ویرایش</a></li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><form asp-action="Delete" asp-route-id="@item.Id" method="post" data-ptg-confirm="true" data-ptg-confirm-title="حذف بندر" data-ptg-confirm-message="این مکان حذف یا در صورت استفاده غیرفعال شود؟">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item ak-danger"><i class="bi bi-trash" aria-hidden="true"></i>حذف</button>
                                        </form></li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!items.Any())
                    {
                        <tr><td colspan="7"><div class="ak-empty"><i class="bi bi-geo-alt" aria-hidden="true"></i>رکوردی یافت نشد</div></td></tr>
                    }
                </tbody>
            </table>
        </div>
        @{ ViewData["ShownCount"] = items.Count; }
        <div class="ak-pager">@await Html.PartialAsync("_PagedListFooter")</div>
    </div>
</div>
