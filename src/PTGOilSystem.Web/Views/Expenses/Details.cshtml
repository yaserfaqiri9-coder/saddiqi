@model PTGOilSystem.Web.Models.Expenses.ExpenseDetailsViewModel
@{
    string T(string fa, string en) => UiText.T(Context, fa, en);

    var returnUrl = ViewBag.ReturnUrl as string;
    var backUrl = !string.IsNullOrWhiteSpace(returnUrl)
        ? returnUrl
        : Url.Action("Index", "Expenses") ?? "/Expenses";
    var currentReturnUrl = Context.Request.Path + Context.Request.QueryString;
    var ledgerRecorded = Model.LedgerEntryId.HasValue;
    var ledgerStatus = ledgerRecorded ? T("ثبت شده", "Recorded") : T("ثبت نشده", "Pending");
    var isLinked = !string.IsNullOrWhiteSpace(Model.ContractNumber)
        || !string.IsNullOrWhiteSpace(Model.ShipmentCode)
        || !string.IsNullOrWhiteSpace(Model.TransportLegLabel)
        || !string.IsNullOrWhiteSpace(Model.TruckDispatchLabel);
    var relationStatus = isLinked ? T("وصل شده", "Linked") : T("مستقل", "Standalone");
    var providerText = Model.ServiceProviderName ?? Model.OperationalAssetName ?? "-";

    ViewData["Title"] = T("جزئیات مصرف", "Expense Details");
    ViewData["HideSectionTabs"] = true;
}

<div class="ak-form-page" dir="rtl">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((T("جزئیات مصرف", "Expense details") + $" #{Model.Id}", false,
                       T("ویرایش", "Edit"), "bi-pencil-square",
                       Url.Action("Edit", new { id = Model.Id, returnUrl = currentReturnUrl }), (string?)null,
                       T("بازگشت", "Back"), "bi-arrow-right", (string?)backUrl))" />

    <div class="ak-page-actions">
        <span class="ak-status @(ledgerRecorded ?"is-active" : "is-inactive")">@ledgerStatus</span>
        <div class="dropdown ak-row-menu">
            <button type="button" class="ak-row-menu-btn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="@T("عملیات", "Actions")">
                <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="@(Url.Action("Create", new { returnUrl = backUrl }) ?? "#")"><i class="bi bi-plus-lg"></i> @T("مصرف جدید", "New expense")</a></li>
                @if (Model.ExpenseBatchId.HasValue)
                {
                    <li><a class="dropdown-item" asp-action="GroupDetails" asp-route-id="@Model.ExpenseBatchId"><i class="bi bi-collection"></i> @T("مصرف گروهی", "Group expense")</a></li>
                }
            </ul>
        </div>
    </div>

    <section class="ak-form-section ak-form-grid">
        <div class="ak-field">
            <span class="ak-label">@T("تاریخ مصرف", "Expense date")</span>
            <strong>@Model.ExpenseDate.ToDisplayDate()</strong>
            <span class="ak-section-desc">@T("نوع مصرف", "Expense type"): @Model.ExpenseTypeName</span>
        </div>
        <div class="ak-field">
            <span class="ak-label">@T("مبلغ", "Amount") (USD)</span>
            <strong class="ak-num">@Model.AmountUsd.ToString("N2")</strong>
            <span class="ak-section-desc">@T("سند", "Document"): @Model.Amount.ToString("N2") @Model.Currency</span>
        </div>
        <div class="ak-field">
            <span class="ak-label">@T("طرف حساب", "Party")</span>
            <strong>@providerText</strong>
            <span class="ak-section-desc">@T("ارتباط", "Relation"): @relationStatus</span>
        </div>
        <div class="ak-field">
            <span class="ak-label">@T("دفتر کل", "Ledger")</span>
            <span class="ak-status @(ledgerRecorded ?"is-active" : "is-inactive")">@ledgerStatus</span>
            <span class="ak-section-desc">@T("مرجع", "Reference"): @(Model.LedgerReference ?? "-")</span>
        </div>
    </section>

    <div class="ak-form-grid">
        <section class="ak-form-section">
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@((T("مشخصات مصرف", "Expense overview"), (string?)null))" />
            <dl class="ak-list">
                <div class="ak-list-row"><dt>@T("شماره داخلی", "Internal id")</dt><dd class="ak-num">#@Model.Id</dd></div>
                <div class="ak-list-row"><dt>@T("تاریخ مصرف", "Expense date")</dt><dd>@Model.ExpenseDate.ToDisplayDate()</dd></div>
                <div class="ak-list-row"><dt>@T("نوع مصرف", "Expense type")</dt><dd>@Model.ExpenseTypeName</dd></div>
                <div class="ak-list-row"><dt>@T("قرارداد", "Contract")</dt><dd>@(Model.ContractNumber ?? "-")</dd></div>
                <div class="ak-list-row"><dt>Shipment</dt><dd>@(Model.ShipmentCode ?? "-")</dd></div>
                <div class="ak-list-row"><dt>@T("ارسال با موتر", "Truck send")</dt><dd>@(Model.TruckDispatchLabel ?? "-")</dd></div>
                <div class="ak-list-row"><dt>@T("جریان حمل بار", "Cargo flow")</dt><dd>@(Model.TransportLegLabel ?? "-")</dd></div>
                @if (Model.ExpenseBatchId.HasValue)
                {
                    <div class="ak-list-row">
                        <dt>@T("مصرف گروهی", "Group expense")</dt>
                        <dd><a asp-action="GroupDetails" asp-route-id="@Model.ExpenseBatchId">@(Model.ExpenseBatchNumber ?? $"#{Model.ExpenseBatchId}")</a></dd>
                    </div>
                }
            </dl>
        </section>

        <section class="ak-form-section">
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@((T("مبلغ و ارز", "Amount & currency"), (string?)null))" />
            <dl class="ak-list">
                <div class="ak-list-row"><dt>@T("مبلغ سند", "Document amount")</dt><dd class="ak-num">@Model.Amount.ToString("N2") @Model.Currency</dd></div>
                <div class="ak-list-row"><dt>@T("نرخ تبدیل", "FX rate")</dt><dd class="ak-num">@(Model.AppliedFxRateToUsd?.ToString("N6") ?? "-")</dd></div>
                <div class="ak-list-row"><dt>@T("مبلغ USD", "Amount USD")</dt><dd class="ak-num">@Model.AmountUsd.ToString("N2")</dd></div>
            </dl>
        </section>
    </div>

    <div class="ak-form-grid">
        <section class="ak-form-section">
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@((T("دفتر کل", "Ledger"), (string?)null))" />
            @if (!ledgerRecorded)
            {
                <p class="ak-note">@T("برای این مصرف هنوز سند دفتر کل ثبت نشده است.", "No ledger trace recorded for this expense.")</p>
            }
            else
            {
                <dl class="ak-list">
                    <div class="ak-list-row"><dt>@T("شناسه Ledger", "Ledger id")</dt><dd class="ak-num">#@Model.LedgerEntryId</dd></div>
                    <div class="ak-list-row"><dt>@T("مبلغ", "Amount")</dt><dd class="ak-num">@(Model.LedgerAmountUsd?.ToString("N2") ?? "-") USD</dd></div>
                    <div class="ak-list-row"><dt>@T("سمت", "Side")</dt><dd>@(Model.LedgerSideName ?? "-")</dd></div>
                    <div class="ak-list-row"><dt>@T("مرجع", "Reference")</dt><dd>@(Model.LedgerReference ?? "-")</dd></div>
                    <div class="ak-list-row"><dt>@T("شرح", "Description")</dt><dd>@(Model.LedgerDescription ?? "-")</dd></div>
                </dl>
            }
        </section>

        <section class="ak-form-section">
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@((T("ارتباط عملیاتی", "Operational relationship"), (string?)null))" />
            <dl class="ak-list">
                <div class="ak-list-row"><dt>@T("وضعیت ارتباط", "Relation")</dt><dd>@relationStatus</dd></div>
                <div class="ak-list-row">
                    <dt>@T("شرکت خدماتی", "Service provider")</dt>
                    <dd>
                        @if (Model.ServiceProviderId.HasValue)
                        {
                            <a asp-controller="ServiceProviders" asp-action="Details" asp-route-id="@Model.ServiceProviderId">@Model.ServiceProviderName</a>
                        }
                        else { <span>@(Model.ServiceProviderName ?? "-")</span> }
                    </dd>
                </div>
                <div class="ak-list-row">
                    <dt>@T("دارایی عملیاتی", "Operational asset")</dt>
                    <dd>
                        @if (Model.OperationalAssetId.HasValue)
                        {
                            <a asp-controller="OperationalAssets" asp-action="Details" asp-route-id="@Model.OperationalAssetId">@Model.OperationalAssetName</a>
                        }
                        else { <span>@(Model.OperationalAssetName ?? "-")</span> }
                    </dd>
                </div>
                <div class="ak-list-row"><dt>@T("شرح", "Description")</dt><dd>@(string.IsNullOrWhiteSpace(Model.Description) ? T("شرحی ثبت نشده است.", "No description recorded.") : Model.Description)</dd></div>
            </dl>
        </section>
    </div>
</div>
