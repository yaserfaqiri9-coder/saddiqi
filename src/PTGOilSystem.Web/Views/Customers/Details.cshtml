@model PTGOilSystem.Web.Models.Customers.CustomerProfileViewModel
@using PTGOilSystem.Web.Models.Entities
@using PTGOilSystem.Web.Models.Shared
@{
    ViewData["Title"] = "پروفایل مشتری";
    ViewData["HideSectionTabs"] = true;
    var notRecorded = "ثبت نشده";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";

    // مانده حساب مشتری (همان منطق موجود؛ هیچ محاسبهٔ جدیدی نیست).
    var bal = Model.LedgerBalanceUsd;
    var balanceLabel = bal > 0 ? "مشتری به شرکت بدهکار است" : bal < 0 ? "اعتبار / طلب مشتری از شرکت" : "حساب تسویه است";
    var balanceClass = bal > 0 ? "ak-num" : bal < 0 ? "ak-num" : "";

    var showStatement = Model.ActiveTab == "account";
    var showActivity = Model.ActiveTab == "activity";
    var showOverview = !showStatement && !showActivity;

    var activeSales = Model.Sales.Where(s => !s.IsCancelled).ToList();
    var recentStatement = Model.StatementRows.Reverse().Take(5).ToList();
    var allocatedPayments = Model.Payments.Where(p => p.SaleId.HasValue).ToList();
    var unallocatedPayments = Model.Payments.Where(p => !p.SaleId.HasValue).ToList();

    var newPaymentUrl = Url.Action("Create", "Payments", new { customerId = Model.CustomerId, returnUrl }) ?? "#";
    var threeWayUrl = Url.Action("Index", "ThreeWaySettlement", new { customerId = Model.CustomerId }) ?? "#";
    var editUrl = Url.Action("Edit", new { id = Model.CustomerId }) ?? "#";
    var indexUrl = Url.Action("Index") ?? "#";

    var customerTabs = new[]
    {
        $"#customer-overview|خلاصه حساب|bi-grid-1x2|{(showOverview ? "active" : "")}",
        $"#customer-statement|صورت‌حساب|bi-journal-text|{(showStatement ? "active" : "")}",
        $"#customer-activity|فروش‌ها و دریافت‌ها|bi-receipt-cutoff|{(showActivity ? "active" : "")}"
    };
}

<div class="ak-form-page ak-party-page" dir="rtl">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((Model.Name, false,
                       "ثبت دریافت", "bi-cash-coin", newPaymentUrl, (string?)null,
                       "فهرست مشتری‌ها", "bi-arrow-right", (string?)indexUrl))" />

    <div class="ak-page-actions">
        <span class="ak-status @(Model.IsActive ?"is-active" : "is-inactive")">@(Model.IsActive ? "فعال" : "غیرفعال")</span>
        <div class="dropdown ak-row-menu">
            <button type="button" class="ak-row-menu-btn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="عملیات">
                <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="@editUrl"><i class="bi bi-pencil"></i> ویرایش</a></li>
                <li><a class="dropdown-item" href="@threeWayUrl"><i class="bi bi-arrow-left-right"></i> تسویه سه‌طرفه</a></li>
                <li><a class="dropdown-item" href="@newPaymentUrl"><i class="bi bi-cash-coin"></i> ثبت دریافت</a></li>
            </ul>
        </div>
    </div>

    <div class="ak-form-grid">
        <section class="ak-form-section">
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("اطلاعات هویتی", (string?)null))" />
            <dl class="ak-list">
                <div class="ak-list-row"><dt>کد</dt><dd>@(string.IsNullOrWhiteSpace(Model.Code) ? notRecorded : Model.Code)</dd></div>
                <div class="ak-list-row"><dt>نام فارسی</dt><dd>@(string.IsNullOrWhiteSpace(Model.NamePersian) ? notRecorded : Model.NamePersian)</dd></div>
                <div class="ak-list-row"><dt>کشور</dt><dd>@(string.IsNullOrWhiteSpace(Model.Country) ? notRecorded : Model.Country)</dd></div>
                <div class="ak-list-row"><dt>طرف تماس</dt><dd>@(string.IsNullOrWhiteSpace(Model.ContactPerson) ? notRecorded : Model.ContactPerson)</dd></div>
                <div class="ak-list-row"><dt>تلفن</dt><dd>@(string.IsNullOrWhiteSpace(Model.Phone) ? notRecorded : Model.Phone)</dd></div>
                <div class="ak-list-row"><dt>آدرس</dt><dd>@(string.IsNullOrWhiteSpace(Model.Address) ? notRecorded : Model.Address)</dd></div>
                <div class="ak-list-row"><dt>یادداشت</dt><dd>@(string.IsNullOrWhiteSpace(Model.Notes) ? notRecorded : Model.Notes)</dd></div>
            </dl>
        </section>

        <section class="ak-form-section">
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("وضعیت حساب", balanceLabel))" />
            <dl class="ak-list">
                <div class="ak-list-row"><dt>مانده مشتری</dt><dd class="ak-num @balanceClass">@Math.Abs(bal).ToString("N2") USD</dd></div>
                <div class="ak-list-row"><dt>کل فروش</dt><dd class="ak-num">@Model.SoldValueUsd.ToString("N2") USD</dd></div>
                <div class="ak-list-row"><dt>کل دریافت‌شده</dt><dd class="ak-num">@Model.TotalReceivedUsd.ToString("N2") USD</dd></div>
                <div class="ak-list-row"><dt>فاکتور فعال</dt><dd class="ak-num">@activeSales.Count.ToString("N0")</dd></div>
            </dl>
        </section>
    </div>

    <partial name="~/Views/Shared/Partials/_DetailsTabs.cshtml" model="@("بخش‌های پروفایل مشتری", customerTabs)" />

    @* ===== تب ۱: خلاصه — آخرین حرکت‌ها ===== *@
    <section id="customer-overview" class="ak-form-section">
        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("آخرین حرکت‌های حساب", "پنج سند آخر."))" />
        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead>
                    <tr>
                        <th>تاریخ</th>
                        <th class="ak-col-grow">نوع</th>
                        <th>قرارداد / شرح</th>
                        <th class="ak-col-num">مبلغ USD</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var r in recentStatement)
                {
                    var given = r.DebitUsd.HasValue && r.DebitUsd.Value != 0m;
                    var taken = r.CreditUsd.HasValue && r.CreditUsd.Value != 0m;
                    var eff = given ? r.DebitUsd : taken ? r.CreditUsd : null;
                    <tr>
                        <td>@r.Date.ToDisplayDate()</td>
                        <td class="ak-col-grow">@r.Type</td>
                        <td>@(string.IsNullOrWhiteSpace(r.ContractNumber) ? r.Description : "قرارداد " + r.ContractNumber)</td>
                        <td class="ak-col-num ak-num @(given ?"ak-num" : taken ? "ak-num" : "")">@(eff.HasValue ? (given ? "+" : "-") + eff.Value.ToString("N2") : "—")</td>
                    </tr>
                }
                @if (recentStatement.Count == 0)
                {
                    <tr><td colspan="4"><div class="ak-empty"><i class="bi bi-journal-text"></i> هنوز هیچ فروش یا دریافتی برای این مشتری ثبت نشده است.</div></td></tr>
                }
                </tbody>
            </table>
        </div>
    </section>

    @* ===== تب ۲: صورت‌حساب ===== *@
    <section id="customer-statement" class="ak-form-section">
        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("صورت‌حساب کامل", "مانده مثبت = مشتری بدهکار؛ مانده منفی = اعتبار/طلب مشتری."))" />

        <form asp-action="Details" asp-route-id="@Model.CustomerId" method="get" class="ak-detail-toolbar">
            <input type="hidden" name="tab" value="account" />
            <div class="ak-field">
                <label class="ak-label" for="customerStatementContract">نمایش بر اساس قرارداد فروش</label>
                <select id="customerStatementContract" name="contractId" class="ak-input">
                    <option value="">همه قراردادها</option>
                    @foreach (var option in Model.StatementContractOptions)
                    {
                        <option value="@option.ContractId" selected="@(Model.SelectedContractId == option.ContractId)">@option.ContractNumber</option>
                    }
                </select>
            </div>
            <button type="submit" class="btn btn-light">نمایش</button>
            @if (Model.SelectedContractId.HasValue)
            {
                <a asp-action="Details" asp-route-id="@Model.CustomerId" asp-route-tab="account" class="btn btn-light">نمایش همه</a>
            }
        </form>

        @if (Model.SelectedContract is not null)
        {
            var sc = Model.SelectedContract;
            <dl class="ak-list">
                <div class="ak-list-row"><dt>ارزش قرارداد USD</dt><dd class="ak-num">@(sc.EstimatedTotalUsd?.ToString("N2") ?? "-")</dd></div>
                <div class="ak-list-row"><dt>فاکتورشده USD</dt><dd class="ak-num">@sc.SoldValueUsd.ToString("N2")</dd></div>
                <div class="ak-list-row"><dt>دریافت‌شده USD</dt><dd class="ak-num">@sc.ReceivedUsd.ToString("N2")</dd></div>
                <div class="ak-list-row"><dt>مانده حساب USD</dt><dd class="ak-num @(sc.LedgerBalanceUsd >= 0 ?"ak-num" : "ak-num")">@sc.LedgerBalanceUsd.ToString("N2")</dd></div>
            </dl>
        }

        @{
            // قاعدهٔ یک‌دست «داده/گرفته»: فروش جنس = داده‌شده (Credit)، دریافت پول = گرفته‌شده (Debit). مانده = Σ(داده − گرفته).
            var customerStatementRows = new List<PTGOilSystem.Web.Models.Shared.PartyStatementRowViewModel>();
            var customerStatementBalance = 0m;
            foreach (var row in Model.StatementRows)
            {
                var givenUsd = row.DebitUsd;
                var takenUsd = row.CreditUsd;
                var givenOriginal = row.Debit;
                var takenOriginal = row.Credit;
                var hasGiven = givenUsd.HasValue && givenUsd.Value != 0m;
                var hasTaken = takenUsd.HasValue && takenUsd.Value != 0m;
                customerStatementBalance += (givenUsd ?? 0m) - (takenUsd ?? 0m);
                var effectUsd = hasGiven ? givenUsd : hasTaken ? takenUsd : givenUsd ?? takenUsd;
                customerStatementRows.Add(new PTGOilSystem.Web.Models.Shared.PartyStatementRowViewModel
                {
                    LedgerEntryId = row.LedgerEntryId,
                    Date = row.Date,
                    Type = row.Type,
                    Reference = row.Reference,
                    SourceDetailsController = row.SourceDetailsController,
                    SourceDetailsAction = row.SourceDetailsAction,
                    SourceDetailsRouteId = row.SourceDetailsRouteId,
                    ContractNumber = row.ContractNumber,
                    Description = row.Description,
                    SourceAmount = hasGiven ? givenOriginal : hasTaken ? takenOriginal : givenOriginal ?? takenOriginal,
                    Currency = row.Currency,
                    FxRateUsed = row.FxRateUsed,
                    FxRateDisplayPerUsd = row.FxRateDisplayPerUsd,
                    StatementCreditUsd = givenUsd,
                    StatementDebitUsd = takenUsd,
                    EffectLabel = hasGiven ? "فروش / داده شد" : hasTaken ? "دریافت / گرفته شد" : "بدون اثر",
                    EffectClass = hasGiven ? "is-increase" : hasTaken ? "is-decrease" : "is-neutral",
                    SignedUsd = effectUsd.HasValue ? $"{(hasGiven ? "+" : hasTaken ? "-" : "")}{effectUsd.Value:N2}" : "-",
                    RunningBalanceUsd = customerStatementBalance,
                    BalanceLabel = customerStatementBalance > 0 ? "مشتری بدهکار" : customerStatementBalance < 0 ? "اعتبار مشتری" : "تسویه",
                    BalanceClass = customerStatementBalance > 0 ? "ak-num" : customerStatementBalance < 0 ? "ak-num" : ""
                });
            }
            var customerStatementTable = new PTGOilSystem.Web.Models.Shared.PartyStatementTableViewModel
            {
                EmptyTitle = "صورت‌حساب خالی است",
                EmptyMessage = "برای این مشتری یا قرارداد انتخاب‌شده هنوز سند مالی ثبت نشده است.",
                Rows = customerStatementRows
            };
        }
        <partial name="~/Views/Shared/Partials/_PartyStatementTable.cshtml" model="customerStatementTable" />
    </section>

    @* ===== تب ۳: فروش‌ها و دریافت‌ها ===== *@
    <section id="customer-activity" class="ak-form-section">
        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("فاکتورهای فروش", $"{Model.Sales.Count:N0} فاکتور"))" />
        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead>
                    <tr>
                        <th class="ak-col-grow">فاکتور</th>
                        <th>قرارداد</th>
                        <th>محصول</th>
                        <th>واگن / موتر</th>
                        <th>تاریخ</th>
                        <th class="ak-col-num">مقدار MT</th>
                        <th class="ak-col-num">ارزش USD</th>
                        <th class="ak-col-num">دریافت USD</th>
                        <th class="ak-col-num">مانده USD</th>
                        <th>وضعیت</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var s in Model.Sales)
                {
                    <tr class="@(s.IsCancelled ?"ak-row-muted" : "")">
                        <td class="ak-col-grow"><a class="ak-name" asp-controller="Sales" asp-action="Details" asp-route-id="@s.SaleId">@s.InvoiceNumber</a></td>
                        <td>@(s.ContractNumber ?? "-")</td>
                        <td>@s.Product</td>
                        <td>@(string.IsNullOrWhiteSpace(s.TransportReference) ? "-" : s.TransportReference)</td>
                        <td>@s.SaleDate.ToDisplayDate()</td>
                        <td class="ak-col-num ak-num">@NumberDisplay.Quantity(s.QuantityMt)</td>
                        <td class="ak-col-num ak-num">@s.TotalUsd.ToString("N2")</td>
                        <td class="ak-col-num ak-num">@s.ReceivedUsd.ToString("N2")</td>
                        <td class="ak-col-num ak-num @(s.ReceivableUsd > 0 ?"ak-num" : s.ReceivableUsd < 0 ? "ak-num" : "")">@s.ReceivableUsd.ToString("N2")</td>
                        <td><span class="ak-status @(s.IsCancelled ?"is-inactive" : s.ReceivableUsd <= 0 ? "" : "is-active")">@(s.IsCancelled ? "لغوشده" : s.ReceivableUsd <= 0 ? "تسویه" : "باز")</span></td>
                    </tr>
                }
                @if (!Model.Sales.Any())
                {
                    <tr><td colspan="10"><div class="ak-empty"><i class="bi bi-receipt-cutoff"></i> فاکتور فروش ثبت نشده است.</div></td></tr>
                }
                </tbody>
            </table>
        </div>

        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("دریافت‌های تخصیص‌یافته به فروش", $"{allocatedPayments.Count:N0} مورد"))" />
        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead>
                    <tr>
                        <th>تاریخ</th>
                        <th class="ak-col-grow">نوع</th>
                        <th>فاکتور فروش</th>
                        <th>حساب</th>
                        <th class="ak-col-num">مبلغ</th>
                        <th class="ak-col-num">معادل USD</th>
                        <th>مرجع</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var p in allocatedPayments)
                {
                    <tr>
                        <td>@p.PaymentDate.ToDisplayDate()</td>
                        <td class="ak-col-grow">@p.PaymentKindName</td>
                        <td><a asp-controller="Sales" asp-action="Details" asp-route-id="@p.SaleId">@(p.InvoiceNumber ?? "-")</a></td>
                        <td>@p.CashAccount</td>
                        <td class="ak-col-num ak-num">@p.Amount.ToString("N2") @p.Currency</td>
                        <td class="ak-col-num ak-num">@p.AmountUsd.ToString("N2")</td>
                        <td><a asp-controller="Payments" asp-action="Details" asp-route-id="@p.PaymentId">@(p.Reference ?? $"#{p.PaymentId}")</a></td>
                    </tr>
                }
                @if (allocatedPayments.Count == 0)
                {
                    <tr><td colspan="7"><div class="ak-empty"><i class="bi bi-link-45deg"></i> دریافت تخصیص‌یافته‌ای نیست.</div></td></tr>
                }
                </tbody>
            </table>
        </div>

        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("دریافت‌های تخصیص‌نشده / اعتبار آزاد", $"{unallocatedPayments.Count:N0} مورد"))" />
        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead>
                    <tr>
                        <th>تاریخ</th>
                        <th class="ak-col-grow">نوع</th>
                        <th>قرارداد</th>
                        <th>حساب</th>
                        <th class="ak-col-num">مبلغ</th>
                        <th class="ak-col-num">معادل USD</th>
                        <th>مرجع</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var p in unallocatedPayments)
                {
                    <tr>
                        <td>@p.PaymentDate.ToDisplayDate()</td>
                        <td class="ak-col-grow">@p.PaymentKindName</td>
                        <td>@(p.ContractNumber ?? "-")</td>
                        <td>@p.CashAccount</td>
                        <td class="ak-col-num ak-num">@p.Amount.ToString("N2") @p.Currency</td>
                        <td class="ak-col-num ak-num">@p.AmountUsd.ToString("N2")</td>
                        <td><a asp-controller="Payments" asp-action="Details" asp-route-id="@p.PaymentId">@(p.Reference ?? $"#{p.PaymentId}")</a></td>
                    </tr>
                }
                @if (unallocatedPayments.Count == 0)
                {
                    <tr><td colspan="7"><div class="ak-empty"><i class="bi bi-wallet2"></i> اعتبار آزادی نیست.</div></td></tr>
                }
                </tbody>
            </table>
        </div>

        @if (Model.Contracts.Any())
        {
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("قراردادهای فروش", $"{Model.Contracts.Count:N0} قرارداد"))" />
            <div class="ak-table-wrap">
                <table class="ak-table">
                    <thead>
                        <tr>
                            <th class="ak-col-grow">قرارداد</th>
                            <th>محصول</th>
                            <th class="ak-col-num">تعهد MT</th>
                            <th class="ak-col-num">فروش MT</th>
                            <th class="ak-col-num">باقی‌مانده MT</th>
                            <th class="ak-col-num">ارزش باز USD</th>
                            <th>وضعیت</th>
                            <th class="ak-col-actions"></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var c in Model.Contracts)
                    {
                        <tr>
                            <td class="ak-col-grow"><a class="ak-name" asp-controller="Contracts" asp-action="Details" asp-route-id="@c.ContractId">@c.ContractNumber</a></td>
                            <td>@c.Product</td>
                            <td class="ak-col-num ak-num">@NumberDisplay.Quantity(c.QuantityMt)</td>
                            <td class="ak-col-num ak-num">@NumberDisplay.Quantity(c.SoldQuantityMt)</td>
                            <td class="ak-col-num ak-num">@NumberDisplay.Quantity(c.RemainingQuantityMt)</td>
                            <td class="ak-col-num ak-num">@(c.EstimatedRemainingUsd?.ToString("N2") ?? "-")</td>
                            <td><span class="ak-status">@c.StatusName</span></td>
                            <td class="ak-col-actions"><a asp-controller="Sales" asp-action="Create" asp-route-contractId="@c.ContractId" asp-route-returnUrl="@returnUrl">ثبت فروش</a></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>
