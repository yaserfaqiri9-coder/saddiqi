@model PTGOilSystem.Web.Models.Customers.CustomerProfileViewModel
@using PTGOilSystem.Web.Models.Entities
@using PTGOilSystem.Web.Models.Shared
@{
    ViewData["Title"] = "پروفایل مشتری";
    ViewData["HideSectionTabs"] = true;
    var notRecorded = "ثبت نشده";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";

    var officialSummary = ViewData["PartyStatementSummary"] as PTGOilSystem.Web.Models.PartyStatements.PartyStatementSummary;
    var bal = officialSummary?.ClosingBalance ?? Model.LedgerBalanceUsd;
    var balanceLabel = officialSummary?.ClosingBalanceMeaning
        ?? (bal > 0 ? "مشتری به شرکت بدهکار است" : bal < 0 ? "اعتبار / طلب مشتری از شرکت" : "حساب تسویه است");
    var balanceClass = bal > 0 ? "ak-num" : bal < 0 ? "ak-num" : "";

    var showStatement = Model.ActiveTab == "account";
    var showActivity = Model.ActiveTab == "activity";
    var showOverview = !showStatement && !showActivity;

    var activeSales = Model.Sales.Where(s => !s.IsCancelled).ToList();
    var officialRecentRows = ViewData["PartyStatementRecentRows"] as IReadOnlyList<PTGOilSystem.Web.Models.PartyStatements.PartyStatementRow> ?? [];
    var allocatedPayments = Model.Payments.Where(p => p.SaleId.HasValue).ToList();
    var unallocatedPayments = Model.Payments.Where(p => !p.SaleId.HasValue).ToList();

    var newPaymentUrl = Url.Action("Create", "Payments", new { customerId = Model.CustomerId, returnUrl }) ?? "#";
    var threeWayUrl = Url.Action("Index", "ThreeWaySettlement", new { customerId = Model.CustomerId }) ?? "#";
    var editUrl = Url.Action("Edit", new { id = Model.CustomerId }) ?? "#";
    var indexUrl = Url.Action("Index") ?? "#";
    ViewData["AkHeaderStatus"] = Model.IsActive ? "فعال" : "غیرفعال";
    ViewData["AkHeaderStatusState"] = Model.IsActive ? "is-active" : "is-inactive";
    ViewData["AkHeaderContext"] = $"کد: {(string.IsNullOrWhiteSpace(Model.Code) ? notRecorded : Model.Code)} · {balanceLabel}";
    ViewData["AkHeaderKebab"] = new List<AkHeaderMenuItem>
    {
        new() { Label = "صورت‌حساب رسمی", Href = Url.Action("Customer", "PartyStatements", new { id = Model.CustomerId }), Icon = "bi-file-earmark-text" },
        new() { Label = "تسویه سه‌طرفه", Href = threeWayUrl, Icon = "bi-arrow-left-right" },
        new() { Label = "ویرایش", Href = editUrl, Icon = "bi-pencil" }
    };

    var customerTabs = new[]
    {
        $"overview|خلاصه حساب|bi-grid-1x2|{(showOverview ? "active" : "")}",
        $"account|صورت‌حساب|bi-journal-text|{(showStatement ? "active" : "")}",
        $"activity|فروش‌ها و دریافت‌ها|bi-receipt-cutoff|{(showActivity ? "active" : "")}"
    };
}

<div class="ak-form-page ak-party-page ak-detail-page" dir="rtl" data-ak-detail-v2="true">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((Model.Name, false,
                       "ثبت دریافت", "bi-cash-coin", newPaymentUrl, (string?)null,
                       "فهرست مشتری‌ها", "bi-arrow-right", (string?)indexUrl))" />

    <partial name="~/Views/Shared/Partials/_DetailsTabs.cshtml" model="@("بخش‌های پروفایل مشتری", customerTabs)" />

    <div class="ak-form-grid" hidden="@(!showOverview)">
        <section class="ak-form-section ak-detail-section">
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("اطلاعات هویتی", (string?)null))" />
            <dl class="ak-list">
                <div class="ak-list-row"><dt>کد</dt><dd>@(string.IsNullOrWhiteSpace(Model.Code) ? notRecorded : Model.Code)</dd></div>
                <div class="ak-list-row"><dt>نام فارسی</dt><dd>@(string.IsNullOrWhiteSpace(Model.NamePersian) ? notRecorded : Model.NamePersian)</dd></div>
                <div class="ak-list-row"><dt>کشور</dt><dd>@(string.IsNullOrWhiteSpace(Model.Country) ? notRecorded : Model.Country)</dd></div>
                <div class="ak-list-row"><dt>طرف تماس</dt><dd>@(string.IsNullOrWhiteSpace(Model.ContactPerson) ? notRecorded : Model.ContactPerson)</dd></div>
                <div class="ak-list-row"><dt>تلفن</dt><dd>@(string.IsNullOrWhiteSpace(Model.Phone) ? notRecorded : Model.Phone)</dd></div>
                <div class="ak-list-row"><dt>آدرس</dt><dd>@(string.IsNullOrWhiteSpace(Model.Address) ? notRecorded : Model.Address)</dd></div>
                <div class="ak-list-row"><dt>یادداشت</dt><dd>@(string.IsNullOrWhiteSpace(Model.Notes) ? notRecorded : Model.Notes)</dd></div>
            </dl>
        </section>

        <section class="ak-form-section ak-detail-section">
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("وضعیت حساب", balanceLabel))" />
            <dl class="ak-list">
                <div class="ak-list-row"><dt>مانده مشتری</dt><dd class="ak-num @balanceClass">@Math.Abs(bal).ToString("N2") USD</dd></div>
                <div class="ak-list-row"><dt>کل فروش</dt><dd class="ak-num">@Model.SoldValueUsd.ToString("N2") USD</dd></div>
                <div class="ak-list-row"><dt>کل دریافت‌شده</dt><dd class="ak-num">@Model.TotalReceivedUsd.ToString("N2") USD</dd></div>
                <div class="ak-list-row"><dt>فاکتور فعال</dt><dd class="ak-num">@activeSales.Count.ToString("N0")</dd></div>
            </dl>
        </section>
    </div>

    @* ===== تب ۱: خلاصه — آخرین حرکت‌ها ===== *@
    <section id="customer-overview" class="ak-form-section ak-detail-section" hidden="@(!showOverview)">
        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("آخرین حرکت‌های حساب", "پنج سند آخر از موتور مشترک صورت‌حساب."))" />
        <partial name="~/Views/Shared/Statements/_PartyStatementRecent.cshtml" model="officialRecentRows" />
    </section>
    @* ===== تب ۲: صورت‌حساب ===== *@
    <section id="customer-statement" class="ak-form-section ak-detail-section" hidden="@(!showStatement)">
        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("صورت‌حساب رسمی مشتری", "مانده، گردش و نرخ‌های تاریخی در سند مشترک محاسبه می‌شود."))" />
        <div class="ak-empty ak-detail-empty-state">
            <i class="bi bi-file-earmark-text" aria-hidden="true"></i>
            <p>برای مشاهده گردش کامل، فیلتر تاریخ، ارز، چاپ و PDF از سند رسمی استفاده کنید.</p>
            <a asp-controller="PartyStatements" asp-action="Customer" asp-route-id="@Model.CustomerId" class="btn btn-primary">مشاهده صورت‌حساب رسمی</a>
        </div>
    </section>
    @* ===== تب ۳: فروش‌ها و دریافت‌ها ===== *@
    <section id="customer-activity" class="ak-form-section ak-detail-section" hidden="@(!showActivity)">
        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("فاکتورهای فروش", $"{Model.Sales.Count:N0} فاکتور"))" />
        <div class="ak-table-wrap">
            <table class="ak-table ak-detail-table">
                <thead>
                    <tr>
                        <th class="ak-col-grow">فاکتور</th>
                        <th>قرارداد</th>
                        <th>محصول</th>
                        <th>واگن / موتر</th>
                        <th>تاریخ</th>
                        <th class="ak-col-num">مقدار MT</th>
                        <th class="ak-col-num">ارزش USD</th>
                        <th class="ak-col-num">دریافت USD</th>
                        <th class="ak-col-num">مانده USD</th>
                        <th>وضعیت</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var s in Model.Sales)
                {
                    <tr class="@(s.IsCancelled ?"ak-row-muted" : "")">
                        <td class="ak-col-grow"><a class="ak-name" asp-controller="Sales" asp-action="Details" asp-route-id="@s.SaleId">@s.InvoiceNumber</a></td>
                        <td>@(s.ContractNumber ?? "-")</td>
                        <td>@s.Product</td>
                        <td>@(string.IsNullOrWhiteSpace(s.TransportReference) ? "-" : s.TransportReference)</td>
                        <td>@s.SaleDate.ToDisplayDate()</td>
                        <td class="ak-col-num ak-num">@NumberDisplay.Quantity(s.QuantityMt)</td>
                        <td class="ak-col-num ak-num">@s.TotalUsd.ToString("N2")</td>
                        <td class="ak-col-num ak-num">@s.ReceivedUsd.ToString("N2")</td>
                        <td class="ak-col-num ak-num @(s.ReceivableUsd > 0 ?"ak-num" : s.ReceivableUsd < 0 ? "ak-num" : "")">@s.ReceivableUsd.ToString("N2")</td>
                        <td><span class="ak-status @(s.IsCancelled ?"is-inactive" : s.ReceivableUsd <= 0 ? "" : "is-active")">@(s.IsCancelled ? "لغوشده" : s.ReceivableUsd <= 0 ? "تسویه" : "باز")</span></td>
                    </tr>
                }
                @if (!Model.Sales.Any())
                {
                    <tr><td colspan="10"><div class="ak-empty ak-detail-empty-state"><i class="bi bi-receipt-cutoff"></i> فاکتور فروش ثبت نشده است.</div></td></tr>
                }
                </tbody>
            </table>
        </div>

        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("دریافت‌های تخصیص‌یافته به فروش", $"{allocatedPayments.Count:N0} مورد"))" />
        <div class="ak-table-wrap">
            <table class="ak-table ak-detail-table">
                <thead>
                    <tr>
                        <th>تاریخ</th>
                        <th class="ak-col-grow">نوع</th>
                        <th>فاکتور فروش</th>
                        <th>حساب</th>
                        <th class="ak-col-num">مبلغ</th>
                        <th class="ak-col-num">معادل USD</th>
                        <th>مرجع</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var p in allocatedPayments)
                {
                    <tr>
                        <td>@p.PaymentDate.ToDisplayDate()</td>
                        <td class="ak-col-grow">@p.PaymentKindName</td>
                        <td><a asp-controller="Sales" asp-action="Details" asp-route-id="@p.SaleId">@(p.InvoiceNumber ?? "-")</a></td>
                        <td>@p.CashAccount</td>
                        <td class="ak-col-num ak-num">@p.Amount.ToString("N2") @p.Currency</td>
                        <td class="ak-col-num ak-num">@p.AmountUsd.ToString("N2")</td>
                        <td><a asp-controller="Payments" asp-action="Details" asp-route-id="@p.PaymentId">@(p.Reference ?? $"#{p.PaymentId}")</a></td>
                    </tr>
                }
                @if (allocatedPayments.Count == 0)
                {
                    <tr><td colspan="7"><div class="ak-empty ak-detail-empty-state"><i class="bi bi-link-45deg"></i> دریافت تخصیص‌یافته‌ای نیست.</div></td></tr>
                }
                </tbody>
            </table>
        </div>

        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("دریافت‌های تخصیص‌نشده / اعتبار آزاد", $"{unallocatedPayments.Count:N0} مورد"))" />
        <div class="ak-table-wrap">
            <table class="ak-table ak-detail-table">
                <thead>
                    <tr>
                        <th>تاریخ</th>
                        <th class="ak-col-grow">نوع</th>
                        <th>قرارداد</th>
                        <th>حساب</th>
                        <th class="ak-col-num">مبلغ</th>
                        <th class="ak-col-num">معادل USD</th>
                        <th>مرجع</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var p in unallocatedPayments)
                {
                    <tr>
                        <td>@p.PaymentDate.ToDisplayDate()</td>
                        <td class="ak-col-grow">@p.PaymentKindName</td>
                        <td>@(p.ContractNumber ?? "-")</td>
                        <td>@p.CashAccount</td>
                        <td class="ak-col-num ak-num">@p.Amount.ToString("N2") @p.Currency</td>
                        <td class="ak-col-num ak-num">@p.AmountUsd.ToString("N2")</td>
                        <td><a asp-controller="Payments" asp-action="Details" asp-route-id="@p.PaymentId">@(p.Reference ?? $"#{p.PaymentId}")</a></td>
                    </tr>
                }
                @if (unallocatedPayments.Count == 0)
                {
                    <tr><td colspan="7"><div class="ak-empty ak-detail-empty-state"><i class="bi bi-wallet2"></i> اعتبار آزادی نیست.</div></td></tr>
                }
                </tbody>
            </table>
        </div>

        @if (Model.Contracts.Any())
        {
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("قراردادهای فروش", $"{Model.Contracts.Count:N0} قرارداد"))" />
            <div class="ak-table-wrap">
                <table class="ak-table ak-detail-table">
                    <thead>
                        <tr>
                            <th class="ak-col-grow">قرارداد</th>
                            <th>محصول</th>
                            <th class="ak-col-num">تعهد MT</th>
                            <th class="ak-col-num">فروش MT</th>
                            <th class="ak-col-num">باقی‌مانده MT</th>
                            <th class="ak-col-num">ارزش باز USD</th>
                            <th>وضعیت</th>
                            <th class="ak-col-actions"></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var c in Model.Contracts)
                    {
                        <tr>
                            <td class="ak-col-grow"><a class="ak-name" asp-controller="ContractJourney" asp-action="Details" asp-route-contractId="@c.ContractId" asp-route-returnUrl="@returnUrl">@c.ContractNumber</a></td>
                            <td>@c.Product</td>
                            <td class="ak-col-num ak-num">@NumberDisplay.Quantity(c.QuantityMt)</td>
                            <td class="ak-col-num ak-num">@NumberDisplay.Quantity(c.SoldQuantityMt)</td>
                            <td class="ak-col-num ak-num">@NumberDisplay.Quantity(c.RemainingQuantityMt)</td>
                            <td class="ak-col-num ak-num">@(c.EstimatedRemainingUsd?.ToString("N2") ?? "-")</td>
                            <td><span class="ak-status">@c.StatusName</span></td>
                            <td class="ak-col-actions"><a asp-controller="Sales" asp-action="Create" asp-route-contractId="@c.ContractId" asp-route-returnUrl="@returnUrl">ثبت فروش</a></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>
