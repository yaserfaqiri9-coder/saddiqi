@model PTGOilSystem.Web.Models.ServiceProviders.ServiceProviderProfileViewModel
@using PTGOilSystem.Web.Models.Shared
@{
    ViewData["Title"] = Model.Name;
    ViewData["HideSectionTabs"] = true;
    var activeTab = Context.Request.Query["tab"].ToString().Trim().ToLowerInvariant();
    activeTab = activeTab is "statement" or "documents" ? activeTab : "overview";
    var showOverview = activeTab == "overview";
    var showStatement = activeTab == "statement";
    var showDocuments = activeTab == "documents";
    var notRecorded = UiText.T(Context, "ثبت نشده", "Not recorded");
    var providerTypeName = ServiceProviderTypeLabels.ToDisplay(Model.ProviderType, Context);
    var spReturnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";

    var officialSummary = ViewData["PartyStatementSummary"] as PTGOilSystem.Web.Models.PartyStatements.PartyStatementSummary;
    var bal = officialSummary?.ClosingBalance ?? Model.LedgerBalanceUsd;
    var balanceLabel = officialSummary?.ClosingBalanceMeaning ?? (bal > 0
        ? UiText.T(Context, "قابل پرداخت به شرکت خدماتی", "Payable to provider")
        : bal < 0
            ? UiText.T(Context, "پیش‌پرداخت / طلب ما", "Prepaid / they owe us")
            : UiText.T(Context, "حساب تسویه است", "Settled"));
    var balanceClass = bal > 0 ? "ak-num" : bal < 0 ? "ak-num" : "";

    var officialRecentRows = ViewData["PartyStatementRecentRows"] as IReadOnlyList<PTGOilSystem.Web.Models.PartyStatements.PartyStatementRow> ?? [];

    var spPaymentUrl = Url.Action("Create", "Payments", new { serviceProviderId = Model.Id, returnUrl = spReturnUrl }) ?? "#";
    var spExpenseUrl = Url.Action("Create", "Expenses", new { serviceProviderId = Model.Id, returnUrl = spReturnUrl }) ?? "#";
    var spEditUrl = Url.Action("Edit", new { id = Model.Id }) ?? "#";
    var spIndexUrl = Url.Action("Index") ?? "#";
    ViewData["AkHeaderStatus"] = Model.IsActive ? UiText.T(Context, "فعال", "Active") : UiText.T(Context, "غیرفعال", "Inactive");
    ViewData["AkHeaderStatusState"] = Model.IsActive ? "is-active" : "is-inactive";
    ViewData["AkHeaderContext"] = $"{providerTypeName} · {balanceLabel}";
    ViewData["AkHeaderKebab"] = new List<AkHeaderMenuItem>
    {
        new() { Label = UiText.T(Context, "صورت‌حساب رسمی", "Official statement"), Href = Url.Action("ServiceProvider", "PartyStatements", new { id = Model.Id }), Icon = "bi-file-earmark-text" },
        new() { Label = UiText.T(Context, "ثبت مصرف / کرایه", "Record expense"), Href = spExpenseUrl, Icon = "bi-receipt-cutoff" },
        new() { Label = UiText.T(Context, "ویرایش", "Edit"), Href = spEditUrl, Icon = "bi-pencil" }
    };

    string ExpenseRef(PTGOilSystem.Web.Models.ServiceProviders.ServiceProviderExpenseRowViewModel e)
    {
        if (!string.IsNullOrWhiteSpace(e.ContractNumber)) return e.ContractNumber!;
        if (!string.IsNullOrWhiteSpace(e.ShipmentCode)) return e.ShipmentCode!;
        if (!string.IsNullOrWhiteSpace(e.TransportLegLabel)) return e.TransportLegLabel!;
        if (!string.IsNullOrWhiteSpace(e.TruckDispatchLabel)) return e.TruckDispatchLabel!;
        return UiText.T(Context, "بدون سند/قرارداد مشخص", "No linked document");
    }

    var providerTabs = new[]
    {
        $"overview|{UiText.T(Context, "خلاصه حساب", "Summary")}|bi-grid-1x2|{(showOverview ? "active" : "")}",
        $"statement|{UiText.T(Context, "صورت‌حساب", "Statement")}|bi-journal-text|{(showStatement ? "active" : "")}",
        $"documents|{UiText.T(Context, "مصارف و پرداخت‌ها", "Expenses & Payments")}|bi-folder2-open|{(showDocuments ? "active" : "")}"
    };
}

<div class="ak-form-page ak-party-page service-provider-details-page ak-detail-page" dir="rtl" data-ak-detail-v2="true">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((Model.Name, false,
                       UiText.T(Context, "ثبت پرداخت", "Record payment"), "bi-cash-coin", spPaymentUrl, (string?)null,
                       UiText.T(Context, "فهرست شرکت‌ها", "Back to list"), "bi-arrow-right", (string?)spIndexUrl))" />

    <partial name="~/Views/Shared/Partials/_DetailsTabs.cshtml" model="@(UiText.T(Context, "بخش‌های پروفایل", "Profile sections"), providerTabs)" />

    <div class="ak-form-grid" hidden="@(!showOverview)">
        <section class="ak-form-section ak-detail-section">
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@((UiText.T(Context, "اطلاعات هویتی", "Identity"), (string?)null))" />
            <dl class="ak-list">
                <div class="ak-list-row"><dt>@UiText.T(Context, "کد", "Code")</dt><dd>@(string.IsNullOrWhiteSpace(Model.Code) ? notRecorded : Model.Code)</dd></div>
                <div class="ak-list-row"><dt>@UiText.T(Context, "نوع خدمت", "Type")</dt><dd>@providerTypeName</dd></div>
                <div class="ak-list-row"><dt>@UiText.T(Context, "کشور / شهر", "Country / City")</dt><dd>@(string.IsNullOrWhiteSpace(Model.Country) && string.IsNullOrWhiteSpace(Model.City) ? notRecorded : $"{Model.Country} {Model.City}".Trim())</dd></div>
                <div class="ak-list-row"><dt>@UiText.T(Context, "تلفن", "Phone")</dt><dd>@(string.IsNullOrWhiteSpace(Model.Phone) ? notRecorded : Model.Phone)</dd></div>
                <div class="ak-list-row"><dt>@UiText.T(Context, "ایمیل", "Email")</dt><dd>@(string.IsNullOrWhiteSpace(Model.Email) ? notRecorded : Model.Email)</dd></div>
                <div class="ak-list-row"><dt>@UiText.T(Context, "آدرس", "Address")</dt><dd>@(string.IsNullOrWhiteSpace(Model.Address) ? notRecorded : Model.Address)</dd></div>
                <div class="ak-list-row"><dt>@UiText.T(Context, "نمبر مالیاتی", "Tax No.")</dt><dd>@(string.IsNullOrWhiteSpace(Model.TaxNumber) ? notRecorded : Model.TaxNumber)</dd></div>
                <div class="ak-list-row"><dt>@UiText.T(Context, "یادداشت", "Notes")</dt><dd>@(string.IsNullOrWhiteSpace(Model.Notes) ? notRecorded : Model.Notes)</dd></div>
            </dl>
        </section>

        <section class="ak-form-section ak-detail-section">
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@((UiText.T(Context, "وضعیت حساب", "Account status"), balanceLabel))" />
            <dl class="ak-list">
                <div class="ak-list-row"><dt>@UiText.T(Context, "مانده فعلی", "Current balance")</dt><dd class="ak-num @balanceClass">@Math.Abs(bal).ToString("N2") USD</dd></div>
                <div class="ak-list-row"><dt>@UiText.T(Context, "کل مصارف / کرایه‌ها", "Total expenses")</dt><dd class="ak-num">@Model.TotalExpensesUsd.ToString("N2") USD</dd></div>
                <div class="ak-list-row"><dt>@UiText.T(Context, "کل پرداخت‌شده", "Total paid")</dt><dd class="ak-num">@Model.TotalPaymentsUsd.ToString("N2") USD</dd></div>
                <div class="ak-list-row"><dt>@UiText.T(Context, "قرارداد مرتبط", "Related contracts")</dt><dd class="ak-num">@Model.RelatedContracts.Count.ToString("N0")</dd></div>
            </dl>
        </section>
    </div>

    @* ===== تب ۱: خلاصه — آخرین حرکت‌ها ===== *@
    <section id="provider-overview" class="ak-form-section ak-detail-section" hidden="@(!showOverview)">
        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@((UiText.T(Context, "آخرین حرکت‌های حساب", "Recent account activity"), UiText.T(Context, "پنج سند آخر از موتور مشترک صورت‌حساب.", "Last five rows from the shared statement engine.")))" />
        <partial name="~/Views/Shared/Statements/_PartyStatementRecent.cshtml" model="officialRecentRows" />
    </section>
    @* ===== تب ۲: صورت‌حساب ===== *@
    <section id="provider-statement" class="ak-form-section ak-detail-section" hidden="@(!showStatement)">
        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@((UiText.T(Context, "صورت‌حساب رسمی شرکت خدماتی", "Official service provider statement"), UiText.T(Context, "مانده و گردش در موتور مشترک صورت‌حساب محاسبه می‌شود.", "Balance and activity are calculated by the shared statement engine.")))" />
        <div class="ak-empty ak-detail-empty-state">
            <i class="bi bi-file-earmark-text" aria-hidden="true"></i>
            <p>@UiText.T(Context, "برای فیلتر تاریخ، چاپ و PDF سند رسمی را باز کنید.", "Open the official document for date filters, printing and PDF.")</p>
            <a asp-controller="PartyStatements" asp-action="ServiceProvider" asp-route-id="@Model.Id" class="btn btn-primary">@UiText.T(Context, "مشاهده صورت‌حساب رسمی", "View official statement")</a>
        </div>
    </section>
    @* ===== تب ۳: مصارف و پرداخت‌ها ===== *@
    <section id="provider-documents" class="ak-form-section ak-detail-section" hidden="@(!showDocuments)">
        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@((UiText.T(Context, "مصارف و کرایه‌ها", "Expenses & Charges"), $"{Model.Expenses.Count:N0}"))" />
        <div class="ak-table-wrap">
            <table class="ak-table ak-detail-table">
                <thead>
                    <tr>
                        <th>@UiText.T(Context, "تاریخ", "Date")</th>
                        <th>@UiText.T(Context, "نوع مصرف", "Type")</th>
                        <th class="ak-col-grow">@UiText.T(Context, "سند / قرارداد مرتبط", "Linked document")</th>
                        <th>@UiText.T(Context, "شرح", "Description")</th>
                        <th class="ak-col-num">@UiText.T(Context, "مبلغ USD", "Amount USD")</th>
                        <th class="ak-col-actions">@UiText.T(Context, "سند", "Doc")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.Expenses)
                {
                    <tr>
                        <td>@row.ExpenseDate.ToDisplayDate()</td>
                        <td>@row.ExpenseTypeName</td>
                        <td class="ak-col-grow">@ExpenseRef(row)</td>
                        <td>@(row.Description ?? "-")</td>
                        <td class="ak-col-num ak-num">@row.AmountUsd.ToString("N2")</td>
                        <td class="ak-col-actions"><a asp-controller="Expenses" asp-action="Details" asp-route-id="@row.Id">@UiText.T(Context, "مشاهده", "View")</a></td>
                    </tr>
                }
                @if (!Model.Expenses.Any())
                {
                    <tr><td colspan="6"><div class="ak-empty ak-detail-empty-state"><i class="bi bi-receipt"></i> @UiText.T(Context, "مصرف یا کرایه‌ای به این شرکت خدماتی وصل نیست.", "No expense is linked to this provider.")</div></td></tr>
                }
                </tbody>
            </table>
        </div>

        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@((UiText.T(Context, "پرداخت‌ها", "Payments"), $"{Model.Payments.Count:N0}"))" />
        <div class="ak-table-wrap">
            <table class="ak-table ak-detail-table">
                <thead>
                    <tr>
                        <th>@UiText.T(Context, "تاریخ", "Date")</th>
                        <th>@UiText.T(Context, "نوع", "Kind")</th>
                        <th class="ak-col-grow">@UiText.T(Context, "حساب", "Account")</th>
                        <th>@UiText.T(Context, "قرارداد / مرجع", "Contract / Ref")</th>
                        <th class="ak-col-num">@UiText.T(Context, "مبلغ USD", "Amount USD")</th>
                        <th class="ak-col-actions">@UiText.T(Context, "سند", "Doc")</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.Payments)
                {
                    <tr>
                        <td>@row.PaymentDate.ToDisplayDate()</td>
                        <td>@row.PaymentKindName</td>
                        <td class="ak-col-grow">@row.CashAccountName</td>
                        <td>@(row.Reference ?? row.ContractNumber ?? "-")</td>
                        <td class="ak-col-num ak-num">@row.AmountUsd.ToString("N2")</td>
                        <td class="ak-col-actions"><a asp-controller="Payments" asp-action="Details" asp-route-id="@row.Id">@UiText.T(Context, "مشاهده", "View")</a></td>
                    </tr>
                }
                @if (!Model.Payments.Any())
                {
                    <tr><td colspan="6"><div class="ak-empty ak-detail-empty-state"><i class="bi bi-cash-coin"></i> @UiText.T(Context, "پرداختی به این شرکت خدماتی وصل نیست.", "No payment is linked to this provider.")</div></td></tr>
                }
                </tbody>
            </table>
        </div>

        @if (Model.RelatedContracts.Any())
        {
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@((UiText.T(Context, "قراردادهای مرتبط", "Related Contracts"), $"{Model.RelatedContracts.Count:N0}"))" />
            <div class="ak-table-wrap">
                <table class="ak-table ak-detail-table">
                    <thead>
                        <tr>
                            <th class="ak-col-grow">@UiText.T(Context, "قرارداد", "Contract")</th>
                            <th class="ak-col-num">@UiText.T(Context, "مصرف USD", "Expense USD")</th>
                            <th class="ak-col-num">@UiText.T(Context, "پرداخت USD", "Payment USD")</th>
                            <th class="ak-col-actions">@UiText.T(Context, "مسیر قرارداد", "Journey")</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var row in Model.RelatedContracts)
                    {
                        <tr>
                            <td class="ak-col-grow"><a class="ak-name" asp-controller="ContractJourney" asp-action="Details" asp-route-contractId="@row.Id">@row.ContractNumber</a></td>
                            <td class="ak-col-num ak-num">@row.ExpenseUsd.ToString("N2")</td>
                            <td class="ak-col-num ak-num">@row.PaymentUsd.ToString("N2")</td>
                            <td class="ak-col-actions"><a asp-controller="ContractJourney" asp-action="Details" asp-route-contractId="@row.Id">@UiText.T(Context, "مسیر قرارداد", "Journey")</a></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>
