@model PTGOilSystem.Web.Models.ServiceProviders.ServiceProviderIndexViewModel
@{
    ViewData["Title"] = UiText.T(Context, "شرکت‌های خدماتی", "Service Providers");
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="ak-list-page">

    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((UiText.T(Context, "شرکت‌های خدماتی", "Service Providers"), true,
                       UiText.T(Context, "شرکت جدید", "New provider"), "bi-plus-lg",
                       (string?)Url.Action("Create", new { returnUrl }), (string?)null,
                       (string?)null, (string?)null, (string?)null))" />

    <partial name="~/Views/Shared/_AkSearchFilter.cshtml"
             model="@AkSearchFilterModel.SearchOnly("q", Model.Query, UiText.T(Context, "جستجو یا فیلتر نتایج...", "Search or filter results..."))" />

    <div class="ak-list">
        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead>
                    <tr>
                        <th class="ak-col-check"><input type="checkbox" class="ak-check" aria-label="@UiText.T(Context, "انتخاب همه", "Select all")" /></th>
                        <th class="ak-col-grow">@UiText.T(Context, "نام", "Name")</th>
                        <th>@UiText.T(Context, "کد", "Code")</th>
                        <th>@UiText.T(Context, "نوع خدمت", "Service Type")</th>
                        <th>@UiText.T(Context, "تماس", "Contact")</th>
                        <th class="ak-col-spacer"></th>
                        <th class="ak-col-num">@UiText.T(Context, "مانده USD", "Balance USD")</th>
                        <th>@UiText.T(Context, "وضعیت", "Status")</th>
                        <th class="ak-col-actions"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Items)
                    {
                        <tr data-href="@Url.Action("Details", new { id = row.Id })">
                            <td class="ak-col-check"><input type="checkbox" class="ak-check" aria-label="@UiText.T(Context, "انتخاب", "Select")" /></td>
                            <td class="ak-col-grow"><partial name="~/Views/Shared/Partials/_PersonCell.cshtml" model="@((row.Name, (string?)Url.Action("Details", new { id = row.Id }), (string?)null))" /></td>
                            <td class="ak-num">@(string.IsNullOrWhiteSpace(row.Code) ? "-" : row.Code)</td>
                            <td>
                                @{ var spType = ServiceProviderTypeLabels.ToDisplay(row.ProviderType, Context); }
                                @if (!string.IsNullOrWhiteSpace(spType))
                                {
                                    <partial name="~/Views/Shared/Partials/_Capsule.cshtml" model="@((spType, (string?)null))" />
                                }
                                else
                                {
                                    <text>-</text>
                                }
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(row.ContactText) ? "-" : row.ContactText)</td>
                            <td class="ak-col-spacer"></td>
                            <td class="ak-num ak-col-num">@row.LedgerBalanceUsd.ToString("N2")</td>
                            <td>
                                <span class="ak-status @(row.IsActive ?"is-active" : "is-inactive")">
                                    @(row.IsActive ? UiText.T(Context, "فعال", "Active") : UiText.T(Context, "غیرفعال", "Inactive"))
                                </span>
                            </td>
                            <td class="ak-col-actions">
                                <div class="dropdown ak-row-menu">
                                    <button type="button" class="ak-row-menu-btn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="@UiText.T(Context, "عملیات", "Actions")">
                                        <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a class="dropdown-item" asp-action="Details" asp-route-id="@row.Id"><i class="bi bi-eye" aria-hidden="true"></i>@UiText.T(Context, "پروفایل", "Profile")</a></li>
                                        <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@row.Id"><i class="bi bi-pencil" aria-hidden="true"></i>@UiText.T(Context, "ویرایش", "Edit")</a></li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><partial name="~/Views/Shared/Partials/_ToggleActiveButton.cshtml" model="@(("ServiceProviders", row.Id, row.IsActive, "dropdown-item ak-danger", (string?)returnUrl))" /></li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="9">
                                <div class="ak-empty">
                                    <i class="bi bi-building-gear" aria-hidden="true"></i>
                                    @UiText.T(Context, "شرکت خدماتی یافت نشد", "No service providers found")
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @{
            ViewData["CurrentPage"] = Model.CurrentPage;
            ViewData["PageCount"] = Model.PageCount;
            ViewData["TotalCount"] = Model.TotalCount;
            ViewData["ShownCount"] = Model.Items.Count;
        }
        <div class="ak-pager">
            @await Html.PartialAsync("_PagedListFooter")
        </div>
    </div>
</div>
