@model PTGOilSystem.Web.Models.Auth.UserCreateViewModel

@Html.AntiForgeryToken()
<div asp-validation-summary="ModelOnly" class="alert alert-danger ak-form-alert"></div>

<section class="ak-form-section">
    <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml"
             model="@(("اطلاعات کاربر", (string?)"مشخصات ورود، نام کامل و نقش دسترسی کاربر را ثبت کنید."))" />
    <div class="ak-form-grid">
        <div class="ak-field">
            <label asp-for="Username" class="ak-label"></label>
            <input asp-for="Username" class="ak-input" autocomplete="username" />
            <span asp-validation-for="Username" class="ak-field-error"></span>
        </div>
        <div class="ak-field">
            <label asp-for="FullName" class="ak-label"></label>
            <input asp-for="FullName" class="ak-input" />
            <span asp-validation-for="FullName" class="ak-field-error"></span>
        </div>
        <div class="ak-field">
            <label asp-for="RoleId" class="ak-label"></label>
            <select asp-for="RoleId" asp-items="ViewBag.Roles" class="ak-input">
                <option value="">انتخاب نقش</option>
            </select>
            <span asp-validation-for="RoleId" class="ak-field-error"></span>
        </div>
    </div>
</section>

<section class="ak-form-section">
    <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml"
             model="@(("امنیت و وضعیت", (string?)"رمز اولیه را تعیین کنید و وضعیت فعال بودن کاربر را مشخص نگه دارید."))" />
    <div class="ak-form-grid">
        <div class="ak-field">
            <label asp-for="Password" class="ak-label"></label>
            <input asp-for="Password" class="ak-input" autocomplete="new-password" />
            <span asp-validation-for="Password" class="ak-field-error"></span>
        </div>
        <div class="ak-field">
            <label asp-for="ConfirmPassword" class="ak-label"></label>
            <input asp-for="ConfirmPassword" class="ak-input" autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword" class="ak-field-error"></span>
        </div>
        <div class="ak-toggle-field">
            <div class="form-check form-switch">
                <input asp-for="IsActive" class="form-check-input" role="switch" />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>
        </div>
    </div>
</section>
