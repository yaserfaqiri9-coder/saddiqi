@model PTGOilSystem.Web.Models.Auth.ResetPasswordViewModel
@{
    ViewData["Title"] = "بازنشانی رمز عبور";
}

<div class="ak-form-page">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((UiText.T(Context, "بازنشانی رمز عبور", "Reset password"), false,
                       (string?)null, (string?)null, (string?)null, (string?)null,
                       UiText.T(Context, "بازگشت", "Back"), "bi-arrow-right", (string?)Url.Action("Details", new { id = Model.UserId })))" />

    <form asp-action="ResetPassword" asp-route-id="@Model.UserId" method="post" class="ak-form">
            @Html.AntiForgeryToken()
            <input asp-for="UserId" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger ak-form-alert"></div>

            <section class="ak-form-section">
                <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@((UiText.T(Context, "اطلاعات حساب", "Account information"), (string?)UiText.T(Context, "رمز تازه بلافاصله جایگزین رمز قبلی می‌شود.", "The new password immediately replaces the old password.")))" />
                <div class="ak-form-grid">
                    <div class="ak-field">
                        <label asp-for="Username" class="ak-label"></label>
                        <input asp-for="Username" class="ak-input" readonly />
                    </div>
                    <div class="ak-field">
                        <label asp-for="NewPassword" class="ak-label"></label>
                        <input asp-for="NewPassword" class="ak-input" autocomplete="new-password" />
                        <span asp-validation-for="NewPassword" class="ak-field-error"></span>
                    </div>
                    <div class="ak-field">
                        <label asp-for="ConfirmPassword" class="ak-label"></label>
                        <input asp-for="ConfirmPassword" class="ak-input" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="ak-field-error"></span>
                    </div>
                </div>
            </section>

            <div class="ak-note">
                <i class="bi bi-info-circle"></i>
                <div>این عملیات برای نقش‌های مجاز مدیریتی است و دسترسی کاربر را با رمز جدید ادامه‌دار می‌کند.</div>
            </div>

            <div class="ak-footer-actions">
                <button type="submit" class="ak-save">بازنشانی رمز عبور</button>
                <a asp-action="Details" asp-route-id="@Model.UserId" class="ak-cancel">@UiText.T(Context,"انصراف","Cancel")</a>
            </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
