@model PTGOilSystem.Web.Models.Auth.ChangePasswordViewModel
@{
    var requestedLanguage = Context.Request.Cookies["ptg-ui-lang"] ?? "fa";
    var isEn = string.Equals(requestedLanguage, "en", StringComparison.OrdinalIgnoreCase);
    string T(string fa, string en) => isEn ? en : fa;
    ViewData["Title"] = T("تغییر رمز عبور", "Change Password");
}

<div class="ak-form-page">
    <partial name="Components/Ak/_AkPageHeader"
             model='((T("تغییر رمز عبور", "Change Password"), false, (string?)null, (string?)null, (string?)null, (string?)null, (string?)null, (string?)null, (string?)null))' />

    <form asp-action="ChangePassword" method="post" novalidate class="ak-form">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="ak-form-alert text-danger"></div>

        <section class="ak-form-section">
            <partial name="Components/Ak/_AkSectionHead"
                     model='((T("اطلاعات رمز عبور", "Password details"), T("رمز تازه و قوی انتخاب کرده و دوباره تأیید کنید.", "Choose a strong new password and confirm it.")))' />

            <div class="ak-form-grid">
                <div class="ak-field ak-col-full">
                    <label asp-for="CurrentPassword" class="ak-label"></label>
                    <input asp-for="CurrentPassword" class="ak-input" autocomplete="current-password" />
                    <span asp-validation-for="CurrentPassword" class="ak-field-error"></span>
                </div>

                <div class="ak-field">
                    <label asp-for="NewPassword" class="ak-label"></label>
                    <input asp-for="NewPassword" class="ak-input" autocomplete="new-password" />
                    <span asp-validation-for="NewPassword" class="ak-field-error"></span>
                </div>

                <div class="ak-field">
                    <label asp-for="ConfirmPassword" class="ak-label"></label>
                    <input asp-for="ConfirmPassword" class="ak-input" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="ak-field-error"></span>
                </div>
            </div>
        </section>

        <partial name="Components/Ak/_AkFooterActions"
                 model='((T("ثبت رمز عبور", "Save Password"), Url.Action("Index", "Home")!, T("بازگشت", "Back")))' />
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
