@{
    var requestedLanguage = Context.Request.Cookies["ptg-ui-lang"] ?? "fa";
    var isEn = string.Equals(requestedLanguage, "en", StringComparison.OrdinalIgnoreCase);
    string T(string fa, string en) => isEn ? en : fa;
    ViewData["Title"] = T("عدم دسترسی", "Access Denied");
}

<div class="ak-form-page">
    <partial name="Components/Ak/_AkPageHeader"
             model='((T("دسترسی مجاز نیست", "Access Denied"), false, (string?)null, (string?)null, (string?)null, (string?)null, (string?)null, (string?)null, (string?)null))' />

    <section class="ak-form-section">
        <partial name="Components/Ak/_AkSectionHead"
                 model='((T("سطح دسترسی کافی نیست", "Permission required"), T("نقش فعلی شما اجازه بازکردن این بخش را ندارد.", "Your current role cannot open this section.")))' />
        <p class="ak-note">@T("درخواست شما ثبت نشد و هیچ تغییری در اطلاعات سیستم انجام نشده است.", "Your request was not saved and no system data was changed.")</p>
    </section>

    <div class="ak-footer-actions">
        <a asp-controller="Home" asp-action="Index" class="ak-save">@T("بازگشت به داشبورد", "Back to Dashboard")</a>
    </div>
</div>
