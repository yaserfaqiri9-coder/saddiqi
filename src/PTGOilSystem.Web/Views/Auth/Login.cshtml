@model PTGOilSystem.Web.Models.Auth.LoginViewModel
@{
    var requestedLanguage = Context.Request.Cookies["ptg-ui-lang"] ?? "fa";
    var isEn = string.Equals(requestedLanguage, "en", StringComparison.OrdinalIgnoreCase);
    string T(string fa, string en) => isEn ? en : fa;
    ViewData["Title"] = T("ورود به سیستم", "Sign In");
    ViewData["ModalDesignSystemAssets"] = false;
}

@section Styles {
    <link rel="stylesheet" href="@(isEn ? Url.Content("~/vendor/bootstrap/css/bootstrap.min.css") : Url.Content("~/vendor/bootstrap/css/bootstrap.rtl.min.css"))" />
    <link rel="stylesheet" href="~/vendor/fonts/vazirmatn/vazirmatn.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ptg/90-auth-login.css" asp-append-version="true" />
}

<div class="sadd-login-page">
    <section class="sadd-login-art" aria-hidden="true">
        <div class="sadd-login-slides" data-login-carousel>
            <figure class="sadd-login-slide is-active">
                <img src="~/images/auth/scene-1.webp" alt="" loading="eager" />
                <figcaption>@T("پایش لحظه‌ای عملیات نفت و گاز", "Real-time oil &amp; gas operations")</figcaption>
            </figure>
            <figure class="sadd-login-slide">
                <img src="~/images/auth/scene-2.webp" alt="" loading="lazy" />
                <figcaption>@T("داشبورد وضعیت مخازن و تجهیزات", "Tank &amp; asset status dashboard")</figcaption>
            </figure>
            <figure class="sadd-login-slide">
                <img src="~/images/auth/scene-3.webp" alt="" loading="lazy" />
                <figcaption>@T("گزارش‌های مالی و بهره‌وری", "Financial &amp; profitability insights")</figcaption>
            </figure>
        </div>
        <div class="sadd-login-dots" data-login-dots>
            <button type="button" class="is-active" data-login-dot="0" tabindex="-1"></button>
            <button type="button" data-login-dot="1" tabindex="-1"></button>
            <button type="button" data-login-dot="2" tabindex="-1"></button>
        </div>
    </section>

    <main class="sadd-login-side">
        <form asp-action="Login" method="post" class="sadd-login-form" dir="@(isEn ? "ltr" : "rtl")" novalidate>
            @Html.AntiForgeryToken()
            <input asp-for="ReturnUrl" type="hidden" />

            <span class="sadd-login-logo" aria-hidden="true">
                <svg viewBox="0 0 64 64" focusable="false">
                    <circle cx="32" cy="32" r="23" fill="none" stroke="#6ea94e" stroke-width="12" stroke-linecap="round"
                            stroke-dasharray="112 33" stroke-dashoffset="-6" />
                    <path d="M32 25c4.2 5.7 7.6 9.7 7.6 14A7.6 7.6 0 0 1 24.4 39c0-4.3 3.4-8.3 7.6-14z" fill="#6ea94e" />
                </svg>
            </span>

            <h1 class="sadd-login-heading">@T("برای شروع کار وارد حساب خود شوید", "Login to start your session")</h1>

            <div asp-validation-summary="ModelOnly" class="sadd-login-alert" role="alert"></div>

            <div class="sadd-login-field">
                <label asp-for="Username" class="sadd-login-label">@T("نام کاربری", "Username")&nbsp;<b>*</b></label>
                <input asp-for="Username"
                       class="sadd-login-input"
                       autocomplete="username"
                       autocapitalize="none"
                       spellcheck="false"
                       placeholder="@T("نام کاربری", "Username")" />
                <span asp-validation-for="Username" class="sadd-login-error"></span>
            </div>

            <div class="sadd-login-field">
                <label asp-for="Password" class="sadd-login-label">@T("رمز عبور", "Password")&nbsp;<b>*</b></label>
                <input asp-for="Password"
                       class="sadd-login-input"
                       autocomplete="current-password"
                       placeholder="@T("رمز عبور", "Password")" />
                <span asp-validation-for="Password" class="sadd-login-error"></span>
            </div>

            <div class="sadd-login-row">
                <label class="sadd-login-remember">
                    <input type="checkbox" name="RememberMe" value="true" />
                    <span>@T("مرا به خاطر بسپار", "Remember Me")</span>
                </label>
                <details class="sadd-login-help">
                    <summary>@T("رمز عبور را فراموش کرده‌ام", "I forgot my password")</summary>
                    <p>@T("برای تنظیم مجدد رمز عبور با مدیر سیستم تماس بگیرید.", "Contact the system administrator to reset your password.")</p>
                </details>
            </div>

            <button type="submit" class="sadd-login-submit">@T("ورود", "Login")</button>

            <p class="sadd-login-or">@T("یا ورود با", "OR SIGN IN")</p>

            <div class="sadd-login-social">
                <button type="button" class="sadd-social-button" disabled
                        title="@T("ورود با گوگل در این سیستم فعال نیست.", "Google sign-in is not enabled for this system.")">
                    <svg viewBox="0 0 48 48" aria-hidden="true" focusable="false">
                        <path fill="#EA4335" d="M24 9.5c3.5 0 6.6 1.2 9 3.5l6.7-6.7C35.6 2.4 30.1 0 24 0 14.6 0 6.5 5.4 2.6 13.2l7.8 6.1C12.3 13.2 17.7 9.5 24 9.5z"/>
                        <path fill="#4285F4" d="M46.5 24.5c0-1.6-.1-3.1-.4-4.5H24v9h12.7c-.6 3-2.3 5.5-4.8 7.2l7.5 5.8c4.4-4.1 7.1-10.1 7.1-17.5z"/>
                        <path fill="#FBBC05" d="M10.4 28.7A14.5 14.5 0 0 1 9.6 24c0-1.6.3-3.2.8-4.7l-7.8-6.1A24 24 0 0 0 0 24c0 3.9.9 7.5 2.6 10.8l7.8-6.1z"/>
                        <path fill="#34A853" d="M24 48c6.1 0 11.2-2 15-5.5l-7.5-5.8c-2.1 1.4-4.7 2.2-7.5 2.2-6.3 0-11.7-3.7-13.6-9.2l-7.8 6.1C6.5 42.6 14.6 48 24 48z"/>
                    </svg>
                    <span>@T("با گوگل", "with Google")</span>
                </button>
                <button type="button" class="sadd-social-button" disabled
                        title="@T("ورود با مایکروسافت در این سیستم فعال نیست.", "Microsoft sign-in is not enabled for this system.")">
                    <svg viewBox="0 0 23 23" aria-hidden="true" focusable="false">
                        <rect x="1" y="1" width="10" height="10" fill="#F25022"/>
                        <rect x="12" y="1" width="10" height="10" fill="#7FBA00"/>
                        <rect x="1" y="12" width="10" height="10" fill="#00A4EF"/>
                        <rect x="12" y="12" width="10" height="10" fill="#FFB900"/>
                    </svg>
                    <span>@T("با مایکروسافت", "with Microsoft")</span>
                </button>
            </div>

            <span class="sadd-login-create" aria-disabled="true"
                  title="@T("ثبت‌نام عمومی در این سیستم فعال نیست.", "Public sign-up is not enabled for this system.")">
                @T("ساخت حساب جدید", "Create new account")
            </span>
        </form>
    </main>

    <footer class="sadd-login-footer">
        @T("قدرت‌گرفته از سامانه مدیریت نفت و گاز PTG", "Powered by PTG: Oil & Gas Management System")
    </footer>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var carousel = document.querySelector('[data-login-carousel]');
            var dotsWrap = document.querySelector('[data-login-dots]');
            if (!carousel || !dotsWrap) return;
            var slides = carousel.querySelectorAll('.sadd-login-slide');
            var dots = dotsWrap.querySelectorAll('[data-login-dot]');
            if (slides.length < 2) return;
            var index = 0, timer = null;
            var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            function show(i) {
                index = (i + slides.length) % slides.length;
                for (var s = 0; s < slides.length; s++) slides[s].classList.toggle('is-active', s === index);
                for (var d = 0; d < dots.length; d++) dots[d].classList.toggle('is-active', d === index);
            }
            function start() { if (reduce) return; stop(); timer = setInterval(function () { show(index + 1); }, 5000); }
            function stop() { if (timer) { clearInterval(timer); timer = null; } }
            for (var d = 0; d < dots.length; d++) {
                (function (d) { dots[d].addEventListener('click', function () { show(d); start(); }); })(d);
            }
            start();
        })();
    </script>
}
