@model Partner

@Html.AntiForgeryToken()
<div asp-validation-summary="ModelOnly" class="alert alert-danger ak-form-alert"></div>

<section class="ak-form-section">
    <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml"
             model="@(("اطلاعات شریک", (string?)"کد، نام و اطلاعات تماس شریک را وارد کنید."))" />
    <div class="ak-form-grid">
        <div class="ak-field">
            <label asp-for="Code" class="ak-label">کد <span class="ak-req">*</span></label>
            <input asp-for="Code" class="ak-input" autocomplete="off" />
            <span asp-validation-for="Code" class="ak-field-error"></span>
        </div>
        <div class="ak-field">
            <label asp-for="Name" class="ak-label">نام <span class="ak-req">*</span></label>
            <input asp-for="Name" class="ak-input" autocomplete="off" />
            <span asp-validation-for="Name" class="ak-field-error"></span>
        </div>
        <div class="ak-field">
            <label asp-for="Country" class="ak-label">کشور</label>
            <input asp-for="Country" class="ak-input" autocomplete="off" />
            <span asp-validation-for="Country" class="ak-field-error"></span>
        </div>
        <div class="ak-field">
            <label asp-for="ContactPerson" class="ak-label">شخص تماس</label>
            <input asp-for="ContactPerson" class="ak-input" autocomplete="off" />
            <span asp-validation-for="ContactPerson" class="ak-field-error"></span>
        </div>
        <div class="ak-field">
            <label asp-for="Phone" class="ak-label">تلفن</label>
            <input asp-for="Phone" class="ak-input" autocomplete="off" />
            <span asp-validation-for="Phone" class="ak-field-error"></span>
        </div>
        <div class="ak-toggle-field">
            <div class="form-check form-switch">
                <input asp-for="IsActive" class="form-check-input" role="switch" />
                <label asp-for="IsActive" class="form-check-label">فعال</label>
            </div>
        </div>
    </div>
</section>
