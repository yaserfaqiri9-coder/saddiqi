@model IEnumerable<Partner>
@{
    ViewData["Title"] = UiText.T(Context,"شرکا","Partners");
    var items = Model.ToList();
    var activeCount = items.Count(item => item.IsActive);
    var countryCount = items.Select(item => item.Country).Where(country => !string.IsNullOrWhiteSpace(country)).Distinct(StringComparer.OrdinalIgnoreCase).Count();
    var q = ViewData["q"]?.ToString();
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="ak-list-page">

    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((UiText.T(Context, "شرکا", "Partners"), true,
                       UiText.T(Context, "شریک جدید", "New partner"), "bi-plus-lg",
                       (string?)Url.Action("Create", new { returnUrl }), (string?)null,
                       (string?)null, (string?)null, (string?)null))" />

    <section class="ak-stat-grid mb-3" aria-label="@UiText.T(Context, "آمار شرکا", "Partner statistics")">
        <vc:stat-card title="@UiText.T(Context, "کل شرکا", "Total partners")" value="@items.Count.ToString("N0")" unit="@UiText.T(Context, "شریک", "partners")" avatar="customers"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "شرکای فعال", "Active partners")" value="@activeCount.ToString("N0")" unit="@UiText.T(Context, "شریک", "partners")" avatar="loading"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "شرکای غیرفعال", "Inactive partners")" value="@((items.Count - activeCount).ToString("N0"))" unit="@UiText.T(Context, "شریک", "partners")" avatar="losses"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "کشورها", "Countries")" value="@countryCount.ToString("N0")" unit="@UiText.T(Context, "کشور", "countries")" avatar="shipments"></vc:stat-card>
    </section>

    <partial name="~/Views/Shared/_AkSearchFilter.cshtml"
             model="@AkSearchFilterModel.SearchOnly("q", q, UiText.T(Context, "جستجو یا فیلتر نتایج...", "Search or filter results..."))" />

    <div class="ak-list">
        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead>
                    <tr>
                        <th class="ak-col-check"><input type="checkbox" class="ak-check" aria-label="@UiText.T(Context, "انتخاب همه", "Select all")" /></th>
                        <th class="ak-col-grow">@UiText.T(Context, "نام", "Name")</th>
                        <th>@UiText.T(Context, "کد", "Code")</th>
                        <th>@UiText.T(Context, "کشور", "Country")</th>
                        <th>@UiText.T(Context, "شخص تماس", "Contact")</th>
                        <th>@UiText.T(Context, "تلفن", "Phone")</th>
                        <th class="ak-col-spacer"></th>
                        <th>@UiText.T(Context, "وضعیت", "Status")</th>
                        <th class="ak-col-actions"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in items)
                    {
                        <tr data-href="@Url.Action("Details", new { id = item.Id })">
                            <td class="ak-col-check"><input type="checkbox" class="ak-check" aria-label="@UiText.T(Context, "انتخاب", "Select")" /></td>
                            <td class="ak-col-grow"><partial name="~/Views/Shared/Partials/_PersonCell.cshtml" model="@((item.Name, (string?)Url.Action("Details", new { id = item.Id }), (string?)null))" /></td>
                            <td class="ak-num">@(string.IsNullOrWhiteSpace(item.Code) ? "-" : item.Code)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Country) ? "-" : item.Country)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.ContactPerson) ? "-" : item.ContactPerson)</td>
                            <td class="ak-num">@(string.IsNullOrWhiteSpace(item.Phone) ? "-" : item.Phone)</td>
                            <td class="ak-col-spacer"></td>
                            <td>
                                <span class="ak-status @(item.IsActive ?"is-active" : "is-inactive")">
                                    @(item.IsActive ? UiText.T(Context, "فعال", "Active") : UiText.T(Context, "غیرفعال", "Inactive"))
                                </span>
                            </td>
                            <td class="ak-col-actions">
                                <div class="dropdown ak-row-menu">
                                    <button type="button" class="ak-row-menu-btn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="@UiText.T(Context, "عملیات", "Actions")">
                                        <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a class="dropdown-item" asp-action="Details" asp-route-id="@item.Id"><i class="bi bi-eye" aria-hidden="true"></i>@UiText.T(Context, "جزئیات", "Details")</a></li>
                                        <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil" aria-hidden="true"></i>@UiText.T(Context, "ویرایش", "Edit")</a></li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><partial name="~/Views/Shared/Partials/_ToggleActiveButton.cshtml" model="@(("Partners", item.Id, item.IsActive, "dropdown-item ak-danger", (string?)returnUrl))" /></li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!items.Any())
                    {
                        <tr>
                            <td colspan="9">
                                <div class="ak-empty">
                                    <i class="bi bi-people" aria-hidden="true"></i>
                                    @UiText.T(Context, "شریکی برای نمایش پیدا نشد", "No partners found")
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @{ ViewData["ShownCount"] = items.Count; }
        <div class="ak-pager">
            @await Html.PartialAsync("_PagedListFooter")
        </div>
    </div>
</div>
