@using System.Globalization
@using PTGOilSystem.Web.Helpers
@using PTGOilSystem.Web.Models.Entities
@using PTGOilSystem.Web.Models.InventoryTransport
@model InventoryTransportFromInventoryViewModel
@{
    ViewData["Title"] = "حمل گروهی از موجودی";
    ViewData["ContentBodyClass"] = "boltz-content-body-fluid";
    ViewData["HideSectionTabs"] = true;

    var terminals = ViewBag.InventoryTransportTerminals as IReadOnlyList<InventoryTransportLookupOption> ?? Array.Empty<InventoryTransportLookupOption>();
    var products = ViewBag.InventoryTransportProducts as IReadOnlyList<InventoryTransportLookupOption> ?? Array.Empty<InventoryTransportLookupOption>();
    var tanks = ViewBag.InventoryTransportTanks as IReadOnlyList<InventoryTransportLookupOption> ?? Array.Empty<InventoryTransportLookupOption>();
    var trucks = ViewBag.InventoryTransportTrucks as IReadOnlyList<InventoryTransportLookupOption> ?? Array.Empty<InventoryTransportLookupOption>();
    var wagons = ViewBag.InventoryTransportWagons as IReadOnlyList<InventoryTransportLookupOption> ?? Array.Empty<InventoryTransportLookupOption>();
    var drivers = ViewBag.InventoryTransportDrivers as IReadOnlyList<InventoryTransportLookupOption> ?? Array.Empty<InventoryTransportLookupOption>();
    var providers = ViewBag.InventoryTransportProviders as IReadOnlyList<InventoryTransportLookupOption> ?? Array.Empty<InventoryTransportLookupOption>();
    var assets = ViewBag.InventoryTransportAssets as IReadOnlyList<InventoryTransportLookupOption> ?? Array.Empty<InventoryTransportLookupOption>();
    var currencies = ViewBag.InventoryTransportCurrencies as IReadOnlyList<InventoryTransportLookupOption> ?? Array.Empty<InventoryTransportLookupOption>();
    var sources = ViewBag.InventoryTransportSources as IReadOnlyList<InventoryTransportSourceAvailabilityViewModel> ?? Array.Empty<InventoryTransportSourceAvailabilityViewModel>();
    var shipment = ViewBag.InventoryTransportShipment as InventoryTransportLookupOption;
    var shipmentOptions = ViewBag.InventoryTransportShipments as IReadOnlyList<InventoryTransportLookupOption> ?? Array.Empty<InventoryTransportLookupOption>();
    // قفل = محموله از پروندهٔ محموله/لینک آمده؛ در غیر این صورت کاربر خودش در فرم انتخاب می‌کند.
    var shipmentLocked = shipment is not null && Model.ShipmentLocked;
    var sourceQuantities = Model.Sources.ToDictionary(s => s.SourceInventoryMovementId, s => s.QuantityMt);
    // کرایه در این فرم همیشه USD است (فی‌تن × وزن)؛ سرور FreightCurrencyId می‌خواهد،
    // پس واحد پول USD به شکل hidden برای هر ردیف ارسال می‌شود.
    var usdCurrencyId = currencies.FirstOrDefault(c => string.Equals(c.Name, "USD", StringComparison.OrdinalIgnoreCase))?.Id;
}

<main class="page-stack ak-form-page" data-inv-transport-form-page data-sources-url="@Url.Action("InventorySources")" data-import-url="@Url.Action("ImportVehiclesExcel")">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@(("حمل گروهی از موجودی", false, (string?)null, (string?)null, (string?)null, (string?)null, "بازگشت به حمل‌ها", "bi-arrow-right", Url.Action("Active")))" />

    <form asp-action="CreateFromInventory" method="post" class="ak-form" data-inv-transport-form novalidate>
        @Html.AntiForgeryToken()
        @Html.FormToken()
        <input type="hidden" name="ActiveStep" value="@Model.ActiveStep" data-active-step />
        @if (shipmentLocked)
        {
            <input type="hidden" name="ShipmentId" value="@Model.ShipmentId" data-shipment-id />
            <input type="hidden" name="ShipmentLocked" value="true" />
        }
        <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
        <div asp-validation-summary="All" class="alert alert-danger ak-form-alert"></div>
        @if (!shipmentLocked && Model.IsChainContinuation && (Model.ShipmentId ?? 0) <= 0)
        {
            <div class="ak-note is-warning" role="alert">
                <i class="bi bi-exclamation-triangle"></i>
                @if (Model.ShipmentLinkAmbiguous)
                {
                    <span>مبدأ انتخاب‌شده به بیش از یک کشتی وصل است و کشتی به‌طور قطعی مشخص نیست. برای اتصال درست به پرونده، از دکمهٔ «حمل بعدی» در پروندهٔ همان کشتی وارد شوید؛ در غیر این صورت ثبت متوقف می‌شود.</span>
                }
                else
                {
                    <span>کشتیِ این مبدأ تشخیص داده نشد. اگر این حمل ادامهٔ بار یک کشتی است، از پروندهٔ کشتی دکمهٔ «حمل بعدی» را بزنید تا به همان پرونده وصل شود.</span>
                }
            </div>
        }

        <section class="ak-form-section">
            <h2 class="ak-section-title"><i class="bi bi-geo-alt"></i> مبدأ حمل</h2>
            <div class="ak-form-grid">
                @if (shipmentLocked)
                {
                    <div class="ak-field">
                        <label>محموله (مبدأ)</label>
                        <input type="text" class="ak-input" value="@shipment!.Name" readonly />
                        <input type="hidden" name="SourceTerminalId" value="@Model.SourceTerminalId" />
                        <input type="hidden" name="SourceStorageTankId" value="@Model.SourceStorageTankId" />
                    </div>
                }
                else
                {
                    <div class="ak-field">
                        <label>محموله (اختیاری)</label>
                        <select name="ShipmentId" class="ak-input" data-shipment-id>
                            <option value="">— بدون محموله: از ترمینال / مخزن —</option>
                            @foreach (var item in shipmentOptions)
                            {
                                <option value="@item.Id" selected="@(Model.ShipmentId == item.Id ? "selected" : null)">@item.Name</option>
                            }
                        </select>
                    </div>
                    <div class="ak-field" data-terminal-field>
                        <label>ترمینال مبدأ</label>
                        <select name="SourceTerminalId" class="ak-input" data-source-terminal required>
                            <option value="">انتخاب کنید</option>
                            @foreach (var item in terminals)
                            {
                                <option value="@item.Id" selected="@(Model.SourceTerminalId == item.Id ? "selected" : null)">@item.Name</option>
                            }
                        </select>
                    </div>
                }
                <div class="ak-field">
                    <label>محصول</label>
                    <select name="ProductId" class="ak-input" data-source-product required>
                        <option value="">انتخاب کنید</option>
                        @foreach (var item in products)
                        {
                            <option value="@item.Id" selected="@(Model.ProductId == item.Id ? "selected" : null)">@item.Name</option>
                        }
                    </select>
                </div>
                @if (!shipmentLocked)
                {
                    <div class="ak-field" data-tank-field>
                        <label>مخزن مبدأ</label>
                        <select name="SourceStorageTankId" class="ak-input" data-source-tank required>
                            <option value="">انتخاب کنید</option>
                            @foreach (var item in tanks)
                            {
                                <option value="@item.Id" data-terminal-id="@item.TerminalId" data-product-id="@item.ProductId" selected="@(Model.SourceStorageTankId == item.Id ? "selected" : null)">@item.Name</option>
                            }
                        </select>
                    </div>
                }
                <input type="hidden" name="TransportDate" value="@((Model.TransportDate == default ? DateTime.UtcNow.Date : Model.TransportDate).ToString("yyyy-MM-dd"))" />
            </div>
        </section>

        <section class="ak-form-section">
            <h2 class="ak-section-title"><i class="bi bi-database"></i> انتخاب موجودی مختلط</h2>
            <p class="ak-note">فقط منابع را تیک بزنید؛ مقدار هر موتر را در بخش پایین وارد کنید. سیستم خودش جمع بارگیری را به‌ترتیب بین منابع تیک‌خورده تقسیم و کسر می‌کند.</p>
            <div asp-validation-for="Sources" class="ak-field-error"></div>
            <div class="ak-table-wrap">
                <table class="ak-table">
                    <thead><tr><th><input type="checkbox" data-source-check-all title="انتخاب همه" /></th><th>قرارداد</th><th>منبع موجودی</th><th>تاریخ</th><th>قابل حمل MT</th><th>کسر خودکار MT</th></tr></thead>
                    <tbody data-source-rows>
                    @for (var i = 0; i < sources.Count; i++)
                    {
                        var source = sources[i];
                        var quantity = sourceQuantities.GetValueOrDefault(source.SourceInventoryMovementId);
                        var isVesselSource = source.SourceInventoryMovementId < 0;
                        <tr data-source-row data-source-id="@source.SourceInventoryMovementId" data-available="@source.AvailableQuantityMt.ToString(CultureInfo.InvariantCulture)" data-source-vessel="@(isVesselSource ? "true" : null)" data-label="@source.ContractNumber / @source.ReceiptReference">
                            <td><input type="checkbox" data-source-check @(quantity.GetValueOrDefault() > 0 ? "checked" : null) /></td><td>@source.ContractNumber</td><td><span class="ak-status@(isVesselSource ?" is-warning" : "")">@source.SourceKind</span></td><td>@source.SourceDate.ToString("yyyy/MM/dd")</td><td><strong class="ak-num">@source.AvailableQuantityMt.ToString("N4")</strong></td>
                            <td><input type="hidden" name="Sources[@i].SourceInventoryMovementId" value="@source.SourceInventoryMovementId" /><input type="hidden" name="Sources[@i].QuantityMt" value="@(quantity.GetValueOrDefault() > 0 ? quantity.GetValueOrDefault().ToString(CultureInfo.InvariantCulture) : null)" data-source-quantity /><span class="ak-num" data-source-consumed>@(quantity.GetValueOrDefault() > 0 ? quantity.GetValueOrDefault().ToString("N4") : "0.0000")</span></td>
                        </tr>
                    }
                    </tbody>
                </table>
                <div class="ak-empty" data-source-empty @(sources.Count > 0 ? "hidden" : null)>پس از انتخاب مبدأ، موجودی قابل حمل اینجا نمایش داده می‌شود.</div>
            </div>
            <div class="ak-table-total">جمع انتخاب‌شده: <strong data-selected-total>0.0000</strong> MT</div>
        </section>

        <section class="ak-form-section">
            <h2 class="ak-section-title"><i class="bi bi-truck"></i> تقسیم بین موتر و واگن</h2>
            <div asp-validation-for="Vehicles" class="ak-field-error"></div>
            <div class="ak-summary" data-alloc-bar>
                <div class="ak-field" data-alloc-item><span>مقدار انتخاب‌شده</span><strong data-alloc-selected>0.0000</strong> MT</div>
                <div class="ak-field" data-alloc-item><span>تخصیص‌داده‌شده</span><strong data-alloc-assigned>0.0000</strong> MT</div>
                <div class="ak-field is-remaining" data-alloc-item><span>باقی‌مانده</span><strong data-alloc-remaining>0.0000</strong> MT</div>
                <div class="ak-toggle-field" data-alloc-item>
                    <label class="form-check">
                        <input type="checkbox" class="form-check-input" data-freight-toggle checked />
                        <span class="form-check-label">ثبت کرایه</span>
                    </label>
                </div>
            </div>
            <div class="ak-table-wrap">
                <table class="ak-table" data-vehicle-table>
                    <thead><tr><th>نوع</th><th>وسیله</th><th>سیمیر/CMR</th><th>راننده</th><th>مقدار MT</th><th>حمل‌کننده</th><th>شرکت / دارایی</th><th data-freight-col>وزن محاسبه</th><th data-freight-col>کرایه فی‌تن (دالر)</th><th data-freight-col>کرایه کل (دالر)</th><th></th></tr></thead>
                    <tbody data-vehicle-rows>
                    @for (var i = 0; i < Model.Vehicles.Count; i++)
                    {
                        var vehicle = Model.Vehicles[i];
                        <tr data-vehicle-row data-index="@i">
                            <td><select class="ak-input" name="Vehicles[@i].TransportType" data-vehicle-type><option value="3" selected="@(vehicle.TransportType == LoadingTransportType.Truck ? "selected" : null)">موتر</option><option value="2" selected="@(vehicle.TransportType == LoadingTransportType.Wagon ? "selected" : null)">واگن</option></select></td>
                            <td><input class="ak-input" type="text" maxlength="50" list="itf-truck-list" name="Vehicles[@i].TruckPlateNumberInput" value="@vehicle.TruckPlateNumberInput" placeholder="انتخاب یا تایپ نمبر پلیت" autocomplete="off" data-truck-plate /><input class="ak-input" type="text" maxlength="50" list="itf-wagon-list" name="Vehicles[@i].WagonNumberInput" value="@vehicle.WagonNumberInput" placeholder="انتخاب یا تایپ نمبر واگن" autocomplete="off" data-wagon-number /><span class="ak-section-desc" hidden data-asset-vehicle-note>وسیله از دارایی عملیاتی تعیین می‌شود</span></td>
                            <td><input class="ak-input" type="text" maxlength="100" name="Vehicles[@i].RwbNo" value="@vehicle.RwbNo" placeholder="سیمیر" data-rwb /></td>
                            <td><select class="ak-input" name="Vehicles[@i].DriverId" data-driver><option value="">انتخاب راننده</option>@foreach (var item in drivers) { <option value="@item.Id" selected="@(vehicle.DriverId == item.Id ? "selected" : null)">@item.Name</option> }</select></td>
                            <td><input class="ak-input" type="number" min="0" step="0.0001" name="Vehicles[@i].QuantityMt" value="@(vehicle.QuantityMt > 0 ? vehicle.QuantityMt.ToString(CultureInfo.InvariantCulture) : null)" data-vehicle-quantity /></td>
                            <td><select class="ak-input" name="Vehicles[@i].CarrierType" data-carrier-type><option value="1" selected="@(vehicle.CarrierType == CarrierType.ServiceProvider ? "selected" : null)">شرکت خدماتی</option><option value="2" selected="@(vehicle.CarrierType == CarrierType.OperationalAsset ? "selected" : null)">دارایی عملیاتی</option></select></td>
                            <td><select class="ak-input" name="Vehicles[@i].ServiceProviderId" data-provider><option value="">انتخاب شرکت</option>@foreach (var item in providers) { <option value="@item.Id" selected="@(vehicle.ServiceProviderId == item.Id ? "selected" : null)">@item.Name</option> }</select><select class="ak-input" name="Vehicles[@i].OperationalAssetId" data-asset><option value="">انتخاب دارایی</option>@foreach (var item in assets) { <option value="@item.Id" data-asset-type="@item.Type" data-capacity="@(item.CapacityMt.HasValue ? item.CapacityMt.Value.ToString(CultureInfo.InvariantCulture) : null)" selected="@(vehicle.OperationalAssetId == item.Id ? "selected" : null)">@item.Name</option> }</select></td>
                            <td data-freight-col><input class="ak-input" type="number" min="0" step="0.0001" placeholder="وزن کرایه" name="Vehicles[@i].FreightWeightMt" value="@vehicle.FreightWeightMt?.ToString(CultureInfo.InvariantCulture)" data-freight-weight /></td>
                            <td data-freight-col><input class="ak-input" type="number" min="0" step="0.0001" placeholder="فی‌تن" name="Vehicles[@i].FreightRatePerMt" value="@vehicle.FreightRatePerMt?.ToString(CultureInfo.InvariantCulture)" data-freight-rate /></td>
                            <td data-freight-col><span class="ak-num" data-freight-usd>—</span><input type="hidden" name="Vehicles[@i].FreightAmount" value="@vehicle.FreightAmount?.ToString(CultureInfo.InvariantCulture)" data-freight /><input type="hidden" name="Vehicles[@i].FreightCurrencyId" value="@(vehicle.FreightCurrencyId ?? usdCurrencyId)" /><div data-allocation-fields>@for (var allocationIndex = 0; allocationIndex < vehicle.Allocations.Count; allocationIndex++) { var allocation = vehicle.Allocations[allocationIndex]; <input type="hidden" name="Vehicles[@i].Allocations[@allocationIndex].SourceInventoryMovementId" value="@allocation.SourceInventoryMovementId" /><input type="hidden" name="Vehicles[@i].Allocations[@allocationIndex].QuantityMt" value="@allocation.QuantityMt.ToString(CultureInfo.InvariantCulture)" /> }</div></td>
                            <td><button type="button" class="ak-row-menu-btn" data-remove-vehicle aria-label="حذف ردیف">×</button></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
            <div class="ak-subform-toolbar" data-vehicle-import>
                <button type="button" class="btn btn-light ak-secondary-action" data-add-vehicle><i class="bi bi-plus-lg"></i> افزودن وسیله</button>
                <button type="button" class="btn btn-light ak-secondary-action" data-apply-carrier-all title="حمل‌کنندهٔ سطر اول (شرکت خدماتی / دارایی عملیاتی) در تمام سطرها تطبیق می‌شود"><i class="bi bi-arrow-down-square"></i> تطبیق حمل‌کننده به همه سطرها</button>
                <input type="file" accept=".xlsx" data-vehicle-import-file hidden />
                <button type="button" class="btn btn-light ak-secondary-action" data-vehicle-import-btn title="ستون‌ها: سیمیر • نمبر واگون/پلیت • وزن سیمیر (مقدار حمل MT) • وزن محاسبه (مبنای کرایه) • فی تن محاسبه (کرایه = فی‌تن × وزن محاسبه، USD). فرمت ساده «نوع/نمبر/مقدار/کرایه/ارز» هم پشتیبانی می‌شود. جدول فعلی جایگزین می‌شود.">
                    <i class="bi bi-file-earmark-spreadsheet"></i> وارد کردن اکسل موترها/واگن‌ها
                </button>
                <span class="ak-section-desc" data-vehicle-import-status></span>
            </div>
        </section>

        <section class="ak-form-section" data-summary-section hidden>
            <h2 class="ak-section-title"><i class="bi bi-clipboard-check"></i> خلاصه و ثبت</h2>
            <div class="ak-form-grid">
                <div><span>جمع موجودی</span><strong data-summary-source>0.0000 MT</strong></div>
                <div><span>جمع وسایط</span><strong data-summary-vehicles>0.0000 MT</strong></div>
                <div><span>تفاوت</span><strong data-summary-difference>0.0000 MT</strong></div>
                <div><span>جمع کرایه</span><strong data-summary-freight>0.00</strong></div>
            </div>
            <div class="ak-note is-invalid" data-summary-message aria-live="polite" hidden></div>
            <div class="ak-field ak-field is-full ">
                <label>یادداشت</label>
                <textarea name="Notes" class="ak-input" rows="2">@Model.Notes</textarea>
            </div>
            <p class="ak-note">ثبت این سند هیچ بدهی، پرداخت، صندوق یا Ledger ایجاد نمی‌کند.</p>
            <p class="ak-note is-warning" data-vessel-hint hidden><i class="bi bi-exclamation-triangle"></i> «بار روی کشتی» انتخاب شده است: این حمل فقط با «ثبت و بارگیری» ممکن است. هنگام ثبت، یک رسید کشتی در پروندهٔ محموله ثبت و از باقی‌ماندهٔ کشتی کم می‌شود.</p>
        </section>

        <div class="ak-footer-actions">
            <a asp-action="Active" class="btn btn-light ak-secondary-action">انصراف</a>
            <button type="submit" class="btn btn-light ak-secondary-action" name="SubmissionMode" value="0" data-submit-button>ثبت پیش‌نویس</button>
            <button type="submit" class="btn btn-primary ak-primary-action" name="SubmissionMode" value="1" data-submit-button>ثبت و بارگیری</button>
        </div>
    </form>
</main>

<template data-vehicle-template>
    <tr data-vehicle-row data-index="__index__">
        <td><select class="ak-input" name="Vehicles[__index__].TransportType" data-vehicle-type><option value="3">موتر</option><option value="2">واگن</option></select></td>
        <td><input class="ak-input" type="text" maxlength="50" list="itf-truck-list" name="Vehicles[__index__].TruckPlateNumberInput" placeholder="انتخاب یا تایپ نمبر پلیت" autocomplete="off" data-truck-plate /><input class="ak-input" type="text" maxlength="50" list="itf-wagon-list" name="Vehicles[__index__].WagonNumberInput" placeholder="انتخاب یا تایپ نمبر واگن" autocomplete="off" data-wagon-number /><span class="ak-section-desc" hidden data-asset-vehicle-note>وسیله از دارایی عملیاتی تعیین می‌شود</span></td>
        <td><input class="ak-input" type="text" maxlength="100" name="Vehicles[__index__].RwbNo" placeholder="سیمیر" data-rwb /></td>
        <td><select class="ak-input" name="Vehicles[__index__].DriverId" data-driver><option value="">انتخاب راننده</option>@foreach (var item in drivers) { <option value="@item.Id">@item.Name</option> }</select></td>
        <td><input class="ak-input" type="number" min="0" step="0.0001" name="Vehicles[__index__].QuantityMt" data-vehicle-quantity /></td>
        <td><select class="ak-input" name="Vehicles[__index__].CarrierType" data-carrier-type><option value="1">شرکت خدماتی</option><option value="2">دارایی عملیاتی</option></select></td>
        <td><select class="ak-input" name="Vehicles[__index__].ServiceProviderId" data-provider><option value="">انتخاب شرکت</option>@foreach (var item in providers) { <option value="@item.Id">@item.Name</option> }</select><select class="ak-input" name="Vehicles[__index__].OperationalAssetId" data-asset><option value="">انتخاب دارایی</option>@foreach (var item in assets) { <option value="@item.Id" data-asset-type="@item.Type" data-capacity="@(item.CapacityMt.HasValue ? item.CapacityMt.Value.ToString(CultureInfo.InvariantCulture) : null)">@item.Name</option> }</select></td>
        <td data-freight-col><input class="ak-input" type="number" min="0" step="0.0001" placeholder="وزن کرایه" name="Vehicles[__index__].FreightWeightMt" data-freight-weight /></td>
        <td data-freight-col><input class="ak-input" type="number" min="0" step="0.0001" placeholder="فی‌تن" name="Vehicles[__index__].FreightRatePerMt" data-freight-rate /></td>
        <td data-freight-col><span class="ak-num" data-freight-usd>—</span><input type="hidden" name="Vehicles[__index__].FreightAmount" data-freight /><input type="hidden" name="Vehicles[__index__].FreightCurrencyId" value="@usdCurrencyId" /><div data-allocation-fields></div></td>
        <td><button type="button" class="ak-row-menu-btn" data-remove-vehicle aria-label="حذف ردیف">×</button></td>
    </tr>
</template>

@* فهرست موترها/واگن‌های موجود برای کمبوباکس وسیله (هم انتخاب هم تایپ نمبر جدید) *@
<datalist id="itf-truck-list">@foreach (var item in trucks) { <option value="@item.Name"></option> }</datalist>
<datalist id="itf-wagon-list">@foreach (var item in wagons) { <option value="@item.Name"></option> }</datalist>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/inventory-transport-form.js" asp-append-version="true"></script>
}
