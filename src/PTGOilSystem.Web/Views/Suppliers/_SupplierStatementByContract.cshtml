@model PTGOilSystem.Web.Models.Suppliers.SupplierProfileViewModel
@{
    // نمایشِ خلاصهٔ صورت‌حساب بر اساس هر قرارداد (به‌جای هر بارگیری) تا شلوغ نباشد.
    // فقط تجمیعِ نمایشیِ StatementRows موجود است؛ هیچ داده/لِجری تغییر نمی‌کند.
    var groups = Model.StatementRows
        .GroupBy(r => r.ContractId)
        .Select(g => new
        {
            ContractId = g.Key,
            ContractNumber = g.Select(x => x.ContractNumber).FirstOrDefault(x => !string.IsNullOrWhiteSpace(x)),
            Count = g.Count(),
            DebitUsd = g.Sum(x => x.DebitUsd ?? 0m),
            CreditUsd = g.Sum(x => x.CreditUsd ?? 0m),
            HasRub = g.Any(x => x.DebitRubEquivalent.HasValue || x.CreditRubEquivalent.HasValue),
            DebitRub = g.Sum(x => x.DebitRubEquivalent ?? 0m),
            CreditRub = g.Sum(x => x.CreditRubEquivalent ?? 0m)
        })
        .OrderBy(g => g.ContractId == null ? 1 : 0)
        .ThenBy(g => g.ContractNumber)
        .ToList();

    string Amt(decimal value) => Math.Abs(value).ToString("N2");
}

<div class="ak-table-wrap">
    <table class="ak-table">
        <thead>
            <tr>
                <th>قرارداد</th>
                <th class="text-end">تعداد اسناد</th>
                <th class="text-end">بدهکار USD</th>
                <th class="text-end">بستانکار USD</th>
                <th>مانده</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var g in groups)
        {
            var balUsd = g.CreditUsd - g.DebitUsd;
            var balRub = g.CreditRub - g.DebitRub;
            <tr>
                <td>@(string.IsNullOrWhiteSpace(g.ContractNumber) ? "بدون قرارداد" : g.ContractNumber)</td>
                <td class="text-end ak-num">@g.Count.ToString("N0")</td>
                <td class="text-end ak-num">@Amt(g.DebitUsd)</td>
                <td class="text-end ak-num">@Amt(g.CreditUsd)</td>
                <td class="supplier-balance-cell ak-num">
                    <span>USD @Amt(balUsd)</span>
                    @if (g.HasRub)
                    {
                        <span>RUB @Amt(balRub)</span>
                    }
                    else
                    {
                        <span class="supplier-muted">RUB ثبت نشده</span>
                    }
                </td>
                <td class="text-end">
                    @if (g.ContractId.HasValue)
                    {
                        <a class="btn btn-light ak-secondary-action" asp-action="Details" asp-route-id="@Model.SupplierId" asp-route-tab="statement" asp-route-contractId="@g.ContractId">
                            جزییات <i class="bi bi-chevron-left"></i>
                        </a>
                    }
                </td>
            </tr>
        }
        @if (!groups.Any())
        {
            <tr>
                <td colspan="6" class="ak-empty">هنوز صورت‌حسابی برای این تأمین‌کننده ثبت نشده است.</td>
            </tr>
        }
        </tbody>
    </table>
</div>
