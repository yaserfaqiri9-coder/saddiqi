@model PTGOilSystem.Web.Models.Suppliers.SupplierIndexViewModel
@{
    ViewData["Title"] = UiText.T(Context, "تأمین‌کنندگان", "Suppliers");
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var visibleActiveCount = Model.Items.Count(item => item.IsActive);
    var visibleActiveContractCount = Model.Items.Sum(item => item.ActivePurchaseContractsCount);
    var visibleClaimUsd = Model.Items.Sum(item => item.SupplierTotalClaimUsd);
}

@* ak-list-page: phase-2 Akaunting rebuild (real markup, no ulist card wrapper). *@
<div class="ak-list-page">

    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((UiText.T(Context, "تأمین‌کنندگان", "Suppliers"), true,
                       UiText.T(Context, "تأمین‌کننده جدید", "New supplier"), "bi-plus-lg",
                       (string?)Url.Action("Create", new { returnUrl }), (string?)null,
                       (string?)null, (string?)null, (string?)null))" />

    <section class="ak-stat-grid mb-3" aria-label="@UiText.T(Context, "آمار تأمین‌کنندگان", "Supplier statistics")">
        <vc:stat-card title="@UiText.T(Context, "کل تأمین‌کنندگان", "Total suppliers")" value="@Model.TotalCount.ToString("N0")" unit="@UiText.T(Context, "تأمین‌کننده", "suppliers")" avatar="suppliers"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "فعال در این صفحه", "Active on this page")" value="@visibleActiveCount.ToString("N0")" unit="@UiText.T(Context, "تأمین‌کننده", "suppliers")" avatar="loading"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "قرارداد فعال در این صفحه", "Active contracts on page")" value="@visibleActiveContractCount.ToString("N0")" unit="@UiText.T(Context, "قرارداد", "contracts")" avatar="purchase-contracts"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "طلب در این صفحه", "Claim on this page")" value="@visibleClaimUsd.ToString("#,0.##")" unit="USD" avatar="receivables"></vc:stat-card>
    </section>

    <partial name="~/Views/Shared/_AkSearchFilter.cshtml"
             model="@AkSearchFilterModel.SearchOnly("q", Model.Search, UiText.T(Context, "جستجو یا فیلتر نتایج...", "Search or filter results..."))" />

    <div class="d-flex justify-content-end mb-2 no-print">
        <partial name="~/Views/Shared/_ExportMenu.cshtml" model="@(new PTGOilSystem.Web.Services.Exports.ExportMenuModel("Export"))" />
    </div>

    <div class="ak-list">
        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead>
                    <tr>
                        <th class="ak-col-check">
                            <input type="checkbox" class="ak-check" aria-label="@UiText.T(Context, "انتخاب همه", "Select all")" />
                        </th>
                        <th class="ak-col-grow">@UiText.T(Context, "نام", "Name")</th>
                        <th>@UiText.T(Context, "کد", "Code")</th>
                        <th>@UiText.T(Context, "قراردادها", "Contracts")</th>
                        <th class="ak-col-num">@UiText.T(Context, "مقدار خرید", "Purchased")</th>
                        <th class="ak-col-spacer"></th>
                        <th class="ak-col-num">@UiText.T(Context, "طلب/بدهی USD", "Balance USD")</th>
                        <th>@UiText.T(Context, "وضعیت", "Status")</th>
                        <th class="ak-col-actions"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Items)
                    {
                        <tr data-href="@Url.Action("Details", new { id = row.SupplierId })">
                            <td class="ak-col-check">
                                <input type="checkbox" class="ak-check" aria-label="@UiText.T(Context, "انتخاب", "Select")" />
                            </td>
                            <td class="ak-col-grow">
                                <partial name="~/Views/Shared/Partials/_PersonCell.cshtml"
                                         model="@((row.Name, (string?)Url.Action("Details", new { id = row.SupplierId }), (string?)null))" />
                            </td>
                            <td class="ak-num">@(string.IsNullOrWhiteSpace(row.Code) ? "-" : row.Code)</td>
                            <td>@row.PurchaseContractsCount.ToString("N0") (@row.ActivePurchaseContractsCount.ToString("N0"))</td>
                            <td class="ak-num ak-col-num">@row.TotalPurchaseQuantityMt.ToString("N2") MT</td>
                            <td class="ak-col-spacer"></td>
                            <td class="ak-num ak-col-num">@row.SupplierTotalClaimUsd.ToString("N2")</td>
                            <td>
                                <span class="ak-status @(row.IsActive ?"is-active" : "is-inactive")">
                                    @(row.IsActive ? UiText.T(Context, "فعال", "Active") : UiText.T(Context, "غیرفعال", "Inactive"))
                                </span>
                            </td>
                            <td class="ak-col-actions">
                                <div class="dropdown ak-row-menu">
                                    <button type="button" class="ak-row-menu-btn" data-bs-toggle="dropdown" aria-expanded="false"
                                            aria-label="@UiText.T(Context, "عملیات", "Actions")">
                                        <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li>
                                            <a class="dropdown-item" asp-action="Details" asp-route-id="@row.SupplierId">
                                                <i class="bi bi-eye" aria-hidden="true"></i>@UiText.T(Context, "پروفایل", "Profile")
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-action="Edit" asp-route-id="@row.SupplierId">
                                                <i class="bi bi-pencil" aria-hidden="true"></i>@UiText.T(Context, "ویرایش", "Edit")
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li>
                                            <partial name="~/Views/Shared/Partials/_ToggleActiveButton.cshtml"
                                                     model="@(("Suppliers", row.SupplierId, row.IsActive, "dropdown-item ak-danger", (string?)returnUrl))" />
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="9">
                                <div class="ak-empty">
                                    <i class="bi bi-person-vcard" aria-hidden="true"></i>
                                    @UiText.T(Context, "تأمین‌کننده‌ای پیدا نشد", "No suppliers found")
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @{
            ViewData["CurrentPage"] = Model.CurrentPage;
            ViewData["PageCount"] = Model.PageCount;
            ViewData["TotalCount"] = Model.TotalCount;
            ViewData["ShownCount"] = Model.Items.Count;
        }
        <div class="ak-pager">
            @await Html.PartialAsync("_PagedListFooter")
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            document.querySelectorAll('.ak-list-page .ak-table tbody tr[data-href]').forEach(function (row) {
                row.addEventListener('click', function (e) {
                    if (e.target.closest('a, button, input, label, select, form, .dropdown-menu')) return;
                    window.location.href = row.getAttribute('data-href');
                });
            });
        })();
    </script>
}
