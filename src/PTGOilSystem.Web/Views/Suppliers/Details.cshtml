@model PTGOilSystem.Web.Models.Suppliers.SupplierProfileViewModel
@using PTGOilSystem.Web.Models.Entities
@using PTGOilSystem.Web.Models.Shared
@{
    ViewData["Title"] = "پروفایل تأمین‌کننده";
    ViewData["HideSectionTabs"] = true;
    var notRecorded = "ثبت نشده";
    var supplierReturnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";

    var officialSummary = ViewData["PartyStatementSummary"] as PTGOilSystem.Web.Models.PartyStatements.PartyStatementSummary;
    var endingUsd = officialSummary?.ClosingBalance ?? Model.SupplierRemainingClaimUsd;
    var endingRub = officialSummary is null ? Model.SupplierRemainingClaimRub : null;
    var hasRubBalance = endingRub.HasValue;
    var balanceLabel = officialSummary?.ClosingBalanceMeaning
        ?? (endingUsd > 0 ? "قابل پرداخت به تأمین‌کننده" : endingUsd < 0 ? "پیش‌پرداخت / طلب ما از تأمین‌کننده" : "حساب تسویه است");
    var balanceClass = endingUsd > 0 ? "ak-num" : endingUsd < 0 ? "ak-num" : "";
    var officialRecentRows = ViewData["PartyStatementRecentRows"] as IReadOnlyList<PTGOilSystem.Web.Models.PartyStatements.PartyStatementRow> ?? [];

    // سه تب: خلاصه (پیش‌فرض) · قراردادها (شامل پرداخت‌ها) · صورت‌حساب.
    var activeTab = Model.ActiveTab;
    var showContracts = activeTab is "contracts" or "payments" or "sarraf";
    var showStatement = activeTab == "statement";
    var showOverview = !showContracts && !showStatement;

    var newPaymentUrl = Url.Action("Create", "Payments", new { supplierId = Model.SupplierId, returnUrl = supplierReturnUrl }) ?? "#";
    var editUrl = Url.Action("Edit", new { id = Model.SupplierId }) ?? "#";
    var indexUrl = Url.Action("Index") ?? "#";
    ViewData["AkHeaderStatus"] = Model.IsActive ? "فعال" : "غیرفعال";
    ViewData["AkHeaderStatusState"] = Model.IsActive ? "is-active" : "is-inactive";
    ViewData["AkHeaderContext"] = $"کد: {(string.IsNullOrWhiteSpace(Model.Code) ? notRecorded : Model.Code)} · {balanceLabel}";
    ViewData["AkHeaderKebab"] = new List<AkHeaderMenuItem>
    {
        new() { Label = "صورت‌حساب رسمی", Href = Url.Action("Supplier", "PartyStatements", new { id = Model.SupplierId }), Icon = "bi-file-earmark-text" },
        new() { Label = "ویرایش", Href = editUrl, Icon = "bi-pencil" }
    };

    var supplierTabs = new[]
    {
        $"overview|خلاصه|bi-clipboard-data|{(showOverview ? "active" : "")}",
        $"contracts|قراردادها|bi-file-earmark-text|{(showContracts ? "active" : "")}",
        $"statement|صورت‌حساب|bi-journal-text|{(showStatement ? "active" : "")}"
    };
}

<div class="ak-form-page ak-party-page ak-detail-page" dir="rtl" data-ak-detail-v2="true">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((Model.Name, false,
                       "ثبت پرداخت", "bi-cash-coin", newPaymentUrl, (string?)null,
                       "فهرست تأمین‌کننده‌ها", "bi-arrow-right", (string?)indexUrl))" />

    <partial name="~/Views/Shared/Partials/_DetailsTabs.cshtml" model="@("بخش‌های پروفایل تأمین‌کننده", supplierTabs)" />

    @* ===== اطلاعات هویتی + وضعیت حساب (تخت، بدون Hero/Avatar/KPI رنگی) ===== *@
    <div class="ak-form-grid" hidden="@(!showOverview)">
        <section class="ak-form-section ak-detail-section">
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("اطلاعات هویتی", (string?)null))" />
            <dl class="ak-list">
                <div class="ak-list-row"><dt>کد</dt><dd>@(string.IsNullOrWhiteSpace(Model.Code) ? notRecorded : Model.Code)</dd></div>
                <div class="ak-list-row"><dt>کشور</dt><dd>@(string.IsNullOrWhiteSpace(Model.Country) ? notRecorded : Model.Country)</dd></div>
                <div class="ak-list-row"><dt>طرف تماس</dt><dd>@(string.IsNullOrWhiteSpace(Model.ContactPerson) ? notRecorded : Model.ContactPerson)</dd></div>
                <div class="ak-list-row"><dt>تلفن</dt><dd>@(string.IsNullOrWhiteSpace(Model.Phone) ? notRecorded : Model.Phone)</dd></div>
                <div class="ak-list-row"><dt>آدرس</dt><dd>@(string.IsNullOrWhiteSpace(Model.Address) ? notRecorded : Model.Address)</dd></div>
                <div class="ak-list-row"><dt>یادداشت</dt><dd>@(string.IsNullOrWhiteSpace(Model.Notes) ? notRecorded : Model.Notes)</dd></div>
            </dl>
        </section>

        <section class="ak-form-section ak-detail-section">
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("وضعیت حساب", balanceLabel))" />
            <dl class="ak-list">
                <div class="ak-list-row"><dt>مانده حساب</dt><dd class="ak-num @balanceClass">@NumberDisplay.Money(Math.Abs(endingUsd), "USD")</dd></div>
                @if (hasRubBalance)
                {
                    <div class="ak-list-row"><dt>معادل روبل</dt><dd class="ak-num">@NumberDisplay.Money(Math.Abs(endingRub!.Value), "RUB")</dd></div>
                }
                <div class="ak-list-row"><dt>خرید بارگیری‌شده</dt><dd class="ak-num">@NumberDisplay.Money(Model.LoadedPurchaseValueUsd, "USD")</dd></div>
                <div class="ak-list-row"><dt>پرداخت‌شده</dt><dd class="ak-num">@NumberDisplay.Money(Model.TotalPaidUsd, "USD")</dd></div>
                <div class="ak-list-row"><dt>پیش‌پرداخت آزاد</dt><dd class="ak-num">@NumberDisplay.Money(Model.AdvanceFreeUsd, "USD")</dd></div>
                <div class="ak-list-row"><dt>قرارداد فعال</dt><dd class="ak-num">@Model.ActivePurchaseContractsCount.ToString("N0")</dd></div>
                <div class="ak-list-row"><dt>آخرین پرداخت</dt><dd>@(Model.LastPaymentDate.HasValue ? Model.LastPaymentDate.Value.ToDisplayDate() : notRecorded)</dd></div>
            </dl>
        </section>
    </div>

    @* ===== تب ۱: خلاصه — آخرین حرکت‌های حساب ===== *@
    <section id="supplier-overview" class="ak-form-section ak-detail-section" hidden="@(!showOverview)">
        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("حرکت‌های اخیر", "پنج سند آخر از موتور مشترک صورت‌حساب."))" />
        <partial name="~/Views/Shared/Statements/_PartyStatementRecent.cshtml" model="officialRecentRows" />
    </section>
    @* ===== تب ۲: قراردادها + پرداخت‌ها ===== *@
    <section id="supplier-contracts" class="ak-form-section ak-detail-section" hidden="@(!showContracts)">
        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("قراردادهای خرید", $"{Model.Contracts.Count:N0} قرارداد")) " />
        @{
            // گروه‌بندی پرداخت‌ها فقط نمایشی است؛ هیچ مبلغی دوباره محاسبه نمی‌شود.
            var payByContract = Model.PaymentLines
                .Where(p => !string.IsNullOrWhiteSpace(p.ContractNumber))
                .GroupBy(p => p.ContractNumber!)
                .ToDictionary(g => g.Key, g => g.ToList(), StringComparer.Ordinal);
            var unallocatedPayments = Model.PaymentLines
                .Where(p => string.IsNullOrWhiteSpace(p.ContractNumber))
                .ToList();
        }
        <div class="ak-table-wrap">
            <table class="ak-table ak-detail-table">
                <thead>
                    <tr>
                        <th class="ak-col-grow">قرارداد</th>
                        <th>جنس</th>
                        <th class="ak-col-num">مقدار MT</th>
                        <th class="ak-col-num">بارگیری‌شده MT</th>
                        <th class="ak-col-num">قابل پرداخت USD</th>
                        <th class="ak-col-num">پرداخت‌شده USD</th>
                        <th class="ak-col-num">مانده USD</th>
                        <th>وضعیت</th>
                        <th class="ak-col-actions"></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var c in Model.Contracts)
                {
                    var cps = payByContract.TryGetValue(c.ContractNumber, out var _cl) ? _cl : new();
                    var balClass = c.LoadedValueBalanceUsd > 0 ? "ak-num" : c.LoadedValueBalanceUsd < 0 ? "ak-num" : "";
                    <tr>
                        <td class="ak-col-grow">
                            <a class="ak-name" asp-controller="ContractJourney" asp-action="Details" asp-route-contractId="@c.ContractId">@c.ContractNumber</a>
                        </td>
                        <td>@c.Product</td>
                        <td class="ak-col-num ak-num">@NumberDisplay.Quantity(c.QuantityMt, "MT")</td>
                        <td class="ak-col-num ak-num">@NumberDisplay.Quantity(c.LoadedQuantityMt, "MT")</td>
                        <td class="ak-col-num ak-num">@NumberDisplay.Money(c.LoadedValueUsd, "USD")</td>
                        <td class="ak-col-num ak-num">@NumberDisplay.Money(c.PaidUsd, "USD")</td>
                        <td class="ak-col-num ak-num @balClass">@NumberDisplay.Money(c.LoadedValueBalanceUsd, "USD")</td>
                        <td><span class="ak-status">@c.StatusName</span></td>
                        <td class="ak-col-actions">
                            <div class="dropdown ak-row-menu">
                                <button type="button" class="ak-row-menu-btn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="عملیات">
                                    <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" asp-controller="ContractJourney" asp-action="Details" asp-route-contractId="@c.ContractId"><i class="bi bi-diagram-3"></i> جریان قرارداد</a></li>
                                    <li><a class="dropdown-item" href="@newPaymentUrl"><i class="bi bi-cash-coin"></i> ثبت پرداخت</a></li>
                                </ul>
                            </div>
                        </td>
                    </tr>
                    @if (cps.Any())
                    {
                        foreach (var p in cps)
                        {
                            <tr class="ak-subrow">
                                <td class="ak-col-grow">↳ پرداخت @(p.Method)</td>
                                <td>@p.Date.ToDisplayDate()</td>
                                <td class="ak-col-num ak-num" colspan="2">@NumberDisplay.Money(p.Amount, p.Currency)</td>
                                <td class="ak-col-num ak-num" colspan="2">@NumberDisplay.Money(p.AmountUsd, "USD")</td>
                                <td colspan="2">
                                    @if (p.IsLedgerOnlyViaSarraf)
                                    {
                                        <span>@p.Reference</span>
                                    }
                                    else if (p.IsSarraf)
                                    {
                                        <a asp-controller="SarrafSettlements" asp-action="Details" asp-route-id="@p.SarrafSettlementId">@p.Reference</a>
                                    }
                                    else
                                    {
                                        <a asp-controller="Payments" asp-action="Details" asp-route-id="@p.PaymentId">@p.Reference</a>
                                    }
                                </td>
                                <td class="ak-col-actions"></td>
                            </tr>
                        }
                    }
                }
                @if (!Model.Contracts.Any())
                {
                    <tr><td colspan="9"><div class="ak-empty ak-detail-empty-state"><i class="bi bi-file-earmark-text"></i> برای این تأمین‌کننده هنوز قرارداد خرید ثبت نشده است.</div></td></tr>
                }
                </tbody>
            </table>
        </div>

        @if (unallocatedPayments.Any())
        {
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("پیش‌پرداخت آزاد / بدون قرارداد", $"جمع {NumberDisplay.Money(Model.UnallocatedPaymentTotalUsd, "USD")}"))" />
            <div class="ak-table-wrap">
                <table class="ak-table ak-detail-table">
                    <thead>
                        <tr>
                            <th>تاریخ</th>
                            <th class="ak-col-grow">روش</th>
                            <th class="ak-col-num">مبلغ سند</th>
                            <th class="ak-col-num">معادل USD</th>
                            <th>رسید / حواله</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var p in unallocatedPayments)
                    {
                        <tr>
                            <td>@p.Date.ToDisplayDate()</td>
                            <td class="ak-col-grow">@p.Method</td>
                            <td class="ak-col-num ak-num">@NumberDisplay.Money(p.Amount, p.Currency)</td>
                            <td class="ak-col-num ak-num">@NumberDisplay.Money(p.AmountUsd, "USD")</td>
                            <td>
                                @if (p.IsSarraf)
                                {
                                    <a asp-controller="SarrafSettlements" asp-action="Details" asp-route-id="@p.SarrafSettlementId">@p.Reference</a>
                                }
                                else
                                {
                                    <a asp-controller="Payments" asp-action="Details" asp-route-id="@p.PaymentId">@p.Reference</a>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }

        @if (Model.HasAdvances)
        {
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("پیش‌پرداخت تفصیلی", (string?)null))" />
            <dl class="ak-list">
                <div class="ak-list-row"><dt>مجموع پیش‌پرداخت</dt><dd class="ak-num">@Model.AdvanceTotalUsd.ToString("N2") USD</dd></div>
                <div class="ak-list-row"><dt>مصرف‌شده برای قراردادها</dt><dd class="ak-num">@Model.AdvanceAllocatedUsd.ToString("N2") USD</dd></div>
                <div class="ak-list-row"><dt>مانده آزاد</dt><dd class="ak-num">@Model.AdvanceFreeUsd.ToString("N2") USD</dd></div>
            </dl>
            @if (Model.AdvanceAllocations.Any())
            {
                <div class="ak-table-wrap">
                    <table class="ak-table ak-detail-table">
                        <thead>
                            <tr>
                                <th>تاریخ</th>
                                <th class="ak-col-grow">پرداخت</th>
                                <th>قرارداد</th>
                                <th class="ak-col-num">مبلغ مصرف‌شده USD</th>
                                <th>وضعیت</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var a in Model.AdvanceAllocations)
                        {
                            <tr>
                                <td>@a.AllocationDate.ToDisplayDate()</td>
                                <td class="ak-col-grow"><a asp-controller="Payments" asp-action="Details" asp-route-id="@a.PaymentTransactionId">@a.PaymentReference</a></td>
                                <td><a asp-controller="ContractJourney" asp-action="Details" asp-route-contractId="@a.ContractId" asp-route-returnUrl="@supplierReturnUrl">@a.ContractNumber</a></td>
                                <td class="ak-col-num ak-num">@a.AllocatedBookAmountUsd.ToString("N2")</td>
                                <td><span class="ak-status @(a.IsActive ?"is-active" : "is-inactive")">@a.StatusName</span></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        }

        @if (Model.SarrafSettlements.Any())
        {
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("تسویه‌های صراف", (string?)null))" />
            <div class="ak-table-wrap">
                <table class="ak-table ak-detail-table">
                    <thead>
                        <tr>
                            <th>تاریخ</th>
                            <th class="ak-col-grow">صراف</th>
                            <th>قرارداد</th>
                            <th>مرجع</th>
                            <th class="ak-col-num">کاهش بدهی USD</th>
                            <th class="ak-col-num">اختلاف USD</th>
                            <th>وضعیت</th>
                            <th class="ak-col-actions">سند</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var row in Model.SarrafSettlements)
                    {
                        <tr>
                            <td>@row.SettlementDate.ToDisplayDate()</td>
                            <td class="ak-col-grow">@row.SarrafName</td>
                            <td>@(row.ContractNumber ?? "-")</td>
                            <td>@(row.ReferenceNumber ?? $"#{row.Id}")</td>
                            <td class="ak-col-num ak-num">@row.SupplierReductionAmountUsd.ToString("N2")</td>
                            <td class="ak-col-num ak-num @(row.DifferenceAmountUsd >= 0 ?"ak-num" : "ak-num")">@row.DifferenceAmountUsd.ToString("N2")</td>
                            <td><span class="ak-status @(row.Status == SarrafSettlementStatus.Posted ?"is-active" : row.Status == SarrafSettlementStatus.Cancelled ? "is-inactive" : "")">@SarrafSettlementLabels.ToPersian(row.Status)</span></td>
                            <td class="ak-col-actions"><a asp-controller="SarrafSettlements" asp-action="Details" asp-route-id="@row.Id">مشاهده</a></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </section>

    @* ===== تب ۳: صورت‌حساب ===== *@
    <section id="supplier-statement" class="ak-form-section ak-detail-section" hidden="@(!showStatement)">
        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("صورت‌حساب رسمی تأمین‌کننده", "مانده، نرخ تاریخی و اطلاعات نفتی در موتور مشترک محاسبه می‌شود."))" />
        <div class="ak-empty ak-detail-empty-state">
            <i class="bi bi-file-earmark-text" aria-hidden="true"></i>
            <p>جدول تکراری و تغییر علامت نمایشی حذف شد؛ سند رسمی تنها مرجع گردش حساب است.</p>
            <a asp-controller="PartyStatements" asp-action="Supplier" asp-route-id="@Model.SupplierId" class="btn btn-primary">مشاهده صورت‌حساب رسمی</a>
        </div>
    </section>
</div>
