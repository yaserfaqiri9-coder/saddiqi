@model PTGOilSystem.Web.Models.Dispatch.DispatchDirectFromReceiptCreateViewModel
@{
    ViewData["Title"] = "ارسال با موتر از رسید";
    ViewData["HideSectionTabs"] = true;
    var hasLocalReturnUrl = !string.IsNullOrWhiteSpace(Model.ReturnUrl) && Url.IsLocalUrl(Model.ReturnUrl);
    var backUrl = hasLocalReturnUrl
        ? Model.ReturnUrl
        : Url.Action("Details", "LoadingReceipts", new { id = Model.LoadingReceiptId });
}

<div class="ak-form-page">
    <partial name="Components/Ak/_AkPageHeader"
                 model='((ViewData["Title"]?.ToString() ?? "Dispatch", false, (string?)null, (string?)null, (string?)null, (string?)null, UiText.T(Context, "بازگشت", "Back"), "bi-arrow-right", backUrl))' />

    <form asp-action="CreateDirectFromReceipt" method="post" class="ak-form">



        <div class="ak-section-body">
            @Html.AntiForgeryToken()
            <input asp-for="LoadingReceiptAllocationId" type="hidden" />
            <input asp-for="ReturnUrl" type="hidden" />
            <div asp-validation-summary="All" class="ak-form-alert text-danger"></div>

            <div class="summary-strip ak-summary">
                <div class="summary-tile"><div class="summary-tile-label">Allocation</div><div class="summary-tile-value">#@Model.LoadingReceiptAllocationId</div></div>
                <div class="summary-tile"><div class="summary-tile-label">Allocation Quantity</div><div class="summary-tile-value">@NumberDisplay.Quantity(Model.AllocationQuantityMt) MT</div></div>
                <div class="summary-tile"><div class="summary-tile-label">Already Dispatched</div><div class="summary-tile-value">@NumberDisplay.Quantity(Model.TotalDirectDispatchedQuantityMt) MT</div></div>
                <div class="summary-tile"><div class="summary-tile-label">Remaining</div><div class="summary-tile-value">@NumberDisplay.Quantity(Model.RemainingQuantityMt) MT</div></div>
            </div>

            <div class="ak-note" role="status">
                این مسیر فقط ارسال با موتر از همان رسید را ثبت می‌کند. فروش، Ledger، انتقال، StockService یا InventoryMovement جدید ساخته نمی‌شود.
            </div>

            <div class="ak-form-grid g-3 mb-4">
                <div class="ak-field"><strong>Contract</strong><div>@Model.ContractNumber</div></div>
                <div class="ak-field"><strong>Product</strong><div>@Model.ProductName</div></div>
                <div class="ak-field"><strong>Source Terminal</strong><div>@(string.IsNullOrWhiteSpace(Model.SourceTerminalName) ? "-" : Model.SourceTerminalName)</div></div>
                <div class="ak-field"><strong>Allocation Status</strong><div>@Model.AllocationStatusName</div></div>
                <div class="ak-field"><strong>Destination Trace</strong><div>@(Model.DestinationSummary ?? "-")</div></div>
            </div>

            <div class="ak-form-grid g-3">
                <div class="ak-field">
                    <label asp-for="TruckId" class="ak-label"></label>
                    <select asp-for="TruckId" asp-items="ViewBag.Trucks" class="ak-input">
                        <option value="">Select truck</option>
                    </select>
                    <input asp-for="TruckPlateNumberInput" class="ak-input mt-2" placeholder="یا نمبر پلیت جدید را تایپ کنید" />
                    <span asp-validation-for="TruckId" class="field-validation-error"></span>
                    <span asp-validation-for="TruckPlateNumberInput" class="field-validation-error"></span>
                </div>
                <div class="ak-field">
                    <label asp-for="DriverId" class="ak-label"></label>
                    <select asp-for="DriverId" asp-items="ViewBag.Drivers" class="ak-input">
                        <option value="">No driver</option>
                    </select>
                    <input asp-for="DriverNameInput" class="ak-input mt-2" placeholder="یا نام راننده جدید را تایپ کنید" />
                    <span asp-validation-for="DriverNameInput" class="field-validation-error"></span>
                </div>
                <div class="ak-field">
                    <label asp-for="DestinationLocationId" class="ak-label"></label>
                    <select asp-for="DestinationLocationId" asp-items="ViewBag.Destinations" class="ak-input">
                        <option value="">No destination</option>
                    </select>
                </div>
                <div class="ak-field">
                    <label asp-for="DispatchDate" class="ak-label"></label>
                    <input asp-for="DispatchDate" type="date" class="ak-input" />
                    <span asp-validation-for="DispatchDate" class="field-validation-error"></span>
                </div>
                <div class="ak-field">
                    <label asp-for="LoadedQuantityMt" class="ak-label"></label>
                    <input asp-for="LoadedQuantityMt" class="ak-input" />
                    <span asp-validation-for="LoadedQuantityMt" class="field-validation-error"></span>
                </div>
                <div class="ak-field">
                    <label asp-for="TicketSerialNumber" class="ak-label"></label>
                    <input asp-for="TicketSerialNumber" class="ak-input" />
                </div>
                <div class="ak-field">
                    <label asp-for="DischargedQuantityMt" class="ak-label"></label>
                    <input asp-for="DischargedQuantityMt" class="ak-input" />
                </div>
                <div class="ak-field">
                    <label asp-for="ShortageMt" class="ak-label"></label>
                    <input asp-for="ShortageMt" class="ak-input" />
                </div>
                <div class="ak-field">
                    <label asp-for="AllowanceMt" class="ak-label"></label>
                    <input asp-for="AllowanceMt" class="ak-input" />
                </div>
                <div class="ak-field">
                    <label asp-for="FreightCostUsd" class="ak-label"></label>
                    <input asp-for="FreightCostUsd" class="ak-input" />
                </div>
                <div class="ak-field">
                    <label asp-for="ShortageRateUsd" class="ak-label"></label>
                    <input asp-for="ShortageRateUsd" class="ak-input" />
                </div>
                <div class="ak-field">
                    <label asp-for="ToleranceMt" class="ak-label"></label>
                    <input asp-for="ToleranceMt" class="ak-input" />
                </div>
                <div class="ak-field">
                    <label asp-for="ChargeableShortageMt" class="ak-label"></label>
                    <input asp-for="ChargeableShortageMt" class="ak-input" />
                </div>
                <div class="ak-field">
                    <label asp-for="ServiceProviderId" class="ak-label">@UiText.T(Context, "شرکت خدماتی بیرونی", "External Service Provider")</label>
                    <select asp-for="ServiceProviderId" asp-items="ViewBag.ServiceProviders" class="ak-input">
                        <option value="">@UiText.T(Context, "بدون شرکت خدماتی", "No service provider")</option>
                    </select>
                    <span asp-validation-for="ServiceProviderId" class="field-validation-error"></span>
                </div>
                <div class="ak-field">
                    <label asp-for="OperationalAssetId" class="ak-label">@UiText.T(Context, "دارایی عملیاتی شرکت", "Operational Asset")</label>
                    <select asp-for="OperationalAssetId" asp-items="ViewBag.OperationalAssets" class="ak-input">
                        <option value="">@UiText.T(Context, "بدون دارایی عملیاتی", "No operational asset")</option>
                    </select>
                    <span asp-validation-for="OperationalAssetId" class="field-validation-error"></span>
                </div>
                <div class="ak-field">
                    <label asp-for="Notes" class="ak-label"></label>
                    <textarea asp-for="Notes" rows="3" class="ak-input"></textarea>
                </div>
            </div>
        </div>
        <div class="ak-summary ak-note mx-3 mb-2">
            <i class="bi bi-clipboard-check"></i>
            <div>
                <strong>@UiText.T(Context, "قبل از ثبت بررسی کنید:", "Before saving, check:")</strong>
                @UiText.T(Context, "این فورم فقط ارسال با موتر از رسید می‌سازد؛ موجودی، فروش، دفتر کل و انتقال جدید ساخته نمی‌شود.", "This form only creates a truck send from the receipt; no stock, sale, ledger or transfer is created.")
                <div class="text-muted small mt-1">@UiText.T(Context, "قدم بعدی: بعد از ثبت به رسید یا مرکز عملیات برگردید و باقی‌مانده تخصیص را بررسی کنید.", "Next step: return to the receipt or operation hub and review the remaining allocation.")</div>
            </div>
        </div>

        <div class="ak-footer-actions">
            @if (hasLocalReturnUrl)
            {
                <a href="@Model.ReturnUrl" class="btn btn-light ak-secondary-action">@UiText.T(Context,"لغو","Cancel")</a>
            }
            <button type="submit" class="btn btn-primary ak-primary-action">ثبت ارسال با موتر</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
