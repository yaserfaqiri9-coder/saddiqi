@model IReadOnlyList<SarrafSettlementListItemViewModel>
@{
    ViewData["Title"] = "تسویه‌های صراف";
}

<div class="ak-list-page">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@(("تسویه‌های صراف", false,
                       "ثبت تسویه", "bi-plus-lg", Url.Action("Create"), (string?)null,
                       "صراف‌ها", "bi-arrow-right", Url.Action("Index", "Sarrafs")))" />

    <partial name="~/Views/Shared/_AkSearchFilter.cshtml"
             model="@AkSearchFilterModel.SearchOnly("search", ViewData["Search"] as string, "جستجو یا فیلتر نتایج...")" />

    <div class="ak-list">
        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead>
                    <tr>
                        <th>تاریخ</th>
                        <th class="ak-col-grow">مرجع</th>
                        <th>صراف</th>
                        <th>تأمین‌کننده</th>
                        <th>قرارداد</th>
                        <th class="ak-col-num">درخواست USD</th>
                        <th class="ak-col-num">قبول‌شده USD</th>
                        <th class="ak-col-num">طلب صراف USD</th>
                        <th class="ak-col-num">اختلاف USD</th>
                        <th>رفتار</th>
                        <th>وضعیت</th>
                        <th class="ak-col-actions">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr data-href="@Url.Action("Details", new { id = item.Id })">
                        <td>@item.SettlementDate.ToDisplayDate()</td>
                        <td class="ak-col-grow"><a class="ak-name" asp-action="Details" asp-route-id="@item.Id">@(item.ReferenceNumber ?? $"#{item.Id}")</a></td>
                        <td>@item.SarrafName</td>
                        <td>@(item.SupplierName ?? "-")</td>
                        <td>@(item.ContractNumber ?? "-")</td>
                        <td class="ak-col-num ak-num">@item.RequestedAmountUsd.ToString("N2")</td>
                        <td class="ak-col-num ak-num">@item.SupplierAcceptedAmountUsd.ToString("N2")</td>
                        <td class="ak-col-num ak-num">@item.SarrafChargedAmountUsd.ToString("N2")</td>
                        <td class="ak-col-num ak-num @(item.DifferenceAmountUsd >= 0 ?"ak-num" : "ak-num")">@item.DifferenceAmountUsd.ToString("N2")</td>
                        <td>@item.DifferenceTreatmentName</td>
                        <td><span class="ak-status @(item.Status == SarrafSettlementStatus.Posted ?"is-active" : item.Status == SarrafSettlementStatus.Cancelled ? "is-inactive" : "")">@item.StatusName</span></td>
                        <td class="ak-col-actions">
                            <div class="dropdown ak-row-menu">
                                <button type="button" class="ak-row-menu-btn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="عملیات">
                                    <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a asp-action="Details" asp-route-id="@item.Id" class="dropdown-item"><i class="bi bi-eye"></i> مشاهده</a></li>
                                    @if (item.LedgerEntryId.HasValue)
                                    {
                                        <li><a asp-controller="Ledger" asp-action="Details" asp-route-id="@item.LedgerEntryId.Value" class="dropdown-item"><i class="bi bi-journal-text"></i> دفتر کل</a></li>
                                    }
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="12"><div class="ak-empty"><i class="bi bi-currency-exchange"></i> هنوز سند تسویه صراف ثبت نشده است.</div></td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            document.querySelectorAll('.ak-table tbody tr[data-href]').forEach(function (row) {
                row.style.cursor = 'pointer';
                row.addEventListener('click', function (e) {
                    if (e.target.closest('a, button, input, label, select, form')) return;
                    window.location.href = row.getAttribute('data-href');
                });
            });
        })();
    </script>
}
