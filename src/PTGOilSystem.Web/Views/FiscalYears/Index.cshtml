@using PTGOilSystem.Web.Models.Accounting
@model FiscalYearIndexViewModel
@{
    ViewData["Title"] = "سال مالی و بستن سال";
    var year = Model.CurrentYear;
    ViewData["FiscalCloseStep"] = 1;
    ViewData["FiscalCloseCompanyId"] = Model.SelectedCompanyId;
    ViewData["FiscalCloseYearId"] = year?.FiscalYearId;
}

<div class="ak-list-page finance-workspace-page">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@(("سال مالی و بستن سال", false,
                       (string?)null, (string?)null, (string?)null, (string?)null,
                       (string?)null, (string?)null, (string?)null))" />

    <partial name="~/Views/Shared/_FiscalCloseFlow.cshtml" />

    <section class="finance-fiscal-summary" aria-labelledby="fiscal-current-title">
        <header class="finance-section-header">
            <div>
                <h2 id="fiscal-current-title">سال مالی جاری</h2>
                <p>شرکت، بازه، دوره جاری و وضعیت بستن را از یک‌جا ببینید.</p>
            </div>
            <form method="get" asp-action="Index" class="finance-inline-filter">
                <label for="companyId">شرکت</label>
                <select class="form-select" id="companyId" name="companyId" onchange="this.form.submit()">
                    @foreach (var company in Model.Companies)
                    {
                        <option value="@company.CompanyId" selected="@company.IsSelected">@company.Name</option>
                    }
                </select>
            </form>
        </header>

        @if (year is null)
        {
            <div class="ak-empty"><i class="bi bi-calendar-x" aria-hidden="true"></i>برای این شرکت سال مالی ثبت نشده است.</div>
        }
        else
        {
            <dl class="finance-fiscal-facts">
                <div><dt>سال مالی</dt><dd>@year.Name</dd></div>
                <div><dt>بازه</dt><dd>@DateDisplay.Date(year.StartDate) — @DateDisplay.Date(year.EndDate)</dd></div>
                <div><dt>وضعیت</dt><dd><span class="ak-status @FiscalStatusDisplay.YearCss(year.Status)">@FiscalStatusDisplay.YearLabel(year.Status)</span></dd></div>
                <div><dt>دوره جاری</dt><dd>@(year.CurrentPeriod?.Name ?? "-")</dd></div>
                <div><dt>تعداد دوره‌ها</dt><dd class="ak-num">@year.PeriodCount</dd></div>
                <div><dt>آخرین بستن</dt><dd>@(Model.LastCloseRun is null ? "اجرا نشده" : FiscalStatusDisplay.CloseRunLabel(Model.LastCloseRun.Status))</dd></div>
            </dl>

            <div class="finance-next-action" id="accounting-readiness">
                @if (Model.ReadinessFindings.Count > 0)
                {
                    <div>
                        <strong>اقدام بعدی: رفع موارد آمادگی</strong>
                        <p>@Model.ReadinessFindings.Count مورد باید پیش از بستن بررسی شود.</p>
                    </div>
                    <a class="btn btn-primary" asp-action="Details" asp-route-id="@year.FiscalYearId" asp-fragment="accounting-readiness">مشاهده موارد</a>
                }
                else
                {
                    <div>
                        <strong>اقدام بعدی: اجرای چک‌لیست بستن</strong>
                        <p>در بررسی اولیه مانع آمادگی ثبت نشده است؛ چک‌لیست رسمی را اجرا کنید.</p>
                    </div>
                    <a class="btn btn-primary" asp-controller="ClosingChecklist" asp-action="Index" asp-route-companyId="@year.CompanyId" asp-route-fiscalYearId="@year.FiscalYearId">بررسی چک‌لیست</a>
                }
            </div>

            <details class="finance-fiscal-details" id="fiscal-periods">
                <summary>دوره‌های مالی و سال‌های قبلی</summary>
                <div class="ak-table-wrap">
                    <table class="ak-table" aria-label="دوره‌های سال مالی">
                        <thead><tr><th>شماره</th><th class="ak-col-grow">دوره</th><th>شروع</th><th>پایان</th><th>وضعیت</th></tr></thead>
                        <tbody>
                            @foreach (var period in year.Periods)
                            {
                                <tr>
                                    <td>@period.PeriodNumber</td><td class="ak-col-grow">@period.Name</td>
                                    <td>@DateDisplay.Date(period.StartDate)</td><td>@DateDisplay.Date(period.EndDate)</td>
                                    <td><span class="ak-status @FiscalStatusDisplay.PeriodCss(period.Status)">@FiscalStatusDisplay.PeriodLabel(period.Status)</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (Model.OtherYears.Count > 0)
                {
                    <nav class="finance-year-links" aria-label="سال‌های مالی قبلی">
                        @foreach (var other in Model.OtherYears)
                        {
                            <a asp-action="Details" asp-route-id="@other.FiscalYearId">@other.Name <span>@FiscalStatusDisplay.YearLabel(other.Status)</span></a>
                        }
                    </nav>
                }
            </details>
        }
    </section>

    @if (year is not null)
    {
        <section class="finance-fiscal-actions" aria-label="عملیات مجاز سال مالی">
            <a class="btn btn-light" asp-action="Details" asp-route-id="@year.FiscalYearId">جزئیات دوره‌ها و اسناد</a>
            @if (Model.CanManage && Model.NextYear.IsAllowed && Model.SelectedCompanyId is int companyId)
            {
                <form asp-action="CreateNextYear" method="post"
                      data-ptg-confirm="true" data-ptg-confirm-title="ایجاد سال مالی بعدی"
                      data-ptg-confirm-message="سال مالی بعدی به‌صورت پیش‌نویس ساخته شود؟">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="companyId" value="@companyId" />
                    <button type="submit" class="btn btn-primary">ایجاد سال مالی بعدی (@Model.NextYear.ProposedName)</button>
                </form>
            }
            else if (!string.IsNullOrWhiteSpace(Model.NextYear.BlockedReason))
            {
                <button type="button" class="btn btn-light" disabled title="@Model.NextYear.BlockedReason">ایجاد سال مالی بعدی</button>
                <span class="ak-hint">@Model.NextYear.BlockedReason</span>
            }
        </section>
    }
</div>
