@model PTGOilSystem.Web.Models.Payments.TreasuryHubViewModel
@{
    ViewData["Title"] = "راهنمای دریافت، پرداخت و تسویه";
}

<div class="ak-form-page finance-workspace-page" dir="rtl">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@(("راهنمای دریافت، پرداخت و تسویه", false,
                       "ثبت دریافت/پرداخت", "bi-plus-lg", Url.Action("Create"), (string?)null,
                       "روزنامه و اسناد", "bi-arrow-right", Url.Action("Index")))" />

    <p class="finance-page-lead">کار موردنظر را انتخاب کنید؛ ثبت‌ها از مسیرهای رسمی فعلی انجام می‌شوند و این صفحه خودش سندی نمی‌سازد.</p>

    <dl class="finance-status-strip" aria-label="وضعیت روزنامه">
        <div><dt>دریافتی امروز</dt><dd class="ak-num">@Model.TodayReceiptUsd.ToString("N2") USD</dd></div>
        <div><dt>پرداختی امروز</dt><dd class="ak-num">@Model.TodayPaymentUsd.ToString("N2") USD</dd></div>
        <div><dt>پول معلق</dt><dd class="ak-num">@Model.SuspenseCount.ToString("N0") مورد</dd></div>
        <div><dt>حواله ثبت‌شده</dt><dd class="ak-num">@Model.PostedHawalaCount.ToString("N0") مورد</dd></div>
        <div><dt>نیازمند بررسی</dt><dd class="ak-num">@Model.NeedsReviewCount.ToString("N0") مورد</dd></div>
    </dl>

    <div class="finance-action-groups">
        <section class="finance-action-group">
            <header><h2>ثبت پول</h2><p>دریافت یا پرداخت روزمره</p></header>
            <a asp-action="Create" asp-route-kind="customer-receipt"><strong>دریافت از مشتری</strong><small>کاهش طلب مشتری</small></a>
            <a asp-action="Create" asp-route-kind="supplier-payment"><strong>پرداخت به تأمین‌کننده</strong><small>کاهش بدهی تأمین‌کننده</small></a>
            <a asp-action="Create" asp-route-kind="supplier-advance"><strong>پیشکی تأمین‌کننده</strong><small>ثبت پیش‌پرداخت رسمی</small></a>
            <a asp-action="Create" asp-route-method="sarraf"><strong>پرداخت از طریق صراف</strong><small>همان فرم رسمی با روش صراف</small></a>
        </section>

        <section class="finance-action-group">
            <header><h2>تسویه و انتقال</h2><p>عملیات میان چند طرف یا قرارداد</p></header>
            <a asp-controller="ThreeWaySettlement" asp-action="Index"><strong>تسویه سه‌طرفه / حواله</strong><small>مشتری، صراف و تأمین‌کننده</small></a>
            <a asp-controller="ContractBalanceTransfers" asp-action="Index"><strong>انتقال مانده قرارداد</strong><small>انتقال کنترل‌شده بین قراردادها</small></a>
            <a asp-controller="Sarrafs" asp-action="Index"><strong>صراف‌ها</strong><small>مانده و حواله‌های مرتبط</small></a>
        </section>

        <section class="finance-action-group">
            <header><h2>بررسی مانده‌ها</h2><p>پیگیری موارد نیازمند توجه</p></header>
            <a asp-controller="Reconciliation" asp-action="SuspenseMoney"><strong>پول‌های معلق</strong><small>سندهایی که باید به طرف حساب وصل شوند</small></a>
            <a asp-controller="Customers" asp-action="Index"><strong>صورت‌حساب مشتریان</strong><small>مانده و گردش هر مشتری</small></a>
            <a asp-controller="Suppliers" asp-action="Index"><strong>صورت‌حساب تأمین‌کنندگان</strong><small>مانده و گردش هر تأمین‌کننده</small></a>
        </section>
    </div>
</div>
