@using PTGOilSystem.Web.Models.StatCards
@model PTGOilSystem.Web.Models.DashboardViewModel
@{
    ViewData["Title"] = UiText.T(Context, "داشبورد", "Dashboard");
    ViewData["HideSectionTabs"] = true;

    var dbWarning = ViewData["DbWarning"] as string;

    string Dir(decimal v) => v >= 0 ? "up" : "down";
}

<div class="ak-form-page ref-dashboard">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((ViewData["Title"]?.ToString() ?? "داشبورد", false,
                       (string?)null, (string?)null, (string?)null, (string?)null,
                       (string?)null, (string?)null, (string?)null))" />

    @if (!string.IsNullOrWhiteSpace(dbWarning))
    {
        <div class="ak-note">
            <i class="bi bi-exclamation-triangle-fill text-warning"></i>
            <div>
                <strong>هشدار اتصال پایگاه‌داده</strong>
                <div class="surface-callout-muted">رشته اتصال <code>ConnectionStrings__DefaultConnection</code> را روی PostgreSQL تنظیم کنید و migrationها را اجرا نمایید.</div>
            </div>
        </div>
    }

    @* 1) Shipment operations *@
    <section class="ak-stat-section">
        <h2 class="ak-stat-section__title"><i class="bi bi-boxes"></i>@UiText.T(Context, "عملیات محموله", "Shipment operations")</h2>
        <div class="ak-stat-grid">
            <vc:stat-card title="کل محموله‌ها" value="@StatCardFormatter.Count(Model.ShipmentCount)" unit="محموله" avatar="shipments"></vc:stat-card>
            <vc:stat-card title="محموله‌های در حال انتقال" value="@StatCardFormatter.Count(Model.ShipmentsInTransitCount)" unit="محموله" avatar="transported"></vc:stat-card>
            <vc:stat-card title="بارگیری‌ها" value="@StatCardFormatter.Count(Model.LoadingCount)" unit="بارگیری" avatar="loading"></vc:stat-card>
        </div>
    </section>

    @* 2) Purchase & supply *@
    <section class="ak-stat-section">
        <h2 class="ak-stat-section__title"><i class="bi bi-cart3"></i>@UiText.T(Context, "تأمین و خرید", "Purchase & supply")</h2>
        <div class="ak-stat-grid">
            <vc:stat-card title="ارزش ذخیره خرید" value="@StatCardFormatter.Number(Model.PurchaseReserveUsd, 0)" unit="دلار" avatar="purchase-value"></vc:stat-card>
            <vc:stat-card title="تأمین‌کنندگان دارای مانده" value="@StatCardFormatter.Count(Model.SupplierBalanceSummary.ItemCount)" unit="تأمین‌کننده" avatar="suppliers"></vc:stat-card>
            <vc:stat-card title="قراردادهای فعال" value="@StatCardFormatter.Count(Model.ActiveContractCount)" unit="قرارداد" avatar="purchase-contracts"></vc:stat-card>
        </div>
    </section>

    @* 3) Sales & revenue *@
    <section class="ak-stat-section">
        <h2 class="ak-stat-section__title"><i class="bi bi-graph-up-arrow"></i>@UiText.T(Context, "فروش و درآمد", "Sales & revenue")</h2>
        <div class="ak-stat-grid">
            <vc:stat-card title="ارزش کل فروش" value="@StatCardFormatter.Number(Model.TotalSalesUsd, 0)" unit="دلار" avatar="sales-value"
                          trend-value="@Model.TotalSalesWeekChangePercent" trend-direction="@Dir(Model.TotalSalesWeekChangePercent)"></vc:stat-card>
            <vc:stat-card title="مشتریان دارای مانده" value="@StatCardFormatter.Count(Model.CustomerBalanceSummary.ItemCount)" unit="مشتری" avatar="customers"></vc:stat-card>
            <vc:stat-card title="تعداد فروش‌ها" value="@StatCardFormatter.Count(Model.SalesCount)" unit="فروش" avatar="sold-quantity"></vc:stat-card>
        </div>
    </section>

    @* 4) Finance & accounting *@
    <section class="ak-stat-section">
        <h2 class="ak-stat-section__title"><i class="bi bi-bank2"></i>@UiText.T(Context, "مالی و حسابداری", "Finance & accounting")</h2>
        <div class="ak-stat-grid">
            <vc:stat-card title="مانده حساب مشتریان" value="@StatCardFormatter.Number(Model.CustomerBalanceSummary.BaseBalanceUsd, 0)" unit="دلار" avatar="receivables"></vc:stat-card>
            <vc:stat-card title="پرداختی‌های امروز" value="@StatCardFormatter.Number(Model.TodayPaymentsUsd, 0)" unit="دلار" avatar="payments"></vc:stat-card>
            <vc:stat-card title="نتیجه خالص فروش و مصارف" value="@StatCardFormatter.Number(Model.NetUsd, 0)" unit="دلار" avatar="profit-loss"></vc:stat-card>
        </div>
    </section>

    @* 5) Inventory & stock *@
    <section class="ak-stat-section">
        <h2 class="ak-stat-section__title"><i class="bi bi-archive"></i>@UiText.T(Context, "انبار و موجودی", "Inventory & stock")</h2>
        <div class="ak-stat-grid">
            <vc:stat-card title="موجودی کل پایانه‌ها" value="@StatCardFormatter.Number(Model.TerminalStockMt, 2)" unit="متریک تن" avatar="total-inventory"></vc:stat-card>
            <vc:stat-card title="مصارف کل" value="@StatCardFormatter.Number(Model.TotalExpensesUsd, 0)" unit="دلار" avatar="expenses"
                          trend-value="@Model.TotalExpensesWeekChangePercent" trend-direction="@Dir(Model.TotalExpensesWeekChangePercent)"></vc:stat-card>
            <vc:stat-card title="رویدادهای کسری و ضایعات" value="@StatCardFormatter.Count(Model.ShortageCount)" unit="مورد" avatar="losses"></vc:stat-card>
        </div>
    </section>
</div>
