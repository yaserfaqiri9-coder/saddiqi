@using System.Text.Json
@model PTGOilSystem.Web.Models.DashboardViewModel
@{
    ViewData["Title"] = UiText.T(Context,"داشبورد","Dashboard");
    ViewData["HideSectionTabs"] = true;
    ViewData["DashboardAssets"] = true;

    var dbWarning = ViewData["DbWarning"] as string;

    string Trend(decimal v) => (v >= 0 ? "+" : "-") + Math.Abs(v).ToString("0.#") + "%";
    string Short(decimal v) => Math.Abs(v) >= 1000 ? (v / 1000).ToString("0.##") + "k" : v.ToString("0");

    // ---- Row 1: four compact operational KPI cards ----
    var kpiCards = new[]
    {
        new { Art = "contract", Label = UiText.T(Context,"قراردادهای فعال","Active Contracts"),     Value = $"{Model.ActiveContractCount:N0}",       Meta = UiText.T(Context,"قرارداد فعال","Active"), Icon = "bi-dot" },
        new { Art = "shipment", Label = UiText.T(Context,"بارهای در جریان","Shipments In Transit"), Value = $"{Model.ShipmentsInTransitCount:N0}",   Meta = UiText.T(Context,"در حال انتقال","In transit"), Icon = "bi-dot" },
        new { Art = "stock",    Label = UiText.T(Context,"موجودی کل","Total Stock"),                Value = $"{Model.TerminalStockMt:N2}",          Meta = UiText.T(Context,"متریک تن","MT"), Icon = "bi-dot" },
        new { Art = "sales",    Label = UiText.T(Context,"فروش امروز","Today's Sales"),             Value = $"${Model.TodaySalesUsd:N0}",           Meta = UiText.T(Context,"ثبت امروز","Today"), Icon = "bi-dot" }
    };
    // ---- Rings: 3-way sales breakdown ----
    var ringSold     = Model.SalesCount;
    var ringPending  = Model.SalesWithoutPaymentCount;
    var ringShortage = Model.ShortageCount;
    var ringTotal    = ringSold + ringPending + ringShortage;
    var ringRows = new[]
    {
        new { Cls = "is-green", Label = UiText.T(Context,"فروش","Sold"),           Count = ringSold },
        new { Cls = "is-amber", Label = UiText.T(Context,"در انتظار پرداخت","Pending"), Count = ringPending },
        new { Cls = "is-red",   Label = UiText.T(Context,"کسری","Shortage"),        Count = ringShortage }
    };

    // ---- Area line: income vs expenses over the period ----
    var areaLabels  = Model.MarketLabels.Count > 0 ? Model.MarketLabels.ToArray()
        : Enumerable.Range(1, 10).Select(w => UiText.T(Context, $"هفته {w:00}", $"W{w:00}")).ToArray();
    var areaIncome  = Model.MarketSalesSeries.Count == areaLabels.Length ? Model.MarketSalesSeries.ToArray()
        : Enumerable.Repeat(0m, areaLabels.Length).ToArray();
    var areaExpense = Model.MarketExpenseSeries.Count == areaLabels.Length ? Model.MarketExpenseSeries.ToArray()
        : Enumerable.Repeat(0m, areaLabels.Length).ToArray();
    var incomeTotal  = areaIncome.Sum();
    var expenseTotal = areaExpense.Sum();

    // ---- Sales overview ----
    var profitUsd = Model.NetUsd;
    var marginPct = Model.TotalSalesUsd > 0 ? Math.Round(Model.NetUsd * 100m / Model.TotalSalesUsd, 1) : 0m;
    var marginBar = (int)Math.Clamp(marginPct, 0m, 100m);

    // ---- Current balance ----
    var currentBalance = Model.CustomerBalanceSummary.BaseBalanceUsd;
    var supplierPayable = Model.SupplierBalanceSummary.BaseBalanceUsd;

    var ringValuesJson  = JsonSerializer.Serialize(new[] { ringSold, ringPending, ringShortage });
    var areaIncomeJson  = JsonSerializer.Serialize(areaIncome);
    var areaExpenseJson = JsonSerializer.Serialize(areaExpense);
    var areaLabelsJson  = JsonSerializer.Serialize(areaLabels);

    // ---- Quick access bar: soft nav shortcuts + one primary create action ----
    var quickLinks = new[]
    {
        new { Controller = "Contracts",  Action = "Index",  Label = UiText.T(Context,"قراردادها","Contracts"),   Icon = "nav-contracts" },
        new { Controller = "Loading",    Action = "Index",  Label = UiText.T(Context,"عملیات","Operations"),      Icon = "nav-operations" },
        new { Controller = "Sales",      Action = "Index",  Label = UiText.T(Context,"فروش","Sales"),             Icon = "nav-sales" },
        new { Controller = "Payments",   Action = "Index",  Label = UiText.T(Context,"مالی","Finance"),           Icon = "nav-finance" },
        new { Controller = "Reports",    Action = "Index",  Label = UiText.T(Context,"گزارشات","Reports"),        Icon = "nav-reports" },
        new { Controller = "Suppliers",  Action = "Index",  Label = UiText.T(Context,"طرف حساب‌ها","Parties"),    Icon = "nav-parties" }
    };
}

<div class="ak-form-page ref-dashboard">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((ViewData["Title"]?.ToString() ?? "داشبورد", false,
                       (string?)null, (string?)null, (string?)null, (string?)null,
                       (string?)null, (string?)null, (string?)null))" />
    @if (!string.IsNullOrWhiteSpace(dbWarning))
    {
        <div class="ak-note">
            <i class="bi bi-exclamation-triangle-fill text-warning"></i>
            <div>
                <strong>هشدار اتصال پایگاه‌داده</strong>
                <div class="surface-callout-muted">رشته اتصال <code>ConnectionStrings__DefaultConnection</code> را روی PostgreSQL تنظیم کنید و migrationها را اجرا نمایید.</div>
            </div>
        </div>
    }

    <!-- Row 1 : KPI cards -->
    <section class="ref-kpi-row">
        @foreach (var item in kpiCards)
        {
            <article class="ref-kpi">
                <div class="ref-kpi-copy">
                    <span class="ref-kpi-label">@item.Label</span>
                    <strong class="ref-kpi-value"><bdi>@item.Value</bdi></strong>
                    <span class="ref-kpi-trend is-neutral">
                        <i class="bi @item.Icon" aria-hidden="true"></i>
                        <bdi>@item.Meta</bdi>
                    </span>
                </div>
                <span class="ref-kpi-art is-@item.Art" aria-hidden="true"></span>
            </article>
        }
    </section>

    <!-- Row 2 : rings + area line -->
    <section class="ref-mid-row">
        <article class="ref-card ref-rings-card">
            <h2 class="ref-card-title">@UiText.T(Context,"ترکیب فروش","Sales breakdown")</h2>
            <div class="ref-rings-wrap">
                <div id="ptg-rings"
                     data-values='@Html.Raw(ringValuesJson)'
                     data-colors='["#8BB475","#7779A2","#FB7185"]'></div>
                <div class="ref-rings-center">
                    <span class="cap">@UiText.T(Context,"مجموع","Total")</span>
                    <strong>@ringTotal.ToString("N0")</strong>
                </div>
            </div>
            <ul class="ref-rings-legend">
                @foreach (var row in ringRows)
                {
                    <li><span class="ref-dot @row.Cls"></span>@row.Label <strong>@row.Count.ToString("N0")</strong></li>
                }
            </ul>
        </article>

        <article class="ref-card ref-area-card">
            <header class="ref-card-head">
                <div>
                    <h2 class="ref-card-title">@UiText.T(Context,"روند درآمد و مصارف","Income vs expenses")</h2>
                    <p class="ref-area-sub">(@Trend(Model.TotalSalesWeekChangePercent)) @UiText.T(Context,"نسبت به دوره قبل","than last period")</p>
                </div>
            </header>
            <div class="ref-area-legend">
                <span><span class="ref-dot is-green"></span>@UiText.T(Context,"درآمد کل","Total income")</span>
                <strong>$@Short(incomeTotal)</strong>
                <span><span class="ref-dot is-amber"></span>@UiText.T(Context,"مصارف کل","Total expenses")</span>
                <strong>$@Short(expenseTotal)</strong>
            </div>
            <div class="ref-area-chart">
                <div id="ptg-area"
                     data-income='@Html.Raw(areaIncomeJson)'
                     data-expenses='@Html.Raw(areaExpenseJson)'
                     data-labels='@Html.Raw(areaLabelsJson)'></div>
            </div>
        </article>
    </section>

    <!-- Quick access bar -->
    <section class="ref-quick" aria-label="@UiText.T(Context,"دسترسی سریع","Quick access")">
        <div class="ref-quick-scroll">
            @foreach (var q in quickLinks)
            {
                <a class="ref-quick-card" asp-controller="@q.Controller" asp-action="@q.Action">
                    <span class="ref-quick-ic"><svg viewBox="0 0 24 24" aria-hidden="true"><use href="#@q.Icon"></use></svg></span>
                    <span class="ref-quick-label">@q.Label</span>
                </a>
            }
            <a class="ref-quick-card is-primary" asp-controller="Sales" asp-action="Create">
                <span class="ref-quick-ic"><i class="bi bi-plus-lg" aria-hidden="true"></i></span>
                <span class="ref-quick-label">@UiText.T(Context,"ثبت فروش","New sale")</span>
            </a>
        </div>
    </section>
</div>
