@model PTGOilSystem.Web.Models.Inventory.InventoryIndexViewModel
@using PTGOilSystem.Web.Models.Entities
@{
    ViewData["Title"] = UiText.T(Context,"موجودی","Inventory");
    var movements = Model.Items.ToList();
    var hasFilter = !string.IsNullOrWhiteSpace(Model.Query);
}

<div class="ak-form-page">

    <div class="ak-page-header">
        <div class="ak-page-heading">
<h1 class="ak-page-title">@UiText.T(Context,"حرکت‌های موجودی","Inventory Movements")</h1>
        </div>
    </div>

    <div class="ak-detail-toolbar">
        <div>
            <form method="get" class="ak-form-grid">
                <div class="ak-field">
                    <label class="ak-label">@UiText.T(Context,"جست‌وجو","Search")</label>
                    <input name="q" value="@Model.Query" class="ak-input"
                        placeholder="@UiText.T(Context,"محصول، ترمینال، قرارداد یا مرجع...","Product, terminal, contract or reference...")" />
                </div>
                <div class="ak-field ak-col-full">
                    <div class="ak-detail-toolbar-actions d-flex justify-content-between align-items-center flex-wrap gap-3">
                        <div class="d-flex align-items-center flex-wrap gap-2">
                            <button type="submit" class="btn btn-light">@UiText.T(Context,"جست‌وجو","Search")</button>
                            @if (hasFilter)
                            {
                                <a asp-action="Index" class="btn ak-secondary-action">@UiText.T(Context,"پاک‌کردن","Clear")</a>
                            }
                        </div>
                        <div class="d-flex align-items-center flex-wrap gap-2">
                            <a asp-action="Create" class="btn ak-primary-action">
                                <i class="bi bi-plus-lg me-1"></i> @UiText.T(Context,"ثبت موجودی","New Movement")
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="ak-table-wrap">
        <div class="ak-table-wrap">
            <table class="ak-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>@UiText.T(Context,"تاریخ","Date")</th>
                        <th>@UiText.T(Context,"نوع حرکت","Movement Type")</th>
                        <th>@UiText.T(Context,"جنس","Product")</th>
                        <th>@UiText.T(Context,"ترمینال","Terminal")</th>
                        <th>@UiText.T(Context,"قرارداد منبع","Source Contract")</th>
                        <th>@UiText.T(Context,"مخزن","Tank")</th>
                        <th class="text-end">@UiText.T(Context,"مقدار (MT)","Qty (MT)")</th>
                        <th>@UiText.T(Context,"مرجع","Reference")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in movements)
                    {
                        <tr>
                            <td>@item.MovementDate.ToDisplayDate()</td>
                            <td>
                                @switch (item.Direction)
                                {
                                    case MovementDirection.In:
                                        <span class="ak-status is-active">@UiText.T(Context,"ورود","In")</span>
                                        break;
                                    case MovementDirection.Out:
                                        <span class="ak-status is-inactive">@UiText.T(Context,"خروج","Out")</span>
                                        break;
                                    case MovementDirection.Transfer:
                                        <span class="ak-status is-pending">@UiText.T(Context,"انتقال","Transfer")</span>
                                        break;
                                    case MovementDirection.Adjustment:
                                        <span class="ak-status is-pending">@UiText.T(Context,"تعدیل","Adjustment")</span>
                                        break;
                                }
                            </td>
                            <td>@item.ProductName</td>
                            <td>@item.TerminalName</td>
                            <td>@(item.ContractNumber ?? "—")</td>
                            <td>@(item.StorageTankCode ?? "—")</td>
                            <td class="text-end fw-semibold">@NumberDisplay.Quantity(item.QuantityMt)</td>
                            <td>@(item.ReferenceDocument ?? "—")</td>
                        </tr>
                    }
                    @if (!movements.Any())
                    {
                        <tr>
                            <td colspan="8">
                                @await Html.PartialAsync("_EmptyState", (UiText.T(Context,"هنوز هیچ حرکت موجودی ثبت نشده است","No inventory movements recorded yet"), UiText.T(Context,"پس از ثبت movement اطلاعات این بخش کامل می‌شود.","After recording a movement, this section will be populated."), "bi-boxes"))
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @await Html.PartialAsync("_Pagination", (Model.CurrentPage, Model.PageCount))
</div>
