@model IEnumerable<Unit>
@{
    ViewData["Title"] = UiText.T(Context, "واحدها", "Units");
    var items = Model.ToList();
    var hasFilters = !string.IsNullOrWhiteSpace((string?)ViewData["unitType"]) || ViewData["isActive"] != null;
    var hasSearch = !string.IsNullOrWhiteSpace((string?)ViewData["q"]) || hasFilters;
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var activeCount = items.Count(item => item.IsActive);
    var baseUnitCount = items.Count(item => item.IsBaseUnit);
    var unitTypeCount = items.Select(item => item.UnitType)
        .Where(type => !string.IsNullOrWhiteSpace(type))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Count();
}

<div class="ak-list-page">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((UiText.T(Context, "واحدهای اندازه‌گیری", "Measurement units"), true,
                       UiText.T(Context, "واحد جدید", "New unit"), "bi-plus-lg",
                       (string?)Url.Action("Create", new { returnUrl }), (string?)null,
                       (string?)null, (string?)null, (string?)null))" />

    <section class="ak-stat-grid mb-3" aria-label="@UiText.T(Context, "آمار واحدها", "Unit statistics")">
        <vc:stat-card title="@UiText.T(Context, "تعداد واحدها", "Units")" value="@items.Count.ToString("N0")" unit="@UiText.T(Context, "واحد", "units")" avatar="purchase-quantity"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "واحدهای فعال", "Active units")" value="@activeCount.ToString("N0")" unit="@UiText.T(Context, "واحد", "units")" avatar="loading"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "واحدهای پایه", "Base units")" value="@baseUnitCount.ToString("N0")" unit="@UiText.T(Context, "واحد", "units")" avatar="total-inventory"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "انواع واحد", "Unit types")" value="@unitTypeCount.ToString("N0")" unit="@UiText.T(Context, "نوع", "types")" avatar="purchase-requests"></vc:stat-card>
    </section>

    @{
        var unitsIsActive = ViewData["isActive"] is bool unitAct ? (unitAct ? "true" : "false") : null;
        var unitTypeOptions = (ViewData["UnitTypes"] as List<string> ?? new List<string>())
            .Select(t => new AkFilterOption(t, t)).ToList();
        var unitsFilter = new AkSearchFilterModel("q", (string?)ViewData["q"],
            UiText.T(Context, "جستجو در کد، نام، نوع یا نماد...", "Search code, name, type, or symbol..."),
            new List<AkFilterDefinition>
            {
                new("unitType", UiText.T(Context, "نوع واحد", "Unit type"), "select", unitTypeOptions, (string?)ViewData["unitType"]),
                new("isActive", UiText.T(Context, "وضعیت", "Status"), "bool",
                    new List<AkFilterOption> { new("true", UiText.T(Context, "فعال", "Active")), new("false", UiText.T(Context, "غیرفعال", "Inactive")) },
                    unitsIsActive)
            });
    }
    <partial name="~/Views/Shared/_AkSearchFilter.cshtml" model="unitsFilter" />

    <div class="ak-list">
        <div class="ak-table-wrap">
            <table class="ak-table" aria-label="@UiText.T(Context, "لیست واحدها", "Unit list")">
                <thead>
                    <tr>
                        <th class="ak-col-check"><input type="checkbox" class="ak-check" aria-label="@UiText.T(Context, "انتخاب همه", "Select all")" /></th>
                        <th class="ak-col-grow">@UiText.T(Context, "نام", "Name")</th>
                        <th>@UiText.T(Context, "کد", "Code")</th>
                        <th>@UiText.T(Context, "نوع واحد", "Unit type")</th>
                        <th>@UiText.T(Context, "واحد پایه", "Base unit")</th>
                        <th class="ak-col-spacer"></th>
                        <th>@UiText.T(Context, "وضعیت", "Status")</th>
                        <th class="ak-col-actions"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in items)
                    {
                        <tr>
                            <td class="ak-col-check"><input type="checkbox" class="ak-check" aria-label="@UiText.T(Context, "انتخاب", "Select")" /></td>
                            <td class="ak-col-grow"><a asp-action="Details" asp-route-id="@item.Id" class="ak-name">@item.Name</a></td>
                            <td>@(string.IsNullOrWhiteSpace(item.Code) ? "—" : item.Code)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.UnitType) ? "—" : item.UnitType)</td>
                            <td>@(item.IsBaseUnit ? UiText.T(Context, "بلی", "Yes") : (string.IsNullOrWhiteSpace(item.BaseUnitCode) ? "—" : item.BaseUnitCode))</td>
                            <td class="ak-col-spacer"></td>
                            <td>
                                <span class="ak-status @(item.IsActive ?"is-active" : "is-inactive")">
                                    @(item.IsActive ? UiText.T(Context, "فعال", "Active") : UiText.T(Context, "غیرفعال", "Inactive"))
                                </span>
                            </td>
                            <td class="ak-col-actions">
                                <div class="dropdown ak-row-menu">
                                    <button type="button" class="ak-row-menu-btn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="@UiText.T(Context, "عملیات", "Actions")">
                                        <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a class="dropdown-item" asp-action="Details" asp-route-id="@item.Id"><i class="bi bi-eye" aria-hidden="true"></i>@UiText.T(Context, "مشاهده", "View")</a></li>
                                        <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil" aria-hidden="true"></i>@UiText.T(Context, "ویرایش", "Edit")</a></li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li>
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" data-ptg-confirm="true" data-ptg-confirm-title="@UiText.T(Context, "حذف واحد", "Delete Unit")" data-ptg-confirm-message="@UiText.T(Context, "این ریکورد حذف یا غیرفعال شود؟", "Delete or deactivate this record?")">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-item ak-danger"><i class="bi bi-trash" aria-hidden="true"></i>@UiText.T(Context, "حذف", "Delete")</button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!items.Any())
                    {
                        <tr>
                            <td colspan="8"><div class="ak-empty"><i class="bi bi-rulers" aria-hidden="true"></i>@UiText.T(Context, "واحدی ثبت نشده", "No unit registered")</div></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @{ ViewData["ShownCount"] = items.Count; }
        <div class="ak-pager">@await Html.PartialAsync("_PagedListFooter")</div>
    </div>
</div>
