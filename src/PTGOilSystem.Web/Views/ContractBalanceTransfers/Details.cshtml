@model PTGOilSystem.Web.Models.ContractBalanceTransfers.ContractBalanceTransferDetailsViewModel
@{
    var returnUrl = ViewBag.ReturnUrl as string;
    var backUrl = !string.IsNullOrWhiteSpace(returnUrl) ? returnUrl : Url.Action("Index") ?? "/ContractBalanceTransfers";
    ViewData["Title"] = $"انتقال مانده #{Model.Id}";
    ViewData["HideSectionTabs"] = true;
}

<div class="ak-form-page ak-detail-page" dir="rtl">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@(($"انتقال مانده #{Model.Id}", false,
                       (string?)null, (string?)null, (string?)null, (string?)null,
                       UiText.T(Context, "بازگشت", "Back"), "bi-arrow-right", (string?)backUrl))" />

    <p class="ak-note">این سند انتقال مانده داخلی بین قراردادها است و پرداخت بانکی محسوب نمی‌شود.</p>

    <dl class="ak-summary-list ak-summary ak-detail-summary">
        <div><dt>از قرارداد</dt><dd>@Model.FromContractNumber</dd></div>
        <div><dt>به قرارداد</dt><dd>@Model.ToContractNumber</dd></div>
        <div><dt>مبلغ اصلی</dt><dd class="ak-num">@Model.AmountOriginal.ToString("N2") @Model.CurrencyCode</dd></div>
        <div><dt>معادل USD</dt><dd class="ak-num">@Model.AmountUsd.ToString("N2") USD</dd></div>
    </dl>

    <div class="ak-form-grid">
        <section class="ak-form-section ak-detail-section">
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("اطلاعات انتقال", (string?)null))" />
            <dl class="ak-list">
                <div class="ak-list-row"><dt>تاریخ</dt><dd>@Model.TransferDate.ToDisplayDate()</dd></div>
                <div class="ak-list-row"><dt>مرجع</dt><dd>@(Model.Reference ?? "-")</dd></div>
                <div class="ak-list-row"><dt>وضعیت</dt><dd><span class="ak-status @(Model.IsCancelled ?"is-inactive" : "is-active")">@(Model.IsCancelled ? "لغوشده" : "فعال")</span></dd></div>
                <div class="ak-list-row"><dt>یادداشت</dt><dd>@(Model.Notes ?? "-")</dd></div>
            </dl>
        </section>

        <section class="ak-form-section ak-detail-section">
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("FX trace", (string?)null))" />
            <dl class="ak-list">
                <div class="ak-list-row"><dt>FX به USD</dt><dd class="ak-num">@Model.FxRateToUsd.ToString("N6")</dd></div>
                <div class="ak-list-row"><dt>تاریخ نرخ</dt><dd>@(Model.FxRateDate?.ToDisplayDate() ?? "-")</dd></div>
                <div class="ak-list-row"><dt>منبع نرخ</dt><dd>@(Model.FxRateSource ?? "-")</dd></div>
                <div class="ak-list-row"><dt>پرداخت اولیه</dt><dd>@(Model.OriginalPaymentTransactionId?.ToString() ?? "-")</dd></div>
                <div class="ak-list-row"><dt>نرخ پرداخت اولیه</dt><dd class="ak-num">@(Model.OriginalPaymentFxRateToUsd?.ToString("N6") ?? "-")</dd></div>
            </dl>
        </section>
    </div>

    <section class="ak-form-section ak-detail-section">
        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("Ledger posting", (string?)null))" />
        <div class="ak-table-wrap">
            <table class="ak-table ak-detail-table">
                <thead>
                    <tr>
                        <th>تاریخ</th>
                        <th>سمت</th>
                        <th class="ak-col-grow">قرارداد</th>
                        <th class="ak-col-num">مبلغ اصلی</th>
                        <th class="ak-col-num">USD</th>
                        <th class="ak-col-actions">Ledger</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var entry in Model.LedgerEntries)
                {
                    <tr>
                        <td>@entry.EntryDate.ToDisplayDate()</td>
                        <td><span class="ak-status @(entry.Side =="Credit" ? "is-active" : "")">@entry.Side</span></td>
                        <td class="ak-col-grow">@entry.ContractNumber</td>
                        <td class="ak-col-num ak-num">@((entry.SourceAmount ?? 0m).ToString("N2")) @(entry.SourceCurrencyCode ?? Model.CurrencyCode)</td>
                        <td class="ak-col-num ak-num">@entry.AmountUsd.ToString("N2") USD</td>
                        <td class="ak-col-actions"><a asp-controller="Ledger" asp-action="Details" asp-route-id="@entry.Id">مشاهده</a></td>
                    </tr>
                }
                @if (!Model.LedgerEntries.Any())
                {
                    <tr><td colspan="6"><div class="ak-empty ak-detail-empty-state"><i class="bi bi-journal-text"></i> LedgerEntry مرتبط پیدا نشد.</div></td></tr>
                }
                </tbody>
            </table>
        </div>
    </section>
</div>
