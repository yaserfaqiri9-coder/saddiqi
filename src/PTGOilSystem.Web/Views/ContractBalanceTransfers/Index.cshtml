@model PTGOilSystem.Web.Models.ContractBalanceTransfers.ContractBalanceTransferIndexViewModel
@{
    ViewData["Title"] = Model.ContractId.HasValue
        ? $"انتقالات مانده قرارداد {Model.ContractNumber}"
        : "انتقالات مانده قراردادها";
    var backHref = Model.ContractId.HasValue ? Url.Action("Details", "ContractJourney", new { contractId = Model.ContractId }) : null;
}

<div class="ak-list-page">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@(("انتقالات مانده قراردادها", false,
                       "انتقال مانده", "bi-arrow-left-right", Url.Action("Create", new { fromContractId = Model.ContractId }), (string?)null,
                       backHref is null ? (string?)null : "بازگشت به قرارداد", "bi-arrow-right", (string?)backHref))" />

    <p class="ak-note">این بخش انتقال داخلی مانده بین قراردادها را نشان می‌دهد؛ پرداخت بانکی یا حرکت موجودی ایجاد نمی‌کند.</p>

    <partial name="~/Views/Shared/_AkSearchFilter.cshtml"
             model="@(new AkSearchFilterModel("search", ViewData["Search"] as string, "جستجو یا فیلتر نتایج...", null,
                       Model.ContractId.HasValue
                           ? new Dictionary<string, string> { ["contractId"] = Model.ContractId.Value.ToString() }
                           : null))" />

    <div class="ak-list">
        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead>
                    <tr>
                        <th>تاریخ</th>
                        <th class="ak-col-grow">از قرارداد</th>
                        <th>به قرارداد</th>
                        <th class="ak-col-num">مبلغ اصلی</th>
                        <th class="ak-col-num">FX</th>
                        <th class="ak-col-num">USD</th>
                        <th>مرجع</th>
                        <th>وضعیت</th>
                        <th class="ak-col-actions">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr data-href="@Url.Action("Details", new { id = item.Id })">
                        <td>@item.TransferDate.ToDisplayDate()</td>
                        <td class="ak-col-grow"><a class="ak-name" asp-action="Details" asp-route-id="@item.Id">@item.FromContractNumber</a></td>
                        <td>@item.ToContractNumber</td>
                        <td class="ak-col-num ak-num">@item.AmountOriginal.ToString("N2") @item.CurrencyCode</td>
                        <td class="ak-col-num ak-num">@item.FxRateToUsd.ToString("N6")</td>
                        <td class="ak-col-num ak-num">@item.AmountUsd.ToString("N2") USD</td>
                        <td>@(item.Reference ?? "-")</td>
                        <td><span class="ak-status @(item.IsCancelled ?"is-inactive" : "is-active")">@(item.IsCancelled ? "لغوشده" : "فعال")</span></td>
                        <td class="ak-col-actions"><a asp-action="Details" asp-route-id="@item.Id" title="مشاهده" aria-label="مشاهده"><i class="bi bi-eye" aria-hidden="true"></i></a></td>
                    </tr>
                }
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="9"><div class="ak-empty"><i class="bi bi-arrow-left-right"></i> برای ثبت انتقال مانده بین قراردادها از دکمه انتقال مانده استفاده کنید.</div></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        @await Html.PartialAsync("_Pagination", (Model.CurrentPage, Model.PageCount))
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            document.querySelectorAll('.ak-table tbody tr[data-href]').forEach(function (row) {
                row.style.cursor = 'pointer';
                row.addEventListener('click', function (e) {
                    if (e.target.closest('a, button, input, label, select, form')) return;
                    window.location.href = row.getAttribute('data-href');
                });
            });
        })();
    </script>
}
