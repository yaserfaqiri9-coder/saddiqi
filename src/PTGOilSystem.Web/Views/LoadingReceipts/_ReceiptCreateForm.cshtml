@model PTGOilSystem.Web.Models.Loading.LoadingReceiptCreateViewModel
@using System.Globalization
@using PTGOilSystem.Web.Models.Entities
@{
    var isReceiptModal = ViewData["IsReceiptModal"] as bool? == true;
    var isReceiptIframeModal = ViewData["IsReceiptIframeModal"] as bool? == true;
    var isEnglish = UiText.IsEn(Context);
    var viewDirection = isEnglish ? "ltr" : "rtl";
    string T(string fa, string en) => UiText.T(Context, fa, en);
    var iframeModalRouteValue = isReceiptIframeModal ? "1" : null;
    var cancelUrl = ViewData["CancelUrl"] as string;
    var hasLocalReturnUrl = !string.IsNullOrWhiteSpace(Model.ReturnUrl) && Url.IsLocalUrl(Model.ReturnUrl);
    var fallbackCancelUrl = Url.Action("Details", "Loading", new { id = Model.LoadingRegisterId }) ?? "#";
    var resolvedCancelUrl = !string.IsNullOrWhiteSpace(cancelUrl)
        ? cancelUrl
        : hasLocalReturnUrl
            ? Model.ReturnUrl
            : fallbackCancelUrl;

    var transportText = string.Join(" / ", new[] { Model.VesselName, Model.WagonNumber, Model.TruckPlateNumber }.Where(v => !string.IsNullOrWhiteSpace(v)));
    var referenceText = string.Join(" / ", new[] { Model.BillOfLadingNumber, Model.RwbNo }.Where(v => !string.IsNullOrWhiteSpace(v)));
    var sourceLabelParts = new List<string> { $"LD-{Model.LoadingRegisterId:D4}" };
    if (!string.IsNullOrWhiteSpace(Model.VesselName))
    {
        sourceLabelParts.Add($"{T("کشتی", "Vessel")}: {Model.VesselName}");
    }
    else if (!string.IsNullOrWhiteSpace(Model.WagonNumber))
    {
        sourceLabelParts.Add($"{T("واگن", "Wagon")}: {Model.WagonNumber}");
    }
    else if (!string.IsNullOrWhiteSpace(Model.TruckPlateNumber))
    {
        sourceLabelParts.Add($"{T("موتر", "Truck")}: {Model.TruckPlateNumber}");
    }
    var sourceLabel = $"{sourceLabelParts[0]}{(sourceLabelParts.Count > 1 ? $" ({sourceLabelParts[1]})" : "")}";
    var sourceReferenceValue = string.IsNullOrWhiteSpace(referenceText) ? sourceLabelParts[0] : referenceText;
    var referenceDocumentValue = string.IsNullOrWhiteSpace(Model.ReferenceDocument) ? sourceReferenceValue : Model.ReferenceDocument;
    var receiptDateValue = Model.ReceiptDate == default ? DateTime.UtcNow.Date : Model.ReceiptDate;
    var displayedReceivedQuantity = Model.ReceivedQuantityMt > 0m ? Model.ReceivedQuantityMt : Math.Max(Model.RemainingToReceiveMt, 0m);
    var displayedActualQuantity = Model.ActualArrivedQuantityMt ?? displayedReceivedQuantity;

    string currentScenario = (Model.ReceiptDestination, Model.AllocationDestination) switch
    {
        (LoadingReceiptDestination.ToInventory, _) => "inventory",
        (LoadingReceiptDestination.DirectDispatch, LoadingReceiptAllocationDestination.DirectSale) => "sale",
        (LoadingReceiptDestination.DirectDispatch, LoadingReceiptAllocationDestination.DirectDispatchToTruck) => "truck",
        (LoadingReceiptDestination.DirectDispatch, LoadingReceiptAllocationDestination.TransferToOtherTerminal) => "transfer",
        (LoadingReceiptDestination.Mixed, _) => "mixed",
        _ => "inventory"
    };
}

<form asp-controller="LoadingReceipts"
      asp-action="Create"
      asp-route-modal="@iframeModalRouteValue"
      method="post"
      class="ak-form @(isReceiptModal ?"is-modal" : "")"
      dir="@viewDirection"
      data-receipt-create-form="true"
      data-receipt-to-inventory="@((int)LoadingReceiptDestination.ToInventory)"
      data-receipt-direct-dispatch="@((int)LoadingReceiptDestination.DirectDispatch)"
      data-receipt-mixed="@((int)LoadingReceiptDestination.Mixed)"
      data-alloc-to-inventory="@((int)LoadingReceiptAllocationDestination.ToInventory)"
      data-alloc-direct-truck="@((int)LoadingReceiptAllocationDestination.DirectDispatchToTruck)"
      data-alloc-direct-sale="@((int)LoadingReceiptAllocationDestination.DirectSale)"
      data-alloc-transfer="@((int)LoadingReceiptAllocationDestination.TransferToOtherTerminal)"
      novalidate>
    @Html.AntiForgeryToken()
    @if (isReceiptIframeModal)
    {
        <input type="hidden" name="modal" value="1" />
    }
    <input asp-for="LoadingRegisterId" type="hidden" />
    <input asp-for="ReturnUrl" type="hidden" />
    <input asp-for="Loss.Stage" type="hidden" />
    <input asp-for="ReceiptDestination" type="hidden" id="ReceiptDestination" />
    <input asp-for="AllocationDestination" type="hidden" id="AllocationDestination" />
    <input type="hidden" id="ScenarioKey" name="ScenarioKey" value="@currentScenario" />
    <div data-receipt-difference-preview data-loaded-quantity="@Model.LoadedQuantityMt.ToString(CultureInfo.InvariantCulture)" hidden>
        <span data-receipt-difference-value>-</span>
        <span>@T("مقدار بارگیری - مقدار رسیده/واقعی", "Loaded Quantity - Received/Actual Quantity")</span>
    </div>

    @{
        ViewData["OpHeaderBackUrl"] = resolvedCancelUrl;
        ViewData["OpHeaderShowBack"] = !isReceiptModal;
        ViewData["OpHeaderBackLabel"] = T("بازگشت", "Back");
    }

    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <main>
        <section class="ak-form-section" aria-labelledby="receiptSourceTitle">
            <div class="ak-section-head">
                <i class="bi bi-truck"></i>
                <h2 id="receiptSourceTitle" class="ak-section-title">@T("اطلاعات منبع", "Source Information")</h2>
            </div>

            <div class="ak-field">
                <label for="SourceLoadingDisplay">@T("بارگیری منبع / بارنامه", "Source Loading / Bill of Loading")</label>
                <select id="SourceLoadingDisplay" class="ak-input" disabled>
                    <option selected>@sourceLabel</option>
                </select>
            </div>

            <div class="ak-field">
                <label for="ReceiptDate">@T("تاریخ رسید", "Received Date")</label>
                <input id="ReceiptDate"
                       name="ReceiptDate"
                       type="datetime-local"
                       class="ak-input"
                       value="@receiptDateValue.ToString("yyyy-MM-ddTHH:mm", CultureInfo.InvariantCulture)" />
                <span asp-validation-for="ReceiptDate" class="ak-field-error"></span>
            </div>

            <div class="ak-form-grid">
                <div class="ak-field">
                    <label for="ManifestQtyMt">@T("مقدار بارنامه (MT)", "Manifest Qty (MT)")</label>
                    <input id="ManifestQtyMt"
                           type="text"
                           class="ak-input"
                           value="@Model.LoadedQuantityMt.ToString("0.####", CultureInfo.InvariantCulture)"
                           disabled />
                </div>
                <div class="ak-field">
                    <label for="ReceivedQuantityMt">@T("مقدار رسید (MT)", "Received Qty (MT)")</label>
                    <input id="ReceivedQuantityMt"
                           name="ReceivedQuantityMt"
                           type="number"
                           step="0.0001"
                           min="0"
                           class="ak-input"
                           value="@displayedReceivedQuantity.ToString("0.####", CultureInfo.InvariantCulture)"
                           data-preview-source="receivedQuantity" />
                    <span asp-validation-for="ReceivedQuantityMt" class="ak-field-error"></span>
                </div>
            </div>

            <div class="ak-form-grid">
                <div class="ak-field">
                    <label for="ActualArrivedQuantityMt">@T("مقدار واقعی رسیده (MT)", "Actual Arrived Qty (MT)")</label>
                    <input id="ActualArrivedQuantityMt"
                           name="ActualArrivedQuantityMt"
                           type="number"
                           step="0.0001"
                           min="0"
                           class="ak-input"
                           value="@displayedActualQuantity.ToString("0.####", CultureInfo.InvariantCulture)" />
                    <span asp-validation-for="ActualArrivedQuantityMt" class="ak-field-error"></span>
                </div>
                <div class="ak-field">
                    <label for="ReferenceDocument">@T("شماره رسید / مرجع", "Receipt Reference")</label>
                    <input id="ReferenceDocument"
                           name="ReferenceDocument"
                           class="ak-input"
                           value="@referenceDocumentValue"
                           data-preview-source="reference" />
                    <span asp-validation-for="ReferenceDocument" class="ak-field-error"></span>
                </div>
            </div>

            @* پیگیری ورود به مقصد — فیلدهای واقعی مدل (ArrivalDate/LeakDate) که Controller ثبت می‌کند *@
            <div class="ak-form-grid">
                <div class="ak-field">
                    <label asp-for="ArrivalDate">@T("تاریخ ورود به مقصد", "Arrival Date")</label>
                    <input asp-for="ArrivalDate" type="date" class="ak-input" />
                    <span asp-validation-for="ArrivalDate" class="ak-field-error"></span>
                </div>
                <div class="ak-field">
                    <label asp-for="LeakDate">@T("تاریخ نشت / خرابی", "Leak / Damage Date")</label>
                    <input asp-for="LeakDate" type="date" class="ak-input" />
                    <span asp-validation-for="LeakDate" class="ak-field-error"></span>
                </div>
            </div>

            <div class="ak-field">
                <label asp-for="Notes">@T("یادداشت رسید", "Receipt Notes")</label>
                <textarea asp-for="Notes" rows="2" class="ak-input"></textarea>
                <span asp-validation-for="Notes" class="ak-field-error"></span>
            </div>
        </section>

        <section class="ak-form-section" aria-labelledby="receiptRoutingTitle">
            <div class="ak-section-head">
                <h2 id="receiptRoutingTitle" class="ak-section-title">@T("مسیر مقصد", "Destination Routing")</h2>
                <p>@T("این محصول رسیده به کدام مقصد تخصیص شود؟", "Where should this received product be allocated?")</p>
            </div>

            <div class="ak-form-grid" aria-label="@T("مسیر مقصد", "Destination routing")">
                <button type="button" class="btn btn-light @(currentScenario =="inventory" ? "is-selected" : "")" data-scenario-pick="inventory" aria-pressed="@(currentScenario == "inventory" ? "true" : "false")">
                    <i class="bi bi-database"></i>
                    <strong>@T("به موجودی", "To Inventory")</strong>
                    <span>@T("ذخیره در مخزن تعیین‌شده...", "Store in designated storage...")</span>
                </button>
                <button type="button" class="btn btn-light @(currentScenario =="sale" ? "is-selected" : "")" data-scenario-pick="sale" aria-pressed="@(currentScenario == "sale" ? "true" : "false")">
                    <i class="bi bi-currency-dollar"></i>
                    <strong>@T("فروش مستقیم", "Direct Sale")</strong>
                    <span>@T("فروش فوری به مشتری", "Sell immediately to customer")</span>
                </button>
                <button type="button" class="btn btn-light @(currentScenario =="truck" ? "is-selected" : "")" data-scenario-pick="truck" aria-pressed="@(currentScenario == "truck" ? "true" : "false")">
                    <i class="bi bi-send"></i>
                    <strong>@T("ارسال با موتر", "Truck Send")</strong>
                    <span>@T("بار مستقیم روی موتر...", "Load directly onto outbound...")</span>
                </button>
                <button type="button" class="btn btn-light @(currentScenario =="transfer" ? "is-selected" : "")" data-scenario-pick="transfer" aria-pressed="@(currentScenario == "transfer" ? "true" : "false")">
                    <i class="bi bi-arrow-repeat"></i>
                    <strong>@T("انتقال", "Transfer")</strong>
                    <span>@T("انتقال به ترمینال دیگر", "Transfer to another terminal")</span>
                </button>
                <button type="button" class="btn btn-light @(currentScenario =="mixed" ? "is-selected" : "")" data-scenario-pick="mixed" aria-pressed="@(currentScenario == "mixed" ? "true" : "false")">
                    <i class="bi bi-diagram-3"></i>
                    <strong>@T("تقسیم ترکیبی", "Mixed Allocation")</strong>
                    <span>@T("تقسیم مقدار به چند مقصد", "Split quantity across destinations")</span>
                </button>
            </div>

            <div class="ak-note mt-2">
                <i class="bi bi-info-circle"></i>
                <div>
                    @T("«به موجودی» و «انتقال» موجودی در مخزن می‌سازند. «فروش مستقیم» و «ارسال با موتر» موجودی نمی‌سازند و بار مستقیم خارج می‌شود. «ترکیبی» بسته به سطرها فرق می‌کند.",
                       "Inventory and transfer create stock. Direct sale and truck send do not create stock.")
                </div>
            </div>

            <div class="ak-section-divider"></div>

            <div class="ak-field">
                <label for="TerminalId">@T("ترمینال رسید", "Receipt Terminal")</label>
                <select asp-for="TerminalId" asp-items="ViewBag.Terminals" class="ak-input" data-preview-source="terminal">
                    <option value=""></option>
                </select>
                <span asp-validation-for="TerminalId" class="ak-field-error"></span>
            </div>

            <div class="ak-form-grid @(currentScenario =="inventory" ? "" : "d-none")" data-scenario-panel="inventory">
                <div class="ak-field">
                    <label asp-for="StorageTankId">@T("مخزن", "Storage Tank")</label>
                    <select asp-for="StorageTankId" asp-items="ViewBag.StorageTanks" class="ak-input" data-preview-source="storageTank">
                        <option value=""></option>
                    </select>
                    <span class="ak-field-note">@T("برای ورود به موجودی، مخزن همان ترمینال را انتخاب کنید.", "Select the tank that receives inventory at this terminal.")</span>
                    <span asp-validation-for="StorageTankId" class="ak-field-error"></span>
                </div>
            </div>

            <div class="ak-form-grid @(currentScenario =="truck" ? "" : "d-none")" data-scenario-panel="truck">
                <div class="ak-form-grid">
                    <div class="ak-field">
                        <label asp-for="DirectTruckId">@T("موتر", "Truck")</label>
                        <select asp-for="DirectTruckId" asp-items="ViewBag.DirectTrucks" class="ak-input">
                            <option value=""></option>
                        </select>
                        <span asp-validation-for="DirectTruckId" class="ak-field-error"></span>
                    </div>
                    <div class="ak-field">
                        <label asp-for="DirectTruckPlateNumber">@T("نمبر پلیت", "Plate Number")</label>
                        <input asp-for="DirectTruckPlateNumber" class="ak-input" />
                        <span asp-validation-for="DirectTruckPlateNumber" class="ak-field-error"></span>
                    </div>
                </div>
                <div class="ak-form-grid">
                    <div class="ak-field">
                        <label asp-for="DirectDriverId">@T("راننده", "Driver")</label>
                        <select asp-for="DirectDriverId" asp-items="ViewBag.DirectDrivers" class="ak-input">
                            <option value=""></option>
                        </select>
                        <span asp-validation-for="DirectDriverId" class="ak-field-error"></span>
                    </div>
                    <div class="ak-field">
                        <label asp-for="DirectDriverName">@T("نام راننده جدید", "New Driver Name")</label>
                        <input asp-for="DirectDriverName" class="ak-input" />
                        <span asp-validation-for="DirectDriverName" class="ak-field-error"></span>
                    </div>
                </div>
                <div class="ak-form-grid">
                    <div class="ak-field">
                        <label asp-for="DirectDispatchDate">@T("تاریخ حرکت موتر", "Truck Send Date")</label>
                        <input asp-for="DirectDispatchDate" type="date" class="ak-input" />
                        <span asp-validation-for="DirectDispatchDate" class="ak-field-error"></span>
                    </div>
                    <div class="ak-field">
                        <label asp-for="DirectTruckTicketSerialNumber">@T("سریال تکت موتر", "Truck Ticket Serial")</label>
                        <input asp-for="DirectTruckTicketSerialNumber" class="ak-input" />
                        <span asp-validation-for="DirectTruckTicketSerialNumber" class="ak-field-error"></span>
                    </div>
                </div>
            </div>

            <div class="ak-form-grid @(currentScenario =="sale" ? "" : "d-none")" data-scenario-panel="sale">
                <div class="ak-form-grid">
                    <div class="ak-field">
                        <label asp-for="SaleCustomerId">@T("مشتری", "Customer")</label>
                        <select asp-for="SaleCustomerId" asp-items="ViewBag.SaleCustomers" class="ak-input">
                            <option value=""></option>
                        </select>
                        <span asp-validation-for="SaleCustomerId" class="ak-field-error"></span>
                    </div>
                    <div class="ak-field">
                        <label asp-for="SaleDate">@T("تاریخ فروش", "Sale Date")</label>
                        <input asp-for="SaleDate" type="date" class="ak-input" />
                        <span asp-validation-for="SaleDate" class="ak-field-error"></span>
                    </div>
                </div>
                <div class="ak-form-grid">
                    <div class="ak-field">
                        <label asp-for="SaleInvoiceNumber">@T("شماره فاکتور", "Invoice Number")</label>
                        <input asp-for="SaleInvoiceNumber" class="ak-input" />
                        <span asp-validation-for="SaleInvoiceNumber" class="ak-field-error"></span>
                    </div>
                    <div class="ak-field">
                        <label asp-for="SaleUnitPriceInCurrency">@T("قیمت واحد", "Unit Price")</label>
                        <input asp-for="SaleUnitPriceInCurrency" class="ak-input" />
                        <span asp-validation-for="SaleUnitPriceInCurrency" class="ak-field-error"></span>
                    </div>
                </div>
                <div class="ak-form-grid">
                    <div class="ak-field">
                        <label asp-for="SaleCurrency">@T("واحد پول", "Currency")</label>
                        <input asp-for="SaleCurrency" class="ak-input" />
                        <span asp-validation-for="SaleCurrency" class="ak-field-error"></span>
                    </div>
                    <div class="ak-field">
                        <label asp-for="SaleAppliedFxRateToUsd">@T("نرخ تبدیل به USD", "FX Rate to USD")</label>
                        <input asp-for="SaleAppliedFxRateToUsd" class="ak-input" />
                        <span asp-validation-for="SaleAppliedFxRateToUsd" class="ak-field-error"></span>
                    </div>
                </div>
                <div class="ak-field">
                    <label asp-for="SaleNotes">@T("یادداشت فروش", "Sale Notes")</label>
                    <textarea asp-for="SaleNotes" rows="2" class="ak-input"></textarea>
                    <span asp-validation-for="SaleNotes" class="ak-field-error"></span>
                </div>
            </div>

            <div class="ak-form-grid @(currentScenario =="transfer" ? "" : "d-none")" data-scenario-panel="transfer">
                <div class="ak-form-grid">
                    <div class="ak-field">
                        <label asp-for="DestinationTerminalId">@T("ترمینال مقصد", "Destination Terminal")</label>
                        <select asp-for="DestinationTerminalId" asp-items="ViewBag.DestinationTerminals" class="ak-input">
                            <option value=""></option>
                        </select>
                        <span asp-validation-for="DestinationTerminalId" class="ak-field-error"></span>
                    </div>
                    <div class="ak-field">
                        <label asp-for="DestinationStorageTankId">@T("مخزن مقصد", "Destination Tank")</label>
                        <select asp-for="DestinationStorageTankId" asp-items="ViewBag.DestinationStorageTanks" class="ak-input">
                            <option value=""></option>
                        </select>
                        <span asp-validation-for="DestinationStorageTankId" class="ak-field-error"></span>
                    </div>
                </div>
            </div>

            <div class="ak-form-grid @(currentScenario =="truck" || currentScenario == "transfer" ? "" : "d-none")" data-scenario-panel="truck transfer">
                <div class="ak-form-grid">
                    <div class="ak-field">
                        <label asp-for="DestinationLocationId">@T("شهر / موقعیت مقصد", "Destination Location")</label>
                        <select asp-for="DestinationLocationId" asp-items="ViewBag.DestinationLocations" class="ak-input">
                            <option value=""></option>
                        </select>
                        <span asp-validation-for="DestinationLocationId" class="ak-field-error"></span>
                    </div>
                    <div class="ak-field">
                        <label asp-for="AllocationDestinationName">@T("نام مقصد", "Destination")</label>
                        <input asp-for="AllocationDestinationName" class="ak-input" />
                        <span asp-validation-for="AllocationDestinationName" class="ak-field-error"></span>
                    </div>
                </div>
                <div class="ak-field">
                    <label asp-for="DestinationReference">@T("مرجع مقصد", "Reference")</label>
                    <input asp-for="DestinationReference" class="ak-input" />
                    <span asp-validation-for="DestinationReference" class="ak-field-error"></span>
                </div>
            </div>
        </section>

        <section class="ak-form-section @(currentScenario =="mixed" ? "" : "d-none")" data-scenario-panel="mixed" aria-labelledby="receiptMixedTitle">
            <div class="ak-section-head">
                <i class="bi bi-diagram-3"></i>
                <h2 id="receiptMixedTitle" class="ak-section-title">@T("تقسیم رسید", "Receipt split")</h2>
            </div>
            <p class="ak-section-desc">@T("هر ردیف می‌تواند مقصد جداگانه داشته باشد. جمع مقدار ردیف‌ها باید با مقدار کل رسید برابر باشد.", "Each row can have a separate destination. Row totals must match the receipt quantity.")</p>
            <div class="ak-table-wrap">
                <table class="ak-table">
                    <thead>
                        <tr>
                            <th>@T("مقصد", "Destination")</th>
                            <th>@T("مقدار MT", "Qty MT")</th>
                            <th>@T("ترمینال", "Terminal")</th>
                            <th>@T("مخزن", "Tank")</th>
                            <th>@T("ترمینال مقصد", "Dest. Terminal")</th>
                            <th>@T("مخزن مقصد", "Dest. Tank")</th>
                            <th>@T("موقعیت مقصد", "Dest. Location")</th>
                            <th>@T("نام/مرجع مقصد", "Destination")</th>
                            <th>@T("فروش", "Sale")</th>
                            <th>@T("یادداشت", "Note")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < Model.AllocationLines.Count; i++)
                        {
                            <tr>
                                <td>
                                    <select asp-for="AllocationLines[i].Destination" asp-items="ViewBag.AllocationDestinations" class="ak-input"></select>
                                    <span asp-validation-for="AllocationLines[i].Destination" class="ak-field-error"></span>
                                </td>
                                <td>
                                    <input asp-for="AllocationLines[i].QuantityMt" class="ak-input" />
                                    <span asp-validation-for="AllocationLines[i].QuantityMt" class="ak-field-error"></span>
                                </td>
                                <td>
                                    <select asp-for="AllocationLines[i].TerminalId" asp-items="ViewBag.Terminals" class="ak-input">
                                        <option value="">-</option>
                                    </select>
                                    <span asp-validation-for="AllocationLines[i].TerminalId" class="ak-field-error"></span>
                                </td>
                                <td>
                                    <select asp-for="AllocationLines[i].StorageTankId" asp-items="ViewBag.StorageTanks" class="ak-input">
                                        <option value="">-</option>
                                    </select>
                                    <span asp-validation-for="AllocationLines[i].StorageTankId" class="ak-field-error"></span>
                                </td>
                                <td>
                                    <select asp-for="AllocationLines[i].DestinationTerminalId" asp-items="ViewBag.DestinationTerminals" class="ak-input">
                                        <option value="">-</option>
                                    </select>
                                    <span asp-validation-for="AllocationLines[i].DestinationTerminalId" class="ak-field-error"></span>
                                </td>
                                <td>
                                    <select asp-for="AllocationLines[i].DestinationStorageTankId" asp-items="ViewBag.DestinationStorageTanks" class="ak-input">
                                        <option value="">-</option>
                                    </select>
                                    <span asp-validation-for="AllocationLines[i].DestinationStorageTankId" class="ak-field-error"></span>
                                </td>
                                <td>
                                    <select asp-for="AllocationLines[i].DestinationLocationId" asp-items="ViewBag.DestinationLocations" class="ak-input">
                                        <option value="">-</option>
                                    </select>
                                    <span asp-validation-for="AllocationLines[i].DestinationLocationId" class="ak-field-error"></span>
                                </td>
                                <td>
                                    <input asp-for="AllocationLines[i].DestinationName" class="ak-input" />
                                    <input asp-for="AllocationLines[i].DestinationReference" class="ak-input mt-2" />
                                    <span asp-validation-for="AllocationLines[i].DestinationName" class="ak-field-error"></span>
                                    <span asp-validation-for="AllocationLines[i].DestinationReference" class="ak-field-error"></span>
                                </td>
                                <td>
                                    <select asp-for="AllocationLines[i].SaleCustomerId" asp-items="ViewBag.SaleCustomers" class="ak-input">
                                        <option value=""></option>
                                    </select>
                                    <input asp-for="AllocationLines[i].SaleDate" type="date" class="ak-input mt-2" />
                                    <input asp-for="AllocationLines[i].SaleInvoiceNumber" class="ak-input mt-2" />
                                    <div class="ak-form-grid">
                                        <input asp-for="AllocationLines[i].SaleUnitPriceInCurrency" class="ak-input" />
                                        <input asp-for="AllocationLines[i].SaleCurrency" class="ak-input" />
                                    </div>
                                    <input asp-for="AllocationLines[i].SaleAppliedFxRateToUsd" class="ak-input mt-2" />
                                    <span asp-validation-for="AllocationLines[i].SaleCustomerId" class="ak-field-error"></span>
                                    <span asp-validation-for="AllocationLines[i].SaleInvoiceNumber" class="ak-field-error"></span>
                                    <span asp-validation-for="AllocationLines[i].SaleUnitPriceInCurrency" class="ak-field-error"></span>
                                </td>
                                <td>
                                    <input asp-for="AllocationLines[i].ReferenceDocument" class="ak-input" />
                                    <textarea asp-for="AllocationLines[i].Notes" rows="2" class="ak-input mt-2"></textarea>
                                    <span asp-validation-for="AllocationLines[i].ReferenceDocument" class="ak-field-error"></span>
                                    <span asp-validation-for="AllocationLines[i].Notes" class="ak-field-error"></span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="ak-form-section" aria-labelledby="receiptLossTitle" data-receipt-loss-card>
            <div >
                <div class="ak-section-head">
                    <i class="bi bi-exclamation-triangle"></i>
                    <h2 id="receiptLossTitle" class="ak-section-title">@T("کسری / ضایعات همین رسید", "Receipt Shortage / Loss")</h2>
                </div>
            </div>

            <input type="hidden" name="LossMode" value="@((int)Model.LossMode)" data-loss-mode-value />
            <div class="ak-form-grid" role="group" aria-label="@T("نحوهٔ ثبت ضایعات", "Loss capture mode")">
                <button type="button"
                        class="btn btn-light @(Model.LossMode == ReceiptLossMode.ImmediateKnownLoss ?"is-selected" : "")"
                        data-loss-mode-pick data-loss-mode-set="@((int)ReceiptLossMode.ImmediateKnownLoss)"
                        aria-pressed="@(Model.LossMode == ReceiptLossMode.ImmediateKnownLoss ? "true" : "false")">
                    <strong>@T("ضایعات حالا معلوم است", "Loss known now")</strong>
                    <span>@T("مقدار دریافت و ضایعات را همین حالا ثبت کنید", "Enter received quantity and loss now")</span>
                </button>
                <button type="button"
                        class="btn btn-light @(Model.LossMode == ReceiptLossMode.DeferredTankSettlement ?"is-selected" : "")"
                        data-loss-mode-pick data-loss-mode-set="@((int)ReceiptLossMode.DeferredTankSettlement)"
                        aria-pressed="@(Model.LossMode == ReceiptLossMode.DeferredTankSettlement ? "true" : "false")">
                    <strong>@T("ضایعات بعداً از تسویه مخزن", "Loss from tank settlement")</strong>
                    <span>@T("رسید در انتظار تسویهٔ نهایی مخزن می‌ماند", "Receipt waits for final tank settlement")</span>
                </button>
            </div>

            <div data-loss-immediate-block>
            <div class="ak-field">
                <input asp-for="Loss.Enabled" id="lossEnabledToggle" class="form-check-input" />
                <label asp-for="Loss.Enabled">@T("هم‌زمان با رسید ثبت شود", "Register with this receipt")</label>
            </div>

            <div id="lossPanelFields" class="ak-form-grid" data-loss-open-default="true">
                <div class="ak-field">
                    <label asp-for="Loss.QuantityMt">@T("مقدار ضایعات (MT)", "Loss Qty (MT)")</label>
                    <input asp-for="Loss.QuantityMt" class="ak-input" />
                    <span asp-validation-for="Loss.QuantityMt" class="ak-field-error"></span>
                </div>
                <div class="ak-field">
                    <label asp-for="Loss.ToleranceQuantityMt">@T("تلورانس ضایعات (MT)", "Loss Tolerance (MT)")</label>
                    <input asp-for="Loss.ToleranceQuantityMt" class="ak-input" />
                    <span asp-validation-for="Loss.ToleranceQuantityMt" class="ak-field-error"></span>
                </div>
                <div class="ak-field">
                    <label asp-for="Loss.ResponsiblePartyName">@T("مسئول / طرف پاسخ‌گو", "Responsible Party")</label>
                    <input asp-for="Loss.ResponsiblePartyName" class="ak-input" />
                    <span asp-validation-for="Loss.ResponsiblePartyName" class="ak-field-error"></span>
                </div>
                <div class="ak-field">
                    <label asp-for="Loss.Reference">@T("مرجع ضایعات", "Loss Reference")</label>
                    <input asp-for="Loss.Reference" class="ak-input" />
                    <span asp-validation-for="Loss.Reference" class="ak-field-error"></span>
                </div>
                <div class="ak-field ak-span-2">
                    <label asp-for="Loss.Notes">@T("یادداشت ضایعات", "Loss Notes")</label>
                    <textarea asp-for="Loss.Notes" rows="2" class="ak-input"></textarea>
                    <span asp-validation-for="Loss.Notes" class="ak-field-error"></span>
                </div>
            </div>
            <div id="lossPanelHint" class="text-muted small">@T("برای ثبت کسری یا ضایعات این رسید، سوییچ را فعال کنید یا یکی از فیلدها را تکمیل کنید.", "Enable the switch or fill a loss field to register receipt shortage/loss.")</div>
            </div>

            <div class="text-muted small d-none" data-loss-deferred-note>
                <i class="bi bi-hourglass-split me-1" aria-hidden="true"></i>
                @T("این رسید به‌صورت «در انتظار تسویه نهایی مخزن» ثبت می‌شود. ضایعات واقعی بعداً هنگام تسویهٔ کامل مخزن از روی موجودی محاسبه و به قرارداد خرید منبع وصل می‌شود.", "This receipt is recorded as pending final tank settlement. The real loss is computed later from inventory when the tank is settled and attributed to the source purchase contract.")
            </div>
        </section>
    </main>

    <div class="alert alert-warning">
        <i class="bi bi-clipboard-check"></i>
        <div>
            <strong>@T("پیش از ثبت بررسی کنید:", "Before saving, check:")</strong>
            @T("رسید از کدام بارگیری؟ مقدار رسیده چقدر؟ مقصد کجاست؟ آیا موجودی ساخته می‌شود؟ آیا فروش/ارسال با موتر ساخته می‌شود؟",
               "From which loading? Received quantity? Destination? Is stock created? Is a sale/truck send created?")
            <div class="text-muted small mt-1">@T("قدم بعدی: بعد از ثبت رسید، اگر بار به موجودی رفت می‌توانید ارسال با موتر یا فروش ثبت کنید؛ اگر فروش/ارسال با موتر مستقیم بود، همان‌جا تکمیل می‌شود.",
               "Next step: after the receipt, if goods went to stock you can record a truck send or sale; for direct sale/truck send it completes here.")</div>
        </div>
    </div>

    <div class="ak-footer-actions">
        @if (isReceiptModal)
        {
            <button type="button" class="ak-cancel" data-bs-dismiss="modal" data-ptg-iframe-modal-close>@T("انصراف", "Cancel")</button>
        }
        else
        {
            <a href="@resolvedCancelUrl" class="ak-cancel">@T("بازگشت", "Back")</a>
        }
        <button type="submit" class="ak-save">
            <i class="bi bi-check-circle me-1" aria-hidden="true"></i>
            @T("تأیید رسید", "Confirm Receipt")
        </button>
    </div>
</form>
