@using PTGOilSystem.Web.Models.Entities
@model PTGOilSystem.Web.Models.Loading.LoadingReceiptDetailsViewModel
@{
    string T(string fa, string en) => UiText.T(Context, fa, en);
    var returnUrl = ViewBag.ReturnUrl as string;
    var currentReturnUrl = Context.Request.Path + Context.Request.QueryString;
    var loadingDetailsUrl = Url.Action("Details", "Loading", new { id = Model.LoadingRegisterId }) ?? "/Loading";
    var backUrl = !string.IsNullOrWhiteSpace(returnUrl) ? returnUrl : loadingDetailsUrl;

    string ToDestinationText(LoadingReceiptDestination destination) => destination switch
    {
        LoadingReceiptDestination.ToInventory => "ورود به موجودی / تانک",
        LoadingReceiptDestination.DirectDispatch => "تخلیه مستقیم / بدون ورود به موجودی",
        LoadingReceiptDestination.Mixed => "ترکیبی / بر اساس خط تخصیص",
        _ => "نامشخص"
    };

    string ToAllocationDestinationText(LoadingReceiptAllocationDestination destination) => destination switch
    {
        LoadingReceiptAllocationDestination.ToInventory => "ورود به موجودی",
        LoadingReceiptAllocationDestination.DirectSale => "فروش مستقیم",
        LoadingReceiptAllocationDestination.DirectDispatchToTruck => "ارسال با موتر",
        LoadingReceiptAllocationDestination.TransferToOtherTerminal => "انتقال به ترمینال دیگر",
        _ => "نامشخص"
    };

    string ToAllocationStatusText(LoadingReceiptAllocationStatus status) => status switch
    {
        LoadingReceiptAllocationStatus.TraceOnly => "فقط ردیابی",
        LoadingReceiptAllocationStatus.Completed => "تکمیل شده",
        LoadingReceiptAllocationStatus.InTransit => "در مسیر",
        LoadingReceiptAllocationStatus.Cancelled => "لغو شده",
        _ => status.ToString()
    };

    string FormatTraceDestination(PTGOilSystem.Web.Models.Loading.LoadingReceiptAllocationSummaryViewModel allocation)
    {
        var parts = new[]
        {
            allocation.DestinationTerminalName,
            allocation.DestinationStorageTankCode,
            allocation.DestinationLocationName,
            allocation.DestinationName
        }.Where(part => !string.IsNullOrWhiteSpace(part));

        return parts.Any() ? string.Join(" / ", parts) : "-";
    }

    decimal QtyByDestination(LoadingReceiptAllocationDestination destination)
        => Model.Allocations
            .Where(a => a.Destination == destination && a.Status != LoadingReceiptAllocationStatus.Cancelled)
            .Sum(a => a.QuantityMt);

    decimal TruckQtyForTank()
        => Model.Allocations
            .Where(a => a.Destination == LoadingReceiptAllocationDestination.DirectDispatchToTruck
                && a.Status != LoadingReceiptAllocationStatus.Cancelled
                && !a.SalesTransactionId.HasValue)
            .Sum(a => a.QuantityMt);

    decimal TruckQtyForCustomer()
        => Model.Allocations
            .Where(a => a.Destination == LoadingReceiptAllocationDestination.DirectDispatchToTruck
                && a.Status != LoadingReceiptAllocationStatus.Cancelled
                && a.SalesTransactionId.HasValue)
            .Sum(a => a.QuantityMt);

    decimal CompletedQty()
        => Model.Allocations
            .Where(a => a.Status == LoadingReceiptAllocationStatus.Completed)
            .Sum(a => a.QuantityMt);

    decimal InTransitQty()
        => Model.Allocations
            .Where(a => a.Status == LoadingReceiptAllocationStatus.InTransit
                || a.Status == LoadingReceiptAllocationStatus.TraceOnly)
            .Sum(a => a.QuantityMt);

    var receiptDestinationText = ToDestinationText(Model.ReceiptDestination);
    var isDirectDispatchReceipt = Model.ReceiptDestination == LoadingReceiptDestination.DirectDispatch;
    var isMixedReceipt = Model.ReceiptDestination == LoadingReceiptDestination.Mixed;
    var pendingDispatchTrace = Model.Allocations.Any(a => a.Destination == LoadingReceiptAllocationDestination.DirectDispatchToTruck && a.DirectTruckDispatchRemainingQuantityMt > 0);
    var pageTitle = isMixedReceipt
        ? "جزئیات رسید ترکیبی"
        : isDirectDispatchReceipt ? "جزئیات رسید تخلیه مستقیم" : "جزئیات رسید ورود به موجودی";

    var qtyToInventory = QtyByDestination(LoadingReceiptAllocationDestination.ToInventory);
    var qtyDirectSale = QtyByDestination(LoadingReceiptAllocationDestination.DirectSale);
    var qtyTruckForTank = TruckQtyForTank();
    var qtyTruckForCustomer = TruckQtyForCustomer();
    var qtyTransfer = QtyByDestination(LoadingReceiptAllocationDestination.TransferToOtherTerminal);
    var qtyInTransit = InTransitQty();
    var qtyCompleted = CompletedQty();
    var lossChargeableTotal = Model.LossItems.Sum(l => l.ChargeableLossMt);
    var lossDifferenceTotal = Model.LossItems.Sum(l => l.DifferenceQuantityMt);
    var receiptProgressPercent = Model.TotalReceivedQuantityMt > 0
        ? Math.Min(100m, Math.Max(0m, Model.ReceivedQuantityMt / Model.TotalReceivedQuantityMt * 100m))
        : 0m;
    var actualDiffMt = Model.ActualArrivedQuantityMt.HasValue
        ? Model.ActualArrivedQuantityMt.Value - Model.ReceivedQuantityMt
        : (decimal?)null;
    var allocBalanced = Model.AllocationDifferenceMt == 0;
    var hasChargeable = lossChargeableTotal > 0;
    var receiptJourneyUrl = Url.Action("Index", "ContractJourney", new { contractId = Model.ContractId }) ?? "#";
    var receiptEditUrl = Url.Action("Edit", new { id = Model.Id, returnUrl = currentReturnUrl }) ?? "#";

    ViewData["AkHeaderStatus"] = allocBalanced ? T("تخصیص متوازن", "Allocation balanced") : T("اختلاف تخصیص", "Allocation mismatch");
    ViewData["AkHeaderStatusState"] = allocBalanced ? "is-active" : "is-warning";
    ViewData["AkHeaderContext"] = $"{Model.ContractNumber} · {Model.ProductName} · {Model.ReceiptDate.ToDisplayDate()}";
    ViewData["AkHeaderKebab"] = new List<AkHeaderMenuItem>
    {
        new() { Label = T("ویرایش", "Edit"), Href = receiptEditUrl, Icon = "bi-pencil" },
        new() { Label = T("نمای قرارداد", "Contract journey"), Href = receiptJourneyUrl, Icon = "bi-diagram-3" }
    };
    var timelineItems = new List<AkTimelineItem>
    {
        new() { Title = T("بارگیری ثبت شد", "Loading registered"), Date = Model.LoadingDate.ToDisplayDate(), Icon = "bi-box-arrow-up", Meta = $"{NumberDisplay.Quantity(Model.LoadedQuantityMt)} MT" },
        new() { Title = T("رسید ثبت شد", "Receipt recorded"), Date = Model.ReceiptDate.ToDisplayDate(), Icon = "bi-box-arrow-in-down", State = "is-current", Meta = $"{NumberDisplay.Quantity(Model.ReceivedQuantityMt)} MT" }
    };
    if (Model.ArrivalDate.HasValue) timelineItems.Add(new AkTimelineItem { Title = T("رسیدن ثبت شد", "Arrival recorded"), Date = Model.ArrivalDate.Value.ToDisplayDate(), Icon = "bi-geo-alt" });
    if (Model.LeakDate.HasValue) timelineItems.Add(new AkTimelineItem { Title = T("نشتی ثبت شد", "Leak recorded"), Date = Model.LeakDate.Value.ToDisplayDate(), Icon = "bi-droplet" });
    timelineItems.AddRange(Model.LossItems.OrderBy(item => item.EventDate).Select(item => new AkTimelineItem { Title = T("کسری ثبت شد", "Loss recorded"), Date = item.EventDate.ToDisplayDate(), Icon = "bi-exclamation-diamond", Href = Url.Action("Details", "LossEvents", new { id = item.Id, returnUrl = currentReturnUrl }), Meta = $"{NumberDisplay.Quantity(item.ChargeableLossMt)} MT" }));
    var relatedRecords = new List<AkRelatedRecord>
    {
        new() { TypeLabel = T("بارگیری", "Loading"), Label = $"LD-{Model.LoadingRegisterId:0000}", Href = loadingDetailsUrl, KeyValue = Model.ProductName, Icon = "bi-box-arrow-up" },
        new() { TypeLabel = T("قرارداد", "Contract"), Label = Model.ContractNumber, Href = receiptJourneyUrl, Icon = "bi-file-earmark-text" },
        new() { TypeLabel = T("حرکت موجودی", "Inventory movement"), Label = $"#{Model.InventoryMovementId}", Icon = "bi-arrow-left-right" }
    };
    foreach (var allocation in Model.Allocations.Where(item => item.TruckDispatchId.HasValue || item.SalesTransactionId.HasValue))
    {
        if (allocation.TruckDispatchId.HasValue) relatedRecords.Add(new AkRelatedRecord { TypeLabel = T("ارسال با موتر", "Truck dispatch"), Label = $"DSP-{allocation.TruckDispatchId.Value:0000}", Href = Url.Action("Details", "Dispatch", new { id = allocation.TruckDispatchId.Value, returnUrl = currentReturnUrl }), KeyValue = $"{NumberDisplay.Quantity(allocation.QuantityMt)} MT", Icon = "bi-truck" });
        if (allocation.SalesTransactionId.HasValue) relatedRecords.Add(new AkRelatedRecord { TypeLabel = T("فروش", "Sale"), Label = $"#{allocation.SalesTransactionId.Value}", Href = Url.Action("Details", "Sales", new { id = allocation.SalesTransactionId.Value, returnUrl = currentReturnUrl }), KeyValue = $"{NumberDisplay.Quantity(allocation.QuantityMt)} MT", Icon = "bi-receipt" });
    }
    var nextActions = new List<AkHeaderMenuItem>();
    if (Model.RemainingToReceiveMt > 0) nextActions.Add(new AkHeaderMenuItem { Label = T("رسید جدید", "New receipt"), Href = Url.Action("Create", new { loadingId = Model.LoadingRegisterId, returnUrl = backUrl }), Icon = "bi-box-arrow-in-down" });

    ViewData["Title"] = pageTitle;
    ViewData["HideSectionTabs"] = true;
    ViewData["ModalDesignSystemAssets"] = true;
}

<div class="ak-form-page ak-detail-page" dir="rtl" data-ak-detail-v2="true">

    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
         model="@((pageTitle, false,
                    Model.RemainingToReceiveMt > 0 ? T("رسید جدید", "New receipt") : (string?)null, "bi-box-arrow-in-down", Model.RemainingToReceiveMt > 0 ? Url.Action("Create", new { loadingId = Model.LoadingRegisterId, returnUrl = backUrl }) : null, (string?)null,
                   UiText.T(Context, "بازگشت", "Back"), "bi-arrow-right", backUrl))" />

    <div class="ak-page-actions">
        @if (Model.ContractId > 0)
        {
            <a class="btn btn-light" href="@receiptJourneyUrl"><i class="bi bi-diagram-3"></i><span>نمای قرارداد</span></a>
        }
        @if (Model.RemainingToReceiveMt > 0)
        {
            <a class="btn btn-primary"
               asp-action="Create"
               asp-route-loadingId="@Model.LoadingRegisterId"
               asp-route-returnUrl="@backUrl"
               data-page-modal="true"
               data-page-modal-title="ثبت رسید بارگیری #@Model.LoadingRegisterId">
                <i class="bi bi-box-arrow-in-down"></i><span>رسید جدید</span>
            </a>
        }
    </div>

    <section class="ak-stat-grid no-print" aria-label="@T("شاخص‌های رسید", "Receipt metrics")">
        <vc:stat-card title="@T("مقدار این رسید", "Receipt quantity")" value="@NumberDisplay.Quantity(Model.ReceivedQuantityMt)" unit="MT" avatar="total-inventory"></vc:stat-card>
        <vc:stat-card title="@T("جمع دریافت", "Total received")" value="@NumberDisplay.Quantity(Model.TotalReceivedQuantityMt)" unit="MT" avatar="loading"></vc:stat-card>
        <vc:stat-card title="@T("باقی‌مانده", "Remaining")" value="@NumberDisplay.Quantity(Model.RemainingToReceiveMt)" unit="MT" avatar="stock-shortage"></vc:stat-card>
        <vc:stat-card title="@T("اختلاف تخصیص", "Allocation difference")" value="@NumberDisplay.Quantity(Model.AllocationDifferenceMt)" unit="MT" avatar="losses"></vc:stat-card>
    </section>

    <div class="ak-form-grid">
        <section class="ak-form-section ak-detail-section">
            <header class="ak-section-head ak-detail-section-header"><i class="bi bi-truck"></i> <h2>خلاصه بارگیری</h2></header>
            <dl class="ak-form-grid">
                <div><dt>ثبت بارگیری</dt><dd>#@Model.LoadingRegisterId</dd></div>
                <div><dt>تاریخ بارگیری</dt><dd>@Model.LoadingDate.ToDisplayDate()</dd></div>
                <div><dt>قرارداد</dt><dd>@Model.ContractNumber</dd></div>
                <div><dt>جنس</dt><dd>@Model.ProductName</dd></div>
                <div><dt>مقدار بارگیری</dt><dd>@NumberDisplay.Quantity(Model.LoadedQuantityMt) MT</dd></div>
                <div><dt>بارنامه</dt><dd>@(Model.BillOfLadingNumber ?? "-")</dd></div>
                <div><dt>واگن</dt><dd>@(Model.WagonNumber ?? "-")</dd></div>
                <div><dt>گیرنده</dt><dd>@(Model.ConsigneeName ?? "-")</dd></div>
                <div><dt>مقصد</dt><dd>@(Model.DestinationName ?? "-")</dd></div>
            </dl>
        </section>

        <section class="ak-form-section ak-detail-section">
            <header class="ak-section-head ak-detail-section-header"><i class="bi bi-box-arrow-in-down"></i> <h2>مشخصات رسید</h2></header>
            <dl class="ak-form-grid">
                <div><dt>مقصد رسید</dt><dd>@receiptDestinationText</dd></div>
                <div><dt>تاریخ رسید</dt><dd>@Model.ReceiptDate.ToDisplayDate()</dd></div>
                <div><dt>ورود واقعی</dt><dd>@(Model.ArrivalDate?.ToDisplayDate() ?? "-")</dd></div>
                <div><dt>نشت / خرابی</dt><dd>@(Model.LeakDate?.ToDisplayDate() ?? "-")</dd></div>
                <div>
                    <dt>مقدار واقعی</dt>
                    <dd>
                        @NumberDisplay.Quantity(Model.ActualArrivedQuantityMt)
                        @if (actualDiffMt.HasValue && actualDiffMt.Value != 0)
                        {
                            <span class="@(actualDiffMt.Value < 0 ?"is-neg" : "")">@(actualDiffMt.Value > 0 ? "+" : "")@NumberDisplay.Quantity(actualDiffMt.Value) MT</span>
                        }
                    </dd>
                </div>
                <div><dt>ترمینال</dt><dd>@Model.TerminalName</dd></div>
                <div><dt>مخزن</dt><dd>@(isDirectDispatchReceipt ? "وارد تانک نشده" : isMixedReceipt ? "بر اساس خط تخصیص" : (Model.StorageTankCode ?? "-"))</dd></div>
                <div><dt>مقدار رسید</dt><dd>@NumberDisplay.Quantity(Model.ReceivedQuantityMt) MT</dd></div>
                <div><dt>مرجع رسید</dt><dd>@(Model.ReferenceDocument ?? "-")</dd></div>
                <div><dt>حرکت موجودی</dt><dd>@(Model.InventoryMovementId == 0 ? (isDirectDispatchReceipt ? "ندارد - تخلیه مستقیم" : "-") : $"#{Model.InventoryMovementId}")</dd></div>
                <div><dt>یادداشت</dt><dd>@(string.IsNullOrWhiteSpace(Model.Notes) ? "-" : Model.Notes)</dd></div>
            </dl>
        </section>

        <section class="ak-form-section ak-detail-section">
            <header class="ak-section-head ak-detail-section-header"><i class="bi bi-diagram-3"></i> <h2>تخصیص و وضعیت</h2></header>
            <dl class="ak-form-grid">
                <div><dt>جمع تخصیص</dt><dd>@NumberDisplay.Quantity(Model.TotalAllocatedQuantityMt) MT</dd></div>
                <div><dt>ورود به موجودی</dt><dd>@NumberDisplay.Quantity(qtyToInventory) MT</dd></div>
                <div><dt>موتر برای مخزن</dt><dd>@NumberDisplay.Quantity(qtyTruckForTank) MT</dd></div>
                <div><dt>موتر برای فروش</dt><dd>@NumberDisplay.Quantity(qtyTruckForCustomer) MT</dd></div>
                <div><dt>فروش مستقیم</dt><dd>@NumberDisplay.Quantity(qtyDirectSale) MT</dd></div>
                <div><dt>انتقال ترمینال</dt><dd>@NumberDisplay.Quantity(qtyTransfer) MT</dd></div>
                <div><dt>در مسیر / ردیابی</dt><dd>@NumberDisplay.Quantity(qtyInTransit) MT</dd></div>
                <div><dt>تکمیل شده</dt><dd>@NumberDisplay.Quantity(qtyCompleted) MT</dd></div>
                <div><dt>اختلاف</dt><dd class="@(allocBalanced ?"" : "is-neg")">@NumberDisplay.Quantity(Model.AllocationDifferenceMt) MT</dd></div>
            </dl>
        </section>
    </div>

    <div class="ak-form-grid">
        <section class="ak-form-section ak-detail-section">
            <header class="ak-section-head ak-detail-section-header"><i class="bi bi-list-check"></i> <h2>ردیف‌های رسید</h2>
                <span class="ak-status">@Model.Allocations.Count</span>
            </header>
            <div class="ak-list">
                @foreach (var allocation in Model.Allocations)
                {
                    var traceDestination = FormatTraceDestination(allocation);
                    <div class="ak-list-row">
                        <div class="ak-col-grow">
                            <span>@ToAllocationStatusText(allocation.Status)</span>
                            <strong>@ToAllocationDestinationText(allocation.Destination)</strong>
                            <span>@traceDestination</span>
                        </div>
                        <div class="ak-num">
                            <strong class="fw-semibold">@NumberDisplay.Quantity(allocation.QuantityMt) MT</strong>
                            <span>@(allocation.InventoryMovementId.HasValue ? $"Movement #{allocation.InventoryMovementId.Value}" : (allocation.ReferenceDocument ?? "-"))</span>
                        </div>
                        @if (allocation.Destination == LoadingReceiptAllocationDestination.DirectDispatchToTruck
                            && allocation.DirectTruckDispatchRemainingQuantityMt > 0
                            && allocation.Status != LoadingReceiptAllocationStatus.Cancelled)
                        {
                            <a class="btn btn-light"
                               asp-controller="Dispatch"
                               asp-action="CreateDirectFromReceipt"
                               asp-route-allocationId="@allocation.Id"
                               asp-route-returnUrl="@currentReturnUrl">ارسال با موتر</a>
                        }
                    </div>
                }
                @if (Model.Allocations.Count == 0)
                {
                    <div class="ak-empty ak-detail-empty-state">هیچ تخصیصی برای این رسید ثبت نشده است.</div>
                }
            </div>
        </section>

        <section class="ak-form-section ak-detail-section">
            <header class="ak-section-head ak-detail-section-header"><i class="bi bi-exclamation-diamond"></i> <h2>ضایعات / اختلاف</h2>
                <span class="ak-status">@NumberDisplay.Quantity(lossDifferenceTotal) MT</span>
            </header>
            <div class="ak-list">
                @foreach (var loss in Model.LossItems)
                {
                    <div class="ak-list-row">
                        <div class="ak-col-grow">
                            <span>@loss.EventDate.ToDisplayDate()</span>
                            <strong>@loss.Stage</strong>
                            <span>@(loss.Reference ?? loss.Notes ?? "-")</span>
                        </div>
                        <div class="ak-num">
                            <strong class="text-danger">@NumberDisplay.Quantity(loss.DifferenceQuantityMt) MT</strong>
                            <span>قابل محاسبه @NumberDisplay.Quantity(loss.ChargeableLossMt) MT</span>
                        </div>
                    </div>
                }
                @if (Model.LossItems.Count == 0)
                {
                    <div class="ak-empty ak-detail-empty-state">برای این رسید کسری ثبت نشده است.</div>
                }
            </div>
        </section>

        <section class="ak-form-section ak-detail-section">
            <header class="ak-section-head ak-detail-section-header"><i class="bi bi-signpost-split"></i> <h2>ردیابی و سندها</h2>
                <span class="ak-status @(pendingDispatchTrace ?"ak-status-amber" : "ak-status-mint")">@(pendingDispatchTrace ? "در انتظار" : "تکمیل")</span>
            </header>
            <div class="ak-list">
                <div class="ak-list-row">
                    <div class="ak-col-grow">
                        <span>نوع رسید</span>
                        <strong>@receiptDestinationText</strong>
                    </div>
                    <div class="ak-num">
                        <strong>@(isDirectDispatchReceipt ? T("بدون ورود به موجودی", "No inventory entry") : isMixedReceipt ? T("بر اساس خط تخصیص", "Allocation based") : T("ثبت موجودی", "Inventory entry"))</strong>
                        <span>@(pendingDispatchTrace ? "در انتظار ارسال با موتر" : "ثبت شده")</span>
                    </div>
                </div>
                <div class="ak-list-row">
                    <div class="ak-col-grow">
                        <span>فروش مستقیم</span>
                        <strong>@NumberDisplay.Quantity(qtyDirectSale) MT</strong>
                    </div>
                    <div class="ak-num">
                        <strong>موتر فروش @NumberDisplay.Quantity(qtyTruckForCustomer) MT</strong>
                        <span>انتقال @NumberDisplay.Quantity(qtyTransfer) MT</span>
                    </div>
                </div>
                <div class="ak-list-row">
                    <div class="ak-col-grow">
                        <span>مرجع</span>
                        <strong>@(Model.ReferenceDocument ?? "-")</strong>
                    </div>
                    <div class="ak-num">
                        <strong>#@Model.Id</strong>
                        <span>@T("بارگیری", "Loading") #@Model.LoadingRegisterId</span>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <section class="ak-form-section ak-detail-section" aria-labelledby="receipt-timeline-title">
        <h2 class="ak-section-title" id="receipt-timeline-title">@T("روند رسید", "Receipt timeline")</h2>
        <partial name="~/Views/Shared/Partials/_DetailTimeline.cshtml" model="@((IReadOnlyList<AkTimelineItem>)timelineItems)" />
    </section>
    <section class="ak-form-section ak-detail-section" aria-labelledby="receipt-related-title">
        <h2 class="ak-section-title" id="receipt-related-title">@T("رکوردهای مرتبط", "Related records")</h2>
        <partial name="~/Views/Shared/Partials/_RelatedRecords.cshtml" model="@((IReadOnlyList<AkRelatedRecord>)relatedRecords)" />
    </section>
    <partial name="~/Views/Shared/Partials/_DetailActionBar.cshtml" model="@((IReadOnlyList<AkHeaderMenuItem>)nextActions)" />

</div>
