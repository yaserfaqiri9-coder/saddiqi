                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="asset-shares" role="tabpanel" hidden="@(activeAssetTab != "shares")">
