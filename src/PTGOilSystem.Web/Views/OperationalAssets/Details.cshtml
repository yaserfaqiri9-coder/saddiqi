                                    </div>
                                </div>
                            </div>
                            <div data-oa-rent-internal-party hidden>
                                <div class="ak-field">
                                    <label class="ak-label">@UiText.T(Context, "نوع طرف حساب داخلی", "Internal Counterparty Type")</label>
