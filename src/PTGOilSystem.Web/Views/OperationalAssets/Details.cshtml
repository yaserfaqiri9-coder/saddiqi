                    </article>
                    <article class="ak-list-row">
                        <span><i class="bi bi-list-ul"></i> @UiText.T(Context, "ردیف‌های سهم", "Share Lines")</span>
                        <strong>@rentShareRowCount.ToString("N0")</strong>
                        <small>@UiText.T(Context, "کل ردیف‌های توزیع سهم", "Total owner share lines")</small>
                    </article>
