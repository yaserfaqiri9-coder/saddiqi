                    </article>
                    <article class="ak-list-row">
                        <span><i class="bi bi-people"></i> @UiText.T(Context, "مالکین درگیر", "Owners Involved")</span>
                        <strong>@rentShareOwnerCount.ToString("N0")</strong>
                        <small>@UiText.T(Context, "مالکینی که سهم گرفته‌اند", "Owners with allocated shares")</small>
                    </article>
                    <article class="ak-list-row">
                        <span><i class="bi bi-receipt"></i> @UiText.T(Context, "کرایه‌های توزیع‌شده", "Distributed Rents")</span>
