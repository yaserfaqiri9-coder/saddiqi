                        </button>
                        <a asp-action="CreateRent" asp-route-assetId="@Model.Id" class="btn btn-light ak-secondary-action">@UiText.T(Context, "فرم کامل کرایه", "Full Rent Form")</a>
                    </form>
                    <button type="button" class="btn btn-light ak-secondary-action" data-oa-reopen hidden title="@UiText.T(Context, "نمایش فرم", "Show Form")">
                        <i class="bi bi-layout-sidebar-reverse"></i>
                        <span>@UiText.T(Context, "فرم", "Form")</span>
                    </button>

                    <div>
                        <div class="ak-section-head ak-detail-section-header">
                            <h3><i class="bi bi-activity"></i> @UiText.T(Context, "تاریخچه کرایه‌ها", "Rent History")</h3>
