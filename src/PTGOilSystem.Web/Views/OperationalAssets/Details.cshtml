@model PTGOilSystem.Web.Models.OperationalAssets.OperationalAssetProfileViewModel
@using PTGOilSystem.Web.Models.Shared
@{
    ViewData["Title"] = Model.Name;
    ViewData["FinanceFormAssets"] = true;
    var activeShareTotal = Model.OwnershipShares.Where(row => row.IsActiveNow).Sum(row => row.SharePercent);
    var allocationReady = Math.Abs(activeShareTotal - 100m) <= 0.0001m;
    var activeOwnerCount = Model.OwnershipShares.Count(row => row.IsActiveNow);
    var externalRentRows = Model.RentTransactions.Where(row => row.UsageType == AssetRentUsageType.ExternalCustomerRental).ToList();
    var internalRentRows = Model.RentTransactions.Where(row => row.UsageType == AssetRentUsageType.InternalCompanyUse).ToList();
    var rentRowCount = Model.RentTransactions.Count;
    var rentAverageUsd = rentRowCount == 0 ? 0m : Model.RentTransactions.Sum(row => row.AmountUsd) / rentRowCount;
    var latestRentDate = Model.RentTransactions.OrderByDescending(row => row.RentDate).FirstOrDefault()?.RentDate;
    var expenseRowCount = Model.Expenses.Count;
    var expenseCategoryCount = Model.Expenses.Select(row => row.ExpenseTypeName).Where(name => !string.IsNullOrWhiteSpace(name)).Distinct().Count();
    var latestExpenseDate = Model.Expenses.OrderByDescending(row => row.ExpenseDate).FirstOrDefault()?.ExpenseDate;
    var rentShareRowCount = Model.RentShares.Count;
    var rentShareOwnerCount = Model.RentShares.Select(row => row.OwnerName).Where(name => !string.IsNullOrWhiteSpace(name)).Distinct().Count();
    var rentShareRentCount = Model.RentShares.Select(row => row.RentTransactionId).Distinct().Count();
    var totalOwnerShareUsd = Model.RentShares.Sum(row => row.ShareAmountUsd);
    var totalCostUsd = Model.DirectExpensesUsd + Model.DepreciationUsd;
    var isNetPositive = Model.NetResultUsd >= 0;
    var activeAssetTab = Context.Request.Query["tab"].ToString().Trim().ToLowerInvariant();
    activeAssetTab = activeAssetTab is "ownership" or "rents" or "expenses" or "shares" or "profit"
        ? activeAssetTab
        : "overview";
    var editUrl = Url.Action("Edit", new { id = Model.Id }) ?? "#";
    var rentUrl = Url.Action("CreateRent", new { assetId = Model.Id }) ?? "#";
    ViewData["AkHeaderStatus"] = Model.IsActive ? UiText.T(Context, "فعال", "Active") : UiText.T(Context, "غیرفعال", "Inactive");
    ViewData["AkHeaderStatusState"] = Model.IsActive ? "is-active" : "is-inactive";
    ViewData["AkHeaderContext"] = $"{Model.AssetCode} · {OperationalAssetLabels.AssetType(Model.AssetType, Context)}";
    ViewData["AkHeaderKebab"] = new List<AkHeaderMenuItem>
    {
        new() { Label = UiText.T(Context, "ثبت مصرف", "Record expense"), Href = Url.Action("Create", "Expenses", new { operationalAssetId = Model.Id, returnUrl = Context.Request.Path }), Icon = "bi-receipt-cutoff" },
        new() { Label = UiText.T(Context, "ویرایش", "Edit"), Href = editUrl, Icon = "bi-pencil" }
    };
    var assetTabs = new[]
    {
        $"overview|{UiText.T(Context, "خلاصه وضعیت", "Status Summary")}|bi-grid-1x2|{(activeAssetTab == "overview" ? "active" : "")}",
        $"ownership|{UiText.T(Context, "مالکیت و سهم‌ها", "Ownership and Shares")}|bi-people|{(activeAssetTab == "ownership" ? "active" : "")}",
        $"rents|{UiText.T(Context, "استفاده / کرایه", "Use / Rent")}|bi-calendar-check|{(activeAssetTab == "rents" ? "active" : "")}",
        $"expenses|{UiText.T(Context, "مصارف", "Expenses")}|bi-receipt-cutoff|{(activeAssetTab == "expenses" ? "active" : "")}",
        $"shares|{UiText.T(Context, "توزیع سود مالکین", "Owner Profit Distribution")}|bi-pie-chart|{(activeAssetTab == "shares" ? "active" : "")}",
        $"profit|{UiText.T(Context, "سود", "Profit")}|bi-graph-up-arrow|{(activeAssetTab == "profit" ? "active" : "")}"
    };
}

<div class="ak-form-page ak-detail-page" data-ak-detail-v2="true">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((Model.Name, false,
                       UiText.T(Context, "ثبت کرایه", "Record rent"), "bi-calendar-plus", rentUrl, (string?)null,
                       UiText.T(Context, "بازگشت", "Back"), "bi-arrow-right", (string?)Url.Action("Index")))" />
    <section class="ak-form-section ak-detail-section" aria-label="@UiText.T(Context, "پرونده دارایی عملیاتی", "Operational asset profile")">
        <partial name="~/Views/Shared/Partials/_DetailsTabs.cshtml"
                 model="@(UiText.T(Context, "بخش‌های دارایی", "Asset sections"), assetTabs)" />

        <div class="tab-content ak-detail-content">
            <div class="tab-pane fade show active" id="asset-overview" role="tabpanel" hidden="@(activeAssetTab != "overview")">
                <div class="ak-section-head ak-detail-section-header">
                    <h3><i class="bi bi-clipboard-data"></i> @UiText.T(Context, "مشخصات پایه دارایی", "Asset Basic Details")</h3>
                </div>
                <div class="ak-list" aria-label="@UiText.T(Context, "خلاصه دارایی", "Asset summary")">
                    <article class="ak-list-row">
                        <span><i class="bi bi-hash"></i> @UiText.T(Context, "کد دارایی", "Asset Code")</span>
                        <strong>@Model.AssetCode</strong>
                        <small>@Model.Name</small>
                    </article>
                    <article class="ak-list-row">
                        <span><i class="bi bi-box-seam"></i> @UiText.T(Context, "نوع دارایی", "Asset Type")</span>
                        <strong>@OperationalAssetLabels.AssetType(Model.AssetType, Context)</strong>
                        <small>@(Model.LinkedResourceText ?? UiText.T(Context, "منبع مرتبط ثبت نشده", "No linked resource"))</small>
                    </article>
                    <article class="ak-list-row">
                        <span><i class="bi bi-diagram-3"></i> @UiText.T(Context, "نوع مالکیت", "Ownership Mode")</span>
                        <strong>@OperationalAssetLabels.OwnershipMode(Model.OwnershipMode, Context)</strong>
                        <small>@UiText.T(Context, "ساختار مالکیت دارایی", "Asset ownership structure")</small>
                    </article>
                    <article class="ak-list-row">
                        <span><i class="bi bi-check-circle"></i> @UiText.T(Context, "وضعیت", "Status")</span>
                        <strong class="@(Model.IsActive ?"" : "")">@(Model.IsActive ? UiText.T(Context, "فعال", "Active") : UiText.T(Context, "غیرفعال", "Inactive"))</strong>
                        <small>@UiText.T(Context, "وضعیت استفاده عملیاتی", "Operational usage status")</small>
                    </article>
                </div>

                <div class="ak-form-grid">
                    <dl class="ak-list">
                        <div>
                            <dt>@UiText.T(Context, "ظرفیت", "Capacity")</dt>
                            <dd>@(Model.CapacityMt.HasValue ? Model.CapacityMt.Value.ToString("N2") + " MT" : "-")</dd>
                        </div>
                        <div>
                            <dt>@UiText.T(Context, "موقعیت", "Location")</dt>
                            <dd>@(Model.LocationName ?? "-")</dd>
                        </div>
                        <div>
                            <dt>@UiText.T(Context, "ترمینال", "Terminal")</dt>
                            <dd>@(Model.TerminalName ?? "-")</dd>
                        </div>
                        <div>
                            <dt>@UiText.T(Context, "یادداشت", "Notes")</dt>
                            <dd>@(Model.Notes ?? "-")</dd>
                        </div>
                    </dl>

                    <dl class="ak-list">
                        <div>
                            <dt>@UiText.T(Context, "استهلاک ماهانه", "Monthly Depreciation")</dt>
                            <dd>$ @Model.MonthlyDepreciationUsd.ToString("N2")</dd>
                        </div>
                        <div>
                            <dt>@UiText.T(Context, "نرخ داخلی پیش‌فرض", "Default Internal Rate")</dt>
                            <dd>@(Model.DefaultInternalRateUsd.HasValue ? "$ " + Model.DefaultInternalRateUsd.Value.ToString("N2") : "-")</dd>
                        </div>
                        <div>
                            <dt>@UiText.T(Context, "نرخ بیرونی پیش‌فرض", "Default External Rate")</dt>
                            <dd>@(Model.DefaultExternalRateUsd.HasValue ? "$ " + Model.DefaultExternalRateUsd.Value.ToString("N2") : "-")</dd>
                        </div>
                        <div>
                            <dt>@UiText.T(Context, "دوره فعلی گزارش", "Current Report Period")</dt>
                            <dd>@Model.FromDate.ToDisplayDate() - @Model.ToDate.ToDisplayDate()</dd>
                        </div>
                    </dl>
                </div>
            </div>

            <div class="tab-pane fade" id="asset-profit" role="tabpanel" hidden="@(activeAssetTab != "profit")">
                <div class="ak-form-section ak-detail-section" aria-label="@UiText.T(Context, "گزارش عملکرد مالی دارایی", "Asset financial performance report")">
                    <div class="ak-section-head ak-detail-section-header">
                        <form method="get" class="ak-detail-toolbar" aria-label="@UiText.T(Context, "فیلتر دوره", "Period filter")">
                            <input name="tab" value="profit" type="hidden" />
                            <button class="btn btn-light ak-secondary-action" type="submit" title="@UiText.T(Context, "اعمال فیلتر", "Apply Filter")">
                                <i class="bi bi-sliders2"></i>
                            </button>
                            <input name="fromDate" value="@Model.FromDate.ToString("yyyy-MM-dd")" type="date" aria-label="@UiText.T(Context, "از تاریخ", "From date")" />
                            <span>@UiText.T(Context, "تا", "to")</span>
                            <input name="toDate" value="@Model.ToDate.ToString("yyyy-MM-dd")" type="date" aria-label="@UiText.T(Context, "تا تاریخ", "To date")" />
                        </form>
                        <div>
                            <h2>@UiText.T(Context, "گزارش عملکرد مالی", "Financial Performance Report")</h2>
                            <p>@UiText.T(Context, "شفاف‌سازی درآمدها و مصارف دارایی", "Transparent asset revenue and expense summary")</p>
                        </div>
                    </div>

                    <div></div>

                    <div class="ak-list-row">
                        <span>@UiText.T(Context, "سود خالص", "Net Profit") <b>(NET PROFIT)</b></span>
                        <strong class="@(isNetPositive ?"is-positive" : "is-negative")">
                            <small>USD</small>
                            @Model.NetResultUsd.ToString("N0")
                        </strong>
                        <em class="@(isNetPositive ?"is-positive" : "is-negative")">
                            <i class="bi @(isNetPositive ?"bi-graph-up-arrow" : "bi-graph-down-arrow")"></i>
                            @(isNetPositive ? UiText.T(Context, "عملکرد مثبت در این دوره", "Positive performance in this period") : UiText.T(Context, "عملکرد منفی در این دوره", "Negative performance in this period"))
                        </em>
                    </div>

                    <div class="ak-list">
                        <article class="ak-list-row">
                            <div>
                                <span><i class="bi bi-graph-down"></i></span>
                                <div>
                                    <p>@UiText.T(Context, "مجموع مصارف", "Total Costs")</p>
                                    <strong><small>USD</small> @totalCostUsd.ToString("N0")</strong>
                                </div>
                            </div>
                            <dl>
                                <div>
                                    <dt>@UiText.T(Context, "مصارف و نگهداری", "Maintenance and expenses")</dt>
                                    <dd>$ @Model.DirectExpensesUsd.ToString("N0")</dd>
                                </div>
                                <div>
                                    <dt>@UiText.T(Context, "استهلاک دوره‌ای", "Periodic depreciation")</dt>
                                    <dd>$ @Model.DepreciationUsd.ToString("N0")</dd>
                                </div>
                            </dl>
                        </article>

                        <article class="ak-list-row">
                            <div>
                                <span><i class="bi bi-graph-up-arrow"></i></span>
                                <div>
                                    <p>@UiText.T(Context, "مجموع درآمدها", "Total Revenue")</p>
                                    <strong><small>USD</small> @Model.TotalRentUsd.ToString("N0")</strong>
                                </div>
                            </div>
                            <dl>
                                <div>
                                    <dt>@UiText.T(Context, "کرایه خارجی (مشتریان)", "External rent from customers")</dt>
                                    <dd>$ @Model.ExternalRentUsd.ToString("N0")</dd>
                                </div>
                                <div>
                                    <dt>@UiText.T(Context, "کرایه داخلی (ون و شرکت)", "Internal rent by company")</dt>
                                    <dd>$ @Model.InternalRentUsd.ToString("N0")</dd>
                                </div>
                            </dl>
                        </article>
                    </div>

                    <div class="ak-table-wrap">
                        <table class="ak-table ak-detail-table">
                            <thead>
                                <tr>
                                    <th>@UiText.T(Context, "شرح", "Description")</th>
                                    <th class="text-end">@UiText.T(Context, "مبلغ USD", "Amount USD")</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>@UiText.T(Context, "جمع درآمد کرایه و استفاده", "Total rent and use revenue")</td>
                                    <td class="text-end"><span>@Model.TotalRentUsd.ToString("N2")</span></td>
                                </tr>
                                <tr>
                                    <td>@UiText.T(Context, "درآمد کرایهٔ حمل/رسید (دارایی شرکت)", "Transport/receipt freight income")</td>
                                    <td class="text-end"><span>@Model.FreightIncomeUsd.ToString("N2")</span></td>
                                </tr>
                                <tr>
                                    <td>@UiText.T(Context, "مصارف مستقیم دارایی", "Direct asset expenses")</td>
                                    <td class="text-end"><span>@Model.DirectExpensesUsd.ToString("N2")</span></td>
                                </tr>
                                <tr>
                                    <td>@UiText.T(Context, "استهلاک محاسباتی دوره", "Calculated period depreciation")</td>
                                    <td class="text-end"><span>@Model.DepreciationUsd.ToString("N2")</span></td>
                                </tr>
                                <tr>
                                    <td><strong>@UiText.T(Context, "نتیجه خالص", "Net result")</strong></td>
                                    <td class="text-end"><strong class="@(isNetPositive ?"" : "")">@Model.NetResultUsd.ToString("N2")</strong></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="asset-ownership" role="tabpanel" hidden="@(activeAssetTab != "ownership")">
                <div class="ak-list" aria-label="@UiText.T(Context, "آمار مالکیت", "Ownership statistics")">
                    <article class="ak-list-row">
                        <span><i class="bi bi-percent"></i> @UiText.T(Context, "مجموع سهم فعال", "Active Share Total")</span>
                        <strong class="@(allocationReady ?"" : "")">@activeShareTotal.ToString("N0")%</strong>
                        <small>@UiText.T(Context, "برای ثبت کرایه باید 100٪ باشد", "Must be 100% for rent recording")</small>
                    </article>
                    <article class="ak-list-row">
                        <span><i class="bi bi-people"></i> @UiText.T(Context, "مالکین فعال", "Active Owners")</span>
                        <strong>@activeOwnerCount.ToString("N0")</strong>
                        <small>@UiText.T(Context, "مالک یا شریک فعال در تاریخ امروز", "Active owners or partners today")</small>
                    </article>
                    <article class="ak-list-row">
                        <span><i class="bi bi-list-check"></i> @UiText.T(Context, "ردیف‌های سهم", "Share Rows")</span>
                        <strong>@Model.OwnershipShares.Count.ToString("N0")</strong>
                        <small>@UiText.T(Context, "کل تاریخچه سهم‌های ثبت‌شده", "Total recorded share history")</small>
                    </article>
                    <article class="ak-list-row">
                        <span><i class="bi bi-check-circle"></i> @UiText.T(Context, "آماده ثبت کرایه", "Ready for Rent")</span>
                        <strong class="@(allocationReady ?"" : "")">@(allocationReady ? UiText.T(Context, "بلی", "Yes") : UiText.T(Context, "نخیر", "No"))</strong>
                        <small>@UiText.T(Context, "کنترل تخصیص مالکیت", "Ownership allocation control")</small>
                    </article>
                </div>

                <div class="ak-form-grid" data-oa-split>
                    <form asp-action="AddOwnershipShare" method="post" class="ak-form-section ak-detail-section ak-form" data-oa-owner-form>
                        @Html.AntiForgeryToken()
                        <input name="OperationalAssetId" value="@Model.Id" type="hidden" />
                        <div class="ak-section-head ak-detail-section-header">
                            <span>@UiText.T(Context, "افزودن سهم جدید", "Add New Share")</span>
                            <div >
                                <button type="button" class="btn btn-light ak-secondary-action" data-oa-collapse title="@UiText.T(Context, "جمع/باز کردن فرم", "Toggle form")">
                                    <i class="bi bi-layout-sidebar-reverse"></i>
                                </button>
                                <i class="bi bi-plus-lg"></i>
                            </div>
                        </div>
                        <div class="ak-form-grid">
                            <div class="ak-field">
                                <label asp-for="NewOwnershipShare.OwnerType" class="ak-label">@UiText.T(Context, "نوع مالک", "Owner Type")</label>
                                <select asp-for="NewOwnershipShare.OwnerType" name="OwnerType" asp-items="ViewBag.OwnerTypes" class="ak-input" data-oa-owner-type></select>
                            </div>
                            <div>
                                <div class="ak-field" data-oa-owner-field="company">
                                    <label asp-for="NewOwnershipShare.CompanyId" class="ak-label">@UiText.T(Context, "شرکت", "Company")</label>
                                    <select asp-for="NewOwnershipShare.CompanyId" name="CompanyId" asp-items="ViewBag.Companies" class="ak-input">
                                        <option value="">@UiText.T(Context, "انتخاب کنید...", "Select...")</option>
                                    </select>
                                </div>
                                <div class="ak-field" data-oa-owner-field="partner">
                                    <label asp-for="NewOwnershipShare.PartnerId" class="ak-label">@UiText.T(Context, "شریک", "Partner")</label>
                                    <select asp-for="NewOwnershipShare.PartnerId" name="PartnerId" asp-items="ViewBag.Partners" class="ak-input">
                                        <option value="">@UiText.T(Context, "انتخاب کنید...", "Select...")</option>
                                    </select>
                                </div>
                                <div class="ak-field" data-oa-owner-field="other">
                                    <label asp-for="NewOwnershipShare.OwnerName" class="ak-label">@UiText.T(Context, "نام مالک دیگر", "Other Owner Name")</label>
                                    <input asp-for="NewOwnershipShare.OwnerName" name="OwnerName" class="ak-input" placeholder="@UiText.T(Context, "برای مالک بیرونی یا حساب دیگر", "For external owner or other account")" />
                                </div>
                            </div>
                        </div>
                        <div class="ak-form-grid">
                            <div class="ak-field">
                                <label asp-for="NewOwnershipShare.SharePercent" class="ak-label">@UiText.T(Context, "درصد سهم (%)", "Share Percent (%)")</label>
                                <input asp-for="NewOwnershipShare.SharePercent" name="SharePercent" class="ak-input" placeholder="@UiText.T(Context, "مثلاً 20", "For example 20")" />
                            </div>
                            <div class="ak-field">
                                <label asp-for="NewOwnershipShare.EffectiveFrom" class="ak-label">@UiText.T(Context, "تاریخ اجرا", "Effective Date")</label>
                                <input asp-for="NewOwnershipShare.EffectiveFrom" name="EffectiveFrom" type="date" class="ak-input" />
                            </div>
                        </div>
                        <div class="ak-field">
                            <label asp-for="NewOwnershipShare.Notes" class="ak-label">@UiText.T(Context, "یادداشت", "Notes")</label>
                            <textarea asp-for="NewOwnershipShare.Notes" name="Notes" rows="2" class="ak-input"></textarea>
                        </div>
                        <button type="submit" class="ak-save">@UiText.T(Context, "ثبت سهم", "Save Share")</button>
                    </form>
                    <button type="button" class="btn btn-light ak-secondary-action" data-oa-reopen hidden title="@UiText.T(Context, "نمایش فرم", "Show Form")">
                        <i class="bi bi-layout-sidebar-reverse"></i>
                        <span>@UiText.T(Context, "فرم", "Form")</span>
                    </button>

                    <div>
                        <div class="ak-table-wrap">
                            <table class="ak-table ak-detail-table">
                                <thead>
                                    <tr>
                                        <th>@UiText.T(Context, "نام مالک / شرکت", "Owner / Company")</th>
                                        <th>@UiText.T(Context, "نوعیت", "Type")</th>
                                        <th class="text-end">@UiText.T(Context, "درصد سهم", "Share Percent")</th>
                                        <th>@UiText.T(Context, "تاریخ اجرا", "Effective Date")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var row in Model.OwnershipShares)
                                {
                                    <tr>
                                        <td><strong>@row.OwnerName</strong></td>
                                        <td><span class="ak-status">@OperationalAssetLabels.OwnerType(row.OwnerType, Context)</span></td>
                                        <td class="text-end"><span>@row.SharePercent.ToString("N0")%</span></td>
                                        <td>@row.EffectiveFrom.ToDisplayDate()</td>
                                    </tr>
                                }
                                @if (!Model.OwnershipShares.Any())
                                {
                                    <tr>
                                        <td colspan="4">
                                            @await Html.PartialAsync("_EmptyState", (UiText.T(Context, "سهم مالکیت ثبت نشده", "No ownership shares"), UiText.T(Context, "قبل از ثبت کرایه/استفاده، سهم مالکین را اضافه کنید.", "Add owner shares before recording rent/use."), "bi-diagram-3"))
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="asset-rents" role="tabpanel" hidden="@(activeAssetTab != "rents")">
                <div class="ak-list" aria-label="@UiText.T(Context, "آمار کرایه و استفاده", "Rent and use statistics")">
                    <article class="ak-list-row">
                        <span><i class="bi bi-box-arrow-up-right"></i> @UiText.T(Context, "عواید کرایه بیرونی", "External Rent Revenue")</span>
                        <strong>@Model.ExternalRentUsd.ToString("N0")</strong>
                        <small>@externalRentRows.Count.ToString("N0") @UiText.T(Context, "ثبت کرایه بیرونی", "external rent rows")</small>
                    </article>
                    <article class="ak-list-row">
                        <span><i class="bi bi-building-check"></i> @UiText.T(Context, "استفاده داخلی شرکت", "Company Internal Use")</span>
                        <strong>@Model.InternalRentUsd.ToString("N0")</strong>
                        <small>@internalRentRows.Count.ToString("N0") @UiText.T(Context, "ثبت استفاده داخلی", "internal use rows")</small>
                    </article>
                    <article class="ak-list-row">
                        <span><i class="bi bi-receipt"></i> @UiText.T(Context, "تعداد ثبت‌ها", "Recorded Rows")</span>
                        <strong>@rentRowCount.ToString("N0")</strong>
                        <small>@UiText.T(Context, "کرایه بیرونی و استفاده داخلی", "External rent and internal use")</small>
                    </article>
                    <article class="ak-list-row">
                        <span><i class="bi bi-calendar-check"></i> @UiText.T(Context, "آخرین کرایه", "Latest Rent")</span>
                        <strong>@(latestRentDate?.ToDisplayDate() ?? "-")</strong>
                        <small>@UiText.T(Context, "میانگین مبلغ", "Average Amount") @rentAverageUsd.ToString("N0")</small>
                    </article>
                </div>

                <div class="ak-form-grid" data-oa-split>
