                                {
                                    <tr>
                                        <td colspan="5">
                                            @await Html.PartialAsync("_EmptyState", (UiText.T(Context, "ردیف کرایه/استفاده وجود ندارد", "No rent/use rows"), UiText.T(Context, "برای دوره انتخاب‌شده استفاده داخلی یا کرایه بیرونی ثبت کنید.", "Record internal use or external rent for the selected period."), "bi-receipt"))
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="asset-expenses" role="tabpanel" hidden="@(activeAssetTab != "expenses")">
                <div class="ak-section-head ak-detail-section-header">
                    <h3>@UiText.T(Context, "تاریخچه مصارف و مصارف", "Expense History")</h3>
                </div>
                <div class="ak-list" aria-label="@UiText.T(Context, "آمار مصارف", "Expense statistics")">
                    <article class="ak-list-row">
                        <span><i class="bi bi-wallet2"></i> @UiText.T(Context, "جمع مصارف", "Total Expenses")</span>
                        <strong>@Model.DirectExpensesUsd.ToString("N0")</strong>
                        <small>@UiText.T(Context, "مصارف مستقیم همین دارایی", "Direct expenses for this asset")</small>
                    </article>
                    <article class="ak-list-row">
                        <span><i class="bi bi-receipt-cutoff"></i> @UiText.T(Context, "تعداد سندها", "Document Count")</span>
                        <strong>@expenseRowCount.ToString("N0")</strong>
                        <small>@UiText.T(Context, "سندهای مصرف در همین دوره", "Expense documents in this period")</small>
                    </article>
                    <article class="ak-list-row">
                        <span><i class="bi bi-tags"></i> @UiText.T(Context, "دسته‌بندی‌ها", "Categories")</span>
                        <strong>@expenseCategoryCount.ToString("N0")</strong>
                        <small>@UiText.T(Context, "نوع مصارف استفاده‌شده", "Used expense categories")</small>
                    </article>
                    <article class="ak-list-row">
                        <span><i class="bi bi-calendar-check"></i> @UiText.T(Context, "آخرین مصرف", "Latest Expense")</span>
