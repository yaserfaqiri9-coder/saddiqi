                                @UiText.T(Context, "فیلتر پیشرفته", "Advanced Filter")
                            </button>
                        </div>
                        <div class="ak-table-wrap">
                            <table class="ak-table ak-detail-table">
                                <thead>
                                    <tr>
                                        <th>@UiText.T(Context, "شماره سند", "Document No.")</th>
                                        <th>@UiText.T(Context, "تاریخ ثبت", "Date")</th>
                                        <th>@UiText.T(Context, "نوع کرایه", "Rent Type")</th>
                                        <th>@UiText.T(Context, "مشتری / ذینفع", "Customer / Beneficiary")</th>
                                        <th class="text-end">@UiText.T(Context, "مبلغ (دالر)", "Amount (USD)")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var row in Model.RentTransactions)
                                {
                                    <tr>
                                        <td><strong>@(row.ReferenceDocument ?? ("#" + row.Id.ToString()))</strong></td>
                                        <td>@row.RentDate.ToDisplayDate()</td>
                                        <td><span class="ak-status is-blue">@OperationalAssetLabels.UsageType(row.UsageType, Context)</span></td>
                                        <td>@(string.IsNullOrWhiteSpace(row.ChargedToName) ? OperationalAssetLabels.ChargedToType(row.ChargedToType, Context) : row.ChargedToName)</td>
