                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var row in Model.RentShares)
                        {
                            <tr>
                                <td><strong>#@row.RentTransactionId</strong></td>
                                <td>@row.RentDate.ToDisplayDate()</td>
                                <td><span class="ak-status is-blue">@OperationalAssetLabels.UsageType(row.UsageType, Context)</span></td>
                                <td>@row.OwnerName</td>
                                <td class="text-end"><span>@row.SharePercent.ToString("N0")%</span></td>
                                <td class="text-end"><span>@row.ShareAmountUsd.ToString("N0")</span></td>
                            </tr>
                        }
                        @if (!Model.RentShares.Any())
                        {
                            <tr>
                                <td colspan="6">
                                    @await Html.PartialAsync("_EmptyState", (UiText.T(Context, "ردیف سهم مالکین وجود ندارد", "No owner share rows"), UiText.T(Context, "تراکنش‌های کرایه/استفاده سهم مالکین را اینجا snapshot می‌کند.", "Rent/use rows will snapshot owner shares here."), "bi-person-vcard"))
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (function () {
        document.querySelectorAll('[data-oa-collapse]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var split = btn.closest('[data-oa-split]');
                if (!split) return;
                var form = split.querySelector('form');
                var reopen = split.querySelector('[data-oa-reopen]');
                if (form) form.hidden = true;
                if (reopen) reopen.hidden = false;
            });
        });
        document.querySelectorAll('[data-oa-reopen]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var split = btn.closest('[data-oa-split]');
                if (!split) return;
                var form = split.querySelector('form');
                if (form) form.hidden = false;
                btn.hidden = true;
            });
        });
    })();
    </script>
}
