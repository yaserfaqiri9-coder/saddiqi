                        <small>@UiText.T(Context, "آخرین تاریخ ثبت مصرف", "Last expense record date")</small>
                    </article>
                </div>
                <div class="ak-form-grid" data-oa-split>
                    <form asp-controller="Expenses" asp-action="Create" method="post" class="ak-form-section ak-detail-section ak-form">
                        @Html.AntiForgeryToken()
