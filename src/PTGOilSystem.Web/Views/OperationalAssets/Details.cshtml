                        <input name="AppliedFxRateToUsd" value="1" type="hidden" />
                        <input name="ReturnUrl" value="@Context.Request.Path@Context.Request.QueryString" type="hidden" />
                        <div class="ak-section-head ak-detail-section-header">
                            <span>@UiText.T(Context, "ثبت مصرف جدید", "Record New Expense")</span>
                            <div >
                                <button type="button" class="btn btn-light ak-secondary-action" data-oa-collapse title="@UiText.T(Context, "جمع/باز کردن فرم", "Toggle form")">
                                    <i class="bi bi-layout-sidebar-reverse"></i>
                                </button>
                                <i class="bi bi-wallet2"></i>
                            </div>
                        </div>
                        <small class="ak-note">@UiText.T(Context, "مصرف مستقیم مربوط به همین دارایی عملیاتی را ثبت کنید.", "Record a direct expense linked to this operational asset.")</small>
                        <div class="ak-form-grid">
                            <div class="ak-field">
                                <label class="ak-label">@UiText.T(Context, "نوع مصرف", "Expense Type")</label>
                                <input name="ManualExpenseTypeName" class="ak-input" placeholder="@UiText.T(Context, "مثلاً تعمیر و نگهداری", "For example maintenance")" />
                            </div>
                            <div class="ak-field">
                                <label class="ak-label">@UiText.T(Context, "مبلغ (دالر)", "Amount (USD)")</label>
                                <input name="Amount" class="ak-input" placeholder="@UiText.T(Context, "مثلاً 2500", "For example 2500")" />
                            </div>
                        </div>
                        <div class="ak-field">
                            <label class="ak-label">@UiText.T(Context, "تاریخ مصرف", "Expense Date")</label>
                            <input name="ExpenseDate" type="date" class="ak-input" value="@DateTime.UtcNow.Date.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="ak-field">
                            <label class="ak-label">@UiText.T(Context, "شرح / مرجع", "Description / Reference")</label>
                            <textarea name="Description" rows="2" class="ak-input"></textarea>
                        </div>
                        <button type="submit" class="ak-save">
                            @UiText.T(Context, "ثبت مصرف", "Save Expense") <i class="bi bi-check-circle"></i>
                        </button>
                        <a asp-controller="Expenses" asp-action="Create" asp-route-operationalAssetId="@Model.Id" asp-route-returnUrl="@Context.Request.Path@Context.Request.QueryString" class="btn btn-light ak-secondary-action">@UiText.T(Context, "فرم کامل مصرف", "Full Expense Form")</a>
                    </form>
                    <button type="button" class="btn btn-light ak-secondary-action" data-oa-reopen hidden title="@UiText.T(Context, "نمایش فرم", "Show Form")">
                        <i class="bi bi-layout-sidebar-reverse"></i>
                        <span>@UiText.T(Context, "فرم", "Form")</span>
                    </button>

                    <div>
                        <div class="ak-table-wrap">
                            <table class="ak-table ak-detail-table">
                                <thead>
                                    <tr>
                                        <th>@UiText.T(Context, "شماره سند", "Document No.")</th>
                                        <th>@UiText.T(Context, "تاریخ", "Date")</th>
                                        <th>@UiText.T(Context, "دسته‌بندی مصرف", "Expense Category")</th>
                                        <th>@UiText.T(Context, "شرح مختصر", "Short Description")</th>
                                        <th class="text-end">@UiText.T(Context, "مبلغ (دالر)", "Amount (USD)")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var row in Model.Expenses)
                                {
                                    <tr>
                                        <td><strong>#@row.Id</strong></td>
                                        <td>@row.ExpenseDate.ToDisplayDate()</td>
                                        <td>
                                            <span class="ak-status">@row.ExpenseTypeName</span>
