                                        <option value="@((int)AssetRentChargedToType.Partner)">@UiText.T(Context, "شریک", "Partner")</option>
                                        <option value="@((int)AssetRentChargedToType.Customer)">@UiText.T(Context, "مشتری", "Customer")</option>
                                        <option value="@((int)AssetRentChargedToType.Other)">@UiText.T(Context, "شرکت خدماتی", "Service Company")</option>
                                    </select>
                                </div>
                                <div class="ak-field" data-oa-rent-party-field="company">
                                    <label asp-for="NewRent.ChargedToCompanyId" class="ak-label">@UiText.T(Context, "شرکت", "Company")</label>
                                    <select asp-for="NewRent.ChargedToCompanyId" name="ChargedToCompanyId" asp-items="ViewBag.Companies" class="ak-input">
                                        <option value="">@UiText.T(Context, "شرکت را انتخاب کنید...", "Select company...")</option>
                                    </select>
                                </div>
                                <div class="ak-field" data-oa-rent-party-field="partner">
                                    <label asp-for="NewRent.ChargedToPartnerId" class="ak-label">@UiText.T(Context, "شریک", "Partner")</label>
                                    <select asp-for="NewRent.ChargedToPartnerId" name="ChargedToPartnerId" asp-items="ViewBag.Partners" class="ak-input">
                                        <option value="">@UiText.T(Context, "شریک را انتخاب کنید...", "Select partner...")</option>
                                    </select>
                                </div>
                                <div class="ak-field" data-oa-rent-party-field="internal-customer">
                                    <label asp-for="NewRent.ChargedToCustomerId" class="ak-label">@UiText.T(Context, "مشتری", "Customer")</label>
                                    <select name="ChargedToCustomerId" asp-items="ViewBag.Customers" class="ak-input">
                                        <option value="">@UiText.T(Context, "مشتری را انتخاب کنید...", "Select customer...")</option>
                                    </select>
                                </div>
                                <div class="ak-field" data-oa-rent-party-field="service-provider">
                                    <label asp-for="NewRent.ChargedToServiceProviderId" class="ak-label">@UiText.T(Context, "شرکت خدماتی", "Service Company")</label>
                                    <select asp-for="NewRent.ChargedToServiceProviderId" name="ChargedToServiceProviderId" asp-items="ViewBag.ServiceProviders" class="ak-input">
                                        <option value="">@UiText.T(Context, "شرکت خدماتی را انتخاب کنید...", "Select service company...")</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="ak-field">
                            <label asp-for="NewRent.AmountOriginal" class="ak-label">@UiText.T(Context, "مبلغ کرایه (دالر)", "Rent Amount (USD)")</label>
                            <input asp-for="NewRent.AmountOriginal" name="AmountOriginal" class="ak-input" placeholder="@UiText.T(Context, "مثلاً 5000", "For example 5000")" />
                        </div>
                        <div class="ak-form-grid">
                            <div class="ak-field">
                                <label asp-for="NewRent.RentDate" class="ak-label">@UiText.T(Context, "از تاریخ", "From Date")</label>
                                <input asp-for="NewRent.RentDate" name="RentDate" type="date" class="ak-input" />
                            </div>
