@model PTGOilSystem.Web.Models.OperationalAssets.OperationalAssetIndexViewModel
@{
    ViewData["Title"] = UiText.T(Context, "دارایی‌های عملیاتی", "Operational Assets");
    ViewData["ContentBodyClass"] = "boltz-content-body-wide";
    ViewData["HideSectionTabs"] = true;

    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var totalRentIncomeUsd = Model.TotalInternalRentUsd + Model.TotalExternalRentUsd;
}

<div class="page-stack ak-list-page operational-assets-index-page">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((UiText.T(Context, "دارایی‌های عملیاتی", "Operational Assets"), true,
                       UiText.T(Context, "دارایی جدید", "New Asset"), "bi-plus-lg",
                       (string?)Url.Action("Create"), (string?)null,
                       UiText.T(Context, "ثبت کرایه", "Record Rent"), "bi-receipt", (string?)Url.Action("CreateRent")))" />

    <section class="ak-stat-grid mb-3" aria-label="@UiText.T(Context, "آمار دارایی‌های عملیاتی", "Operational asset statistics")">
        <vc:stat-card title="@UiText.T(Context, "تعداد دارایی‌ها", "Total assets")" value="@Model.TotalCount.ToString("N0")" unit="@UiText.T(Context, "دارایی", "assets")" avatar="total-inventory"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "جمع درآمد کرایه", "Total rent income")" value="@totalRentIncomeUsd.ToString("N0")" unit="USD" avatar="payments"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "درآمد حمل‌ونقل", "Freight income")" value="@Model.TotalFreightIncomeUsd.ToString("N0")" unit="USD" avatar="shipments"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "نتیجه خالص", "Net result")" value="@Model.TotalNetResultUsd.ToString("N0")" unit="USD" avatar="profit-loss"></vc:stat-card>
    </section>

    @{
        List<AkFilterOption> OaOpts(object? s) => (s as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>
            ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
            .Select(i => new AkFilterOption(i.Value, i.Text)).ToList();
        string? OaQ(string k) { var v = Context.Request.Query[k].ToString(); return string.IsNullOrEmpty(v) ? null : v; }
        var oaFilter = new AkSearchFilterModel("Filter.Query", Model.Filter.Query,
            UiText.T(Context, "کد، نام، نمبر پلیت موتر، کد مخزن...", "Code, name, truck plate, tank code..."),
            new List<AkFilterDefinition>
            {
                new("Filter.AssetType", UiText.T(Context, "نوع دارایی", "Asset Type"), "select", OaOpts(ViewBag.AssetTypes), OaQ("Filter.AssetType")),
                new("Filter.IsActive", UiText.T(Context, "وضعیت", "Status"), "bool",
                    new List<AkFilterOption> { new("true", UiText.T(Context, "فعال", "Active")), new("false", UiText.T(Context, "غیرفعال", "Inactive")) },
                    OaQ("Filter.IsActive"))
            });
    }
    <partial name="~/Views/Shared/_AkSearchFilter.cshtml" model="oaFilter" />

    <div class="ak-list">
        <div class="ak-table-wrap">
            <table class="ak-table" aria-label="@UiText.T(Context, "فهرست دارایی‌های عملیاتی", "Operational assets list")">
                <thead>
                    <tr>
                        <th class="ak-col-check"><input type="checkbox" class="ak-check" aria-label="@UiText.T(Context, "انتخاب همه", "Select all")" /></th>
                        <th class="ak-col-grow">@UiText.T(Context, "دارایی", "Asset")</th>
                        <th>@UiText.T(Context, "کد", "Code")</th>
                        <th>@UiText.T(Context, "نوع", "Type")</th>
                        <th>@UiText.T(Context, "کرایه‌ها (داخلی/خارجی)", "Rents (int/ext)")</th>
                        <th>@UiText.T(Context, "درآمد کرایه حمل", "Freight income")</th>
                        <th>@UiText.T(Context, "مصرف / نتیجه", "Expense / Net")</th>
                        <th class="ak-col-spacer"></th>
                        <th>@UiText.T(Context, "وضعیت", "Status")</th>
                        <th class="ak-col-actions"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Items)
                    {
                        <tr data-href="@Url.Action("Details", new { id = row.Id })">
                            <td class="ak-col-check"><input type="checkbox" class="ak-check" aria-label="@UiText.T(Context, "انتخاب", "Select")" /></td>
                            <td class="ak-col-grow"><a asp-action="Details" asp-route-id="@row.Id" class="ak-name">@row.Name</a></td>
                            <td>@(string.IsNullOrWhiteSpace(row.AssetCode) ? "-" : row.AssetCode)</td>
                            <td>@OperationalAssetLabels.AssetType(row.AssetType, Context)</td>
                            <td class="ak-num">
                                <span>@row.InternalRentUsd.ToString("N0")</span>
                                / <span>@row.ExternalRentUsd.ToString("N0")</span> USD
                            </td>
                            <td class="ak-num"><span>@row.FreightIncomeUsd.ToString("N0")</span> USD</td>
                            <td class="ak-num">
                                <span>@row.DirectExpensesUsd.ToString("N0")</span>
                                / <span>@row.NetBeforeDepreciationUsd.ToString("N0")</span> USD
                            </td>
                            <td class="ak-col-spacer"></td>
                            <td>
                                <span class="ak-status @(row.IsActive ? "is-active" : "is-inactive")">
                                    @(row.IsActive ? UiText.T(Context, "فعال", "Active") : UiText.T(Context, "غیرفعال", "Inactive"))
                                </span>
                            </td>
                            <td class="ak-col-actions">
                                <div class="dropdown ak-row-menu">
                                    <button type="button" class="ak-row-menu-btn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="@UiText.T(Context, "عملیات", "Actions")">
                                        <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a class="dropdown-item" asp-action="Details" asp-route-id="@row.Id"><i class="bi bi-eye" aria-hidden="true"></i>@UiText.T(Context, "پرونده", "File")</a></li>
                                        <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@row.Id"><i class="bi bi-pencil" aria-hidden="true"></i>@UiText.T(Context, "ویرایش", "Edit")</a></li>
                                        <li><a class="dropdown-item" asp-action="CreateRent" asp-route-assetId="@row.Id"><i class="bi bi-receipt" aria-hidden="true"></i>@UiText.T(Context, "کرایه", "Rent")</a></li>
                                        <li><a class="dropdown-item" asp-controller="Expenses" asp-action="Create" asp-route-operationalAssetId="@row.Id" asp-route-returnUrl="@returnUrl"><i class="bi bi-wallet2" aria-hidden="true"></i>@UiText.T(Context, "مصرف", "Expense")</a></li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><partial name="~/Views/Shared/Partials/_ToggleActiveButton.cshtml" model="@(("OperationalAssets", row.Id, row.IsActive, "dropdown-item ak-danger", (string?)returnUrl))" /></li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="10">
                                <div class="ak-empty"><i class="bi bi-truck-front" aria-hidden="true"></i>@UiText.T(Context, "هیچ دارایی عملیاتی یافت نشد", "No operational assets found")</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="ak-pager">@await Html.PartialAsync("_Pagination", (Model.CurrentPage, Model.PageCount))</div>
    </div>
</div>
