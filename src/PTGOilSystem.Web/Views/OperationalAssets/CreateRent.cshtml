@model PTGOilSystem.Web.Models.OperationalAssets.AssetRentCreateViewModel
@{
    ViewData["Title"] = UiText.T(Context, "ثبت کرایه/استفاده دارایی", "Record Asset Use/Rent");
    ViewData["HideSectionTabs"] = true;
    var cancelUrl = Url.Action("Index", "OperationalAssets") ?? "/OperationalAssets";
}

<div class="ak-form-page">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((ViewData["Title"]?.ToString() ?? "ثبت کرایه/استفاده دارایی", false,
                       (string?)null, (string?)null, (string?)null, (string?)null,
                       UiText.T(Context, "بازگشت", "Back"), "bi-arrow-right", cancelUrl))" />
    <form asp-action="CreateRent" method="post" class="ak-form">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

        <section class="ak-form-section">
            <h2 class="ak-section-title">@UiText.T(Context, "اطلاعات کرایه/استفاده", "Use / Rent Information")</h2>
            <div class="ak-form-grid">
                <div class="ak-field">
                    <label asp-for="OperationalAssetId" class="ak-label">@UiText.T(Context, "دارایی عملیاتی", "Operational Asset") <span class="req">*</span></label>
                    <select asp-for="OperationalAssetId" asp-items="ViewBag.Assets" class="ak-input"><option value="">@UiText.T(Context, "انتخاب دارایی", "Select asset")</option></select>
                    <span asp-validation-for="OperationalAssetId" class="ak-field-error"></span>
                </div>
                <div class="ak-field">
                    <label asp-for="RentDate" class="ak-label">@UiText.T(Context, "تاریخ کرایه/استفاده", "Rent Date")</label>
                    <input asp-for="RentDate" type="date" class="ak-input" />
                    <span asp-validation-for="RentDate" class="ak-field-error"></span>
                </div>
                <div class="ak-field">
                    <label asp-for="UsageType" class="ak-label">@UiText.T(Context, "نوع استفاده", "Usage Type")</label>
                    <select asp-for="UsageType" asp-items="ViewBag.UsageTypes" class="ak-input"></select>
                    <span asp-validation-for="UsageType" class="ak-field-error"></span>
                </div>
                <div class="ak-field">
                    <label asp-for="ChargedToType" class="ak-label">@UiText.T(Context, "طرف حساب", "Charged To")</label>
                    <select asp-for="ChargedToType" asp-items="ViewBag.ChargedToTypes" class="ak-input"></select>
                    <span asp-validation-for="ChargedToType" class="ak-field-error"></span>
                </div>
                <div class="ak-field d-none" data-counterparty-group="contract">
                    <label asp-for="ChargedToContractId" class="ak-label">@UiText.T(Context, "قرارداد", "Contract")</label>
                    <select asp-for="ChargedToContractId" asp-items="ViewBag.Contracts" class="ak-input"><option value="">@UiText.T(Context, "بدون قرارداد", "No contract")</option></select>
                    <span asp-validation-for="ChargedToContractId" class="ak-field-error"></span>
                </div>
                <div class="ak-field d-none" data-counterparty-group="customer">
                    <label asp-for="ChargedToCustomerId" class="ak-label">@UiText.T(Context, "مشتری", "Customer")</label>
                    <select asp-for="ChargedToCustomerId" asp-items="ViewBag.Customers" class="ak-input"><option value="">@UiText.T(Context, "بدون مشتری", "No customer")</option></select>
                    <input asp-for="NewCustomerName" class="ak-input" placeholder="@UiText.T(Context, "یا نام مشتری جدید را وارد کنید", "Or enter a new customer name")" />
                    <span asp-validation-for="ChargedToCustomerId" class="ak-field-error"></span>
                    <span asp-validation-for="NewCustomerName" class="ak-field-error"></span>
                </div>
                <div class="ak-field d-none" data-counterparty-group="company">
                    <label asp-for="ChargedToCompanyId" class="ak-label">@UiText.T(Context, "شرکت", "Company")</label>
                    <select asp-for="ChargedToCompanyId" asp-items="ViewBag.Companies" class="ak-input"><option value="">@UiText.T(Context, "بدون شرکت", "No company")</option></select>
                    <span asp-validation-for="ChargedToCompanyId" class="ak-field-error"></span>
                </div>
                <div class="ak-field d-none" data-counterparty-group="partner">
                    <label asp-for="ChargedToPartnerId" class="ak-label">@UiText.T(Context, "شریک", "Partner")</label>
                    <select asp-for="ChargedToPartnerId" asp-items="ViewBag.Partners" class="ak-input"><option value="">@UiText.T(Context, "بدون شریک", "No partner")</option></select>
                    <span asp-validation-for="ChargedToPartnerId" class="ak-field-error"></span>
                </div>
                <div class="ak-field d-none" data-counterparty-group="service-provider">
                    <label asp-for="ChargedToServiceProviderId" class="ak-label">@UiText.T(Context, "شرکت خدماتی", "Service Provider")</label>
                    <select asp-for="ChargedToServiceProviderId" asp-items="ViewBag.ServiceProviders" class="ak-input"><option value="">@UiText.T(Context, "بدون شرکت خدماتی", "No service provider")</option></select>
                    <span asp-validation-for="ChargedToServiceProviderId" class="ak-field-error"></span>
                </div>
                <div class="ak-field ak-col-full d-none" data-counterparty-group="contract">
                    <span class="ak-note">@UiText.T(Context, "برای استفاده داخلی مربوط به قرارداد، نوع طرف حساب را قرارداد خرید یا قرارداد فروش انتخاب کنید.", "For internal contract use, choose Purchase Contract or Sales Contract as charged-to type.")</span>
                </div>
            </div>
        </section>

        <section class="ak-form-section">
            <p class="ak-note">@UiText.T(Context, "اگر مبلغ خالی باشد، سیستم نرخ × روز، در غیر آن نرخ × کیلومتر، در غیر آن نرخ × MT، و در نهایت نرخ × 1 را حساب می‌کند.", "If Amount is blank, the system calculates Rate × Days, otherwise Rate × KM, otherwise Rate × MT, otherwise Rate × 1.")</p>
            <div class="ak-form-grid">
                <div class="ak-field" data-measure-group="mt">
                    <label asp-for="QuantityMt" class="ak-label">@UiText.T(Context, "مقدار MT", "Quantity MT")</label>
                    <input asp-for="QuantityMt" class="ak-input" />
                    <span asp-validation-for="QuantityMt" class="ak-field-error"></span>
                </div>
                <div class="ak-field" data-measure-group="km">
                    <label asp-for="DistanceKm" class="ak-label">@UiText.T(Context, "مسافت KM", "Distance KM")</label>
                    <input asp-for="DistanceKm" class="ak-input" />
                    <span asp-validation-for="DistanceKm" class="ak-field-error"></span>
                </div>
                <div class="ak-field" data-measure-group="days">
                    <label asp-for="Days" class="ak-label">@UiText.T(Context, "روز", "Days")</label>
                    <input asp-for="Days" class="ak-input" />
                    <span asp-validation-for="Days" class="ak-field-error"></span>
                </div>
                <div class="ak-field">
                    <label asp-for="Rate" class="ak-label">@UiText.T(Context, "نرخ", "Rate")</label>
                    <input asp-for="Rate" class="ak-input" />
                    <span asp-validation-for="Rate" class="ak-field-error"></span>
                </div>
                <div class="ak-field">
                    <label asp-for="AmountOriginal" class="ak-label">@UiText.T(Context, "مبلغ", "Amount")</label>
                    <input asp-for="AmountOriginal" class="ak-input" />
                    <span asp-validation-for="AmountOriginal" class="ak-field-error"></span>
                </div>
                <div class="ak-field">
                    <label asp-for="Currency" class="ak-label">@UiText.T(Context, "ارز", "Currency")</label>
                    <select asp-for="Currency" asp-items="ViewBag.Currencies" class="ak-input"><option value="">@UiText.T(Context, "ارز", "Currency")</option></select>
                    <span asp-validation-for="Currency" class="ak-field-error"></span>
                </div>
                <div class="ak-field ak-col-full" data-fx-rate-group data-fx-currency-source="#Currency">
                    <div data-fx-rate-field>
                        <label class="ak-label">نرخ دالر به <span data-fx-currency-name>ارز</span></label>
                        <input type="text" inputmode="decimal" class="ak-input" data-fx-rate-input
                               id="rentFxDisplay" placeholder="مثال: ۷۷ یعنی ۱ دالر = ۷۷ روبل" autocomplete="off" />
                        <input asp-for="FxRateToUsd" type="hidden" data-fx-rate-technical />
                        <small class="ak-note">۱ دالر = چند واحد ارز سند؟</small>
                        <span asp-validation-for="FxRateToUsd" class="ak-field-error"></span>
                    </div>
                    <div data-fx-usd-note class="d-none">
                        <small class="ak-note"><i class="bi bi-info-circle"></i> پرداخت دالری است؛ نرخ تبدیل لازم نیست.</small>
                    </div>
                </div>
            </div>
        </section>

        <div class="ak-footer-actions">
            <button type="submit" class="ak-save">
                <i class="bi bi-floppy" aria-hidden="true"></i>
                @UiText.T(Context, "ذخیره کرایه/استفاده", "Save Use/Rent")
            </button>
            <a href="@cancelUrl" class="ak-cancel">@UiText.T(Context, "بازگشت", "Back")</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/fx-rate-field.js" asp-append-version="true" defer></script>
    <script>
        (() => {
            const chargedToType = document.getElementById("ChargedToType");
            const operationalAsset = document.getElementById("OperationalAssetId");
            const currency = document.getElementById("Currency");
            if (!chargedToType || !operationalAsset) {
                return;
            }

            const assetTypeById = @Html.Raw(ViewBag.AssetTypeByIdJson ?? "{}");
            const transportAssetTypes = new Set([1, 2, 3, 7]);
            const storageAssetTypes = new Set([4, 5, 6]);

            const groups = {
                contract: document.querySelectorAll('[data-counterparty-group="contract"]'),
                customer: document.querySelector('[data-counterparty-group="customer"]'),
                company: document.querySelector('[data-counterparty-group="company"]'),
                partner: document.querySelector('[data-counterparty-group="partner"]'),
                serviceProvider: document.querySelector('[data-counterparty-group="service-provider"]')
            };

            const measurementGroups = {
                mt: document.querySelector('[data-measure-group="mt"]'),
                km: document.querySelector('[data-measure-group="km"]'),
                days: document.querySelector('[data-measure-group="days"]')
            };

            // Matches enum AssetRentChargedToType values in server code.
            const visibleGroupsByType = {
                "1": ["contract"],
                "2": ["contract"],
                "3": ["customer"],
                "4": ["company"],
                "5": ["partner"],
                "6": ["serviceProvider"]
            };

            const allGroupKeys = Object.keys(groups);
            const allMeasurementKeys = Object.keys(measurementGroups);

            const setGroupVisible = (groupElement, visible) => {
                if (!groupElement) {
                    return;
                }

                groupElement.classList.toggle("d-none", !visible);
                groupElement.setAttribute("aria-hidden", visible ? "false" : "true");

                const controls = groupElement.querySelectorAll("select, input, textarea");
                controls.forEach(control => {
                    control.disabled = !visible;
                });
            };

            const setGroupVisibleAll = (group, visible) => {
                if (group instanceof NodeList) {
                    group.forEach(element => setGroupVisible(element, visible));
                } else {
                    setGroupVisible(group, visible);
                }
            };

            const applyCounterpartyVisibility = () => {
                const visibleKeys = visibleGroupsByType[String(chargedToType.value)] || [];

                allGroupKeys.forEach(key => {
                    setGroupVisibleAll(groups[key], visibleKeys.includes(key));
                });
            };

            const resolveMeasurementProfile = () => {
                const assetTypeId = Number(assetTypeById[String(operationalAsset.value)]);
                if (transportAssetTypes.has(assetTypeId)) {
                    return "transport";
                }

                if (storageAssetTypes.has(assetTypeId)) {
                    return "storage";
                }

                return "flexible";
            };

            const applyMeasurementVisibility = () => {
                const profile = resolveMeasurementProfile();
                const visibleKeys = profile === "transport"
                    ? ["km", "days"]
                    : profile === "storage"
                        ? ["mt", "days"]
                        : ["mt", "km", "days"];

                allMeasurementKeys.forEach(key => {
                    setGroupVisible(measurementGroups[key], visibleKeys.includes(key));
                });
            };

            chargedToType.addEventListener("change", applyCounterpartyVisibility);
            operationalAsset.addEventListener("change", applyMeasurementVisibility);
            applyCounterpartyVisibility();
            applyMeasurementVisibility();
        })();
    </script>
}
