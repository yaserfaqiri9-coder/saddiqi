@model IEnumerable<ExpenseType>
@{
    ViewData["Title"] = "انواع مصارف";
    var items = Model.ToList();
    var hasFilters = !string.IsNullOrWhiteSpace((string?)ViewData["category"]) || ViewData["isActive"] != null;
    var hasSearch = !string.IsNullOrWhiteSpace((string?)ViewData["q"]) || hasFilters;
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var activeCount = items.Count(item => item.IsActive);
    var categoryCount = items.Select(item => item.Category)
        .Where(category => !string.IsNullOrWhiteSpace(category))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Count();
    var payableAccountCount = items.Count(item => item.PayableAccountKind.HasValue);
}

<div class="ak-list-page">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((UiText.T(Context, "انواع مصارف", "Expense types"), true,
                       UiText.T(Context, "نوع مصرف جدید", "New expense type"), "bi-plus-lg",
                       (string?)Url.Action("Create", new { returnUrl }), (string?)null,
                       (string?)null, (string?)null, (string?)null))" />

    <section class="ak-stat-grid mb-3" aria-label="@UiText.T(Context, "آمار انواع مصرف", "Expense type statistics")">
        <vc:stat-card title="@UiText.T(Context, "تعداد انواع مصرف", "Expense types")" value="@items.Count.ToString("N0")" unit="@UiText.T(Context, "نوع", "types")" avatar="expenses"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "انواع فعال", "Active types")" value="@activeCount.ToString("N0")" unit="@UiText.T(Context, "نوع", "types")" avatar="loading"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "دسته‌های مصرف", "Categories")" value="@categoryCount.ToString("N0")" unit="@UiText.T(Context, "دسته", "categories")" avatar="purchase-requests"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "دارای حساب پرداختنی", "With payable account")" value="@payableAccountCount.ToString("N0")" unit="@UiText.T(Context, "نوع", "types")" avatar="bank-accounts"></vc:stat-card>
    </section>

    @{
        var expTypesIsActive = ViewData["isActive"] is bool etAct ? (etAct ? "true" : "false") : null;
        var expTypeCatOptions = (ViewData["Categories"] as List<string> ?? new List<string>())
            .Select(c => new AkFilterOption(c, c)).ToList();
        var expenseTypesFilter = new AkSearchFilterModel("q", (string?)ViewData["q"],
            UiText.T(Context, "جستجو در کد یا نام...", "Search code or name..."),
            new List<AkFilterDefinition>
            {
                new("category", UiText.T(Context, "دسته", "Category"), "select", expTypeCatOptions, (string?)ViewData["category"]),
                new("isActive", UiText.T(Context, "وضعیت", "Status"), "bool",
                    new List<AkFilterOption> { new("true", UiText.T(Context, "فعال", "Active")), new("false", UiText.T(Context, "غیرفعال", "Inactive")) },
                    expTypesIsActive)
            });
    }
    <partial name="~/Views/Shared/_AkSearchFilter.cshtml" model="expenseTypesFilter" />

    <div class="ak-list">
        <div class="ak-table-wrap">
            <table class="ak-table" aria-label="@UiText.T(Context, "لیست انواع مصارف", "Expense type list")">
                <thead>
                    <tr>
                        <th class="ak-col-check"><input type="checkbox" class="ak-check" aria-label="@UiText.T(Context, "انتخاب همه", "Select all")" /></th>
                        <th class="ak-col-grow">@UiText.T(Context, "نام", "Name")</th>
                        <th>@UiText.T(Context, "دسته", "Category")</th>
                        <th class="ak-col-spacer"></th>
                        <th>@UiText.T(Context, "وضعیت", "Status")</th>
                        <th class="ak-col-actions"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in items)
                    {
                        <tr>
                            <td class="ak-col-check"><input type="checkbox" class="ak-check" aria-label="@UiText.T(Context, "انتخاب", "Select")" /></td>
                            <td class="ak-col-grow"><a asp-action="Details" asp-route-id="@item.Id" class="ak-name">@item.Name</a></td>
                            <td>@item.Category</td>
                            <td class="ak-col-spacer"></td>
                            <td><span class="ak-status @(item.IsActive ?"is-active" : "is-inactive")">@(item.IsActive ? "فعال" : "غیرفعال")</span></td>
                            <td class="ak-col-actions">
                                <div class="dropdown ak-row-menu">
                                    <button type="button" class="ak-row-menu-btn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="@UiText.T(Context, "عملیات", "Actions")">
                                        <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a class="dropdown-item" asp-action="Details" asp-route-id="@item.Id"><i class="bi bi-eye" aria-hidden="true"></i>مشاهده</a></li>
                                        <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil" aria-hidden="true"></i>ویرایش</a></li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li>
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" data-ptg-confirm="true" data-ptg-confirm-title="حذف نوع مصرف" data-ptg-confirm-message="آیا از حذف مطمئن هستید؟">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-item ak-danger"><i class="bi bi-trash" aria-hidden="true"></i>حذف</button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!items.Any())
                    {
                        <tr><td colspan="6"><div class="ak-empty"><i class="bi bi-tags" aria-hidden="true"></i>رکوردی یافت نشد</div></td></tr>
                    }
                </tbody>
            </table>
        </div>

        @{ ViewData["ShownCount"] = items.Count; }
        <div class="ak-pager">@await Html.PartialAsync("_PagedListFooter")</div>
    </div>
</div>
