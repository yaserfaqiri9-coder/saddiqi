@model (int CurrentPage, int PageCount)
@if (Model.PageCount > 1)
{
    var current = Model.Item1;
    var total = Model.Item2;
    var qs = Context.Request.Query
        .Where(kv => !string.Equals(kv.Key, "page", StringComparison.OrdinalIgnoreCase))
        .SelectMany(kv => kv.Value.Select(v => $"{Uri.EscapeDataString(kv.Key)}={Uri.EscapeDataString(v ?? "")}"))
        .ToList();

    string PageUrl(int p)
    {
        var parts = new System.Collections.Generic.List<string>(qs) { $"page={p}" };
        return "?" + string.Join("&", parts);
    }

    int windowStart = Math.Max(1, current - 2);
    int windowEnd = Math.Min(total, windowStart + 4);
    if (windowEnd - windowStart < 4) windowStart = Math.Max(1, windowEnd - 4);

    <nav aria-label="صفحه‌بندی" class="ak-pager">
        <ul class="pagination pagination-sm mb-0">
            <li class="page-item @(current == 1 ?"disabled" : "")">
                <a class="page-link" href="@PageUrl(current - 1)">«</a>
            </li>
            @if (windowStart > 1)
            {
                <li class="page-item"><a class="page-link" href="@PageUrl(1)">۱</a></li>
                @if (windowStart > 2)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
            }
            @for (int i = windowStart; i <= windowEnd; i++)
            {
                <li class="page-item @(i == current ?"active" : "")">
                    <a class="page-link" href="@PageUrl(i)">@i</a>
                </li>
            }
            @if (windowEnd < total)
            {
                @if (windowEnd < total - 1)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
                <li class="page-item"><a class="page-link" href="@PageUrl(total)">@total</a></li>
            }
            <li class="page-item @(current == total ?"disabled" : "")">
                <a class="page-link" href="@PageUrl(current + 1)">»</a>
            </li>
        </ul>
    </nav>
}
