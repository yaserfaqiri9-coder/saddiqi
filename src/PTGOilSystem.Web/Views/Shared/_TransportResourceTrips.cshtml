@model TransportResourceProfileViewModel
@{
    const int PageSize = 4;
    var requestedPage = Context.Request.Query["page"].ToString();
    var currentPage = int.TryParse(requestedPage, out var parsedPage) && parsedPage > 0 ? parsedPage : 1;
    var totalCount = Model.Trips.Count;
    var pageCount = Math.Max(1, (int)Math.Ceiling(totalCount / (double)PageSize));
    currentPage = Math.Min(currentPage, pageCount);
    var visibleTrips = Model.Trips
        .Skip((currentPage - 1) * PageSize)
        .Take(PageSize)
        .ToList();

    string FormatDate(DateTime? date) => date.HasValue ? date.Value.ToDisplayDate() : "بدون تاریخ";
}

<div>
    @await Html.PartialAsync("~/Views/Shared/Components/Ak/_AkSectionHead.cshtml", ("تاریخچه حرکت‌ها", (string?)$"{totalCount} ثبت"))

    @if (visibleTrips.Any())
    {
        <div class="ak-list">
            @foreach (var item in visibleTrips)
            {
                <article class="ak-list-row">
                    <div>
                        <div>@FormatDate(item.Date)</div>
                        <div>
                            <strong>@item.Route</strong>
                            <i class="bi bi-arrow-left-short" aria-hidden="true"></i>
                            <strong>@item.Title</strong>
                        </div>
                    </div>
                    <div>
                        <span>@item.Status</span>
                        <b>@item.Quantity</b>
                        @if (!string.IsNullOrWhiteSpace(item.Controller) && !string.IsNullOrWhiteSpace(item.Action) && item.RouteId.HasValue)
                        {
                            <a asp-controller="@item.Controller" asp-action="@item.Action" asp-route-id="@item.RouteId" class="btn btn-light ak-secondary-action">مشاهده</a>
                        }
                    </div>
                </article>
            }
        </div>

        @await Html.PartialAsync("_Pagination", (currentPage, pageCount))
    }
    else
    {
        <div class="ak-empty">برای این مورد هنوز سفر یا حمل ثبت نشده است.</div>
    }
</div>
