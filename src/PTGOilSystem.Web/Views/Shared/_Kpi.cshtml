@{
    var label = ViewData["Label"] as string ?? "";
    var value = ViewData["Value"] as string ?? "0";
    var icon  = ViewData["Icon"]  as string ?? "bi-circle";
    var color = ViewData["Color"] as string ?? "primary";
}
<div class="ak-field ak-col-full col-sm-6">
    <div class="kpi-card">
        <div class="kpi-content">
            <div class="kpi-meta">
                <div class="kpi-label">@label</div>
                <div class="kpi-value">@value</div>
            </div>
            <div class="kpi-icon-wrap text-@color">
                <i class="bi @icon"></i>
            </div>
        </div>
    </div>
</div>
