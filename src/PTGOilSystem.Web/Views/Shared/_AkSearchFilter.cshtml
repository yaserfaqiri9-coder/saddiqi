@*
    Shared Search/Filter component — single owner (groups A & B).
    Free-text search is a native GET submit; structured filters are rendered as
    hidden inputs with the EXACT existing query-string param names, so the produced
    request is byte-identical to the legacy bar. The chrome (chips + popover) is the
    only thing that changes. No controller / query-contract change.

    Model: AkSearchFilterModel (SearchName, SearchValue, Placeholder, Filters?)
*@
@using System.Text.Json
@model AkSearchFilterModel
@{
    var filterPage = ViewContext.RouteData.Values["controller"]?.ToString()?.ToLowerInvariant() ?? "list";
    var searchLabel = UiText.T(Context, "جستجو", "Search");
    var clearLabel = UiText.T(Context, "پاک کردن همه", "Clear all");
    var filters = Model.Filters ?? new List<AkFilterDefinition>();

    string? OptionLabel(AkFilterDefinition f, string? value)
        => f.Options?.FirstOrDefault(o => o.Value == value)?.Label ?? value;

    bool IsApplied(AkFilterDefinition f)
        => !string.IsNullOrEmpty(f.Value) || !string.IsNullOrEmpty(f.SecondValue);

    string ChipValueText(AkFilterDefinition f)
    {
        if (f.Type == "daterange")
        {
            var from = string.IsNullOrEmpty(f.Value) ? "…" : f.Value;
            var to = string.IsNullOrEmpty(f.SecondValue) ? "…" : f.SecondValue;
            return $"{from} → {to}";
        }
        return OptionLabel(f, f.Value) ?? f.Value ?? "";
    }

    // Config consumed by ak-search-filter.js to build the field/value popover.
    var config = filters.Select(f => new
    {
        key = f.Key,
        label = f.Label,
        type = f.Type,
        secondKey = f.SecondKey,
        options = (f.Options ?? new List<AkFilterOption>()).Select(o => new { value = o.Value, label = o.Label })
    });
    var configJson = JsonSerializer.Serialize(config);
}
<div class="ak-filter-host">
    <form class="ak-filter" method="get" role="search" data-ak-filter data-ak-filter-page="@filterPage">
        <div class="ak-filter-chips" data-ak-filter-chips aria-live="polite">
            @foreach (var f in filters.Where(IsApplied))
            {
                <span class="ak-chip-group" data-ak-chip="@f.Key">
                    <span class="ak-chip">@f.Label</span>
                    <span class="ak-chip">
                        <span>@ChipValueText(f)</span>
                        <button type="button" class="ak-chip-remove" data-ak-remove-chip="@f.Key"
                                aria-label="@UiText.T(Context, "حذف فیلتر", "Remove filter")">&times;</button>
                    </span>
                </span>
            }
        </div>

        @* Hidden inputs = the real submitted params (server-rendered so state survives reload). *@
        @foreach (var f in filters.Where(IsApplied))
        {
            if (!string.IsNullOrEmpty(f.Value))
            {
                <input type="hidden" name="@f.Key" value="@f.Value" data-ak-filter-param="@f.Key" />
            }
            if (f.Type == "daterange" && !string.IsNullOrEmpty(f.SecondKey) && !string.IsNullOrEmpty(f.SecondValue))
            {
                <input type="hidden" name="@f.SecondKey" value="@f.SecondValue" data-ak-filter-param="@f.Key" />
            }
        }

        @* Scoping params preserved across search/filter/clear (not chips, e.g. contractId). *@
        @if (Model.Hidden != null)
        {
            foreach (var kv in Model.Hidden)
            {
                <input type="hidden" name="@kv.Key" value="@kv.Value" />
            }
        }

        <div class="ak-filter-input-wrap">
            @* Filters-only pages (no free-text search) render the input without a name,
               so it is not submitted — it still serves as the popover entry point. *@
            <input class="ak-filter-input"
                   type="search"
                   name="@(string.IsNullOrEmpty(Model.SearchName) ? null : Model.SearchName)"
                   value="@Model.SearchValue"
                   autocomplete="off"
                   data-ak-filter-input
                   placeholder="@Model.Placeholder"
                   aria-label="@Model.Placeholder" />

            <button class="ak-filter-enter" type="submit" data-ak-filter-enter>@searchLabel</button>
        </div>

        <button class="ak-filter-clear" type="button" data-ak-filter-clear
                hidden aria-label="@clearLabel">&times;</button>

        <div class="ak-filter-popover" data-ak-filter-popover role="listbox" hidden></div>

        @if (filters.Any())
        {
            <script type="application/json" data-ak-filter-config>@Html.Raw(configJson)</script>
        }
    </form>
</div>
