@*
    Shared "next operations" bar (AK Detail v2 zone 7).
    End-of-page action row; sticks to the bottom of the viewport under 768px.
    At most 4 direct buttons — pass overflow items to the header kebab instead.
    Destructive items never belong here (kebab + confirm only).
    Model: IReadOnlyList<AkHeaderMenuItem>
*@
@model IReadOnlyList<PTGOilSystem.Web.Models.Shared.AkHeaderMenuItem>
@{
    var actions = (Model ?? Array.Empty<PTGOilSystem.Web.Models.Shared.AkHeaderMenuItem>())
        .Where(a => a.IsRenderable && !a.IsDestructive)
        .Take(4)
        .ToList();
}
@if (actions.Count > 0)
{
    <nav class="ak-detail-actionbar no-print" aria-label="@UiText.T(Context, "عملیات بعدی", "Next operations")">
        @for (var i = 0; i < actions.Count; i++)
        {
            var action = actions[i];
            var buttonClass = i == 0 ? "btn btn-primary ak-primary-action" : "btn btn-light ak-secondary-action";
            if (!string.IsNullOrWhiteSpace(action.ModalTarget))
            {
                <button type="button" class="@buttonClass" data-bs-toggle="modal" data-bs-target="#@action.ModalTarget"
                        aria-label="@action.AccessibleLabel"
                        data-ptg-confirm="@(string.IsNullOrWhiteSpace(action.ConfirmMessage) ? null : "true")"
                        data-ptg-confirm-title="@action.ConfirmTitle"
                        data-ptg-confirm-message="@action.ConfirmMessage">
                    @if (!string.IsNullOrWhiteSpace(action.Icon))
                    {
                        <i class="bi @action.Icon" aria-hidden="true"></i>
                    }
                    <span>@action.Label</span>
                </button>
            }
            else
            {
                <a href="@action.Href" class="@buttonClass" aria-label="@action.AccessibleLabel"
                   data-ptg-confirm="@(string.IsNullOrWhiteSpace(action.ConfirmMessage) ? null : "true")"
                   data-ptg-confirm-title="@action.ConfirmTitle"
                   data-ptg-confirm-message="@action.ConfirmMessage">
                    @if (!string.IsNullOrWhiteSpace(action.Icon))
                    {
                        <i class="bi @action.Icon" aria-hidden="true"></i>
                    }
                    <span>@action.Label</span>
                </a>
            }
        }
    </nav>
}
