@*
    Unified compact server pager for lists inside Details pages.
    State lives in the query-string under a per-list key so several lists on
    one page can page independently. Mobile-friendly: «قبلی · x / y · بعدی».
    Model: (CurrentPage, PageCount, QueryKey, Anchor) — Anchor without '#'.
*@
@model (int CurrentPage, int PageCount, string QueryKey, string? Anchor)
@if (Model.PageCount > 1)
{
    var current = Math.Clamp(Model.CurrentPage, 1, Model.PageCount);
    var key = string.IsNullOrWhiteSpace(Model.QueryKey) ? "page" : Model.QueryKey.Trim();
    var currentPageLabel = UiText.T(
        Context,
        $"صفحه {current} از {Model.PageCount}",
        $"Page {current} of {Model.PageCount}");
    var baseParams = Context.Request.Query
        .Where(kv => !string.Equals(kv.Key, key, StringComparison.OrdinalIgnoreCase))
        .SelectMany(kv => kv.Value.Select(v => $"{Uri.EscapeDataString(kv.Key)}={Uri.EscapeDataString(v ?? "")}"))
        .ToList();

    string PageUrl(int page)
    {
        var parts = new List<string>(baseParams) { $"{Uri.EscapeDataString(key)}={page}" };
        var anchor = string.IsNullOrWhiteSpace(Model.Anchor) ? "" : "#" + Model.Anchor;
        return "?" + string.Join("&", parts) + anchor;
    }

    <nav class="ak-pager ak-detail-pager no-print" aria-label="@UiText.T(Context, "صفحه‌بندی فهرست", "List paging")">
        @if (current > 1)
        {
            <a class="ak-detail-pager-link" href="@PageUrl(current - 1)" rel="prev">@UiText.T(Context, "قبلی", "Previous")</a>
        }
        else
        {
            <span class="ak-detail-pager-link is-disabled" aria-disabled="true">@UiText.T(Context, "قبلی", "Previous")</span>
        }
        <span class="ak-detail-pager-state" dir="ltr" aria-current="page" aria-label="@currentPageLabel">
            @current / @Model.PageCount
        </span>
        @if (current < Model.PageCount)
        {
            <a class="ak-detail-pager-link" href="@PageUrl(current + 1)" rel="next">@UiText.T(Context, "بعدی", "Next")</a>
        }
        else
        {
            <span class="ak-detail-pager-link is-disabled" aria-disabled="true">@UiText.T(Context, "بعدی", "Next")</span>
        }
    </nav>
}
