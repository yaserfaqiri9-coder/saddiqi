@model PTGOilSystem.Web.Models.StorageTanks.StorageTankIndexViewModel
@{
    ViewData["Title"] = "مخازن ذخیره";
    ViewData["StorageTanksAssets"] = true;
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var hasFilters = Model.TerminalId.HasValue || Model.ProductId.HasValue || Model.IsActive.HasValue;
    var hasSearch = !string.IsNullOrWhiteSpace(Model.Query) || hasFilters;

    string FormatQuantity(decimal value)
    {
        var rounded = Math.Round(value, 2);
        if (rounded == decimal.Truncate(rounded)) return rounded.ToString("N0");
        if (rounded * 10m == decimal.Truncate(rounded * 10m)) return rounded.ToString("N1");
        return rounded.ToString("N2");
    }
}

<div class="ak-list-page">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((UiText.T(Context, "مخازن ذخیره", "Storage Tanks"), true,
                       UiText.T(Context, "مخزن جدید", "New tank"), "bi-plus-lg",
                       (string?)Url.Action("Create", new { returnUrl }), (string?)null,
                       (string?)null, (string?)null, (string?)null))" />

    <section class="ak-stat-grid mb-3" aria-label="@UiText.T(Context, "آمار مخازن", "Storage tank statistics")">
        <vc:stat-card title="@UiText.T(Context, "کل مخازن", "Total tanks")" value="@Model.TotalTanks.ToString("N0")" unit="@UiText.T(Context, "مخزن", "tanks")" avatar="tank-inventory"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "مخازن فعال", "Active tanks")" value="@Model.ActiveTanks.ToString("N0")" unit="@UiText.T(Context, "مخزن", "tanks")" avatar="loading"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "ظرفیت کل", "Total capacity")" value="@FormatQuantity(Model.TotalCapacityMt)" unit="MT" avatar="total-inventory"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "موجودی دفتری", "Book stock")" value="@FormatQuantity(Model.TotalCurrentQuantityMt)" unit="MT" avatar="unloaded"></vc:stat-card>
    </section>

    @{
        var tankTerminalOptions = (ViewBag.Terminals as Microsoft.AspNetCore.Mvc.Rendering.SelectList ??
                Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
            .Select(i => new AkFilterOption(i.Value, i.Text)).ToList();
        var tankProductOptions = (ViewBag.Products as Microsoft.AspNetCore.Mvc.Rendering.SelectList ??
                Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
            .Select(i => new AkFilterOption(i.Value, i.Text)).ToList();
        var tankIsActive = Model.IsActive.HasValue ? (Model.IsActive.Value ? "true" : "false") : null;
        var storageTanksFilter = new AkSearchFilterModel(
            "q", Model.Query,
            UiText.T(Context, "جستجو در مخازن...", "Search tanks..."),
            new List<AkFilterDefinition>
            {
                new("terminalId", UiText.T(Context, "ترمینال", "Terminal"), "select",
                    tankTerminalOptions, Model.TerminalId?.ToString()),
                new("productId", UiText.T(Context, "نوع جنس", "Product"), "select",
                    tankProductOptions, Model.ProductId?.ToString()),
                new("isActive", UiText.T(Context, "وضعیت", "Status"), "bool",
                    new List<AkFilterOption>
                    {
                        new("true", UiText.T(Context, "فعال", "Active")),
                        new("false", UiText.T(Context, "غیرفعال", "Inactive"))
                    }, tankIsActive)
            });
    }
    <partial name="~/Views/Shared/_AkSearchFilter.cshtml" model="storageTanksFilter" />

    <div class="ak-list">
        <div class="ak-table-wrap">
            <table class="ak-table" aria-label="@UiText.T(Context, "لیست مخازن", "Storage Tanks List")">
                <thead>
                    <tr>
                        <th class="ak-col-check"><input type="checkbox" class="ak-check" aria-label="@UiText.T(Context, "انتخاب همه", "Select all")" /></th>
                        <th class="ak-col-grow">@UiText.T(Context, "مخزن", "Tank")</th>
                        <th>@UiText.T(Context, "ترمینال", "Terminal")</th>
                        <th>@UiText.T(Context, "جنس", "Product")</th>
                        <th>@UiText.T(Context, "ظرفیت", "Capacity")</th>
                        <th>@UiText.T(Context, "موجودی دفتری", "Book stock")</th>
                        <th>@UiText.T(Context, "پر بودن", "Fill")</th>
                        <th>@UiText.T(Context, "قراردادها", "Contracts")</th>
                        <th class="ak-col-spacer"></th>
                        <th>@UiText.T(Context, "وضعیت", "Status")</th>
                        <th class="ak-col-actions"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        var percent = Math.Max(0m, Math.Min(100m, item.FillPercent));
                        var unitText = string.IsNullOrWhiteSpace(item.UnitOfMeasure) ? "MT" : item.UnitOfMeasure.Trim();
                        <tr data-href="@Url.Action("Details", new { id = item.Id })">
                            <td class="ak-col-check"><input type="checkbox" class="ak-check" aria-label="@UiText.T(Context, "انتخاب", "Select")" /></td>
                            <td class="ak-col-grow"><a asp-action="Details" asp-route-id="@item.Id" class="ak-name">@item.DisplayName</a></td>
                            <td>@(string.IsNullOrWhiteSpace(item.TerminalName) ? "-" : item.TerminalName)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.ProductName) ? "-" : item.ProductName)</td>
                            <td class="ak-num">@FormatQuantity(item.CapacityMt) @unitText</td>
                            <td class="ak-num">@FormatQuantity(item.CurrentQuantityMt) @unitText</td>
                            <td class="ak-num">@percent.ToString("N0")%</td>
                            <td class="ak-num">@item.ContractCount.ToString("N0")</td>
                            <td class="ak-col-spacer"></td>
                            <td>
                                <span class="ak-status @(item.IsActive ?"is-active" : "is-inactive")">
                                    @(item.IsActive ? UiText.T(Context, "فعال", "Active") : UiText.T(Context, "غیرفعال", "Inactive"))
                                </span>
                            </td>
                            <td class="ak-col-actions">
                                <div class="dropdown ak-row-menu">
                                    <button type="button" class="ak-row-menu-btn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="@UiText.T(Context, "عملیات", "Actions")">
                                        <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a class="dropdown-item" asp-action="Details" asp-route-id="@item.Id"><i class="bi bi-eye" aria-hidden="true"></i>@UiText.T(Context, "جزئیات", "Details")</a></li>
                                        <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil" aria-hidden="true"></i>@UiText.T(Context, "ویرایش مخزن", "Edit tank")</a></li>
                                        @if (item.ContractCount > 0)
                                        {
                                            <li><a class="dropdown-item" asp-action="SettleFinal" asp-route-id="@item.Id"><i class="bi bi-cash-coin" aria-hidden="true"></i>@UiText.T(Context, "تسویه مخزن", "Settle tank")</a></li>
                                        }
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="11">
                                <div class="ak-empty"><i class="bi bi-bounding-box" aria-hidden="true"></i>@UiText.T(Context, "مخازنی یافت نشد", "No tanks found")</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="ak-pager">@await Html.PartialAsync("_Pagination", (Model.CurrentPage, Model.PageCount))</div>
    </div>
</div>
