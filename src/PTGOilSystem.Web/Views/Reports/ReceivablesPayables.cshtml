@model PTGOilSystem.Web.Models.Reports.ReceivablesPayablesReportViewModel
@{
    ViewData["Title"] = UiText.T(Context, "بدهی‌ها و طلب‌ها", "Receivables & Payables");
    var hasActiveFilters = Model.Filter.FromDate.HasValue || Model.Filter.ToDate.HasValue
        || Model.Filter.ContractId.HasValue || Model.Filter.CustomerId.HasValue || Model.Filter.SupplierId.HasValue;
}

<div class="ak-list-page">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((UiText.T(Context, "بدهی‌ها و طلب‌ها", "Receivables & Payables"), false,
                       (string?)null, (string?)null, (string?)null, (string?)null,
                       UiText.T(Context, "گزارش‌ها", "Reports"), "bi-arrow-right", Url.Action("Index")))" />

    <p class="ak-note">@UiText.T(Context, "مانده مشتریان، تأمین‌کنندگان، خدماتی‌ها و صراف‌ها.", "Customer, supplier, service provider and sarraf balances.")</p>

    <section class="ak-stat-grid" aria-label="@UiText.T(Context, "آمار بدهی و طلب", "Receivable and payable metrics")">
            @foreach (var metric in Model.Metrics.Take(4))
            {
                @await Html.PartialAsync("_ReferenceMetricCard", ("", metric.Icon, metric.Label, metric.Value, metric.Detail ?? "", metric.ToneClass))
            }
    </section>

    <div class="ak-list">
        <form method="get" class="ak-report-parameters" id="rpFilterForm">
            <div class="ak-report-parameters-bar">
                <div class="ak-report-parameters-anchor">
                    <button type="button" class="btn btn-light ak-report-parameters-toggle @(hasActiveFilters ?"is-on" : null)" id="rpFilterToggle" aria-label="فیلتر" aria-expanded="false">
                        <i class="bi bi-funnel"></i>
                    </button>
                    <div class="ak-report-parameters-pop" id="rpFilterPop" hidden>
                        <label class="ak-report-parameters-field">@UiText.T(Context, "از تاریخ", "From")</label>
                        <input class="ak-input" type="date" name="FromDate" value="@Model.Filter.FromDate?.ToHtmlDateInput()" />
                        <label class="ak-report-parameters-field">@UiText.T(Context, "تا تاریخ", "To")</label>
                        <input class="ak-input" type="date" name="ToDate" value="@Model.Filter.ToDate?.ToHtmlDateInput()" />
                        <label class="ak-report-parameters-field">@UiText.T(Context, "قرارداد", "Contract")</label>
                        <select class="ak-input" name="ContractId" asp-items="ViewBag.Contracts"><option value="">@UiText.T(Context, "همه قراردادها", "All Contracts")</option></select>
                        <label class="ak-report-parameters-field">@UiText.T(Context, "مشتری", "Customer")</label>
                        <select class="ak-input" name="CustomerId" asp-items="ViewBag.Customers"><option value="">@UiText.T(Context, "همه مشتری‌ها", "All Customers")</option></select>
                        <label class="ak-report-parameters-field">@UiText.T(Context, "تأمین‌کننده", "Supplier")</label>
                        <select class="ak-input" name="SupplierId" asp-items="ViewBag.Suppliers"><option value="">@UiText.T(Context, "همه تأمین‌کنندگان", "All Suppliers")</option></select>
                        <button type="submit" class="btn btn-primary ak-report-parameters-apply">@UiText.T(Context, "اعمال", "Apply")</button>
                        <button type="button" class="btn btn-light ak-report-parameters-apply" onclick="window.print()"><i class="bi bi-printer"></i> @UiText.T(Context, "چاپ", "Print")</button>
                        @if (hasActiveFilters)
                        {
                            <a asp-action="ReceivablesPayables" class="btn btn-light ak-report-parameters-apply">@UiText.T(Context, "پاک‌کردن", "Clear")</a>
                        }
                    </div>
                </div>
            </div>
        </form>

        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead>
                    <tr>
                        <th class="ak-col-grow">@UiText.T(Context, "طرف حساب", "Party")</th>
                        <th>@UiText.T(Context, "نوع", "Type")</th>
                        <th>@UiText.T(Context, "شرح مانده", "Balance Kind")</th>
                        <th class="ak-col-num">Debit</th>
                        <th class="ak-col-num">Credit</th>
                        <th class="ak-col-num">@UiText.T(Context, "مانده", "Balance")</th>
                        <th>@UiText.T(Context, "آخرین تاریخ", "Last Date")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Rows)
                    {
                        <tr>
                            <td class="ak-col-grow">@row.PartyName</td>
                            <td>@row.PartyType</td>
                            <td>@row.BalanceKind</td>
                            <td class="ak-col-num ak-num">@row.DebitUsd.ToString("N2")</td>
                            <td class="ak-col-num ak-num">@row.CreditUsd.ToString("N2")</td>
                            <td class="ak-col-num ak-num @(row.BalanceUsd >= 0 ?"ak-num" : "ak-num")">@row.BalanceUsd.ToString("N2")</td>
                            <td>@(row.LastEntryDate?.ToDisplayDate() ?? "-")</td>
                        </tr>
                    }
                    @if (!Model.Rows.Any())
                    {
                        <tr><td colspan="7"><div class="ak-empty"><i class="bi bi-people"></i> @UiText.T(Context, "مانده‌ای پیدا نشد؛ فیلترها را تغییر دهید.", "No balance found; change the filters.")</div></td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var toggle = document.getElementById('rpFilterToggle');
            var pop = document.getElementById('rpFilterPop');
            if (!toggle || !pop) return;
            function close() { pop.hidden = true; toggle.setAttribute('aria-expanded', 'false'); }
            toggle.addEventListener('click', function (e) {
                e.stopPropagation();
                var open = pop.hidden;
                pop.hidden = !open;
                toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
            });
            document.addEventListener('click', function (e) {
                if (!pop.hidden && !pop.contains(e.target) && e.target !== toggle) close();
            });
            document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
        })();
    </script>
}
