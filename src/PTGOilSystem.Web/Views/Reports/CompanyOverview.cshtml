@model PTGOilSystem.Web.Models.Reports.CompanyFinancialOverviewViewModel
@{
    ViewData["Title"] = UiText.T(Context, "نمای کلی مالی", "Company Financial Overview");
    var hasActiveFilters = Model.Filter.FromDate.HasValue || Model.Filter.ToDate.HasValue
        || Model.Filter.ProductId.HasValue || Model.Filter.ContractId.HasValue
        || Model.Filter.CustomerId.HasValue || Model.Filter.SupplierId.HasValue;
}

<div class="ak-list-page finance-workspace-page" dir="@(UiText.IsEn(Context) ? "ltr" : "rtl")">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((UiText.T(Context, "نمای کلی مالی", "Company Financial Overview"), false,
                       (string?)null, (string?)null, (string?)null, (string?)null,
                       UiText.T(Context, "گزارشات", "Reports"), "bi-arrow-right", Url.Action("Index")))" />

    <p class="finance-page-lead">@UiText.T(Context, "شش عدد اصلی برای دیدن وضعیت مالی؛ همه مستقیماً از فروش، مصارف، روزنامه و دفتر سیستم خوانده می‌شوند.", "Six essential figures read directly from sales, expenses, journal and ledger records.")</p>

    <section class="ak-stat-grid finance-overview-metrics" aria-label="@UiText.T(Context, "خلاصهٔ مالی", "Financial summary")">
        <vc:stat-card title="@UiText.T(Context, "نقدینگی (خالص حرکت)", "Liquidity (net movement)")" value="@Model.NetCashMovementUsd.ToString("N2")" unit="USD" avatar="payments"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "دریافتنی مشتریان", "Customer receivables")" value="@Model.CustomerReceivableUsd.ToString("N2")" unit="USD" avatar="receivables"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "پرداختنی تأمین‌کنندگان", "Supplier payables")" value="@Model.SupplierPayableUsd.ToString("N2")" unit="USD" avatar="payments"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "درآمد", "Revenue")" value="@Model.RevenueUsd.ToString("N2")" unit="USD" avatar="sales-value"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "مصرف و ضایعات", "Expenses and losses")" value="@((Model.ExpenseUsd + Model.LossCostUsd).ToString("N2"))" unit="USD" avatar="expenses"></vc:stat-card>
        <vc:stat-card title="@UiText.T(Context, "سود / زیان", "Profit / loss")" value="@Model.NetProfitUsd.ToString("N2")" unit="USD" avatar="profit-loss"></vc:stat-card>
    </section>

    <div class="ak-list">
        <form method="get" class="ak-report-parameters" id="coFilterForm">
            <div class="ak-report-parameters-bar">
                <div class="ak-report-parameters-anchor">
                    <button type="button" class="btn btn-light ak-report-parameters-toggle @(hasActiveFilters ?"is-on" : null)" id="coFilterToggle" aria-label="فیلتر" aria-expanded="false">
                        <i class="bi bi-funnel"></i>
                    </button>
                    <div class="ak-report-parameters-pop" id="coFilterPop" hidden>
                        <label class="ak-report-parameters-field">@UiText.T(Context, "از تاریخ", "From date")</label>
                        <input class="ak-input" type="date" name="FromDate" value="@Model.Filter.FromDate?.ToHtmlDateInput()" />
                        <label class="ak-report-parameters-field">@UiText.T(Context, "تا تاریخ", "To date")</label>
                        <input class="ak-input" type="date" name="ToDate" value="@Model.Filter.ToDate?.ToHtmlDateInput()" />
                        <label class="ak-report-parameters-field">@UiText.T(Context, "جنس", "Product")</label>
                        <select class="ak-input" name="ProductId" asp-items="ViewBag.Products"><option value="">@UiText.T(Context, "همه اجناس", "All products")</option></select>
                        <label class="ak-report-parameters-field">@UiText.T(Context, "قرارداد", "Contract")</label>
                        <select class="ak-input" name="ContractId" asp-items="ViewBag.Contracts"><option value="">@UiText.T(Context, "همه قراردادها", "All contracts")</option></select>
                        <label class="ak-report-parameters-field">@UiText.T(Context, "مشتری", "Customer")</label>
                        <select class="ak-input" name="CustomerId" asp-items="ViewBag.Customers"><option value="">@UiText.T(Context, "همه مشتری‌ها", "All customers")</option></select>
                        <label class="ak-report-parameters-field">@UiText.T(Context, "تأمین‌کننده", "Supplier")</label>
                        <select class="ak-input" name="SupplierId" asp-items="ViewBag.Suppliers"><option value="">@UiText.T(Context, "همه تأمین‌کنندگان", "All suppliers")</option></select>
                        <button type="submit" class="btn btn-primary ak-report-parameters-apply">@UiText.T(Context, "اعمال", "Apply")</button>
                        <button type="button" class="btn btn-light ak-report-parameters-apply" onclick="window.print()"><i class="bi bi-printer"></i> @UiText.T(Context, "چاپ", "Print")</button>
                        @if (hasActiveFilters)
                        {
                            <a asp-action="CompanyOverview" class="btn btn-light ak-report-parameters-apply">@UiText.T(Context, "پاک‌کردن", "Clear")</a>
                        }
                    </div>
                </div>
            </div>
        </form>

        <section class="ak-form-section">
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@((UiText.T(Context, "قراردادهای مهم", "Key contracts"), UiText.T(Context, "قراردادهایی که بیشترین اثر مالی را دارند.", "Contracts with the largest financial impact.")))" />
            <div class="ak-table-wrap">
                <table class="ak-table">
                    <thead>
                        <tr>
                            <th class="ak-col-grow">@UiText.T(Context, "قرارداد", "Contract")</th>
                            <th>@UiText.T(Context, "جنس", "Product")</th>
                            <th>@UiText.T(Context, "طرف حساب", "Counterparty")</th>
                            <th class="ak-col-num">@UiText.T(Context, "مصرف (USD)", "Cost (USD)")</th>
                            <th class="ak-col-num">@UiText.T(Context, "فروش (USD)", "Revenue (USD)")</th>
                            <th class="ak-col-num">@UiText.T(Context, "سود (USD)", "Profit (USD)")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.TopContracts)
                        {
                            <tr>
                                <td class="ak-col-grow"><a class="ak-name" asp-controller="ContractJourney" asp-action="Details" asp-route-id="@row.ContractId">@row.ContractNumber</a></td>
                                <td>@row.ProductName</td>
                                <td>@(row.CounterpartyName ?? "-")</td>
                                <td class="ak-col-num ak-num">@row.TotalCostUsd.ToString("N2")</td>
                                <td class="ak-col-num ak-num">@row.TotalRevenueUsd.ToString("N2")</td>
                                <td class="ak-col-num ak-num @(row.GrossMarginUsd >= 0 ?"ak-num" : "ak-num")">@row.GrossMarginUsd.ToString("N2")</td>
                            </tr>
                        }
                        @if (!Model.TopContracts.Any())
                        {
                            <tr>
                                <td colspan="6"><div class="ak-empty"><i class="bi bi-graph-up"></i> @UiText.T(Context, "فیلترها را تغییر دهید یا بازه تاریخ را گسترده‌تر بگیرید.", "Change the filters or widen the date range.")</div></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var toggle = document.getElementById('coFilterToggle');
            var pop = document.getElementById('coFilterPop');
            if (!toggle || !pop) return;
            function close() { pop.hidden = true; toggle.setAttribute('aria-expanded', 'false'); }
            toggle.addEventListener('click', function (e) {
                e.stopPropagation();
                var open = pop.hidden;
                pop.hidden = !open;
                toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
            });
            document.addEventListener('click', function (e) {
                if (!pop.hidden && !pop.contains(e.target) && e.target !== toggle) close();
            });
            document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
        })();
    </script>
}
