@model PTGOilSystem.Web.Models.Reports.ReportHubViewModel
@{
    ViewData["Title"] = UiText.T(Context, "گزارش‌های مالی", "Financial Reports");

    var reports = new[]
    {
        new { Controller = "Reports", Action = "CompanyOverview", TitleFa = "سود و زیان شرکت", TitleEn = "Company Profit & Loss", DescriptionFa = "درآمد، قیمت خرید، مصارف، ضایعات، اختلاف ارز و سود یا زیان خالص.", DescriptionEn = "Revenue, purchase cost, expenses, losses, exchange difference and net result.", Icon = "bi-graph-up-arrow" },
        new { Controller = "Reports", Action = "CashFlow", TitleFa = "جریان نقدی", TitleEn = "Cash Flow", DescriptionFa = "ورودی و خروجی واقعی پول بر اساس روزنامه و حساب‌های نقدی/بانکی.", DescriptionEn = "Actual cash inflow and outflow from journal and cash or bank accounts.", Icon = "bi-cash-stack" },
        new { Controller = "Reports", Action = "ReceivablesPayables", TitleFa = "دریافتنی‌ها و پرداختنی‌ها", TitleEn = "Receivables & Payables", DescriptionFa = "طلب مشتریان و بدهی تأمین‌کنندگان در یک گزارش هماهنگ.", DescriptionEn = "Customer receivables and supplier payables in one coordinated report.", Icon = "bi-people" },
        new { Controller = "Reports", Action = "InventoryOperations", TitleFa = "موجودی و عملیات", TitleEn = "Inventory & Operations", DescriptionFa = "مقدار موجودی، گردش‌ها و موارد عملیاتی نیازمند بررسی.", DescriptionEn = "Inventory quantities, movements and operational items requiring attention.", Icon = "bi-box-seam" },
        new { Controller = "Reports", Action = "ContractPnl", TitleFa = "سود و زیان قرارداد و محموله", TitleEn = "Contract & Shipment P&L", DescriptionFa = "درآمد، بهای خرید، مصارف، ضایعات، صراف و اختلاف ارز هر قرارداد.", DescriptionEn = "Revenue, purchase cost, expenses, losses, sarraf and exchange difference by contract.", Icon = "bi-file-earmark-spreadsheet" }
    };
}

<div class="ak-reports-page finance-workspace-page" dir="@(UiText.IsEn(Context) ? "ltr" : "rtl")">
    <header class="finance-report-header">
        <div>
            <h1 class="ak-reports-title">@UiText.T(Context, "گزارش‌های مالی", "Financial Reports")</h1>
            <p class="finance-page-lead">@UiText.T(Context, "گزارش‌های اصلی بر پایه داده ثبت‌شده؛ هر موضوع فقط یک مسیر روشن دارد.", "Core reports based on posted data, with one clear route per topic.")</p>
        </div>
        <a class="btn btn-light ak-secondary-action" asp-controller="Reconciliation" asp-action="Index">
            <i class="bi bi-check2-square" aria-hidden="true"></i>
            <span>@UiText.T(Context, "کنترل مغایرت‌ها", "Reconciliation checks")</span>
        </a>
    </header>

    <section class="finance-report-list" aria-label="@UiText.T(Context, "گزارش‌های موجود", "Available reports")">
        @foreach (var report in reports)
        {
            <a class="finance-report-link" asp-controller="@report.Controller" asp-action="@report.Action">
                <span class="finance-report-link-icon" aria-hidden="true"><i class="bi @report.Icon"></i></span>
                <span class="finance-report-link-copy">
                    <strong>@UiText.T(Context, report.TitleFa, report.TitleEn)</strong>
                    <small>@UiText.T(Context, report.DescriptionFa, report.DescriptionEn)</small>
                </span>
                <i class="bi bi-chevron-left finance-report-link-arrow" aria-hidden="true"></i>
            </a>
        }
    </section>

    <p class="finance-source-note">
        <i class="bi bi-shield-check" aria-hidden="true"></i>
        @UiText.T(Context, "اعداد این مسیرها از اسناد و گردش‌های موجود سیستم خوانده می‌شوند؛ این صفحه محاسبه تازه‌ای ایجاد نمی‌کند.", "These routes read existing documents and movements; this page creates no new calculation.")
    </p>
</div>
