@model PTGOilSystem.Web.Models.Reports.ContractPnlReportViewModel
@{
    ViewData["Title"] = UiText.T(Context,"سود و زیان قراردادها","Contract P&L");
    var hasActiveFilters = Model.Filter.FromDate.HasValue || Model.Filter.ToDate.HasValue
        || Model.Filter.ProductId.HasValue || Model.Filter.CustomerId.HasValue
        || Model.Filter.SupplierId.HasValue;
    var marginPct = Model.TotalSalesRevenueUsd > 0
        ? Math.Round((Model.TotalGrossMarginUsd / Model.TotalSalesRevenueUsd) * 100m, 1)
        : 0m;
}

<div class="ak-list-page">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((UiText.T(Context,"سود و زیان قراردادها","Contract P&L"), false,
                       (string?)null, (string?)null, (string?)null, (string?)null,
                       UiText.T(Context,"گزارش‌ها","Reports"), "bi-arrow-right", Url.Action("Index")))" />

    <p class="ak-note">@UiText.T(Context,"مصرف قراردادهای خرید، درآمد قراردادهای فروش و سود ناخالص. قیمت نهایی قرارداد دستی ثبت می‌شود و نرخ‌های مرجع فقط برای مقایسه و کنترل استفاده می‌شوند.","Purchase costs, sales revenue and gross profit. Final contract prices are entered manually; reference rates are used only for comparison and control.")</p>

    <section class="ak-form-section ak-summary" aria-label="@UiText.T(Context, "آمار سود و زیان قراردادها", "Contract P&L metrics")">
        <dl class="ak-summary-list">
            <div><dt>@UiText.T(Context, "جمع مصرف خرید", "Total Purchase Cost")</dt><dd class="ak-num">@Model.TotalPurchaseCostUsd.ToString("N2")</dd></div>
            <div><dt>@UiText.T(Context, "جمع درآمد فروش", "Total Sales Revenue")</dt><dd class="ak-num">@Model.TotalSalesRevenueUsd.ToString("N2")</dd></div>
            <div><dt>@UiText.T(Context, "سود ناخالص", "Gross Profit")</dt><dd class="ak-num @(Model.TotalGrossMarginUsd >= 0 ?"ak-num" : "ak-num")">@Model.TotalGrossMarginUsd.ToString("N2")</dd></div>
            <div><dt>@UiText.T(Context, "حاشیه سود", "Profit Margin")</dt><dd class="ak-num @(marginPct >= 0 ?"ak-num" : "ak-num")">@($"{marginPct:N1}%")</dd></div>
        </dl>
    </section>

    <div class="ak-list">
        <form method="get" class="ak-report-parameters" id="pnlFilterForm">
            <div class="ak-report-parameters-bar">
                <div class="ak-report-parameters-anchor">
                    <button type="button" class="btn btn-light ak-report-parameters-toggle @(hasActiveFilters ?"is-on" : null)" id="pnlFilterToggle" aria-label="فیلتر" aria-expanded="false">
                        <i class="bi bi-funnel"></i>
                    </button>
                    <div class="ak-report-parameters-pop" id="pnlFilterPop" hidden>
                        <label class="ak-report-parameters-field">@UiText.T(Context,"از تاریخ","From Date")</label>
                        <input asp-for="Filter.FromDate" type="date" class="ak-input" />
                        <label class="ak-report-parameters-field">@UiText.T(Context,"تا تاریخ","To Date")</label>
                        <input asp-for="Filter.ToDate" type="date" class="ak-input" />
                        <label class="ak-report-parameters-field">@UiText.T(Context,"جنس","Product")</label>
                        <select asp-for="Filter.ProductId" asp-items="ViewBag.Products" class="ak-input"><option value="">@UiText.T(Context,"همه اجناس","All Products")</option></select>
                        <label class="ak-report-parameters-field">@UiText.T(Context,"تأمین‌کننده","Supplier")</label>
                        <select asp-for="Filter.SupplierId" asp-items="ViewBag.Suppliers" class="ak-input"><option value="">@UiText.T(Context,"همه تأمین‌کنندگان","All Suppliers")</option></select>
                        <label class="ak-report-parameters-field">@UiText.T(Context,"مشتری","Customer")</label>
                        <select asp-for="Filter.CustomerId" asp-items="ViewBag.Customers" class="ak-input"><option value="">@UiText.T(Context,"همه مشتری‌ها","All Customers")</option></select>
                        <button type="submit" class="btn btn-primary ak-report-parameters-apply">@UiText.T(Context,"اعمال","Apply")</button>
                        <button type="button" class="btn btn-light ak-report-parameters-apply" onclick="window.print()"><i class="bi bi-printer"></i> @UiText.T(Context,"چاپ","Print")</button>
                        @if (hasActiveFilters)
                        {
                            <a asp-action="ContractPnl" class="btn btn-light ak-report-parameters-apply">@UiText.T(Context,"پاک‌کردن","Clear")</a>
                        }
                    </div>
                </div>
            </div>
        </form>

        <section class="ak-form-section">
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@((UiText.T(Context,"قراردادهای خرید — تحلیل مصرف","Purchase Contracts — Cost Analysis"), (string?)null))" />
            <div class="ak-table-wrap">
                <table class="ak-table">
                    <thead>
                        <tr>
                            <th class="ak-col-grow">@UiText.T(Context,"قرارداد","Contract")</th>
                            <th>@UiText.T(Context,"جنس","Product")</th>
                            <th>@UiText.T(Context,"تأمین‌کننده","Supplier")</th>
                            <th>@UiText.T(Context,"وضعیت","Status")</th>
                            <th class="ak-col-num">@UiText.T(Context,"مقدار قرارداد","Contract Qty")</th>
                            <th class="ak-col-num">@UiText.T(Context,"بارگیری MT","Loaded MT")</th>
                            <th class="ak-col-num">@UiText.T(Context,"ارزش خرید","Purchase Value")</th>
                            <th class="ak-col-num">@UiText.T(Context,"حمل","Transport")</th>
                            <th class="ak-col-num">@UiText.T(Context,"گدام","Warehouse")</th>
                            <th class="ak-col-num">@UiText.T(Context,"سایر","Other")</th>
                            <th class="ak-col-num">@UiText.T(Context,"خط آهن","Railway")</th>
                            <th class="ak-col-num">@UiText.T(Context,"گمرک","Customs")</th>
                            <th class="ak-col-num">@UiText.T(Context,"مصرف عمومی","General Exp")</th>
                            <th class="ak-col-num">@UiText.T(Context,"کسری","Loss Cost")</th>
                            <th class="ak-col-num">Sarraf Shortfall</th>
                            <th class="ak-col-num">Net FX</th>
                            <th class="ak-col-num">@UiText.T(Context,"جمع مصرف","Total Cost")</th>
                            <th class="ak-col-num">@UiText.T(Context,"فروش مستقیم MT","DirectSale MT")</th>
                            <th class="ak-col-num">@UiText.T(Context,"درآمد فروش مستقیم","DirectSale Revenue")</th>
                            <th class="ak-col-num">@UiText.T(Context,"حاشیه","Margin")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.PurchaseRows.Any())
                        {
                            <tr><td colspan="20"><div class="ak-empty"><i class="bi bi-file-earmark-x"></i> @UiText.T(Context,"قراردادی یافت نشد؛ فیلترها را تغییر دهید.","No contracts found; change the filters.")</div></td></tr>
                        }
                        @foreach (var row in Model.PurchaseRows)
                        {
                            <tr>
                                <td class="ak-col-grow">
                                    <a class="ak-name" asp-controller="ContractJourney" asp-action="Details" asp-route-id="@row.ContractId">@row.ContractNumber</a>
                                    @if (row.HasPendingTankSettlement)
                                    {
                                        <span class="ak-status">@UiText.T(Context, "موقت", "Provisional")</span>
                                    }
                                </td>
                                <td>@row.ProductName</td>
                                <td>@(row.CounterpartyName ?? "—")</td>
                                <td><span class="ak-status">@row.Status</span></td>
                                <td class="ak-col-num ak-num">@row.ContractQuantityMt.ToString("N0")</td>
                                <td class="ak-col-num ak-num">@NumberDisplay.Quantity(row.TotalLoadedMt)</td>
                                <td class="ak-col-num ak-num">@(row.PurchaseValueUsd > 0 ? row.PurchaseValueUsd.ToString("N2") : "—")</td>
                                <td class="ak-col-num ak-num">@(row.TransportCostUsd > 0 ? row.TransportCostUsd.ToString("N2") : "—")</td>
                                <td class="ak-col-num ak-num">@(row.WarehouseCostUsd > 0 ? row.WarehouseCostUsd.ToString("N2") : "—")</td>
                                <td class="ak-col-num ak-num">@(row.OtherCostUsd > 0 ? row.OtherCostUsd.ToString("N2") : "—")</td>
                                <td class="ak-col-num ak-num">@(row.RailwayCostUsd > 0 ? row.RailwayCostUsd.ToString("N2") : "—")</td>
                                <td class="ak-col-num ak-num">@(row.CustomsCostUsd > 0 ? row.CustomsCostUsd.ToString("N2") : "—")</td>
                                <td class="ak-col-num ak-num">@(row.GeneralExpenseCostUsd > 0 ? row.GeneralExpenseCostUsd.ToString("N2") : "—")</td>
                                <td class="ak-col-num ak-num">
                                    @(row.LossCostUsd > 0 ? row.LossCostUsd.ToString("N2") : "—")
                                    @if (row.UnvaluedLossCount > 0)
                                    {
                                        <span class="ak-status">@row.UnvaluedLossCount @UiText.T(Context, "بدون قیمت", "unvalued")</span>
                                    }
                                </td>
                                <td class="ak-col-num ak-num">@(row.SarrafSupplierShortfallUsd > 0 ? row.SarrafSupplierShortfallUsd.ToString("N2") : "—")</td>
                                <td class="ak-col-num ak-num @(row.NetExchangeDifferenceUsd <= 0 ?"ak-num" : "ak-num")">@(row.NetExchangeDifferenceUsd != 0 ? row.NetExchangeDifferenceUsd.ToString("N2") : "—")</td>
                                <td class="ak-col-num ak-num">@row.TotalCostUsd.ToString("N2")</td>
                                <td class="ak-col-num ak-num">@(row.TotalSoldMt > 0 ? NumberDisplay.Quantity(row.TotalSoldMt) : "—")</td>
                                <td class="ak-col-num ak-num">@(row.TotalRevenueUsd > 0 ? row.TotalRevenueUsd.ToString("N2") : "—")</td>
                                <td class="ak-col-num ak-num @(row.GrossMarginUsd >= 0 ?"ak-num" : "ak-num")">
                                    @(row.TotalRevenueUsd > 0 ? row.GrossMarginUsd.ToString("N2") : "—")
                                    @if (row.DirectSaleQuantityMismatchCount > 0)
                                    {
                                        <span class="ak-status">Qty review</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                    @if (Model.PurchaseRows.Any())
                    {
                        <tfoot>
                            <tr>
                                <td colspan="5" class="fw-bold">@UiText.T(Context,"مجموع","Total")</td>
                                <td class="ak-col-num ak-num fw-bold">@NumberDisplay.Quantity(Model.PurchaseRows.Sum(r => r.TotalLoadedMt))</td>
                                <td class="ak-col-num ak-num fw-bold">@Model.PurchaseRows.Sum(r => r.PurchaseValueUsd).ToString("N2")</td>
                                <td class="ak-col-num ak-num">@Model.PurchaseRows.Sum(r => r.TransportCostUsd).ToString("N2")</td>
                                <td class="ak-col-num ak-num">@Model.PurchaseRows.Sum(r => r.WarehouseCostUsd).ToString("N2")</td>
                                <td class="ak-col-num ak-num">@Model.PurchaseRows.Sum(r => r.OtherCostUsd).ToString("N2")</td>
                                <td class="ak-col-num ak-num">@Model.PurchaseRows.Sum(r => r.RailwayCostUsd).ToString("N2")</td>
                                <td class="ak-col-num ak-num">@Model.PurchaseRows.Sum(r => r.CustomsCostUsd).ToString("N2")</td>
                                <td class="ak-col-num ak-num">@Model.PurchaseRows.Sum(r => r.GeneralExpenseCostUsd).ToString("N2")</td>
                                <td class="ak-col-num ak-num">@Model.PurchaseRows.Sum(r => r.LossCostUsd).ToString("N2")</td>
                                <td class="ak-col-num ak-num">@Model.TotalSarrafSupplierShortfallUsd.ToString("N2")</td>
                                <td class="ak-col-num ak-num @(Model.TotalNetExchangeDifferenceUsd <= 0 ?"ak-num" : "ak-num")">@Model.TotalNetExchangeDifferenceUsd.ToString("N2")</td>
                                <td class="ak-col-num ak-num fw-bold">@Model.TotalPurchaseCostUsd.ToString("N2")</td>
                                <td class="ak-col-num ak-num">@NumberDisplay.Quantity(Model.PurchaseRows.Sum(r => r.TotalSoldMt))</td>
                                <td class="ak-col-num ak-num">@Model.TotalDirectSaleRevenueUsd.ToString("N2")</td>
                                <td class="ak-col-num ak-num @(Model.PurchaseRows.Sum(r => r.GrossMarginUsd) >= 0 ?"ak-num" : "ak-num")">@Model.PurchaseRows.Sum(r => r.GrossMarginUsd).ToString("N2")</td>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </section>

        <section class="ak-form-section">
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@((UiText.T(Context,"قراردادهای فروش — درآمد","Sale Contracts — Revenue"), (string?)null))" />
            <div class="ak-table-wrap">
                <table class="ak-table">
                    <thead>
                        <tr>
                            <th class="ak-col-grow">@UiText.T(Context,"قرارداد","Contract")</th>
                            <th>@UiText.T(Context,"جنس","Product")</th>
                            <th>@UiText.T(Context,"مشتری","Customer")</th>
                            <th>@UiText.T(Context,"وضعیت","Status")</th>
                            <th class="ak-col-num">@UiText.T(Context,"مقدار قرارداد","Contract Qty")</th>
                            <th class="ak-col-num">@UiText.T(Context,"فروخته‌شده MT","Sold MT")</th>
                            <th class="ak-col-num">@UiText.T(Context,"قیمت واحد","Unit Price")</th>
                            <th class="ak-col-num">@UiText.T(Context,"درآمد کل USD","Total Revenue USD")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.SaleRows.Any())
                        {
                            <tr><td colspan="8"><div class="ak-empty"><i class="bi bi-file-earmark-x"></i> @UiText.T(Context,"قراردادی یافت نشد؛ فیلترها را تغییر دهید.","No contracts found; change the filters.")</div></td></tr>
                        }
                        @foreach (var row in Model.SaleRows)
                        {
                            <tr>
                                <td class="ak-col-grow"><a class="ak-name" asp-controller="ContractJourney" asp-action="Details" asp-route-id="@row.ContractId">@row.ContractNumber</a></td>
                                <td>@row.ProductName</td>
                                <td>@(row.CounterpartyName ?? "—")</td>
                                <td><span class="ak-status">@row.Status</span></td>
                                <td class="ak-col-num ak-num">@row.ContractQuantityMt.ToString("N0")</td>
                                <td class="ak-col-num ak-num">@NumberDisplay.Quantity(row.TotalSoldMt)</td>
                                <td class="ak-col-num ak-num">@(row.ContractUnitPriceUsd?.ToString("N2") ?? "—")</td>
                                <td class="ak-col-num ak-num">@row.TotalRevenueUsd.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                    @if (Model.SaleRows.Any())
                    {
                        <tfoot>
                            <tr>
                                <td colspan="5" class="fw-bold">@UiText.T(Context,"مجموع","Total")</td>
                                <td class="ak-col-num ak-num fw-bold">@NumberDisplay.Quantity(Model.SaleRows.Sum(r => r.TotalSoldMt))</td>
                                <td></td>
                                <td class="ak-col-num ak-num fw-bold">@Model.TotalSalesRevenueUsd.ToString("N2")</td>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </section>

        <section class="ak-form-section">
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@((UiText.T(Context,"خلاصه P&L","P&L Summary"), (string?)null))" />
            <dl class="ak-summary-list ak-summary">
                <div><dt>@UiText.T(Context,"درآمد فروش","Sales Revenue")</dt><dd class="ak-num">@Model.TotalSalesRevenueUsd.ToString("N2") USD</dd></div>
                <div><dt>@UiText.T(Context,"مصرف خرید","Purchase Cost")</dt><dd class="ak-num">@Model.TotalPurchaseCostUsd.ToString("N2") USD</dd></div>
                <div><dt>@UiText.T(Context,"سود ناخالص","Gross Profit")</dt><dd class="ak-num @(Model.TotalGrossMarginUsd >= 0 ?"ak-num" : "ak-num")">@Model.TotalGrossMarginUsd.ToString("N2") USD @(Model.TotalSalesRevenueUsd > 0 ? $"({marginPct}%)" : "")</dd></div>
            </dl>
        </section>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var toggle = document.getElementById('pnlFilterToggle');
            var pop = document.getElementById('pnlFilterPop');
            if (!toggle || !pop) return;
            function close() { pop.hidden = true; toggle.setAttribute('aria-expanded', 'false'); }
            toggle.addEventListener('click', function (e) {
                e.stopPropagation();
                var open = pop.hidden;
                pop.hidden = !open;
                toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
            });
            document.addEventListener('click', function (e) {
                if (!pop.hidden && !pop.contains(e.target) && e.target !== toggle) close();
            });
            document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
        })();
    </script>
}
