@model SarrafDetailsViewModel
@using PTGOilSystem.Web.Models.Shared
@using PTGOilSystem.Web.Models.Entities
@{
    ViewData["Title"] = Model.Name;
    ViewData["HideSectionTabs"] = true;
    var activeTab = Context.Request.Query["tab"].ToString().Trim().ToLowerInvariant();
    activeTab = activeTab is "statement" or "documents" ? activeTab : "overview";
    var showOverview = activeTab == "overview";
    var showStatement = activeTab == "statement";
    var showDocuments = activeTab == "documents";

    var notRecorded = "ثبت نشده";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";

    var sarrafEditUrl = Url.Action("Edit", new { id = Model.Id }) ?? "#";
    var sarrafIndexUrl = Url.Action("Index") ?? "#";

    var officialSummary = ViewData["PartyStatementSummary"] as PTGOilSystem.Web.Models.PartyStatements.PartyStatementSummary;
    var payableUsd = officialSummary?.ClosingBalance ?? Model.PayableUsd;
    var payableLabel = officialSummary?.ClosingBalanceMeaning ?? (payableUsd > 0
        ? "قابل پرداخت به صراف"
        : payableUsd < 0
            ? "طلب ما از صراف"
            : "حساب تسویه است");
    var payableClass = payableUsd > 0
        ? "ak-num"
        : payableUsd < 0
            ? "ak-num"
            : "";

    var officialRecentRows = ViewData["PartyStatementRecentRows"] as IReadOnlyList<PTGOilSystem.Web.Models.PartyStatements.PartyStatementRow> ?? [];
    var lastRow = officialRecentRows.FirstOrDefault();

    var sarrafPayForSupplierUrl = Url.Action("Create", "Payments", new { method = "sarraf", sarrafId = Model.Id, returnUrl }) ?? "#";
    var sarrafSettleUrl = Url.Action("Create", "Payments", new { sarrafId = Model.Id, returnUrl }) ?? "#";
    ViewData["AkHeaderStatus"] = Model.IsActive ? "فعال" : "غیرفعال";
    ViewData["AkHeaderStatusState"] = Model.IsActive ? "is-active" : "is-inactive";
    ViewData["AkHeaderContext"] = payableLabel;
    ViewData["AkHeaderKebab"] = new List<AkHeaderMenuItem>
    {
        new() { Label = "صورت‌حساب رسمی", Href = Url.Action("Sarraf", "PartyStatements", new { id = Model.Id }), Icon = "bi-file-earmark-text" },
        new() { Label = "ما با صراف حساب کردیم", Href = sarrafSettleUrl, Icon = "bi-cash-coin" },
        new() { Label = "ویرایش", Href = sarrafEditUrl, Icon = "bi-pencil" }
    };

    var sarrafTabs = new[]
    {
        $"overview|خلاصه حساب|bi-grid-1x2|{(showOverview ? "active" : "")}",
        $"statement|صورت‌حساب|bi-journal-text|{(showStatement ? "active" : "")}",
        $"documents|اسناد و حواله‌ها|bi-folder2-open|{(showDocuments ? "active" : "")}"
    };
}

<div class="ak-form-page ak-party-page ak-detail-page" dir="rtl" data-ak-detail-v2="true">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((Model.Name, false,
                       "صراف برای تأمین‌کننده پرداخت کرد", "bi-currency-exchange", sarrafPayForSupplierUrl, (string?)null,
                       "فهرست صراف‌ها", "bi-arrow-right", (string?)sarrafIndexUrl))" />

    <partial name="~/Views/Shared/Partials/_DetailsTabs.cshtml" model="@("بخش‌های پروفایل صراف", sarrafTabs)" />

    <div class="ak-form-grid" hidden="@(!showOverview)">
        <section class="ak-form-section ak-detail-section">
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("اطلاعات هویتی", (string?)null))" />
            <dl class="ak-list">
                <div class="ak-list-row"><dt>شماره تماس</dt><dd>@(string.IsNullOrWhiteSpace(Model.PhoneNumber) ? notRecorded : Model.PhoneNumber)</dd></div>
                <div class="ak-list-row"><dt>تاریخ ثبت</dt><dd>@Model.CreatedAtUtc.ToLocalTime().ToDisplayDate()</dd></div>
                <div class="ak-list-row"><dt>آدرس</dt><dd>@(string.IsNullOrWhiteSpace(Model.Address) ? notRecorded : Model.Address)</dd></div>
                <div class="ak-list-row"><dt>یادداشت</dt><dd>@(string.IsNullOrWhiteSpace(Model.Notes) ? notRecorded : Model.Notes)</dd></div>
            </dl>
        </section>

        <section class="ak-form-section ak-detail-section">
            <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("وضعیت حساب", payableLabel))" />
            <dl class="ak-list">
                <div class="ak-list-row"><dt>مانده فعلی</dt><dd class="ak-num @payableClass">@Math.Abs(payableUsd).ToString("N2") USD</dd></div>
                <div class="ak-list-row"><dt>پرداخت صراف برای تأمین‌کننده‌ها</dt><dd class="ak-num">@Model.ChargedUsd.ToString("N2") USD</dd></div>
                <div class="ak-list-row"><dt>پرداخت ما به صراف</dt><dd class="ak-num">@Model.PaidUsd.ToString("N2") USD</dd></div>
                @if (lastRow is not null)
                {
                    <div class="ak-list-row"><dt>آخرین حرکت حساب</dt><dd>@lastRow.Date.ToDisplayDate()</dd></div>
                }
            </dl>
        </section>
    </div>

    @* ===== تب ۱: خلاصه — آخرین حرکت‌ها ===== *@
    <section id="sarraf-overview" class="ak-form-section ak-detail-section" hidden="@(!showOverview)">
        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("آخرین حرکت‌های حساب", "پنج سند آخر از موتور مشترک صورت‌حساب."))" />
        <partial name="~/Views/Shared/Statements/_PartyStatementRecent.cshtml" model="officialRecentRows" />
    </section>
    @* ===== تب ۲: صورت‌حساب ===== *@
    <section id="sarraf-statement" class="ak-form-section ak-detail-section" hidden="@(!showStatement)">
        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("صورت‌حساب رسمی صراف", "پرداخت‌ها، تسویه‌های ثبت‌شده و مانده در موتور مشترک محاسبه می‌شود."))" />
        <div class="ak-empty ak-detail-empty-state">
            <i class="bi bi-file-earmark-text" aria-hidden="true"></i>
            <p>برای مشاهده گردش کامل، نرخ ارز، چاپ و PDF سند رسمی را باز کنید.</p>
            <a asp-controller="PartyStatements" asp-action="Sarraf" asp-route-id="@Model.Id" class="btn btn-primary">مشاهده صورت‌حساب رسمی</a>
        </div>
    </section>

    @* ===== تب ۳: اسناد و حواله‌ها ===== *@
    <section id="sarraf-documents" class="ak-form-section ak-detail-section" hidden="@(!showDocuments)">
        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("پرداخت‌های صراف برای تأمین‌کنندگان", $"{Model.Settlements.Count:N0}"))" />
        <div class="ak-table-wrap">
            <table class="ak-table ak-detail-table">
                <thead>
                    <tr>
                        <th>تاریخ</th>
                        <th class="ak-col-grow">تأمین‌کننده</th>
                        <th class="ak-col-num">مبلغ</th>
                        <th>شماره حواله</th>
                        <th>وضعیت</th>
                        <th class="ak-col-actions">سند</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.Settlements)
                {
                    <tr>
                        <td>@row.SettlementDate.ToDisplayDate()</td>
                        <td class="ak-col-grow">@(row.SupplierName ?? "-")</td>
                        <td class="ak-col-num ak-num">@row.SarrafChargedAmount.ToString("N2") @row.SarrafCurrency</td>
                        <td>@(row.ReferenceNumber ?? $"#{row.Id}")</td>
                        <td><span class="ak-status @(row.Status == SarrafSettlementStatus.Cancelled ?"is-inactive" : "is-active")">@row.UserStatusName</span></td>
                        <td class="ak-col-actions"><a asp-controller="SarrafSettlements" asp-action="Details" asp-route-id="@row.Id">مشاهده</a></td>
                    </tr>
                }
                @if (!Model.Settlements.Any())
                {
                    <tr><td colspan="6"><div class="ak-empty ak-detail-empty-state"><i class="bi bi-currency-exchange"></i> هنوز پرداخت صراف برای تأمین‌کننده ثبت نشده است.</div></td></tr>
                }
                </tbody>
            </table>
        </div>

        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("پرداخت‌های ما به صراف", $"{Model.Payments.Count:N0}"))" />
        <div class="ak-table-wrap">
            <table class="ak-table ak-detail-table">
                <thead>
                    <tr>
                        <th>تاریخ</th>
                        <th class="ak-col-grow">حساب</th>
                        <th class="ak-col-num">مبلغ</th>
                        <th>شماره حواله</th>
                        <th class="ak-col-actions">سند</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.Payments)
                {
                    <tr>
                        <td>@row.PaymentDate.ToDisplayDate()</td>
                        <td class="ak-col-grow">@row.CashAccountName</td>
                        <td class="ak-col-num ak-num">@row.Amount.ToString("N2") @row.Currency</td>
                        <td>@(row.Reference ?? $"#{row.PaymentId}")</td>
                        <td class="ak-col-actions"><a asp-controller="Payments" asp-action="Details" asp-route-id="@row.PaymentId">مشاهده</a></td>
                    </tr>
                }
                @if (!Model.Payments.Any())
                {
                    <tr><td colspan="5"><div class="ak-empty ak-detail-empty-state"><i class="bi bi-cash-coin"></i> وقتی شرکت با صراف حساب کند، پرداخت‌های مرتبط اینجا دیده می‌شود.</div></td></tr>
                }
                </tbody>
            </table>
        </div>

        <partial name="~/Views/Shared/Components/Ak/_AkSectionHead.cshtml" model="@(("حواله‌های مشتری", "بدون اثر بر مانده صراف — فقط برای ردیابی."))" />
        <div class="ak-table-wrap">
            <table class="ak-table ak-detail-table">
                <thead>
                    <tr>
                        <th>تاریخ</th>
                        <th class="ak-col-grow">مشتری</th>
                        <th>تأمین‌کننده</th>
                        <th>مرجع حواله</th>
                        <th class="ak-col-num">مبلغ USD</th>
                        <th>وضعیت</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.CustomerHawalas)
                {
                    <tr>
                        <td>@row.SettlementDate.ToDisplayDate()</td>
                        <td class="ak-col-grow">@(row.CustomerName ?? "-")</td>
                        <td>@(row.SupplierName ?? "-")</td>
                        <td>@(row.HawalaReference ?? $"#{row.Id}")</td>
                        <td class="ak-col-num ak-num">@row.CustomerPaidUsd.ToString("N2")</td>
                        <td><span class="ak-status">@row.StatusName</span></td>
                    </tr>
                }
                @if (!Model.CustomerHawalas.Any())
                {
                    <tr><td colspan="6"><div class="ak-empty ak-detail-empty-state"><i class="bi bi-arrow-left-right"></i> حواله‌های مشتری که این صراف واسطه آن بوده، اینجا فقط برای ردیابی دیده می‌شود.</div></td></tr>
                }
                </tbody>
            </table>
        </div>
    </section>
</div>
