@model PTGOilSystem.Web.Models.AccountStatements.AccountStatementIndexViewModel
@{
    var currencies = ViewBag.Currencies as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    ViewData["Title"] = "استیتمنت‌های ارزی";
    var netChangeUsd = Model.ClosingBalanceUsd - Model.OpeningBalanceUsd;
    var hasAdvancedFilter = Model.Filter.FromDate.HasValue || Model.Filter.ToDate.HasValue
        || !string.IsNullOrWhiteSpace(Model.Filter.SourceCurrencyCode) || Model.Filter.ContractId.HasValue
        || Model.Filter.CustomerId.HasValue || Model.Filter.SupplierId.HasValue || !string.IsNullOrWhiteSpace(Model.Filter.Reference);
}

<div class="ak-list-page">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@(("استیتمنت‌های ارزی", false,
                       "ثبت Opening / Adjustment", "bi-plus-lg", Url.Action("Create"), (string?)null,
                       (string?)null, (string?)null, (string?)null))" />

    <section class="ak-form-section ak-summary" aria-label="آمار استیتمنت‌های ارزی">
        <dl class="ak-summary-list">
            <div><dt>تعداد استیتمنت</dt><dd class="ak-num">@Model.Items.Count().ToString("N0")</dd></div>
            <div><dt>مانده ابتدایی</dt><dd class="ak-num">@Model.OpeningBalanceUsd.ToString("N2") USD</dd></div>
            <div><dt>مانده اختتامی</dt><dd class="ak-num">@Model.ClosingBalanceUsd.ToString("N2") USD</dd></div>
            <div><dt>خالص تغییرات</dt><dd class="ak-num @(netChangeUsd < 0 ?"ak-num" : "ak-num")">@netChangeUsd.ToString("N2") USD</dd></div>
        </dl>
    </section>

    <div class="ak-list">
        @{
            List<AkFilterOption> StmtOpts(object? s) => (s as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>
                ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
                .Where(i => !string.IsNullOrEmpty(i.Value)).Select(i => new AkFilterOption(i.Value, i.Text)).ToList();
            string? StmtQ(string k) { var v = Context.Request.Query[k].ToString(); return string.IsNullOrEmpty(v) ? null : v; }
            var stmtFilter = new AkSearchFilterModel("q", (string?)ViewData["q"],
                "مرجع، طرف حساب یا شماره قرارداد...",
                new List<AkFilterDefinition>
                {
                    new("Filter.FromDate", UiText.T(Context, "بازه تاریخ", "Date range"), "daterange", null,
                        Model.Filter.FromDate?.ToHtmlDateInput(), "Filter.ToDate", Model.Filter.ToDate?.ToHtmlDateInput()),
                    new("Filter.SourceCurrencyCode", UiText.T(Context, "ارز منبع", "Source currency"), "select", StmtOpts(currencies), StmtQ("Filter.SourceCurrencyCode")),
                    new("Filter.ContractId", UiText.T(Context, "قرارداد", "Contract"), "select", StmtOpts(ViewBag.Contracts), StmtQ("Filter.ContractId")),
                    new("Filter.CustomerId", UiText.T(Context, "مشتری", "Customer"), "select", StmtOpts(ViewBag.Customers), StmtQ("Filter.CustomerId")),
                    new("Filter.SupplierId", UiText.T(Context, "تأمین‌کننده", "Supplier"), "select", StmtOpts(ViewBag.Suppliers), StmtQ("Filter.SupplierId")),
                    new("Filter.Reference", UiText.T(Context, "مرجع", "Reference"), "text", null, Model.Filter.Reference)
                });
        }
        <div class="ak-list-toolbar">
            <partial name="~/Views/Shared/_AkSearchFilter.cshtml" model="stmtFilter" />
            <div class="ak-list-toolbar-actions">
                <a asp-action="Csv"
                   asp-route-FromDate="@Model.Filter.FromDate?.ToHtmlDateInput()"
                   asp-route-ToDate="@Model.Filter.ToDate?.ToHtmlDateInput()"
                   asp-route-SourceCurrencyCode="@Model.Filter.SourceCurrencyCode"
                   asp-route-ContractId="@Model.Filter.ContractId"
                   asp-route-CustomerId="@Model.Filter.CustomerId"
                   asp-route-SupplierId="@Model.Filter.SupplierId"
                   asp-route-Reference="@Model.Filter.Reference"
                   class="btn btn-light ak-secondary-action"><i class="bi bi-filetype-csv" aria-hidden="true"></i><span>CSV</span></a>
            </div>
        </div>

        <div class="ak-table-wrap">
            <table class="ak-table">
                <thead>
                    <tr>
                        <th>@UiText.T(Context,"تاریخ","Date")</th>
                        <th>سمت</th>
                        <th class="ak-col-num">مبلغ منبع</th>
                        <th>ارز منبع</th>
                        <th class="ak-col-num">FX به USD</th>
                        <th class="ak-col-num">مبلغ USD</th>
                        <th class="ak-col-num">Running balance</th>
                        <th class="ak-col-grow">@UiText.T(Context,"مرجع","Reference")</th>
                        <th>Source</th>
                        <th>@UiText.T(Context,"قرارداد","Contract")</th>
                        <th>طرف حساب</th>
                        <th class="ak-col-actions">@UiText.T(Context,"عملیات","Operations")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.EntryDate.ToDisplayDate()</td>
                            <td><span class="ak-status @(item.Side == PTGOilSystem.Web.Models.Entities.LedgerSide.Debit ?"is-inactive" : "is-active")">@item.SideName</span></td>
                            <td class="ak-col-num ak-num">@item.SourceAmount.ToString("N2")</td>
                            <td>@item.SourceCurrencyCode</td>
                            <td class="ak-col-num ak-num">@item.AppliedFxRateToUsd.ToString("N6")</td>
                            <td class="ak-col-num ak-num">@item.AmountUsd.ToString("N2")</td>
                            <td class="ak-col-num ak-num @(item.RunningBalanceUsd >= 0 ?"ak-num" : "ak-num")">@item.RunningBalanceUsd.ToString("N2")</td>
                            <td class="ak-col-grow">@(item.Reference ?? "-")</td>
                            <td>@item.SourceType / @("#" + item.SourceId)</td>
                            <td>@(item.ContractNumber ?? "-")</td>
                            <td>@(item.CustomerName ?? item.SupplierName ?? "-")</td>
                            <td class="ak-col-actions"><a asp-action="Details" asp-route-id="@item.Id" title="مشاهده" aria-label="مشاهده"><i class="bi bi-eye" aria-hidden="true"></i></a></td>
                        </tr>
                    }
                    @if (!Model.Items.Any())
                    {
                        <tr><td colspan="12"><div class="ak-empty"><i class="bi bi-journal-richtext"></i> برای فیلتر انتخابی استیتمنتی پیدا نشد.</div></td></tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="ak-pager">
            @await Html.PartialAsync("_Pagination", (Model.CurrentPage, Model.PageCount))
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var toggle = document.getElementById('stmtFilterToggle');
            var pop = document.getElementById('stmtFilterPop');
            if (!toggle || !pop) return;
            function close() { pop.hidden = true; toggle.setAttribute('aria-expanded', 'false'); }
            toggle.addEventListener('click', function (e) {
                e.stopPropagation();
                var open = pop.hidden;
                pop.hidden = !open;
                toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
            });
            document.addEventListener('click', function (e) {
                if (!pop.hidden && !pop.contains(e.target) && e.target !== toggle) close();
            });
            document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
        })();
    </script>
}
