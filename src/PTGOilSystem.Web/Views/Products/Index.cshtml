@model IEnumerable<Product>
@{
    ViewData["Title"] = UiText.T(Context, "اجناس", "Products");
    var items = Model.ToList();
    var hasFilters = ViewData["unitId"] != null || ViewData["isActive"] != null;
    var hasSearch = !string.IsNullOrWhiteSpace((string?)ViewData["q"]) || hasFilters;
    var deleteConfirm = UiText.T(Context, "آیا از حذف مطمئن هستید؟", "Are you sure you want to delete?");
    var unitItems = ViewBag.Units as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var selectedUnitId = ViewData["unitId"]?.ToString();
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="ak-list-page">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((UiText.T(Context, "اجناس", "Products"), true,
                       UiText.T(Context, "جنس جدید", "New product"), "bi-plus-lg",
                       (string?)Url.Action("Create", new { returnUrl }), (string?)null,
                       (string?)null, (string?)null, (string?)null))" />

    @{
        var productUnitOptions = (unitItems ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
            .Select(i => new AkFilterOption(i.Value, i.Text)).ToList();
        var productIsActive = ViewData["isActive"] is bool pIsActive ? (pIsActive ? "true" : "false") : null;
        var productsFilter = new AkSearchFilterModel(
            "q", (string?)ViewData["q"],
            UiText.T(Context, "جستجو در کد یا نام جنس...", "Search code or product name..."),
            new List<AkFilterDefinition>
            {
                new("unitId", UiText.T(Context, "واحد", "Unit"), "select", productUnitOptions, selectedUnitId),
                new("isActive", UiText.T(Context, "وضعیت", "Status"), "bool",
                    new List<AkFilterOption>
                    {
                        new("true", UiText.T(Context, "فعال", "Active")),
                        new("false", UiText.T(Context, "غیرفعال", "Inactive"))
                    }, productIsActive)
            });
    }
    <partial name="~/Views/Shared/_AkSearchFilter.cshtml" model="productsFilter" />

    <div class="ak-list">
        <div class="ak-table-wrap">
            <table class="ak-table" aria-label="@UiText.T(Context, "لیست اجناس", "Product list")">
                <thead>
                    <tr>
                        <th class="ak-col-check"><input type="checkbox" class="ak-check" aria-label="@UiText.T(Context, "انتخاب همه", "Select all")" /></th>
                        <th class="ak-col-grow">@UiText.T(Context, "نام جنس", "Product name")</th>
                        <th>@UiText.T(Context, "کد", "Code")</th>
                        <th>@UiText.T(Context, "واحد", "Unit")</th>
                        <th class="ak-col-spacer"></th>
                        <th>@UiText.T(Context, "وضعیت", "Status")</th>
                        <th class="ak-col-actions"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in items)
                    {
                        var unitText = item.Unit?.NamePersian ?? item.Unit?.Name ?? item.UnitOfMeasure ?? "-";
                        <tr>
                            <td class="ak-col-check"><input type="checkbox" class="ak-check" aria-label="@UiText.T(Context, "انتخاب", "Select")" /></td>
                            <td class="ak-col-grow"><a asp-action="Details" asp-route-id="@item.Id" class="ak-name">@item.Name</a></td>
                            <td>@(string.IsNullOrWhiteSpace(item.Code) ? "—" : item.Code)</td>
                            <td>@(string.IsNullOrWhiteSpace(unitText) || unitText == "-" ? UiText.T(Context, "بدون واحد", "No unit") : unitText)</td>
                            <td class="ak-col-spacer"></td>
                            <td>
                                <span class="ak-status @(item.IsActive ?"is-active" : "is-inactive")">
                                    @(item.IsActive ? UiText.T(Context, "فعال", "Active") : UiText.T(Context, "غیرفعال", "Inactive"))
                                </span>
                            </td>
                            <td class="ak-col-actions">
                                <div class="dropdown ak-row-menu">
                                    <button type="button" class="ak-row-menu-btn" data-bs-toggle="dropdown" aria-expanded="false" aria-label="@UiText.T(Context, "عملیات", "Actions")">
                                        <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a class="dropdown-item" asp-action="Details" asp-route-id="@item.Id"><i class="bi bi-eye" aria-hidden="true"></i>@UiText.T(Context, "مشاهده", "View")</a></li>
                                        <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil" aria-hidden="true"></i>@UiText.T(Context, "ویرایش", "Edit")</a></li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li>
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" data-ptg-confirm="true" data-ptg-confirm-title="حذف جنس" data-ptg-confirm-message="@deleteConfirm">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-item ak-danger"><i class="bi bi-trash" aria-hidden="true"></i>@UiText.T(Context, "حذف", "Delete")</button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!items.Any())
                    {
                        <tr>
                            <td colspan="7">
                                <div class="ak-empty"><i class="bi bi-box-seam" aria-hidden="true"></i>@UiText.T(Context, "رکوردی یافت نشد", "No records found")</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @{ ViewData["ShownCount"] = items.Count; }
        <div class="ak-pager">@await Html.PartialAsync("_PagedListFooter")</div>
    </div>
</div>
