@model Product
@{
    ViewData["Title"] = "جزئیات جنس";
    var unitText = Model.Unit?.NamePersian ?? Model.Unit?.Name ?? Model.UnitOfMeasure ?? "-";
    var secondaryUnitText = Model.SecondaryUnit?.NamePersian ?? Model.SecondaryUnit?.Name ?? "-";
    var statusText = Model.IsActive ? "فعال" : "غیرفعال";
}

<div class="ak-form-page">
    <partial name="~/Views/Shared/Components/Ak/_AkPageHeader.cshtml"
             model="@((ViewData["Title"]?.ToString() ?? "جزئیات", false,
                       "ویرایش", "bi-pencil", (string?)Url.Action("Edit", new { id = Model.Id }), (string?)null,
                       "بازگشت", "bi-arrow-right", (string?)Url.Action("Index")))" />
    <section id="product-summary" class="ak-form-section">
        @await Html.PartialAsync("~/Views/Shared/Components/Ak/_AkSectionHead.cshtml", ("مشخصات اصلی", (string?)"اطلاعاتی که برای شناسایی جنس در عملیات روزانه لازم است."))
        <dl class="ak-list">
            <div class="ak-list-row"><dt>کد</dt><dd><code>@Model.Code</code></dd></div>
            <div class="ak-list-row"><dt>نام</dt><dd>@Model.Name</dd></div>
            <div class="ak-list-row"><dt>واحد پایه</dt><dd>@unitText</dd></div>
            <div class="ak-list-row"><dt>وضعیت</dt><dd><span class="ak-status @(Model.IsActive ?"is-active" : "is-inactive")">@statusText</span></dd></div>
        </dl>
    </section>

    <section id="product-advanced" class="ak-form-section">
        @await Html.PartialAsync("~/Views/Shared/Components/Ak/_AkSectionHead.cshtml", ("جزئیات بیشتر", (string?)"اطلاعات تکمیلی برای آماده‌سازی تبدیل واحد و دسته‌بندی جنس."))
        <dl class="ak-list">
            <div class="ak-list-row"><dt>SecondaryUnit</dt><dd>@secondaryUnitText</dd></div>
            <div class="ak-list-row"><dt>یادداشت تبدیل واحد ثانویه</dt><dd>@(string.IsNullOrWhiteSpace(Model.SecondaryUnitConversionNote) ? "-" : Model.SecondaryUnitConversionNote)</dd></div>
            <div class="ak-list-row"><dt>دسته / گرید</dt><dd>@(string.IsNullOrWhiteSpace(Model.Category) ? "-" : Model.Category)</dd></div>
            <div class="ak-list-row"><dt>یادداشت</dt><dd>@(string.IsNullOrWhiteSpace(Model.Notes) ? "-" : Model.Notes)</dd></div>
            <div class="ak-list-row"><dt>تاریخ ایجاد</dt><dd>@Model.CreatedAtUtc.ToDisplayDateTime()</dd></div>
        </dl>
    </section>
</div>
