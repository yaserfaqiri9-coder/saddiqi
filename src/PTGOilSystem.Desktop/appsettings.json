{
  "Web": {
    // PostgreSQL connection string passed to the web app as
    // ConnectionStrings__DefaultConnection. Keep empty to let the web app use
    // its own appsettings / DATABASE_URL environment variable instead.
    "ConnectionString": "",

    // Loopback host the web server binds to.
    "Host": "127.0.0.1",

    // Fixed port. 0 = pick a free port automatically (recommended).
    "Port": 0,

    // ASPNETCORE_ENVIRONMENT for the hosted web app.
    "Environment": "Production",

    // Never migrate the database automatically from the desktop app.
    // Set true only if you intentionally want migrations on launch.
    "AutoMigrate": false,

    // Seconds to wait for the web server /health probe before giving up.
    // Higher so the dev fallback (`dotnet run`) has time for a cold first build.
    "StartupTimeoutSeconds": 120,

    // How the web app is launched. Resolved relative to the desktop exe folder.
    // Default layout (publish output):  <desktop>\web\PTGOilSystem.Web.dll
    // ExecutablePath: a published self-contained .exe (preferred for release).
    // DllPath:        a framework/portable .dll launched via `dotnet`.
    "ExecutablePath": "web\\PTGOilSystem.Web.exe",
    "DllPath": "web\\PTGOilSystem.Web.dll",

    // Dev fallback: if neither path above exists, run the project from source.
    // Point this at the web .csproj (used with `dotnet run`).
    "DevProjectPath": "..\\..\\..\\..\\PTGOilSystem.Web\\PTGOilSystem.Web.csproj"
  }
}
