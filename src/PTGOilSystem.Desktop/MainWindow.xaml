<Window x:Class="PTGOilSystem.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="PTG Oil System" Height="800" Width="1280"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft"
        Background="#0F172A">
    <Grid>
        <wv2:WebView2 x:Name="WebView" Visibility="Collapsed" />

        <!-- Req #4 — loading screen shown while the server starts. -->
        <Grid x:Name="LoadingOverlay" Background="#0F172A">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="PTG Oil System"
                           Foreground="#F8FAFC" FontSize="30" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,24" />
                <ProgressBar IsIndeterminate="True" Width="320" Height="6"
                             Foreground="#38BDF8" Background="#1E293B" BorderThickness="0" />
                <TextBlock x:Name="StatusText" Text="در حال آماده‌سازی…"
                           Foreground="#94A3B8" FontSize="15"
                           HorizontalAlignment="Center" Margin="0,18,0,0" />
                <TextBlock x:Name="ErrorText" Text="" Visibility="Collapsed"
                           Foreground="#F87171" FontSize="13" TextWrapping="Wrap"
                           MaxWidth="520" TextAlignment="Center"
                           HorizontalAlignment="Center" Margin="0,16,0,0" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
