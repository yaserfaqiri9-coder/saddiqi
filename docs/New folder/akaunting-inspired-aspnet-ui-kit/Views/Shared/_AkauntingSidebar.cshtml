@* Clean-room Akaunting-inspired sidebar. Replace labels/routes/icons with your modules. *@
<aside class="ak-sidebar" data-ak-sidebar aria-label="Main navigation">
    <div class="ak-rail ak-menu-scroll">
        <div class="ak-rail-group">
            <button class="ak-rail-button" type="button" aria-label="Profile">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>
            </button>
            <button class="ak-rail-button" type="button" aria-label="Notifications">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M18 8a6 6 0 1 0-12 0c0 7-3 7-3 9h18c0-2-3-2-3-9"/><path d="M10 21h4"/></svg>
            </button>
            <button class="ak-rail-button" type="button" aria-label="Global search">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="11" cy="11" r="7"/><path d="m20 20-4-4"/></svg>
            </button>
            <button class="ak-rail-button" type="button" aria-label="Create new">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="9"/><path d="M12 8v8M8 12h8"/></svg>
            </button>
            <button class="ak-rail-button" type="button" aria-label="Settings">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.7 1.7 0 0 0 .34 1.88l.06.06-2.83 2.83-.06-.06A1.7 1.7 0 0 0 15 19.4a1.7 1.7 0 0 0-1 .6 1.7 1.7 0 0 0-.4 1.1V21H9.6v-.1A1.7 1.7 0 0 0 9 19.4a1.7 1.7 0 0 0-1.88.34l-.06.06-2.83-2.83.06-.06A1.7 1.7 0 0 0 4.6 15a1.7 1.7 0 0 0-.6-1 1.7 1.7 0 0 0-1.1-.4H3V9.6h.1A1.7 1.7 0 0 0 4.6 9a1.7 1.7 0 0 0-.34-1.88l-.06-.06 2.83-2.83.06.06A1.7 1.7 0 0 0 9 4.6a1.7 1.7 0 0 0 1-.6 1.7 1.7 0 0 0 .4-1.1V3h4v.1A1.7 1.7 0 0 0 15 4.6a1.7 1.7 0 0 0 1.88-.34l.06-.06 2.83 2.83-.06.06A1.7 1.7 0 0 0 19.4 9c.12.37.33.7.6 1 .28.27.64.4 1.1.4h.1v4h-.1a1.7 1.7 0 0 0-1.7.6Z"/></svg>
            </button>
        </div>
    </div>

    <nav class="ak-main-menu ak-menu-scroll">
        <button class="ak-company" type="button">
            <span class="ak-company-mark">P</span>
            <span class="ak-company-name">PTG Oil System</span>
            <svg class="ak-company-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="m8 9 4-4 4 4M16 15l-4 4-4-4"/></svg>
        </button>

        <ul class="ak-menu">
            <li class="ak-menu-item">
                <a class="ak-menu-link is-active" asp-controller="Dashboard" asp-action="Index">
                    <span class="ak-menu-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg></span>
                    <span class="ak-menu-label">Dashboard</span>
                    <span class="ak-menu-active-rail"></span>
                </a>
            </li>

            <li class="ak-menu-item">
                <details class="ak-menu-details" open>
                    <summary class="ak-menu-summary" aria-expanded="true">
                        <span class="ak-menu-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M4 6h16M4 12h16M4 18h10"/></svg></span>
                        <span class="ak-menu-label">Contracts</span>
                        <svg class="ak-menu-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="m7 10 5 5 5-5"/></svg>
                    </summary>
                    <div class="ak-submenu-wrap">
                        <ul class="ak-submenu">
                            <li class="ak-submenu-item"><a class="ak-submenu-link" asp-controller="Contracts" asp-action="Index">All contracts</a></li>
                            <li class="ak-submenu-item"><a class="ak-submenu-link" asp-controller="Contracts" asp-action="Purchases">Purchase contracts</a></li>
                            <li class="ak-submenu-item"><a class="ak-submenu-link" asp-controller="Contracts" asp-action="Sales">Sale contracts</a></li>
                            <li class="ak-submenu-item"><a class="ak-submenu-link" asp-controller="Amendments" asp-action="Index">Amendments</a></li>
                        </ul>
                    </div>
                </details>
            </li>

            <li class="ak-menu-item">
                <details class="ak-menu-details">
                    <summary class="ak-menu-summary" aria-expanded="false">
                        <span class="ak-menu-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 6h11v10H3zM14 9h4l3 3v4h-7z"/><circle cx="7" cy="18" r="2"/><circle cx="18" cy="18" r="2"/></svg></span>
                        <span class="ak-menu-label">Logistics</span>
                        <svg class="ak-menu-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="m7 10 5 5 5-5"/></svg>
                    </summary>
                    <div class="ak-submenu-wrap">
                        <ul class="ak-submenu">
                            <li class="ak-submenu-item"><a class="ak-submenu-link" asp-controller="Loadings" asp-action="Index">Loadings</a></li>
                            <li class="ak-submenu-item"><a class="ak-submenu-link" asp-controller="Discharges" asp-action="Index">Discharges</a></li>
                            <li class="ak-submenu-item"><a class="ak-submenu-link" asp-controller="Dispatches" asp-action="Index">Dispatches</a></li>
                        </ul>
                    </div>
                </details>
            </li>

            <li class="ak-menu-item">
                <a class="ak-menu-link" asp-controller="Customers" asp-action="Index">
                    <span class="ak-menu-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="9" cy="8" r="3"/><circle cx="17" cy="9" r="2"/><path d="M3 20a6 6 0 0 1 12 0M14 16a5 5 0 0 1 7 4"/></svg></span>
                    <span class="ak-menu-label">Customers</span>
                    <span class="ak-menu-active-rail"></span>
                </a>
            </li>

            <li class="ak-menu-item">
                <a class="ak-menu-link" asp-controller="Reports" asp-action="Index">
                    <span class="ak-menu-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M4 20V10M10 20V4M16 20v-7M22 20H2"/></svg></span>
                    <span class="ak-menu-label">Reports</span>
                    <span class="ak-menu-active-rail"></span>
                </a>
            </li>
        </ul>
    </nav>

    <button class="ak-menu-toggle" type="button" data-ak-sidebar-toggle aria-label="Collapse sidebar" aria-expanded="true">‹</button>
</aside>
