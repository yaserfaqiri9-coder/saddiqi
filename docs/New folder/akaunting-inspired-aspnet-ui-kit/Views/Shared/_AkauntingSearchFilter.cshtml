@* Place this partial inside a list/index page. Initialize it with AkFilterBar in the page script. *@
<div class="ak-filter-host">
    <div class="ak-filter" data-ak-filter>
        <div class="ak-filter-chips" data-ak-filter-chips aria-live="polite"></div>

        <div class="ak-filter-input-wrap">
            <input
                class="ak-filter-input"
                type="search"
                autocomplete="off"
                data-ak-filter-input
                placeholder="Search or filter results..."
                aria-label="Search or filter results"
                aria-autocomplete="list"
                aria-haspopup="listbox" />

            <button class="ak-filter-enter" type="button" data-ak-filter-enter disabled>
                Enter
            </button>
        </div>

        <button class="ak-filter-clear" type="button" data-ak-filter-clear hidden aria-label="Clear all filters">×</button>
        <ul class="ak-filter-popover" data-ak-filter-popover role="listbox" hidden></ul>
    </div>
</div>
